import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using a Cost-Aware Steiner Tree heuristic.

    Improvements over previous version:
    1. Calibrated economic weights: Drastically reduced throughput penalty to reflect
       realistic instance costs ($1-2/hr) vs egress costs ($0.02-0.12/GB). This prevents
       selecting expensive high-bandwidth links over cheap moderate-bandwidth ones.
    2. Reduced depth penalty: Lowers the penalty for path depth, encouraging the algorithm
       to stay within cheap cloud backbones (intra-provider) even if it requires more hops,
       avoiding expensive internet egress/ingress loops ("leakage").
    3. Robust graph handling: Ensures connectivity and correct path extraction.

    Args:
        src: Source node identifier
        dsts: List of destination node identifiers
        G: NetworkX DiGraph with cost ($/GB) and throughput (Gbps) attributes
        num_partitions: Number of data partitions

    Returns:
        BroadCastTopology object with paths for all destinations and partitions
    """

    # --- Configuration Constants ---
    # TIME_COST_FACTOR: Converts transfer time (derived from throughput) into monetary cost ($/GB).
    # Derivation:
    # Time to transfer 1GB = 8 bits / Throughput(Gbps).
    # Cost = Time(hrs) * Instance_Cost($/hr).
    # Assume Instance_Cost ~ $2/hr (conservative estimate for large instances).
    # Cost/GB ~ (8 / Thru) / 3600 * 2 = 0.0044 / Thru.
    # We use 0.005 to slightly favor speed without overriding egress cost savings.
    TIME_COST_FACTOR = 0.005

    # DEPTH_PENALTY_ALPHA: Weight multiplier for distance from source.
    # Lower values (e.g., 0.05) approximate a pure Steiner Tree (min total cost).
    # Higher values (e.g., 0.5) approximate a Shortest Path Tree (min individual latency).
    # We use 0.05 to strongly favor cost optimization (keeping traffic in-network)
    # while providing a tie-breaker against excessively deep daisy-chains.
    DEPTH_PENALTY_ALPHA = 0.05

    # 1. Graph Preparation
    h = G.copy()

    # Cleanup: Remove incoming edges to source (prevent loops back to root)
    if src in h:
        h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # Pre-calculate composite weights
    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 0.1)
        throughput = data.get('throughput', 1.0)

        # Avoid division by zero
        safe_throughput = max(throughput, 1e-3)

        # Composite Weight = Egress Cost + Time Value
        # This aligns the graph optimization directly with the total cost objective function.
        data['weight'] = cost + (TIME_COST_FACTOR / safe_throughput)

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 2. Steiner Tree Construction (Priority-First Search)
    # Uses a Prim-like heuristic to grow a tree covering all destinations.

    tree_nodes = {src}
    tree_edges = []
    path_cost_from_src = {src: 0.0}

    # Identify unique targets (dsts might contain duplicates or src)
    targets = set(d for d in dsts if d != src and d in h)
    if not targets:
        return bc_topology

    pq = [] # Priority Queue
    visited_priority = {} # Optimization for skipping stale PQ entries

    def add_neighbors_to_pq(u):
        if u not in h: return
        dist_u = path_cost_from_src[u]

        for v, data in h[u].items():
            if v not in tree_nodes:
                w = data['weight']

                # Priority Logic:
                # We want to minimize edge weight (Cost) to the tree.
                # We add a small fraction of the distance from source to prevent
                # degenerate deep chains if costs are equal.
                priority = w + (DEPTH_PENALTY_ALPHA * dist_u)

                # Dijkstra optimization: only push if we found a better path to this candidate
                if v not in visited_priority or priority < visited_priority[v]:
                    visited_priority[v] = priority
                    heapq.heappush(pq, (priority, v, u, w))

    # Initialize PQ
    add_neighbors_to_pq(src)

    remaining_targets = targets.copy()

    while remaining_targets and pq:
        priority, v, u, w = heapq.heappop(pq)

        if v in tree_nodes:
            continue

        # Add to tree
        tree_nodes.add(v)
        tree_edges.append((u, v))
        path_cost_from_src[v] = path_cost_from_src[u] + w

        if v in remaining_targets:
            remaining_targets.remove(v)

        add_neighbors_to_pq(v)

    # 3. Path Extraction
    # Build a directed graph representing the multicast tree
    st_graph = nx.DiGraph()
    st_graph.add_nodes_from(tree_nodes)
    for u, v in tree_edges:
        if u in h and v in h[u]:
            st_graph.add_edge(u, v, **h[u][v])

    # Generate paths for each destination
    for dst in dsts:
        if dst == src:
            continue

        edge_path = []
        path_nodes = []

        try:
            # Try to route through the constructed optimized tree
            if dst in st_graph:
                path_nodes = nx.shortest_path(st_graph, source=src, target=dst)
            else:
                # Fallback: If heuristic failed to connect (e.g. graph partition),
                # use shortest weighted path in original graph.
                path_nodes = nx.shortest_path(h, source=src, target=dst, weight='weight')

            # Convert node sequence to edge list
            for i in range(len(path_nodes) - 1):
                u, v = path_nodes[i], path_nodes[i+1]
                # Retrieve original edge data
                edge_data = G[u][v]
                edge_path.append([u, v, edge_data])

        except (nx.NetworkXNoPath, KeyError):
            # Destination unreachable
            continue

        if edge_path:
            # Assign the optimal path to all partitions.
            # Rationale: Minimizing total cost is the primary goal. Splitting partitions
            # across suboptimal paths (multipath) increases egress cost linearly.
            # The adjusted weights ensure this path has acceptable throughput.
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, edge_path)

    return bc_topology
