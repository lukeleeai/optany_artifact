import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Constructs a Steiner Tree that minimizes total cost (Egress + Instance).
    Uses multiple heuristic strategies (Greedy Steiner, Star, Hub-Spoke) with
    throughput-aware edge weights to balance cost against transfer time.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning and Preparation
    h = G.copy()
    # Remove upstream edges to source to prevent loops
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    valid_dsts = [d for d in dsts if d != src and d in h]
    if not valid_dsts:
        return bc_topology

    # 2. Weight Configuration
    # We define multiple weight profiles to explore trade-offs between pure egress cost
    # and "virtual cost" of time (latency/instance cost).
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t = max(t, 0.001) # Safety floor to prevent division by zero

        # Profile 1: Cost-Centric (w_egress)
        # Minimal penalty for throughput, mainly to break ties.
        data['w_egress'] = c + (1e-6 / t)

        # Profile 2: Balanced (w_balanced)
        # Moderate penalty. For 100GB transfer, 1 Gbps -> ~0.002 virtual cost.
        # This helps avoid extremely slow links that save negligible money.
        data['w_balanced'] = c + (0.002 / t)

        # Profile 3: Performance (w_perf)
        # Higher throughput penalty + Hop cost (0.005) to discourage long daisy-chains (snakes).
        data['w_perf'] = c + (0.01 / t) + 0.005

    candidates = []

    def evaluate_candidate(edges_subset):
        """Constructs subgraph and calculates total unit cost + throughput metrics."""
        sub = nx.DiGraph()
        total_cost = 0.0
        min_tp = float('inf')

        for u, v in edges_subset:
            if h.has_edge(u, v):
                d = h[u][v]
                sub.add_edge(u, v, **d)
                # For broadcast trees, we sum the cost of edges used in the tree once
                total_cost += d.get('cost', 0.0)
                t = d.get('throughput', 1.0)
                if t < min_tp: min_tp = t

        if min_tp == float('inf'): min_tp = 0.0

        # Verify validity and extract paths
        try:
            paths_map = {}
            for d in valid_dsts:
                # Use simple cost to extract the unique path in the tree
                paths_map[d] = nx.shortest_path(sub, src, d, weight='cost')

            return {
                'edges': edges_subset,
                'subgraph': sub,
                'cost_unit': total_cost,
                'min_throughput': min_tp,
                'paths': paths_map
            }
        except (nx.NetworkXNoPath, Exception):
            return None

    # --- Strategy A: Greedy Steiner Tree ---
    # Iteratively connect closest destination to the tree.
    # Run with different weight profiles to find best structure.
    for weight_attr in ['w_egress', 'w_balanced', 'w_perf']:
        tree_edges = set()
        tree_nodes = {src}
        remaining = set(valid_dsts)

        while remaining:
            try:
                # Find shortest path from any node in tree to any node in remaining
                # multi_source_dijkstra returns (distance_dict, path_dict)
                dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight=weight_attr)

                # Identify the closest remaining destination
                best_dst = None
                best_dist = float('inf')
                for r in remaining:
                    if r in dists and dists[r] < best_dist:
                        best_dist = dists[r]
                        best_dst = r

                if best_dst:
                    path = paths[best_dst]
                    # Add path edges to tree
                    for i in range(len(path) - 1):
                        u, v = path[i], path[i+1]
                        if (u, v) not in tree_edges:
                            tree_edges.add((u, v))
                            tree_nodes.add(v)
                    # Update remaining set - remove any nodes that are now part of the tree
                    remaining = remaining - tree_nodes
                else:
                    break # Cannot reach remaining nodes
            except:
                break

        if not remaining:
            cand = evaluate_candidate(tree_edges)
            if cand: candidates.append(cand)

    # --- Strategy B: Union of Shortest Paths (USP) ---
    # Baseline "Star/Mesh" topology. Often higher cost but best latency.
    usp_edges = set()
    try:
        for d in valid_dsts:
            p = nx.shortest_path(h, src, d, weight='w_balanced')
            for i in range(len(p)-1):
                usp_edges.add((p[i], p[i+1]))
        cand = evaluate_candidate(usp_edges)
        if cand: candidates.append(cand)
    except:
        pass

    # --- Strategy C: Hub-and-Spoke (Top K) ---
    # Force routing via a high-degree intermediate node to aggregate traffic.
    nodes_by_degree = sorted(h.nodes(), key=lambda n: h.degree(n), reverse=True)
    hubs = [n for n in nodes_by_degree[:5] if n != src]

    for hub in hubs:
        try:
            hub_edges = set()
            # Path Src -> Hub
            p_src = nx.shortest_path(h, src, hub, weight='w_balanced')
            for i in range(len(p_src)-1):
                hub_edges.add((p_src[i], p_src[i+1]))

            # Paths Hub -> Dsts
            possible = True
            for d in valid_dsts:
                if d == hub: continue
                p_dst = nx.shortest_path(h, hub, d, weight='w_balanced')
                for i in range(len(p_dst)-1):
                    hub_edges.add((p_dst[i], p_dst[i+1]))

            if possible:
                cand = evaluate_candidate(hub_edges)
                if cand: candidates.append(cand)
        except:
            continue

    # 3. Selection
    if not candidates:
        return bc_topology

    # Scoring Function: Minimize Total Cost (Egress + Virtual Time Cost)
    # Score = CostUnit + (TimeFactor / Throughput)
    # Calibrated for typical data volumes (100-500GB) where egress dominates
    # but low throughput (<1 Gbps) causes significant instance cost accumulation.
    def score(c):
        t = c['min_throughput']
        # Strong penalty for < 100 Mbps (likely VPN/Tunnel bottlenecks that cause timeouts)
        if t < 0.1: return float('inf')

        # 0.003 roughly equates to $0.50-$1.00 instance cost impact per GB
        # on very slow links vs fast links.
        return c['cost_unit'] + (0.003 / t)

    best_cand = min(candidates, key=score)

    # 4. Path Assignment
    paths_map = best_cand['paths']
    for dst in valid_dsts:
        path_nodes = paths_map[dst]
        path_edges = []
        for i in range(len(path_nodes)-1):
            u, v = path_nodes[i], path_nodes[i+1]
            edge_data = h[u][v]
            path_edges.append([u, v, edge_data])

        # Assign same path to all partitions for optimal cost efficiency
        # (Splitting partitions typically increases egress cost without sufficient gain)
        for i in range(num_partitions):
            bc_topology.set_dst_partition_paths(dst, i, path_edges)

    return bc_topology
