import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _calculate_edge_weight(data, penalty_multiplier=1.0):
    """
    Composite weight emphasizing egress cost but penalizing low throughput.
    Weight = (Cost + Alpha/Throughput) * Penalty
    """
    cost = data.get('cost', 0.1)
    throughput = data.get('throughput', 1.0)

    # Avoid division by zero, clamp minimum throughput
    t_safe = max(throughput, 0.001)

    # Alpha selection:
    # Small alpha (0.02) ensures cost dominates decision making unless throughput is critically low (<100Mbps).
    # This addresses the 'high egress cost' failure pattern.
    alpha = 0.02

    base_weight = cost + (alpha / t_safe)
    return base_weight * penalty_multiplier

def _build_shallow_light_tree(G, src, dsts, edge_penalties):
    """
    Builds a tree rooted at src that balances total weight (Steiner)
    and path length (Shortest Path).

    Uses a modified Prim's algorithm with a 'regret' factor (beta).
    Priority = EdgeWeight(u,v) + Beta * DistFromRoot(u)

    Beta = 0.0 -> Prim's (MST/Steiner approximation). Maximizes shared edges.
    Beta = 1.0 -> Dijkstra (SPT). Minimizes individual path costs/hops.

    Beta = 0.2 is chosen to create a 'Light Approximate Shortest-path Tree' (LAST),
    preventing the 'tromboning' and high hop count issues observed in feedback.
    """

    # Priority Queue: (priority, current_node, parent_node, edge_weight_uv, dist_from_root_u)
    pq = []

    # Start with source
    heapq.heappush(pq, (0.0, src, None, 0.0, 0.0))

    tree_edges = {} # v -> (u, data)
    path_dist = {}  # v -> dist
    visited = set()

    BETA = 0.2

    dst_set = set(dsts)
    # Count how many unique destinations we need to cover (excluding src)
    target_dsts = len(dst_set - {src})
    found_dsts = 0

    while pq:
        prio, u, parent, w_uv, dist_u = heapq.heappop(pq)

        if u in visited:
            continue
        visited.add(u)
        path_dist[u] = dist_u

        if parent is not None:
            # Reconstruct edge data from graph to ensure we have the object
            edge_data = G[parent][u]
            tree_edges[u] = (parent, edge_data)

        if u in dst_set and u != src:
            found_dsts += 1

        # Optimization: If all destinations reached, we can stop?
        # In a weighted graph, we must continue until PQ empty or we are sure no better path exists.
        # But this is a greedy tree builder, so once a node is popped, it's fixed.
        if found_dsts >= target_dsts:
            # We can stop early if we only care about destinations,
            # but continuing might find better branches for remaining non-dest nodes?
            # For efficiency, stopping is fine as long as all dsts are covered.
            break

        for v, data in G[u].items():
            if v in visited:
                continue

            penalty = edge_penalties.get((u, v), 1.0)
            weight = _calculate_edge_weight(data, penalty)

            new_dist = dist_u + weight

            # Metric: Cost of this specific hop + fraction of cost to get here
            metric = weight + (BETA * dist_u)

            heapq.heappush(pq, (metric, v, u, weight, new_dist))

    return tree_edges

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm using diverse Shallow-Light Trees.

    Strategy:
    1. Generate multiple candidate trees (topologies) by iteratively penalizing used edges.
    2. Trees are built using a hybrid Steiner/SPT heuristic (Shallow-Light Tree) to
       balance shared trunk usage (cost reduction) with path shortness (latency reduction).
    3. Select the best cost-effective trees and distribute partitions among them.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preprocessing
    h = G.copy()

    # Strictly enforce source as root (no incoming flow to source used)
    # This eliminates immediate loops back to start
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 2. Iterative Tree Generation
    candidates = []
    edge_penalties = {} # (u,v) -> multiplier

    # Generate enough candidates to find diverse paths
    num_iterations = max(num_partitions, 5)

    if not h.out_edges(src):
        return bc_topology

    for i in range(num_iterations):
        tree_structure = _build_shallow_light_tree(h, src, dsts, edge_penalties)

        if not tree_structure:
            break

        paths_map = {}
        tree_egress_cost = 0.0
        used_edges = set()
        current_tree_raw_cost = 0.0
        valid_tree = True

        for dst in dsts:
            if dst == src:
                continue

            if dst not in tree_structure:
                # Tree failed to cover this destination
                # Fallback: patch with shortest path
                try:
                    sp_nodes = nx.shortest_path(h, src, dst, weight='cost')
                    path_segment = []
                    for k in range(len(sp_nodes)-1):
                        u_node, v_node = sp_nodes[k], sp_nodes[k+1]
                        edge_data = h[u_node][v_node]
                        path_segment.append([u_node, v_node, edge_data])

                        if (u_node, v_node) not in used_edges:
                            used_edges.add((u_node, v_node))
                            current_tree_raw_cost += edge_data.get('cost', 0.0)
                    paths_map[dst] = path_segment
                except nx.NetworkXNoPath:
                    valid_tree = False
                    break
            else:
                # Backtrack from dst to src using tree_structure
                path_segment = []
                curr = dst
                while curr != src:
                    parent_info = tree_structure.get(curr)
                    if not parent_info:
                        valid_tree = False
                        break
                    parent, edge_data = parent_info
                    path_segment.append([parent, curr, edge_data])

                    if (parent, curr) not in used_edges:
                        used_edges.add((parent, curr))
                        current_tree_raw_cost += edge_data.get('cost', 0.0)

                    curr = parent

                if not valid_tree:
                    break
                paths_map[dst] = list(reversed(path_segment))

        if valid_tree:
            # Deduplication check
            edge_frozenset = frozenset(used_edges)
            is_duplicate = False
            for c in candidates:
                if c['edge_set'] == edge_frozenset:
                    is_duplicate = True
                    break

            if not is_duplicate:
                candidates.append({
                    'cost': current_tree_raw_cost,
                    'paths': paths_map,
                    'edge_set': edge_frozenset
                })

                # Penalize edges to force diversity in next iteration
                for u, v in used_edges:
                    old_p = edge_penalties.get((u, v), 1.0)
                    edge_penalties[(u, v)] = old_p * 1.3

        if len(candidates) >= num_partitions * 2:
            break

    # 3. Candidate Selection and Assignment
    if not candidates:
        # Fallback: Dijkstra Shortest Path Tree
        try:
            fallback_map = {}
            for dst in dsts:
                if dst == src: continue
                path = nx.shortest_path(h, src, dst, weight='cost')
                edges = []
                for k in range(len(path)-1):
                    edges.append([path[k], path[k+1], h[path[k]][path[k+1]]])
                fallback_map[dst] = edges
            candidates.append({'cost': 0, 'paths': fallback_map})
        except:
            return bc_topology

    # Sort by cost (lowest first)
    candidates.sort(key=lambda x: x['cost'])

    # Filtering: Select best trees.
    # We allow a small cost margin (20%) to incorporate diverse paths if they exist,
    # as multipath usage improves throughput.
    best_cost = candidates[0]['cost']
    allowed_candidates = [c for c in candidates if c['cost'] <= best_cost * 1.2]

    pool = allowed_candidates if allowed_candidates else [candidates[0]]
    num_pool = len(pool)

    # Round robin assignment of partitions to selected trees
    for i in range(num_partitions):
        selected_cand = pool[i % num_pool]
        p_map = selected_cand['paths']

        for dst, path_list in p_map.items():
            bc_topology.set_dst_partition_paths(dst, i, path_list)

    return bc_topology
