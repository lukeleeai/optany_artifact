import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using K-Shortest Paths with Economic Scoring.

    Replaces the previous Steiner Tree heuristic with a per-destination path search
    that explicitly models Total Cost of Ownership (TCO).

    Optimization Logic:
    1. Pruning: Removes links with insufficient throughput (<0.1Gbps) to prevent timeout failures.
    2. Path Finding: Uses Dijkstra's algorithm (Shortest Path) based primarily on Egress Cost.
       This prevents geographically inefficient loops (e.g., Asia->UK->Australia) often caused
       by greedy tree construction.
    3. Path Selection: Generates top-K candidates and scores them using a composite formula:
       Score = (Egress_Cost * Vol) + (Num_Hops * (Vol/Throughput) * Instance_Rate)
       This correctly penalizes multi-hop paths (high instance costs) and low-throughput paths.
    4. Multipath: Distributes partitions across the top scoring paths if they are cost-competitive,
       improving reliability and aggregate bandwidth.
    """

    # --- Cost Model Configuration ---
    # Assumptions based on domain context (~300GB transfers)
    DATA_VOLUME_GB = 300.0
    INSTANCE_COST_PER_HR = 0.5  # Estimated cost per instance hour
    MIN_THROUGHPUT_GBPS = 0.1   # Prune edges below 100Mbps
    K_PATHS = 3                 # Number of candidate paths to evaluate
    MULTIPATH_TOLERANCE = 1.02  # Use secondary paths if cost is within 2% of best

    # 1. Graph Preparation
    # Work on a copy to avoid modifying the global graph
    h = G.copy()

    # Remove incoming edges to source to prevent loops
    if src in h:
        h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # Prune low-throughput edges and set weights for search
    edges_to_remove = []
    for u, v, data in h.edges(data=True):
        throughput = data.get('throughput', 0.0)
        cost = data.get('cost', 10.0)

        if throughput < MIN_THROUGHPUT_GBPS:
            edges_to_remove.append((u, v))
            continue

        # Dijkstra Weight: Pure Egress Cost.
        # We add a tiny epsilon to prefer fewer hops when costs are identical.
        # We do NOT penalize throughput here (which causes expensive detours);
        # instead we filter/score candidates later.
        data['weight'] = cost + 1e-7

    h.remove_edges_from(edges_to_remove)

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 2. Per-Destination Optimization
    for dst in dsts:
        if dst == src:
            continue

        candidates = []

        try:
            # Generate K shortest simple paths based on egress cost
            # This is efficient for small cloud graphs (~50 nodes)
            raw_paths_gen = nx.shortest_simple_paths(h, src, dst, weight='weight')

            for _ in range(K_PATHS):
                try:
                    path_nodes = next(raw_paths_gen)
                except StopIteration:
                    break

                # Reconstruct path details for scoring
                path_edges = []
                total_egress_per_gb = 0.0
                min_bw = float('inf')
                hops = 0

                valid_path = True
                for i in range(len(path_nodes) - 1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    if not G.has_edge(u, v):
                        valid_path = False
                        break

                    edge_data = G[u][v] # Use original G data
                    path_edges.append([u, v, edge_data])

                    total_egress_per_gb += edge_data.get('cost', 0.0)
                    min_bw = min(min_bw, edge_data.get('throughput', 0.1))
                    hops += 1

                if not valid_path:
                    continue

                # --- Economic Scoring ---
                # Egress Cost ($)
                egress_cost = total_egress_per_gb * DATA_VOLUME_GB

                # Transfer Time (Hours) = (Vol * 8 bits) / (BW * 3600)
                # BW is in Gbps. Result is hours.
                transfer_time_hr = (DATA_VOLUME_GB * 8.0) / (min_bw * 3600.0)

                # Instance Cost ($) = Hops * Time * Rate
                # Each node in the chain (approx = hops) runs an instance
                instance_cost = hops * transfer_time_hr * INSTANCE_COST_PER_HR

                total_cost = egress_cost + instance_cost

                candidates.append({
                    'path': path_edges,
                    'cost': total_cost,
                    'bw': min_bw
                })

        except (nx.NetworkXNoPath, nx.NodeNotFound):
            pass

        if not candidates:
            # Fallback: Try one unweighted search if weighted failed (connectivity check)
            try:
                path_nodes = nx.shortest_path(h, src, dst)
                # ... convert to edge list and assign ...
                path_edges = [[path_nodes[i], path_nodes[i+1], G[path_nodes[i]][path_nodes[i+1]]]
                              for i in range(len(path_nodes)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, path_edges)
            except:
                pass
            continue

        # 3. Path Selection & Multipath Assignment
        # Sort candidates by calculated Total Cost
        candidates.sort(key=lambda x: x['cost'])

        best_candidate = candidates[0]
        selected_paths = [best_candidate]

        # Multipath: Include secondary paths if they are very close in cost
        # This helps balance load if the primary path is saturated, without wasting money
        for candidate in candidates[1:]:
            if candidate['cost'] <= best_candidate['cost'] * MULTIPATH_TOLERANCE:
                selected_paths.append(candidate)

        # Round-robin assignment of partitions to selected paths
        num_selected = len(selected_paths)
        for i in range(num_partitions):
            chosen = selected_paths[i % num_selected]
            bc_topology.set_dst_partition_paths(dst, i, chosen['path'])

    return bc_topology
