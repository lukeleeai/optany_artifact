import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _extract_topology_stats(edges, G):
    cost_sum = 0.0
    min_tp = float('inf')
    for u, v in edges:
        if G.has_edge(u, v):
            data = G[u][v]
            cost_sum += data.get('cost', 0.0)
            min_tp = min(min_tp, data.get('throughput', 1000.0))
    return cost_sum, min_tp

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.
    Strategies:
    1. Aggressive Graph Pruning: Enforce rooted tree structure and penalize low throughput.
    2. Hybrid Search: Uses Shortest Path Tree (SPT) for latency baseline and Steiner Heuristics for cost optimization.
    3. Strict Candidate Selection: Only multipaths across topologies that are close to optimal to prevent stragglers.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation & Weighting
    h = G.copy()

    # Enforce Source Rooting: Remove incoming edges to source to prevent cycles/backtracking
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weight Calculation
    # We prioritize Cost but add significant penalties for Low Throughput and Hops.
    # Weight = Cost + (Alpha / Throughput) + Hop_Penalty
    # Alpha = 0.05: 1Gbps adds $0.05 'virtual cost', 10Gbps adds $0.005.
    # Hop_Penalty = 0.002: Disfavors long chains (e.g., A->B->C->D) vs direct (A->D).
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)

        # Combined metric for pathfinding
        data['metric_weight'] = c + (0.05 / t_safe) + 0.002

        # Pure cost for accurate bookkeeping
        data['actual_cost'] = c

    candidates = []

    def build_candidate_from_edges(edge_collection):
        # Create a subgraph from selected edges to ensure connectivity
        sub_g = nx.DiGraph()
        for u, v in edge_collection:
            if h.has_edge(u, v):
                sub_g.add_edge(u, v, **h[u][v])

        cand_paths = {}
        valid = True

        # Extract loop-free paths for each destination from this subgraph
        for dst in dsts:
            if dst == src: continue
            try:
                # Use shortest_path to guarantee acyclic routes within the selected topology
                path_nodes = nx.shortest_path(sub_g, src, dst, weight='metric_weight')
                edges_list = []
                for i in range(len(path_nodes)-1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    edges_list.append([u, v, h[u][v]])
                cand_paths[dst] = edges_list
            except nx.NetworkXNoPath:
                # If a destination is unreachable in this specific subgraph (should not happen if logic is correct)
                valid = False
                break

        if valid:
            cost_val, min_tp_val = _extract_topology_stats(edge_collection, h)
            return {
                'paths': cand_paths,
                'edges': set(edge_collection),
                'cost': cost_val,
                'min_throughput': min_tp_val
            }
        return None

    # Strategy A: Shortest Path Tree (SPT)
    # Minimizes individual path weights (latency/cost mix) without forcing shared edges.
    # Good baseline for performance.
    spt_edges = set()
    try:
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(h, src, dst, weight='metric_weight')
            for i in range(len(path)-1):
                spt_edges.add((path[i], path[i+1]))

        cand = build_candidate_from_edges(spt_edges)
        if cand:
            candidates.append(cand)
    except nx.NetworkXNoPath:
        pass

    # Strategy B: Iterative Steiner Tree Heuristic
    # Optimizes for shared edges (reduced total cost) at the expense of potentially longer paths.
    penalty_map = {}

    # Run limited iterations to find diverse but cost-effective topologies
    iterations = 3 if num_partitions > 1 else 1

    for _ in range(iterations):
        # Update weights based on penalty map to force diversity
        for u, v, data in h.edges(data=True):
            base = data['metric_weight']
            pen = penalty_map.get((u, v), 1.0)
            data['calc_weight'] = base * pen

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        # Greedy Construction
        while remaining:
            # Connect closest remaining node to the current tree
            path, target = _dijkstra_multisource_incremental(h, list(tree_nodes), remaining, weight_attr='calc_weight')

            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

        if not remaining:
            cand = build_candidate_from_edges(tree_edges)
            if cand:
                # Dedup
                is_dup = False
                for c in candidates:
                    if c['edges'] == cand['edges']:
                        is_dup = True
                        break
                if not is_dup:
                    candidates.append(cand)
                    # Penalize edges for next iteration
                    for u, v in cand['edges']:
                        penalty_map[(u, v)] = penalty_map.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 3. Candidate Filtering & Assignment
    # Sort by total cost
    candidates.sort(key=lambda x: x['cost'])

    best_cand = candidates[0]
    best_cost = best_cand['cost']
    best_tp = best_cand['min_throughput']

    # Select candidates for multipath only if they are comparable to the best.
    # Stragglers (slow paths) define the total transfer time, so we must be strict.
    valid_candidates = []

    # Thresholds:
    # 1. Cost must be within 3% of the best.
    # 2. Throughput must be at least 50% of the best candidate's bottleneck.
    cost_limit = best_cost * 1.03
    tp_limit = best_tp * 0.5

    for c in candidates:
        if c['cost'] <= cost_limit and c['min_throughput'] >= tp_limit:
            valid_candidates.append(c)

    # Fallback to just the best if filtering removed everything (unlikely)
    if not valid_candidates:
        valid_candidates = [best_cand]

    # Assign partitions round-robin among valid candidates
    num_valid = len(valid_candidates)
    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']
        for dst, path in paths_map.items():
            bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
