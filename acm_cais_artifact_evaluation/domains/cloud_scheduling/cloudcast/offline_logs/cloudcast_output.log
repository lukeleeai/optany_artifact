import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_path_edges(path):
    """Helper to convert node list to edge list."""
    return [(path[i], path[i+1]) for i in range(len(path)-1)]

def _calculate_tree_metrics(tree_edges, G, src, dsts):
    """
    Calculates Egress Cost and Bottleneck Throughput for a multicast tree topology.
    - Egress Cost: Sum of costs of used edges (paid once per edge in multicast).
    - Throughput: Limited by edge capacity divided by number of downstream flows.
    """
    sub = nx.DiGraph()
    cost = 0.0

    # Construct subgraph and sum unique edge costs
    for u, v in tree_edges:
        if G.has_edge(u, v):
            data = G[u][v]
            sub.add_edge(u, v, **data)
            cost += data.get('cost', 0.0)

    # Calculate flow distribution (how many destinations share each edge)
    edge_flow_counts = {e: 0 for e in sub.edges()}
    valid = True

    # 1. Map flows
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(sub, src, dst)
            for i in range(len(path)-1):
                edge_flow_counts[(path[i], path[i+1])] += 1
        except (nx.NetworkXNoPath, Exception):
            valid = False
            break

    if not valid:
        return float('inf'), 0.0, None

    # 2. Calculate system bottleneck
    # The throughput to a destination is constrained by the most congested link on its path.
    # The system throughput is the minimum across all destinations (broadcast time).

    min_system_throughput = float('inf')

    for dst in dsts:
        if dst == src: continue
        path = nx.shortest_path(sub, src, dst)
        path_bw = float('inf')

        for i in range(len(path)-1):
            u, v = path[i], path[i+1]
            capacity = sub[u][v].get('throughput', 1.0)
            # Bandwidth sharing: Capacity / N_flows
            flows = edge_flow_counts.get((u, v), 1)
            effective_bw = capacity / max(flows, 1)

            if effective_bw < path_bw:
                path_bw = effective_bw

        if path_bw < min_system_throughput:
            min_system_throughput = path_bw

    if min_system_throughput == float('inf'):
        min_system_throughput = 0.0

    return cost, min_system_throughput, sub

def _steiner_tree_heuristic(G, src, targets):
    """
    Constructs a Steiner Tree approximation using a greedy strategy.
    Iteratively connects the closest unconnected target to the existing tree.
    """
    # Working graph with heuristic weights
    # Weight = Cost + small penalty for low throughput (to prefer faster links if costs similar)
    work_G = G.copy()
    for u, v, d in work_G.edges(data=True):
        d['h_weight'] = d.get('cost', 0.0) + (0.001 / max(d.get('throughput', 1.0), 0.001))

    tree_nodes = {src}
    tree_edges = set()
    remaining = set(targets)

    while remaining:
        # Find closest path from ANY node in tree to ANY node in remaining
        try:
            dists, paths = nx.multi_source_dijkstra(work_G, sources=list(tree_nodes), weight='h_weight')
        except:
            break

        # Select best target
        candidates = [t for t in remaining if t in dists]
        if not candidates:
            break

        best_target = min(candidates, key=lambda x: dists[x])
        path = paths[best_target]

        # Add path to tree
        for i in range(len(path)-1):
            u, v = path[i], path[i+1]
            if (u, v) not in tree_edges:
                tree_edges.add((u, v))
                tree_nodes.add(v)
                # Set cost to zero for subsequent iterations (multicast benefit)
                work_G[u][v]['h_weight'] = 1e-9

        # Remove covered targets
        # Note: Dijkstra path might pass through other targets, removing them from 'remaining'
        # is efficient, but we must ensure they are actually connected.
        # Since we added all nodes in path to tree_nodes, they are connected.
        if best_target in remaining:
            remaining.remove(best_target)
        for node in path:
            if node in remaining:
                remaining.remove(node)

    return tree_edges

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Approaches:
    1. Greedy Steiner Tree: iteratively builds a shared multicast tree to minimize total egress.
    2. Hub-and-Spoke: tests routing via high-degree aggregation nodes (gateways).
    3. Union of Shortest Paths: baseline for performance.

    Selection Metric: Egress Cost + (Penalty / Effective Throughput)
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Pre-processing: Remove incoming edges to source to prevent cycles/backflow
    h = G.copy()

    valid_dsts = [d for d in dsts if d != src and d in h]
    if not valid_dsts:
        return bc_topology

    candidates = []

    # -------------------------------------------------------------------------
    # Strategy A: Greedy Steiner Tree
    # -------------------------------------------------------------------------
    # Good for finding shared paths that minimize Egress Cost
    edges_steiner = _steiner_tree_heuristic(h, src, valid_dsts)
    m_steiner = _calculate_tree_metrics(edges_steiner, h, src, valid_dsts)
    if m_steiner[2]:
        candidates.append({
            'type': 'Steiner',
            'cost': m_steiner[0],
            'bw': m_steiner[1],
            'sub': m_steiner[2]
        })

    # -------------------------------------------------------------------------
    # Strategy B: Hub-and-Spoke / Gateway Optimization
    # -------------------------------------------------------------------------
    # Tests specific nodes as aggregation points.
    # Useful for cross-cloud transfers (Src -> Hub -> Dsts).

    # Select potential hubs: Neighbors, Existing Dsts, and Random High-Degree nodes
    potential_hubs = set(valid_dsts) | set(h.neighbors(src))
    nodes_sorted = sorted(h.degree, key=lambda x: x[1], reverse=True)
    potential_hubs.update([n for n, d in nodes_sorted[:15]])
    if src in potential_hubs: potential_hubs.remove(src)

    # Weight for pathfinding in Hub strategy
    for u, v, d in h.edges(data=True):
        d['hub_weight'] = d.get('cost', 0.0) + (0.0001 / max(d.get('throughput', 1.0), 0.001))

    # We limit hub search to a reasonable number to keep runtime low
    search_hubs = list(potential_hubs)
    if len(search_hubs) > 20:
        search_hubs = random.sample(search_hubs, 20)
        # Ensure we check at least one node from each target cloud if identifiable
        target_clouds = set(d.split(':')[0] for d in valid_dsts if ':' in d)
        for tc in target_clouds:
            cloud_nodes = [n for n in potential_hubs if n.startswith(tc)]
            if cloud_nodes: search_hubs.append(cloud_nodes[0])

    for hub in search_hubs:
        try:
            # Construct Hub Topology: Src -> Hub -> Dsts
            hub_edges = set()

            # Leg 1: Src -> Hub
            path_to_hub = nx.shortest_path(h, src, hub, weight='hub_weight')
            hub_edges.update(_get_path_edges(path_to_hub))

            # Leg 2: Hub -> Dsts
            # Optimization: If Dst is on path to Hub, route directly?
            # Simplification: Just calculate Hub -> Dst. The metric function handles overlaps.
            for dst in valid_dsts:
                if dst == hub: continue
                path_from_hub = nx.shortest_path(h, hub, dst, weight='hub_weight')
                hub_edges.update(_get_path_edges(path_from_hub))

            metrics = _calculate_tree_metrics(hub_edges, h, src, valid_dsts)
            if metrics[2]:
                candidates.append({
                    'type': 'Hub',
                    'cost': metrics[0],
                    'bw': metrics[1],
                    'sub': metrics[2]
                })
        except nx.NetworkXNoPath:
            continue

    # -------------------------------------------------------------------------
    # Strategy C: Union of Shortest Paths (USP)
    # -------------------------------------------------------------------------
    # Baseline: Optimizes purely for individual path costs/latency, ignores sharing benefits.
    usp_edges = set()
    try:
        for dst in valid_dsts:
            p = nx.shortest_path(h, src, dst, weight='hub_weight')
            usp_edges.update(_get_path_edges(p))

        m_usp = _calculate_tree_metrics(usp_edges, h, src, valid_dsts)
        if m_usp[2]:
            candidates.append({
                'type': 'USP',
                'cost': m_usp[0],
                'bw': m_usp[1],
                'sub': m_usp[2]
            })
    except:
        pass

    # -------------------------------------------------------------------------
    # Final Selection
    # -------------------------------------------------------------------------
    if not candidates:
        return bc_topology

    # Scoring Function: Total Cost + Instance Penalty
    # We balance raw Egress Cost against the Time penalty (Instance Cost).
    # Penalty factor derived from typical instance pricing vs data volume.
    # A weighting of 10.0-15.0 on (1/BW) works well for typical cloud pricing ratios.
    def score_candidate(c):
        return c['cost'] + (15.0 / max(c['bw'], 0.001))

    best_candidate = min(candidates, key=score_candidate)
    final_subgraph = best_candidate['sub']

    # -------------------------------------------------------------------------
    # Path Extraction
    # -------------------------------------------------------------------------
    # Route all partitions over the optimal topology
    for dst in valid_dsts:
        try:
            # Extract simple path from the tree/DAG
            path_nodes = nx.shortest_path(final_subgraph, src, dst)

            # Reconstruct detailed edge list with original attributes
            path_edges = []
            for i in range(len(path_nodes)-1):
                u, v = path_nodes[i], path_nodes[i+1]
                edge_data = h[u][v]
                path_edges.append([u, v, edge_data])

            # Assign to all partitions
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

        except nx.NetworkXNoPath:
            # Fallback (should ideally not happen if metrics returned valid subgraph)
            pass

    return bc_topology
