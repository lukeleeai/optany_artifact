import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

def _build_heuristic_steiner_tree(G, src, dsts, weight_attr='weight'):
    """
    Constructs a Steiner Tree approximation.
    Starts with the source and iteratively connects the closest remaining destination
    to the existing tree structure (similar to Prim's algorithm but for Steiner Trees).
    """
    tree_nodes = {src}
    tree_edges = set()

    # Set of targets we need to connect
    remaining_targets = set(d for d in dsts if d != src and d in G)

    while remaining_targets:
        # Multi-source Dijkstra initialization
        # The priority queue stores (distance, current_node, parent_node)
        pq = []
        for node in tree_nodes:
            # All existing tree nodes are "sources" with distance 0
            heapq.heappush(pq, (0.0, node, None))

        distances = {node: 0.0 for node in tree_nodes}
        predecessors = {}

        closest_target = None

        # Search for the closest reachable target outside the tree
        while pq:
            d, u, parent = heapq.heappop(pq)

            if d > distances.get(u, float('inf')):
                continue

            predecessors[u] = parent

            if u in remaining_targets:
                closest_target = u
                break

            # Expand neighbors
            for v, attr in G[u].items():
                if v in tree_nodes:
                    continue

                w = attr.get(weight_attr, 1.0)
                new_dist = d + w

                if new_dist < distances.get(v, float('inf')):
                    distances[v] = new_dist
                    heapq.heappush(pq, (new_dist, v, u))

        if closest_target:
            # Backtrack to add the new path branch to the tree
            curr = closest_target
            path_segment = []

            while curr is not None and curr not in tree_nodes:
                par = predecessors.get(curr)
                if par is None:
                    break
                path_segment.append((par, curr))
                curr = par

            # Reverse to get proper direction (Tree -> Target)
            path_segment.reverse()

            # Commit edges to tree
            for u, v in path_segment:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            # Update remaining targets
            # (The path might have incidentally covered other targets)
            if closest_target in remaining_targets:
                remaining_targets.remove(closest_target)
            for _, v in path_segment:
                if v in remaining_targets:
                    remaining_targets.remove(v)
        else:
            # Graph disconnected or targets unreachable
            break

    return tree_edges

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.

    Strategy:
    1. Weighted Graph: Combines egress cost and throughput penalty.
       Penalty is tuned to be negligible for high speed links (>1Gbps) but
       significant for very slow links, preventing instance cost inflation.
    2. Iterative Diversity: Generates a Steiner Tree for each partition.
    3. Load Balancing: After each partition is routed, the edges used are
       penalized (weight increased). This encourages subsequent partitions
       to find alternative paths (multipath) if cost-effective, utilizing
       aggregate bandwidth across the network.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Clean graph: remove incoming edges to source to strictly enforce root role
    H = G.copy()
    to_remove = list(H.in_edges(src)) + list(nx.selfloop_edges(H))
    H.remove_edges_from(to_remove)

    # Tuning Parameters
    # ALPHA: Coefficient for throughput penalty.
    # Logic: 0.005 / 1Gbps = 0.005 cost penalty.
    #        0.005 / 0.1Gbps = 0.05 cost penalty (significant).
    #        0.005 / 10Gbps = 0.0005 cost penalty (negligible).
    ALPHA = 0.005
    PENALTY_FACTOR = 1.25  # Increase cost of used edges by 25% per usage

    # Initialize weights
    for u, v, data in H.edges(data=True):
        c = data.get('cost', 0.1)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.01) # Avoid division by zero

        # Base weight minimizes cost primarily, with a soft floor for throughput
        data['weight'] = c + (ALPHA / t_safe)

    # Generate paths for each partition
    for partition in range(num_partitions):
        # 1. Build a Steiner Tree for this partition
        tree_edges = _build_heuristic_steiner_tree(H, src, dsts, weight_attr='weight')

        if not tree_edges:
            continue

        # 2. Create a temporary graph for the tree to facilitate path extraction
        tree_graph = nx.DiGraph()
        for u, v in tree_edges:
            if H.has_edge(u, v):
                tree_graph.add_edge(u, v, **H[u][v])

        # 3. Extract paths and update Global Graph weights
        for dst in dsts:
            if dst == src:
                continue

            path_edges = []
            try:
                # Extract path from the constructed tree
                path_nodes = nx.shortest_path(tree_graph, src, dst)

                for i in range(len(path_nodes) - 1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    edge_data = H[u][v]
                    path_edges.append([u, v, edge_data])

                    # Apply penalty to the main graph H to encourage diversity
                    # for the next partition
                    current_w = H[u][v]['weight']
                    H[u][v]['weight'] = current_w * PENALTY_FACTOR

                bc_topology.set_dst_partition_paths(dst, partition, path_edges)

            except (nx.NetworkXNoPath, KeyError):
                # Fallback: If tree construction missed a node (e.g. graph disconnect),
                # try shortest path on original graph
                try:
                    path_nodes = nx.shortest_path(H, src, dst, weight='weight')
                    for i in range(len(path_nodes) - 1):
                        u, v = path_nodes[i], path_nodes[i+1]
                        path_edges.append([u, v, H[u][v]])
                    bc_topology.set_dst_partition_paths(dst, partition, path_edges)
                except nx.NetworkXNoPath:
                    pass # Unreachable

    return bc_topology
