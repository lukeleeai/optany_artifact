import heapq
import random
from typing import Dict, List, Set, Tuple, Any

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from any node in 'sources' to the closest node in 'targets'.
    Returns the path as a list of edges [(u, v), ...] and the target reached.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def _simplify_path_nodes(nodes):
    """
    Removes cycles from a path node list.
    E.g., [A, B, C, B, D] -> [A, B, D].
    Keeps the first occurrence of a node and skips to its last occurrence in the sequence.
    """
    if not nodes:
        return []

    # Map node to its last occurrence index
    last_occurrence = {node: i for i, node in enumerate(nodes)}

    new_nodes = []
    i = 0
    while i < len(nodes):
        node = nodes[i]
        new_nodes.append(node)
        # Jump to the index after the last occurrence of this node
        # If node only appears once, this effectively increments i by 1
        i = last_occurrence[node] + 1

    return new_nodes

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.

    Improvements:
    1. Weighted Function: Penalizes low throughput more aggressively to prevent bottlenecks
       while maintaining cost efficiency. Adds small hop penalty to reduce spaghetti routing.
    2. Candidate Generation: Uses Randomized Steiner Tree heuristics to find diverse,
       low-cost topologies.
    3. Loop Pruning: Explicitly removes cycles/redundant visits in reconstructed paths.
    4. Multipath Selection: Selects top K unique topologies and distributes partitions.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation & Weighting
    h = G.copy()
    # Remove incoming edges to source to enforce rooted tree structure
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weights:
    # Cost is dominant. Throughput penalties apply strongly if < 1 Gbps.
    # Small hop_penalty prevents unnecessary long chains for negligible cost savings.
    hop_penalty = 1e-4
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)

        # Penalize very low throughput to avoid transfer time bottlenecks
        # 0.02/t roughly equates to adding $0.02 cost for a 1Gbps link, $0.20 for 0.1Gbps.
        # This tradeoff prefers slightly more expensive links over very slow ones.
        t_safe = max(t, 0.01)
        tp_penalty = 0.02 / t_safe

        data['base_weight'] = c + tp_penalty + hop_penalty

    candidates = []

    # 2. Candidate Generation Strategies

    # Strategy A: Union of Shortest Paths (USP) - Baseline for latency/directness
    try:
        usp_edges = set()
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(h, src, dst, weight='base_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        if usp_edges:
            candidates.append({
                'edges': usp_edges,
                'cost': _get_topology_cost(usp_edges, h),
                'type': 'usp'
            })
    except nx.NetworkXNoPath:
        pass

    # Strategy B: Randomized Iterative Steiner Trees
    # Generate multiple diverse trees by perturbing weights
    num_iterations = min(num_partitions * 2, 8) if num_partitions > 0 else 1

    for i in range(num_iterations):
        # Perturb weights for diversity (+/- 15%)
        # This encourages the Steiner heuristic to explore different shared segments
        for u, v, data in h.edges(data=True):
            factor = random.uniform(0.85, 1.15)
            data['rand_weight'] = data['base_weight'] * factor

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        # Greedy Steiner Construction
        while remaining:
            # Find closest remaining destination to the current tree
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'rand_weight')

            if not target:
                break

            # Add path to tree
            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

            # Optimization: If the path passed through other remaining nodes, mark them as done
            # (Implicitly handled as they are now in tree_nodes, but we must update 'remaining' set)
            # Check if any other node in 'remaining' was visited in this path
            path_nodes_set = set(u for u, v in path).union({target})
            remaining = remaining - path_nodes_set

        if not tree_edges:
            continue

        # Avoid exact duplicates
        is_dup = False
        for c in candidates:
            if c['edges'] == tree_edges:
                is_dup = True
                break

        if not is_dup:
            candidates.append({
                'edges': tree_edges,
                'cost': _get_topology_cost(tree_edges, h),
                'type': 'steiner'
            })

    if not candidates:
        return bc_topology

    # 3. Path Extraction & Simplification
    for cand in candidates:
        # Build subgraph for this candidate
        st_graph = nx.DiGraph()
        for u, v in cand['edges']:
            if h.has_edge(u, v):
                st_graph.add_edge(u, v, **h[u][v])

        paths_map = {}
        for dst in dsts:
            if dst == src: continue
            path_edges_list = []

            try:
                # Get raw path nodes
                # Use base_weight to find best route within the selected topology
                raw_nodes = nx.shortest_path(st_graph, src, dst, weight='base_weight')

                # Critical: Remove cycles/loops (e.g., A->B->C->B->D)
                # These occur due to Steiner construction artifacts or graph structure
                clean_nodes = _simplify_path_nodes(raw_nodes)

                # Convert nodes back to edge list with original attributes
                for k in range(len(clean_nodes)-1):
                    u, v = clean_nodes[k], clean_nodes[k+1]
                    # We must use 'h' (original graph) to get complete edge data
                    # st_graph has subset, but safer to reference 'h'
                    path_edges_list.append([u, v, h[u][v]])

            except (nx.NetworkXNoPath, KeyError):
                # Fallback: Route via global graph if topology is disconnected
                try:
                    raw_nodes = nx.shortest_path(h, src, dst, weight='base_weight')
                    # No simplification needed on global shortest path usually, but safe to do
                    clean_nodes = _simplify_path_nodes(raw_nodes)
                    for k in range(len(clean_nodes)-1):
                        u, v = clean_nodes[k], clean_nodes[k+1]
                        path_edges_list.append([u, v, h[u][v]])
                except nx.NetworkXNoPath:
                    pass

            paths_map[dst] = path_edges_list
        cand['paths'] = paths_map

    # 4. Selection & Assignment
    # Sort candidates by cost
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Allow max 10% cost deviation from best to ensure cost efficiency
    # But ensure we have enough diversity if possible
    best_cost = candidates[0]['cost']
    limit_cost = best_cost * 1.10

    valid_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    # Deduplicate candidates based on the actual path maps (sometimes different trees yield same paths)
    unique_candidates = []
    seen_hashes = set()

    for c in valid_candidates:
        # Create a hashable signature of the paths
        # Sort edges to ensure consistent signature
        path_sig = []
        for dst in sorted(dsts):
            if dst in c['paths']:
                p_edges = c['paths'][dst]
                # Store tuple of (u,v) pairs
                sig = tuple((e[0], e[1]) for e in p_edges)
                path_sig.append(sig)
        path_hash = hash(tuple(path_sig))

        if path_hash not in seen_hashes:
            seen_hashes.add(path_hash)
            unique_candidates.append(c)

    # Round-robin assignment
    num_valid = len(unique_candidates)
    if num_valid == 0:
        # Should not happen if candidates existed, fallback to best raw
        unique_candidates = [candidates[0]]
        num_valid = 1

    for i in range(num_partitions):
        selected = unique_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
