import heapq
from typing import Dict, List

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]


class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)


def _build_steiner_tree(src: str, dsts: List[str], G: nx.DiGraph, weight_key: str) -> Dict[str, List]:
    """
    Constructs a Steiner Tree approximation using a greedy heuristic (repetitive shortest path)
    to minimize the total weight of the tree connecting src to all dsts.
    """
    # Initialize tree with source
    tree_nodes = {src}

    # We need to reconstruct the full graph of the tree to extract paths at the end
    st_graph = nx.DiGraph()
    st_graph.add_node(src)

    remaining_dsts = set(d for d in dsts if d != src and d in G)

    while remaining_dsts:
        # Dijkstra from the CURRENT SET of tree_nodes to find the closest non-tree node.
        # This approximates the Steiner Tree by greedily adding the cheapest path
        # from the existing tree to any uncovered destination.
        pq = []
        distances = {}
        local_preds = {} # Map node -> parent for the current search path reconstruction

        # Initialize priority queue with all current tree nodes as sources (dist=0)
        # This effectively treats the current tree as a single super-node
        for t_node in tree_nodes:
            distances[t_node] = 0
            heapq.heappush(pq, (0, t_node))

        target_node = None
        visited = set()

        while pq:
            d, u = heapq.heappop(pq)

            if d > distances.get(u, float('inf')):
                continue
            if u in visited:
                continue
            visited.add(u)

            # Check if we found a new destination
            if u in remaining_dsts:
                target_node = u
                break

            for v, data in G[u].items():
                if v in tree_nodes:
                    continue # Already in tree, no cost to reach, but don't traverse back in

                w = data.get(weight_key, 1.0)
                new_dist = d + w

                if new_dist < distances.get(v, float('inf')):
                    distances[v] = new_dist
                    local_preds[v] = u
                    heapq.heappush(pq, (new_dist, v))

        if target_node:
            # Backtrack from target_node to the existing tree
            curr = target_node
            path_segment = []
            while curr not in tree_nodes:
                parent = local_preds.get(curr)
                if parent is None:
                    break
                path_segment.append((parent, curr))
                curr = parent

            # Add the new segment to the Steiner Tree structure
            for u, v in reversed(path_segment):
                if u not in st_graph: st_graph.add_node(u)
                if v not in st_graph: st_graph.add_node(v)
                st_graph.add_edge(u, v, **G[u][v])
                tree_nodes.add(v)

            # Remove satisfied destinations (path might have covered multiple)
            remaining_dsts = remaining_dsts - tree_nodes
        else:
            # Graph is disconnected regarding remaining destinations
            break

    # Extract explicit paths from the constructed tree for each destination
    results = {}
    for dst in dsts:
        if dst == src:
            continue
        try:
            if dst in st_graph:
                path_nodes = nx.shortest_path(st_graph, src, dst)
                edge_list = []
                for i in range(len(path_nodes) - 1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    edge_list.append([u, v, G[u][v]])
                results[dst] = edge_list
        except (nx.NetworkXNoPath, KeyError):
            pass

    return results


def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.

    Improvements:
    1. Tuned Weight Metric: Balances egress cost and throughput to avoid low-bandwidth bottlenecks
       while maintaining low costs. (Cost + alpha/Throughput)
    2. Multipath Routing: Generates two distinct Steiner Trees (Primary and Diversity)
       to utilize parallel bandwidth where cost-effective.
    3. Partition Striping: Distributes data partitions across generated trees to reduce transfer time.
    """

    # 1. Prepare Graph
    h = G.copy()
    # Remove incoming edges to source to prevent cycles/back-propagation
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # 2. Calculate Weights
    # Weight formula aims to minimize Cost, but apply a penalty for low Throughput.
    # Alpha selection: We want 10Gbps vs 1Gbps to be significant, but not override
    # a massive cost difference.
    # Approx: $0.01 cost difference is roughly equivalent to a significant throughput gain.
    throughput_alpha = 0.15

    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 100.0)
        tp = data.get('throughput', 0.001)
        # Primary weight for cost-optimized tree
        # Small epsilon to avoid division by zero
        data['weight_primary'] = cost + (throughput_alpha / (tp + 1e-9))

    # 3. Build Tree 1: Cost-Optimized Steiner Tree
    tree1_paths = _build_steiner_tree(src, dsts, h, 'weight_primary')

    # 4. Build Tree 2: Diversity Steiner Tree (Multipath)
    # Penalize edges used in Tree 1 to encourage finding disjoint paths or different bottlenecks.
    # Penalty is capped (1.1x) to ensure we don't pick vastly more expensive paths just for diversity.
    # This ensures "Total Cost" remains low.
    diversity_penalty = 1.1

    # Identify edges used in Tree 1
    used_edges = set()
    for d, path in tree1_paths.items():
        for edge in path:
            used_edges.add((edge[0], edge[1]))

    # set secondary weights
    for u, v, data in h.edges(data=True):
        base_w = data['weight_primary']
        if (u, v) in used_edges:
            data['weight_secondary'] = base_w * diversity_penalty
        else:
            # Slight discount to unused edges to bias towards exploration
            data['weight_secondary'] = base_w * 0.99

    tree2_paths = _build_steiner_tree(src, dsts, h, 'weight_secondary')

    # 5. Assign Partitions to Trees
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    trees = [tree1_paths, tree2_paths]

    for dst in dsts:
        if dst == src:
            continue

        # Identify which trees successfully reached this destination
        valid_tree_indices = []
        for i, tree in enumerate(trees):
            if dst in tree and tree[dst]:
                valid_tree_indices.append(i)

        # Fallback: If no Steiner tree reached this dst (unlikely in connected graph),
        # try a direct shortest path on the original graph.
        if not valid_tree_indices:
            try:
                path_nodes = nx.shortest_path(h, src, dst, weight='weight_primary')
                fallback_path = []
                for k in range(len(path_nodes) - 1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    fallback_path.append([u, v, G[u][v]])

                for p_id in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, p_id, fallback_path)
            except (nx.NetworkXNoPath, KeyError):
                pass # Destination unreachable
            continue

        # Distribute partitions round-robin among valid trees
        # This exploits multipath bandwidth
        for p_id in range(num_partitions):
            tree_idx = valid_tree_indices[p_id % len(valid_tree_indices)]
            path = trees[tree_idx][dst]
            bc_topology.set_dst_partition_paths(dst, p_id, path)

    return bc_topology
