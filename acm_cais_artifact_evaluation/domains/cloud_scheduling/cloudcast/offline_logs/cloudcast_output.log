import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_tree_metrics(tree_edges, G):
    """
    Calculates cost per GB (assuming multicast overlay) and bottleneck throughput for a tree.
    """
    cost_per_gb = 0.0
    min_throughput = float('inf')

    # In a multicast overlay, we pay for each edge exactly once regardless of destinations served downstream
    for u, v in tree_edges:
        if not G.has_edge(u, v): continue
        data = G[u][v]
        cost_per_gb += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t

    if min_throughput == float('inf'): min_throughput = 0.0
    return cost_per_gb, min_throughput

def _extract_topology(G, edges, src, dsts):
    """
    Verifies a set of edges forms a valid tree connecting src to all dsts.
    Returns metrics and subgraph.
    """
    sub = nx.DiGraph()
    for u, v in edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    final_edges = set()

    try:
        # Check reachability and prune dead ends
        # Using BFS/Dijkstra to find paths to all DSTs on this specific subgraph
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(sub, src, dst)
            for i in range(len(path)-1):
                final_edges.add((path[i], path[i+1]))
    except (nx.NetworkXNoPath, Exception):
        return None

    if not final_edges:
        return None

    c, t = _get_tree_metrics(final_edges, sub)

    # Create clean subgraph with only necessary edges
    final_sub = nx.DiGraph()
    for u, v in final_edges:
        final_sub.add_edge(u, v, **G[u][v])

    return {
        'edges': final_edges,
        'cost_per_gb': c,
        'throughput': t,
        'subgraph': final_sub
    }

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing with Multipath Support.

    1. Generates candidate Steiner Trees using variable-weighted Shortest Path Trees and Hub heuristics.
    2. Evaluates candidates based on a composite score of Egress Cost + Instance Cost (Time Penalty).
    3. Selects either a single best tree or a mix of two trees to balance cost and throughput across partitions.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune incoming edges to src and self-loops
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    candidates = []

    # -------------------------------------------------------------------------
    # Strategy 1: Variable Weight Shortest Path Trees (SPT)
    # -------------------------------------------------------------------------
    # Explore trade-off between Cost and Throughput by varying alpha in:
    # Weight = Cost + Alpha * (1 / Throughput)
    # Alpha ranges cover: Pure Cost -> Balanced -> Pure Throughput
    alphas = [0.0, 0.0001, 0.001, 0.01, 0.05, 0.2, 1.0, 10.0]

    for alpha in alphas:
        # Apply temporary weights
        for u, v, data in h.edges(data=True):
            c = data.get('cost', 0.0)
            t = max(data.get('throughput', 1.0), 0.001) # Avoid div/0
            data['calc_weight'] = c + (alpha / t)

        try:
            # Union of Shortest Paths for this weight setting
            tree_edges = set()
            # Calculate paths to all targets
            paths = nx.shortest_path(h, source=src, weight='calc_weight')

            complete = True
            for dst in target_dsts:
                if dst not in paths:
                    complete = False
                    break
                p = paths[dst]
                for i in range(len(p)-1):
                    tree_edges.add((p[i], p[i+1]))

            if complete:
                cand = _extract_topology(h, tree_edges, src, target_dsts)
                if cand: candidates.append(cand)
        except:
            pass

    # -------------------------------------------------------------------------
    # Strategy 2: Hub-and-Spoke Heuristic
    # -------------------------------------------------------------------------
    # Test specific high-potential nodes to act as central hubs.
    # Prioritize neighbors of Src and nodes with high degree.
    potential_hubs = set(h.neighbors(src))

    # Add a few high-degree nodes
    degrees = sorted(h.degree(), key=lambda x: x[1], reverse=True)
    for n, d in degrees[:5]:
        potential_hubs.add(n)

    for hub in potential_hubs:
        if hub == src: continue
        try:
            # Path Src -> Hub (Balance cost/time)
            path_to_hub = nx.shortest_path(h, src, hub, weight=lambda u,v,d: d.get('cost',0) + 0.01/max(d.get('throughput',0.001), 0.001))

            hub_edges = set()
            for k in range(len(path_to_hub)-1):
                hub_edges.add((path_to_hub[k], path_to_hub[k+1]))

            # Hub -> Dsts (Minimize cost primarily, as Hub usually has good BW)
            for dst in target_dsts:
                if dst == hub: continue
                p = nx.shortest_path(h, hub, dst, weight='cost')
                for k in range(len(p)-1):
                    hub_edges.add((p[k], p[k+1]))

            cand = _extract_topology(h, hub_edges, src, target_dsts)
            if cand: candidates.append(cand)
        except:
            continue

    # -------------------------------------------------------------------------
    # Candidate Selection
    # -------------------------------------------------------------------------
    if not candidates:
        return bc_topology

    # Deduplicate candidates (keyed by cost and throughput)
    unique = {}
    for c in candidates:
        k = (round(c['cost_per_gb'], 5), round(c['throughput'], 3))
        if k not in unique: unique[k] = c
    candidates = list(unique.values())

    # Calibration constant K derived from instance costs vs data volume
    # Instance Cost ~ $10/hr. Data ~ 300GB.
    # Formula: TotalCost = Vol * (Egress + K/Throughput)
    # K approx 0.022.
    K = 0.022

    best_config = []
    min_score = float('inf')

    # 1. Evaluate Single Topologies
    # Score = Cost_per_GB + (K / Throughput)
    for c in candidates:
        t = c['throughput']
        if t < 0.001: continue
        score = c['cost_per_gb'] + (K / t)
        if score < min_score:
            min_score = score
            best_config = [(c, num_partitions)]

    # 2. Evaluate Multipath (Top 2 Topologies)
    # Combine partitions to average cost and sum throughput.
    # Sort by a balanced metric to find top contenders for mixing.
    ranked = sorted(candidates, key=lambda x: x['cost_per_gb'] + K/max(x['throughput'], 0.001))
    top_subset = ranked[:5] # Check combinations of top 5

    for i in range(len(top_subset)):
        for j in range(i+1, len(top_subset)):
            c1 = top_subset[i]
            c2 = top_subset[j]

            # Metric for 50/50 split (assuming equal partition spread approx)
            avg_cost = (c1['cost_per_gb'] + c2['cost_per_gb']) / 2
            sum_throughput = c1['throughput'] + c2['throughput']

            score = avg_cost + (K / sum_throughput)

            if score < min_score:
                min_score = score
                p1 = num_partitions // 2
                p2 = num_partitions - p1
                best_config = [(c1, p1), (c2, p2)]

    # -------------------------------------------------------------------------
    # Topology Assignment
    # -------------------------------------------------------------------------
    partition_counter = 0

    for cand, count in best_config:
        sub = cand['subgraph']

        # Calculate routes for all destinations in this tree
        # Since 'sub' is a DAG/Tree rooted at src, shortest_path works
        routes = {}
        for dst in target_dsts:
            try:
                # Reconstruct path data [u, v, attr]
                path_nodes = nx.shortest_path(sub, src, dst)
                path_edges = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    # Use original graph data for the output
                    path_edges.append([u, v, G[u][v]])
                routes[dst] = path_edges
            except:
                pass

        # Assign to partitions
        for _ in range(count):
            if partition_counter >= num_partitions: break

            for dst, route in routes.items():
                bc_topology.set_dst_partition_paths(dst, partition_counter, route)

            partition_counter += 1

    # Handle any remaining partitions (rare rounding edge cases)
    if partition_counter < num_partitions:
        # Assign rest to first config (or just last calculated routes)
        if routes:
             for i in range(partition_counter, num_partitions):
                 for dst, route in routes.items():
                    bc_topology.set_dst_partition_paths(dst, i, route)

    return bc_topology
