import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _evaluate_topology(candidates, data_vol=300.0, instance_cost_ph=15.0):
    """
    Selects the best topology based on Egress Cost + Instance Cost penalty.

    Instance Cost Model: Transfer Time * Hourly Rate
    Transfer Time ~ Data Volume (Gb) / Bottleneck Throughput (Gbps)
    """
    best_cand = None
    best_score = float('inf')

    for cand in candidates:
        unique_edges = cand['edges']
        sub = cand['subgraph']

        topo_egress = 0.0
        min_topo_throughput = float('inf')

        # Calculate Cost of the Overlay Tree
        # Assumes multicast-like behavior at application layer (send once to hub)
        for u, v in unique_edges:
            if sub.has_edge(u, v):
                data = sub[u][v]
                topo_egress += data.get('cost', 0.0) * data_vol
                t = data.get('throughput', 1.0)
                min_topo_throughput = min(min_topo_throughput, t)

        if min_topo_throughput <= 0.001: min_topo_throughput = 0.001

        # Time Estimation (Seconds)
        # Volume (GB) * 8 = Gb. Time = Gb / Gbps.
        # We add a buffer factor (1.2) for latency/overhead accumulation
        time_est = (data_vol * 8.0 * 1.2) / min_topo_throughput

        # Instance Cost Estimation
        instance_cost = (time_est / 3600.0) * instance_cost_ph

        # Total Score (Minimize)
        # We penalize depth to avoid "snake" topologies that kill latency
        depth_penalty = cand.get('max_hops', 1) * 2.0

        total_score = topo_egress + instance_cost + depth_penalty

        cand['score'] = total_score
        cand['time_est'] = time_est

        if total_score < best_score:
            best_score = total_score
            best_cand = cand

    return best_cand

def search_algorithm(src, dsts, G, num_partitions):
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Pruning
    # Keep src, dsts, and nodes that are potentially good hubs (high degree/bandwidth)
    # or exist on shortest paths between src and dsts.
    relevant_nodes = {src} | set(dsts)

    # Expand to neighbors to allow 1-hop detours
    for n in list(relevant_nodes):
        if n in G:
            relevant_nodes.update(G.neighbors(n))

    h = G.subgraph(list(relevant_nodes)).copy()

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 2. Weight Configuration
    # Balance Cost and Throughput.
    # We want to avoid very slow links even if they are cheap.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # 'opt_weight' ensures we prefer high bandwidth when costs are similar
        # If T=10, add 0.01. If T=0.1, add 1.0.
        data['opt_weight'] = c + (0.1 / max(t, 0.1))

    candidates = []

    # ---------------------------------------------------------
    # Strategy A: Union of Shortest Paths (USP / Star)
    # ---------------------------------------------------------
    # Minimizes latency, maximizes reliability. Baseline for cost.
    try:
        star_edges = set()
        star_sub = nx.DiGraph()
        max_hops = 0
        valid_star = True

        for dst in target_dsts:
            # Use opt_weight to pick good unicast paths
            path = nx.shortest_path(h, src, dst, weight='opt_weight')
            max_hops = max(max_hops, len(path)-1)
            for k in range(len(path)-1):
                u, v = path[k], path[k+1]
                star_edges.add((u, v))
                star_sub.add_edge(u, v, **h[u][v])

        candidates.append({
            'type': 'Star',
            'edges': star_edges,
            'subgraph': star_sub,
            'max_hops': max_hops
        })
    except nx.NetworkXNoPath:
        pass

    # ---------------------------------------------------------
    # Strategy B: Bounded Hub-and-Spoke
    # ---------------------------------------------------------
    # Test specific high-quality hubs.
    # Limit depth to prevent long chains (src->A->Hub->B->dst).
    # Only test hubs that are neighbors of src (Depth 1) to keep it fast and shallow.
    potential_hubs = [n for n in h.neighbors(src) if n != src]
    # Also include a few random nodes if graph is dense
    if len(h) > 50:
        potential_hubs += random.sample(list(h.nodes()), min(10, len(h)))

    for hub in potential_hubs:
        if hub in target_dsts: continue # Treated in Steiner/Star logic usually

        try:
            hub_edges = set()
            hub_sub = nx.DiGraph()

            # Src -> Hub (ensure it's direct or very short)
            path_sh = nx.shortest_path(h, src, hub, weight='opt_weight')
            if len(path_sh) > 2: continue # Prune deep hubs

            for k in range(len(path_sh)-1):
                u, v = path_sh[k], path_sh[k+1]
                hub_edges.add((u, v))
                hub_sub.add_edge(u, v, **h[u][v])

            # Hub -> Dsts
            possible = True
            curr_max_hops = len(path_sh)-1

            for dst in target_dsts:
                if dst == hub: continue
                path_hd = nx.shortest_path(h, hub, dst, weight='opt_weight')

                # DEPTH CHECK
                if (len(path_sh)-1) + (len(path_hd)-1) > 3:
                    possible = False
                    break

                for k in range(len(path_hd)-1):
                    u, v = path_hd[k], path_hd[k+1]
                    hub_edges.add((u, v))
                    hub_sub.add_edge(u, v, **h[u][v])
                curr_max_hops = max(curr_max_hops, (len(path_sh)-1) + (len(path_hd)-1))

            if possible:
                candidates.append({
                    'type': 'Hub',
                    'edges': hub_edges,
                    'subgraph': hub_sub,
                    'max_hops': curr_max_hops
                })
        except:
            continue

    # ---------------------------------------------------------
    # Strategy C: Constrained Greedy Steiner Tree
    # ---------------------------------------------------------
    # Build tree by adding closest node, but strictly penalize depth.
    mst_edges = set()
    mst_sub = nx.DiGraph()
    tree_nodes = {src}
    remaining = set(target_dsts)
    if src in remaining: remaining.remove(src)

    failed_mst = False
    while remaining:
        best_dist = float('inf')
        best_path = None
        best_target = None

        # Multi-source Dijkstra from current tree
        try:
            dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight='opt_weight')

            for r in remaining:
                if r in dists and dists[r] < best_dist:
                    # Check depth constraint: Logic is tricky without tracking tree depth
                    # Simplified: Prefer short segments (<= 2 hops) to expand tree
                    p = paths[r]
                    if len(p) - 1 <= 2:
                        best_dist = dists[r]
                        best_target = r
                        best_path = p
        except:
            failed_mst = True
            break

        if best_target and best_path:
            for k in range(len(best_path)-1):
                u, v = best_path[k], best_path[k+1]
                mst_edges.add((u, v))
                mst_sub.add_edge(u, v, **h[u][v])
                tree_nodes.add(v)
                if v in remaining: remaining.remove(v)
        else:
            # If we can't find a short path to extend, break and discard strategy
            failed_mst = True
            break

    if not failed_mst:
        # Verify total depth
        try:
            max_d = 0
            for d in target_dsts:
                l = nx.shortest_path_length(mst_sub, src, d)
                max_d = max(max_d, l)
            if max_d <= 4:
                candidates.append({
                    'type': 'Steiner',
                    'edges': mst_edges,
                    'subgraph': mst_sub,
                    'max_hops': max_d
                })
        except:
            pass

    # ---------------------------------------------------------
    # Selection & Path Extraction
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    best_topology = _evaluate_topology(candidates)
    subgraph = best_topology['subgraph']

    # Assign paths to partitions
    # We use the single best topology for all partitions to maximize consistency
    # and simplify debugging, unless we had multipath logic ready.
    for dst in target_dsts:
        path_edges = []
        try:
            # Extract path from the specific topology subgraph
            path = nx.shortest_path(subgraph, src, dst)
            for k in range(len(path)-1):
                u, v = path[k], path[k+1]
                path_edges.append([u, v, h[u][v]]) # Use original graph data

            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

        except nx.NetworkXNoPath:
            # Fallback to direct shortest path on original graph
            try:
                p = nx.shortest_path(h, src, dst, weight='opt_weight')
                pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, pe)
            except:
                pass

    return bc_topology
