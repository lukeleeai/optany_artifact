import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

# --- Optimization Logic ---

def _calculate_composite_weight(u, v, data):
    """
    Calculates edge weight balancing Cost (primary) and Throughput (secondary).
    Weight = Cost + (Alpha / Throughput) + Hop_Penalty
    """
    cost = data.get('cost', 0.0)
    throughput = data.get('throughput', 1.0)

    # Ensure throughput isn't zero to avoid division error
    t_safe = max(throughput, 0.001)

    # Constants
    # Alpha: Determines how much we pay for bandwidth.
    # 0.01 implies we are willing to pay $0.01 extra to save significant time/congestion.
    # Hop Penalty: Small bias (1e-6) towards paths with fewer hops if costs are identical.
    return cost + (0.01 / t_safe) + 1e-6

def _dijkstra_nearest_terminal(G, tree_nodes, remaining_terminals, weight_attr):
    """
    Finds shortest path from any node in the current tree (tree_nodes)
    to the nearest node in the set of remaining terminals.
    """
    pq = []
    # Initialize PQ with all current tree nodes at distance 0
    for node in tree_nodes:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent_node)

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in remaining_terminals:
            # Reconstruct path backwards from u to the tree connection point
            path = []
            curr = u
            while curr is not None:
                dist_info = visited.get(curr)
                if not dist_info: break
                _, par = dist_info
                if par is None:
                    # Reached a node that was originally in tree_nodes
                    break
                path.append((par, curr))
                curr = par
            return list(reversed(path)), u

        for v, attr in G[u].items():
            if v not in visited:
                w = attr.get(weight_attr, 1.0)
                heapq.heappush(pq, (d + w, v, u))

    return None, None

def _generate_spt(G, src, dsts, weight_attr):
    """
    Strategy: Union of Shortest Paths (SPT).
    Best for latency and valid as a cost baseline.
    """
    edges = set()
    try:
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(G, src, dst, weight=weight_attr)
            for i in range(len(path)-1):
                edges.add((path[i], path[i+1]))
        return edges
    except nx.NetworkXNoPath:
        return None

def _generate_sph(G, src, dsts, weight_attr):
    """
    Strategy: Shortest Path Heuristic (SPH) for Steiner Tree.
    Greedily connects the closest unconnected destination to the current tree.
    Efficient approximation for minimizing total tree cost.
    """
    tree_nodes = {src}
    tree_edges = set()
    remaining = set(dsts) - {src}

    while remaining:
        path, target = _dijkstra_nearest_terminal(G, tree_nodes, remaining, weight_attr)
        if not path and remaining:
            # If we can't reach remaining nodes, the graph is disconnected
            return None

        if path:
            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            # Remove the found target from remaining set
            remaining.discard(target)

            # Also remove any other terminals that might have been picked up along this path
            for u, v in path:
                if v in remaining:
                    remaining.discard(v)
        else:
            # Should not happen if graph is connected and remaining is not empty
            break

    return tree_edges

def _evaluate_topology(G, edges, src, dsts):
    """
    Calculates the total cost of the topology and verifies connectivity.
    Returns (total_cost, paths_map).
    """
    if not edges:
        return float('inf'), None

    # Calculate Total Cost based on original edge costs
    total_cost = 0.0
    for u, v in edges:
        total_cost += G[u][v].get('cost', 0.0)

    # Verify Connectivity and Build Path Map
    # We build a temporary subgraph
    subg = nx.DiGraph()
    for u, v in edges:
        subg.add_edge(u, v, **G[u][v])

    paths_map = {}
    valid = True

    for dst in dsts:
        if dst == src: continue
        try:
            # Use unweighted BFS for path extraction on the tree structure
            p = nx.shortest_path(subg, src, dst)
            path_list = []
            for i in range(len(p)-1):
                u_node, v_node = p[i], p[i+1]
                # Reconstruct [u, v, data] format expected by BroadCastTopology
                path_list.append([u_node, v_node, G[u_node][v_node]])
            paths_map[dst] = path_list
        except nx.NetworkXNoPath:
            valid = False
            break

    if not valid:
        return float('inf'), None

    return total_cost, paths_map

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Approach:
    1. Pre-process graph to filter back-flow and calculate composite weights (Cost + Throughput).
    2. Generate candidate topologies using multiple heuristics:
       - Union of Shortest Paths (low latency, baseline cost).
       - Greedy Steiner Tree (minimized shared cost).
       - Randomized Steiner Tree (exploration of local optima).
    3. Evaluate candidates based on total egress cost.
    4. Distribute partitions across the best valid candidates to balance load.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    h = G.copy()

    # Remove incoming edges to source to enforce tree root structure
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate weights
    for u, v, data in h.edges(data=True):
        data['std_weight'] = _calculate_composite_weight(u, v, data)

    candidates = []

    # 2. Candidate Generation

    # Strategy A: Shortest Path Tree (SPT)
    spt_edges = _generate_spt(h, src, dsts, 'std_weight')
    cost_spt, paths_spt = _evaluate_topology(h, spt_edges, src, dsts)
    if paths_spt:
        candidates.append({'cost': cost_spt, 'paths': paths_spt, 'type': 'SPT'})

    # Strategy B: Greedy Steiner (SPH)
    sph_edges = _generate_sph(h, src, dsts, 'std_weight')
    if sph_edges:
        cost_sph, paths_sph = _evaluate_topology(h, sph_edges, src, dsts)
        if paths_sph:
            candidates.append({'cost': cost_sph, 'paths': paths_sph, 'type': 'SPH'})

    # Strategy C: Randomized SPH for diversity
    # Run multiple times with perturbed weights to find alternative trees
    num_random_tries = min(num_partitions, 4)
    for i in range(num_random_tries):
        rand_h = h.copy()
        for u, v, d in rand_h.edges(data=True):
            # Perturb weight: +/- 20% random variance
            r_factor = 0.8 + 0.4 * random.random()
            d['rand_weight'] = d['std_weight'] * r_factor

        r_edges = _generate_sph(rand_h, src, dsts, 'rand_weight')
        if r_edges:
            c_cost, c_paths = _evaluate_topology(h, r_edges, src, dsts)
            if c_paths:
                candidates.append({'cost': c_cost, 'paths': c_paths, 'type': f'R_SPH_{i}'})

    # 3. Selection
    if not candidates:
        return bc_topology # Fail-safe, returns empty mapping

    # Sort candidates by cost
    candidates.sort(key=lambda x: x['cost'])

    # Select best cost as baseline
    best_cost = candidates[0]['cost']

    # Filter candidates that are within acceptable cost margin (e.g., 5%)
    # This ensures we don't pick significantly more expensive paths just for diversity.
    valid_candidates = [c for c in candidates if c['cost'] <= best_cost * 1.05]

    # 4. Partition Assignment
    count_valid = len(valid_candidates)

    for i in range(num_partitions):
        # Round-robin assignment across valid diverse topologies
        chosen = valid_candidates[i % count_valid]
        paths = chosen['paths']

        for dst, p_list in paths.items():
            bc_topology.set_dst_partition_paths(dst, i, p_list)

    return bc_topology
