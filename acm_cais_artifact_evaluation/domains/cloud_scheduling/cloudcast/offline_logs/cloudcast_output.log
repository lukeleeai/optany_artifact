import heapq
import random
from typing import Dict, List, Set, Tuple
from itertools import combinations

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

# --------------------------------------------------------------------------------
# Helper Functions
# --------------------------------------------------------------------------------

def _calculate_edge_weight(data: dict) -> float:
    """
    Computes a composite weight for routing.
    Goal: Minimize Cost, maximize Throughput, minimize Hops.
    Weight = Cost + (Alpha / Throughput) + Epsilon

    - Cost: Egress cost per GB.
    - Throughput term: Penalizes low bandwidth edges to reduce instance costs/latency.
    - Epsilon: Slight penalty per hop to discourage deep 'snake' topologies.
    """
    cost = data.get('cost', 0.0)
    throughput = data.get('throughput', 1.0)
    # Avoid div by zero, clamp min throughput
    t_safe = max(throughput, 0.001)

    # Alpha=0.0005: Willing to pay ~$0.0005/GB extra to avoid 1Gbps bottleneck
    # Epsilon=1e-4: Adds small cost per hop to prevent long chains of equal cost
    return cost + (0.0005 / t_safe) + 1e-4

def _evaluate_candidate(edges: Set[Tuple], G: nx.DiGraph, data_vol: float = 1.0) -> float:
    """
    Scores a set of edges forming a multicast topology.
    Score = Total Egress Cost + Virtual Instance Cost (Time penalty)
    Low score is better.
    """
    if not edges:
        return float('inf')

    total_egress = 0.0
    min_throughput = float('inf')

    for u, v in edges:
        if not G.has_edge(u, v):
            continue
        data = G[u][v]
        total_egress += data.get('cost', 0.0) * data_vol
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t

    if min_throughput == float('inf') or min_throughput <= 0:
        return float('inf')

    # Virtual Instance Cost estimation
    # Heuristic: Cost of running instances is proportional to time ~ (1/throughput)
    # Factor 0.5 balances this against egress dollar costs
    time_penalty = 0.5 / min_throughput

    return total_egress + time_penalty

def _extract_paths_from_tree(tree_edges: Set[Tuple], src: str, dsts: List[str], G: nx.DiGraph):
    """
    Given a set of edges forming a tree/DAG rooted at src, extract paths to all dsts.
    Returns None if any dst is unreachable in the subgraph.
    """
    # Build temporary graph for traversal
    sub = nx.DiGraph()
    for u, v in tree_edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    paths = {}
    for dst in dsts:
        if dst == src: continue
        try:
            # Use shortest path on the subgraph (unique path in a tree)
            path_nodes = nx.shortest_path(sub, src, dst)
            path_segments = []
            for i in range(len(path_nodes)-1):
                u, v = path_nodes[i], path_nodes[i+1]
                path_segments.append([u, v, G[u][v]])
            paths[dst] = path_segments
        except (nx.NetworkXNoPath, Exception):
            return None
    return paths

# --------------------------------------------------------------------------------
# Strategy Implementations
# --------------------------------------------------------------------------------

def _strategy_shortest_paths(G, src, dsts):
    """
    Strategy A: Union of Shortest Paths (USP).
    Routes each destination independently via its optimal path.
    High throughput, high egress (low sharing), lowest latency.
    """
    edges = set()
    for dst in dsts:
        try:
            path = nx.shortest_path(G, src, dst, weight='opt_weight')
            for i in range(len(path)-1):
                edges.add((path[i], path[i+1]))
        except nx.NetworkXNoPath:
            return None
    return edges

def _strategy_provider_gateways(G, src, dsts):
    """
    Strategy B: Provider-Centric Clustering.
    Groups destinations by provider (aws, gcp, azure).
    Routes Source -> Gateway (Best Node in Provider) -> Dsts in Provider.
    Reduces inter-cloud hops.
    """
    # Identify providers
    providers = {}
    for d in dsts:
        p = d.split(':')[0]
        if p not in providers: providers[p] = []
        providers[p].append(d)

    combined_edges = set()

    for prov, group in providers.items():
        # Potential gateways: nodes belonging to this provider or the source itself
        candidates = [n for n in G.nodes() if n.startswith(prov + ":")]
        if src not in candidates: candidates.append(src)

        best_cost = float('inf')
        best_edges = None

        # Heuristic: Check source + random subset of provider nodes + actual destinations
        # to find the best hub for this cluster.
        prio = [c for c in candidates if c in group or c == src]
        others = [c for c in candidates if c not in prio]
        search_space = list(set(prio + random.sample(others, min(len(others), 5))))

        for gw in search_space:
            current_edges = set()
            try:
                # 1. Path Src -> Gateway
                if src != gw:
                    p_to_gw = nx.shortest_path(G, src, gw, weight='opt_weight')
                    for k in range(len(p_to_gw)-1):
                        current_edges.add((p_to_gw[k], p_to_gw[k+1]))

                # 2. Path Gateway -> Dsts
                possible = True
                for d in group:
                    if gw == d: continue
                    p_gw_d = nx.shortest_path(G, gw, d, weight='opt_weight')
                    for k in range(len(p_gw_d)-1):
                        current_edges.add((p_gw_d[k], p_gw_d[k+1]))

                if possible:
                    # Simple cost estimate for selection
                    cost = sum(G[u][v].get('cost', 0) for u, v in current_edges)
                    if cost < best_cost:
                        best_cost = cost
                        best_edges = current_edges
            except nx.NetworkXNoPath:
                continue

        if best_edges is not None:
            combined_edges.update(best_edges)
        else:
            # Fallback to shortest paths for this group if gateway search fails
            fallback = _strategy_shortest_paths(G, src, group)
            if fallback: combined_edges.update(fallback)
            else: return None

    return combined_edges

def _strategy_steiner_approx(G, src, dsts):
    """
    Strategy C: Metric Closure Steiner Tree Approximation.
    1. Compute all-pairs shortest paths between Terminals ({src} + dsts).
    2. Build MST on this complete graph (Metric Closure).
    3. Map MST edges back to original graph paths.
    Produces a balanced tree that shares edges where efficient.
    """
    terminals = list(set([src] + dsts))
    terminal_indices = {t: i for i, t in enumerate(terminals)}
    n_term = len(terminals)

    # 1. Metric Closure
    # Store edges as (weight, u, v, path_nodes)
    metric_closure = []

    # Run multi-source Dijkstra from each terminal to find dists to other terminals
    for i, u in enumerate(terminals):
        try:
            dists, paths = nx.multi_source_dijkstra(G, [u], weight='opt_weight')
            for j, v in enumerate(terminals):
                # Add edge if v is a terminal and we haven't added (u,v) or (v,u) yet (undirected concept, but directed graph)
                # Since graph is directed, we need connectivity u->v.
                # MST algorithm needs undirected edges usually, but here we build a directed arborescence rooted at src?
                # Actually, standard approx is MST on undirected closure, then direct it.
                # Simpler approximation for Directed Steiner:
                # Prim's from Src on the closure graph.
                if u != v and v in dists:
                    metric_closure.append((dists[v], u, v, paths[v]))
        except:
            continue

    # 2. Prim-like greedy construction on the Closure Graph
    # We want a tree rooted at src covering all dsts
    reached = {src}
    unreached = set(dsts)
    if src in unreached: unreached.remove(src)

    final_edges = set()

    while unreached:
        best_dist = float('inf')
        best_path = None
        best_target = None

        # Find closest connection from Reached Set -> Unreached Set
        # (This is O(N^2) relative to terminals, which is small)
        for w, u, v, path in metric_closure:
            if u in reached and v in unreached:
                if w < best_dist:
                    best_dist = w
                    best_target = v
                    best_path = path

        if best_target and best_path:
            # Add path to topology
            for k in range(len(best_path)-1):
                final_edges.add((best_path[k], best_path[k+1]))
            reached.add(best_target)
            unreached.remove(best_target)
        else:
            return None # Cannot connect

    return final_edges

# --------------------------------------------------------------------------------
# Main Algorithm
# --------------------------------------------------------------------------------

def search_algorithm(src: str, dsts: List[str], G: nx.DiGraph, num_partitions: int):
    """
    Optimized Broadcast Routing Algorithm.
    Strategies:
    1. USP (Star): Best for latency/throughput.
    2. Provider-Centric: Best for inter-cloud cost optimization.
    3. Steiner Approx: Best for general edge sharing.

    Selection maximizes (Cost + Penalty) efficiency.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune graph to relevant component
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    valid_dsts = [d for d in dsts if d != src and d in h]
    if not valid_dsts:
        return bc_topology

    # Assign weights used by all strategies
    for u, v, data in h.edges(data=True):
        data['opt_weight'] = _calculate_edge_weight(data)

    candidates = []

    # Generate Candidates
    strategies = [
        ('USP', _strategy_shortest_paths),
        ('Provider', _strategy_provider_gateways),
        ('Steiner', _strategy_steiner_approx)
    ]

    for name, strategy_func in strategies:
        edges = strategy_func(h, src, valid_dsts)
        if edges:
            score = _evaluate_candidate(edges, h)
            candidates.append({'edges': edges, 'score': score, 'type': name})

    # Selection
    if not candidates:
        return bc_topology

    # Sort by Score (Lower is better)
    candidates.sort(key=lambda x: x['score'])
    best_candidate = candidates[0]

    # Path Extraction & assignment
    final_paths = _extract_paths_from_tree(best_candidate['edges'], src, valid_dsts, h)

    if final_paths:
        for dst, path_segs in final_paths.items():
            # Assign paths to partitions.
            # Note: We use the best found topology for all partitions to ensure stability
            # and because finding >1 disjoint efficient trees is complex/risky for constraints.
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_segs)

    return bc_topology
