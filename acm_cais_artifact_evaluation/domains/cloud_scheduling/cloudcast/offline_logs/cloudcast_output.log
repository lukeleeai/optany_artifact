import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        if G.has_edge(u, v):
            total += G[u][v].get('cost', 0.0)
    return total

def _get_path_edges(G, path_nodes):
    edges = []
    for i in range(len(path_nodes) - 1):
        u, v = path_nodes[i], path_nodes[i+1]
        if G.has_edge(u, v):
            edges.append([u, v, G[u][v]])
    return edges

def _get_spt_topology(G, src, dsts, weight_attr):
    """
    Constructs a Shortest Path Tree (SPT) topology.
    This effectively acts as a Union of Shortest Paths (USP).
    Returns: (edge_set, paths_map, total_cost, max_hops)
    """
    edges = set()
    paths_map = {}
    max_hops = 0

    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(G, src, dst, weight=weight_attr)
            path_len = len(path) - 1
            if path_len > max_hops:
                max_hops = path_len

            path_edges = []
            for i in range(path_len):
                u, v = path[i], path[i+1]
                edges.add((u, v))
                path_edges.append([u, v, G[u][v]])
            paths_map[dst] = path_edges
        except nx.NetworkXNoPath:
            paths_map[dst] = []

    return edges, paths_map, _get_topology_cost(edges, G), max_hops

def _dijkstra_incremental(G, tree_nodes, targets, weight_attr):
    """
    Finds shortest path from any node in tree_nodes to any node in targets.
    Optimized to stop as soon as *any* target is reached.
    """
    pq = []
    # Init PQ with all tree nodes at distance 0
    for node in tree_nodes:
        heapq.heappush(pq, (0.0, node, None))

    visited = {}
    closest_target = None
    target_set = set(targets)

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in target_set:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            heapq.heappush(pq, (d + w, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_steiner_heuristic_topology(G, src, dsts, weight_attr):
    """
    Constructs a topology using a greedy Steiner Tree heuristic.
    Builds a tree by iteratively connecting the closest disconnected destination.
    """
    tree_edges = set()
    tree_nodes = {src}
    remaining = set(d for d in dsts if d != src and d in G)

    while remaining:
        # Find cheapest path from ANY node in current tree to ANY remaining destination
        path, target = _dijkstra_incremental(G, tree_nodes, remaining, weight_attr)
        if not target:
            break

        for u, v in path:
            if (u, v) not in tree_edges:
                tree_edges.add((u, v))
                tree_nodes.add(v)
        remaining.remove(target)

    # Extract paths by running shortest path on the constructed tree
    st_graph = nx.DiGraph()
    for u, v in tree_edges:
        if G.has_edge(u, v):
            st_graph.add_edge(u, v, **G[u][v])

    paths_map = {}
    max_hops = 0

    for dst in dsts:
        if dst == src: continue
        try:
            # Route on the Steiner Tree (unweighted to find hops, or weighted)
            path = nx.shortest_path(st_graph, src, dst)
            path_len = len(path) - 1
            max_hops = max(max_hops, path_len)
            paths_map[dst] = _get_path_edges(G, path)
        except nx.NetworkXNoPath:
            # Fallback to global graph if tree construction failed specific node
            try:
                path = nx.shortest_path(G, src, dst, weight=weight_attr)
                path_edges = _get_path_edges(G, path)
                paths_map[dst] = path_edges
                # Incorporate fallback edges into cost calculation
                for pe in path_edges:
                    tree_edges.add((pe[0], pe[1]))
            except nx.NetworkXNoPath:
                paths_map[dst] = []

    return tree_edges, paths_map, _get_topology_cost(tree_edges, G), max_hops

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.
    Strategies:
    1. Shortest Path Tree (SPT): Baseline for low cost and low latency.
    2. Steiner Heuristic: Optimizes for shared edges (cost), but checked against hop limits.
    3. Latency SPT: Optimizes for throughput/time, used for multipathing if cost permits.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    h = G.copy()
    # Remove incoming edges to source and self-loops
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Assign weights
    # Primary Weight: Cost.
    # Tie-breaker: Throughput (represented as inverse).
    # Logic: cost + (epsilon / throughput).
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        # 0.0001 scalar ensures we prefer 10Gbps over 1Gbps even if cost is identical,
        # but won't pick an expensive link just because it's fast.
        data['std_weight'] = c + (0.0001 / t_safe)
        data['lat_weight'] = (1.0 / t_safe)

    candidates = []

    # 2. Strategy A: Shortest Path Tree (SPT)
    # This is often the most robust solution for cloud egress.
    spt_edges, spt_paths, spt_cost, spt_hops = _get_spt_topology(h, src, dsts, 'std_weight')
    if spt_paths:
        candidates.append({
            'type': 'SPT',
            'paths': spt_paths,
            'edges': spt_edges,
            'cost': spt_cost,
            'hops': spt_hops
        })

    # 3. Strategy B: Greedy Steiner Heuristic
    # Useful when significant edge overlaps exist.
    st_edges, st_paths, st_cost, st_hops = _get_steiner_heuristic_topology(h, src, dsts, 'std_weight')

    if st_paths:
        # Constraint: Do not accept Steiner trees that create excessive daisy-chains (latency bottlenecks).
        # Limit to 2x the hops of the USP/SPT solution.
        hop_limit = max(spt_hops * 2, 4)
        if st_hops <= hop_limit and st_cost < spt_cost:
             candidates.append({
                'type': 'Steiner',
                'paths': st_paths,
                'edges': st_edges,
                'cost': st_cost,
                'hops': st_hops
            })

    # 4. Strategy C: Latency/Throughput Optimization
    # Generate a topology optimized for speed. Only used if cost is reasonable.
    lat_edges, lat_paths, lat_cost, lat_hops = _get_spt_topology(h, src, dsts, 'lat_weight')

    best_cost_so_far = min(c['cost'] for c in candidates) if candidates else float('inf')

    # Allow Latency topology if it's within 20% cost of the best cost option
    if lat_paths and lat_cost <= best_cost_so_far * 1.20:
        # Deduplication check
        if lat_edges != spt_edges:
            candidates.append({
                'type': 'LatSPT',
                'paths': lat_paths,
                'edges': lat_edges,
                'cost': lat_cost,
                'hops': lat_hops
            })

    # 5. Candidate Selection
    if not candidates:
        return bc_topology

    # Sort candidates by Cost
    candidates.sort(key=lambda x: x['cost'])

    best_candidate = candidates[0]

    # 6. Partition Assignment with Multipath Support
    # If a secondary candidate exists that is distinct and reasonably priced, use it for some partitions
    # to better utilize bandwidth (reduce bottlenecking on shared edges).
    secondary_candidate = None
    for cand in candidates[1:]:
        # Allow secondary if cost is within 10% of best
        if cand['cost'] <= best_candidate['cost'] * 1.10:
            secondary_candidate = cand
            break

    for i in range(num_partitions):
        # 66% Primary, 33% Secondary logic (simple load balancing)
        if secondary_candidate and (i % 3 == 2):
            selected = secondary_candidate
        else:
            selected = best_candidate

        for dst, path in selected['paths'].items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
