import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_candidate_metrics(candidate_edges, G):
    """Calculates total cost and min throughput for a set of edges."""
    total_cost = 0.0
    min_throughput = float('inf')
    for u, v in candidate_edges:
        if not G.has_edge(u, v): continue
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    if min_throughput == float('inf'): min_throughput = 0.0
    return total_cost, min_throughput

def _build_topology_from_edges(G, edges, src, dsts):
    """
    Reconstructs paths from src to dsts given a set of edges (tree/dag).
    Returns metrics and the subgraph.
    """
    sub = nx.DiGraph()
    for u, v in edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    # Extract paths using shortest path on subgraph to ensure validity
    # We use the 'opt_weight' or just hops to traverse the subgraph
    final_edges = set()
    valid = True
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(sub, src, dst)
            for i in range(len(path)-1):
                final_edges.add((path[i], path[i+1]))
        except (nx.NetworkXNoPath, Exception):
            valid = False
            break

    if not valid:
        return None

    c, t = _get_candidate_metrics(final_edges, sub)
    return {
        'edges': final_edges,
        'cost': c,
        'min_throughput': t,
        'subgraph': sub
    }

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Weighted Graph: Uses a combined weight of Cost + (Penalty/Throughput) to avoid bottlenecks.
    2. Union of Shortest Paths (USP): Generates a star-like topology (baseline).
    3. Hub-and-Spoke Heuristic: Explicitly tests single-hub overlays to prevent long chains.
    4. Greedy Steiner Tree: Randomized incremental construction for general trees.

    Selection:
    Prioritizes Cost, but applies a virtual penalty for low throughput (high instance costs).
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune graph
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 1. Weight Configuration
    # We add a penalty term for throughput to model instance costs and latency.
    # Penalty factor 0.0005 implies:
    # 10 Gbps -> +0.00005 (negligible)
    # 1 Gbps  -> +0.0005 (small cost equivalent)
    # 0.1 Gbps -> +0.005 (significant, avoids unless saves >0.5 cents)
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        data['opt_weight'] = c + (0.0005 / t_safe)

    candidates = []

    # ---------------------------------------------------------
    # Strategy A: Union of Shortest Paths (USP)
    # ---------------------------------------------------------
    # Calculates the "Star" or "Mesh" topology by routing everyone optimally individually.
    # This is the baseline to beat.
    usp_edges = set()
    try:
        for dst in target_dsts:
            path = nx.shortest_path(h, src, dst, weight='opt_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        cand = _build_topology_from_edges(h, usp_edges, src, target_dsts)
        if cand:
            cand['type'] = 'USP'
            candidates.append(cand)
    except nx.NetworkXNoPath:
        pass

    # ---------------------------------------------------------
    # Strategy B: Hub-and-Spoke Heuristic
    # ---------------------------------------------------------
    # Test every node as a potential "Hub". Src -> Hub -> Dsts.
    # This prevents the "Snake" topology (Src -> A -> B -> C -> D) by enforcing depth limit.
    # We only test top K nodes by closeness to Src to save time, or random subset.
    nodes_to_check = list(h.nodes())
    if len(nodes_to_check) > 20:
        # Prioritize nodes that are destinations or neighbors of src
        prio = set(target_dsts) | set(h.neighbors(src))
        nodes_to_check = list(prio) + random.sample(nodes_to_check, min(10, len(nodes_to_check)))

    for hub in nodes_to_check:
        if hub == src: continue
        # Path Src -> Hub
        try:
            path_to_hub = nx.shortest_path(h, src, hub, weight='opt_weight')
            hub_edges = set()
            for k in range(len(path_to_hub)-1):
                hub_edges.add((path_to_hub[k], path_to_hub[k+1]))

            # Hub -> Dsts
            possible = True
            for dst in target_dsts:
                if dst == hub: continue
                # We use Dijkstra here too
                p = nx.shortest_path(h, hub, dst, weight='opt_weight')
                for k in range(len(p)-1):
                    hub_edges.add((p[k], p[k+1]))

            if possible:
                cand = _build_topology_from_edges(h, hub_edges, src, target_dsts)
                if cand:
                    cand['type'] = 'Hub'
                    candidates.append(cand)
        except nx.NetworkXNoPath:
            continue

    # ---------------------------------------------------------
    # Strategy C: Randomized Greedy Steiner
    # ---------------------------------------------------------
    # Classic approximation: iteratively connect closest terminal to the tree.
    # Run a few times with noise to explore.
    iterations = 5
    for i in range(iterations):
        noise_factor = 0.1 if i > 0 else 0.0

        # Temp weights with noise
        for u, v, data in h.edges(data=True):
            w = data['opt_weight']
            if noise_factor > 0:
                w *= random.uniform(1.0 - noise_factor, 1.0 + noise_factor)
            data['calc_weight'] = w

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(target_dsts)

        # Priority Queue for Prim-like expansion could be O(N^2),
        # here we just iterate (N * Dijkstra) which is acceptable for cloud graph sizes (small).
        while remaining:
            # Find closest (node_in_tree -> node_in_remaining)
            best_path = None
            best_dist = float('inf')
            best_target = None

            # Optimization: Multi-source Dijkstra from all tree nodes
            # Computes shortest path from set tree_nodes to any node in remaining
            # Returns (dist, path)
            # We use a helper or simple loop if graph is small.
            # For efficiency in NetworkX:
            try:
                # multi_source_dijkstra returns (distance_dict, path_dict)
                dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight='calc_weight')

                # Find closest target in remaining
                for r in remaining:
                    if r in dists and dists[r] < best_dist:
                        best_dist = dists[r]
                        best_target = r
                        best_path = paths[r]
            except:
                pass

            if best_target and best_path:
                # Add path edges to tree
                for k in range(len(best_path)-1):
                    u, v = best_path[k], best_path[k+1]
                    tree_edges.add((u, v))
                    tree_nodes.add(v) # Add all nodes on path
                    if v in remaining: remaining.remove(v)
                # Specifically remove target (it might be removed above if on path)
                if best_target in remaining: remaining.remove(best_target)
            else:
                break # Graph disconnected

        if not remaining:
            cand = _build_topology_from_edges(h, tree_edges, src, target_dsts)
            if cand:
                cand['type'] = 'Steiner'
                candidates.append(cand)

    # ---------------------------------------------------------
    # Selection
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    # Filter out very low throughput results unless they are the only option
    robust_candidates = [c for c in candidates if c['min_throughput'] > 0.05]
    if not robust_candidates: robust_candidates = candidates

    # Scoring Function: Minimize Virtual Cost
    # Virtual Cost = Dollar Cost + (Time Penalty)
    # This aligns with "minimize total cost (egress + instance)"
    def score_candidate(c):
        # Penalty: Equivalent to instance cost for keeping system up longer.
        # Adjusted to 0.5 units per inverse-Gbps.
        time_penalty = 0.5 / max(c['min_throughput'], 0.001)
        return c['cost'] + time_penalty

    # Sort and pick best
    robust_candidates.sort(key=score_candidate)
    best_cand = robust_candidates[0]

    # ---------------------------------------------------------
    # Path Extraction
    # ---------------------------------------------------------
    subgraph = best_cand['subgraph']

    for dst in target_dsts:
        try:
            # Re-extract explicit edges from the winning subgraph
            # Shortest path on subgraph is safe (it's a tree/dag essentially)
            path_nodes = nx.shortest_path(subgraph, src, dst, weight='opt_weight')

            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                edge_data = h[u][v] # Original data
                path_edges.append([u, v, edge_data])

            # Apply to all partitions
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)
        except nx.NetworkXNoPath:
            # Fallback to direct routing if something fails
            try:
                p = nx.shortest_path(h, src, dst, weight='opt_weight')
                pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, pe)
            except:
                pass

    return bc_topology
