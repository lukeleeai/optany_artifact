import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm for Multi-Cloud Data Transfer.

    Optimization Strategy:
    1. Primary Goal: Minimize Egress Cost. Egress fees dominate total cost (approx 95%+).
       The algorithm prioritizes edge selection based on pure dollar cost.
    2. Secondary Goal: Maintain acceptable throughput.
       Instance costs are modeled as a penalty derived from transfer time.
    3. Approach:
       - Generates multiple candidate topologies (Minimum Cost Tree, High-Bandwidth Tree).
       - Uses corrected weighting to avoid over-penalizing moderate bandwidth links
         (which are often cheaper intra-cloud links).
       - Selects the topology that minimizes (Egress Cost + Virtual Instance Cost).
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning & Setup
    h = G.copy()
    # Remove edges incoming to source (prevents cycles back to start) and self-loops
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 2. Weight Configuration
    # Previous implementation used a high throughput penalty (0.0005/t) which, when summed
    # over path length, outweighed significant cost differences.
    # We now use 'cost' as the primary weight, with a negligible epsilon for throughput tie-breaking.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)

        # 'cost_weight': Pure cost focus. 100 Mbps vs 10 Gbps difference is negligible
        # unless costs are identical.
        data['cost_weight'] = c + (1e-5 / t_safe)

        # 'balanced_weight': Allows spending slightly more for significantly better bandwidth.
        # Used for finding alternative paths that might prevent bottlenecks.
        # 1 Gbps vs 10 Gbps -> penalty diff ~0.009 (approx 1 cent).
        data['balanced_weight'] = c + (0.01 / t_safe)

    candidates = []

    def build_candidate(strategy_type, weight_attr, edge_predicate=None):
        """Constructs a candidate topology using Union of Shortest Paths."""
        topology_edges = set()

        # Filter graph if needed (e.g., for High-Bandwidth plane)
        search_graph = h
        if edge_predicate:
            valid_edges = [(u,v) for u,v,d in h.edges(data=True) if edge_predicate(d)]
            # If filtering isolates nodes, this candidate might fail, which is handled below.
            if not valid_edges: return
            search_graph = h.edge_subgraph(valid_edges)

        valid = True
        for dst in target_dsts:
            try:
                # Find shortest path for this specific strategy
                path = nx.shortest_path(search_graph, src, dst, weight=weight_attr)
                for i in range(len(path)-1):
                    topology_edges.add((path[i], path[i+1]))
            except (nx.NetworkXNoPath, Exception):
                valid = False
                break

        if valid and topology_edges:
            # Reconstruct the tree to calculate aggregate metrics
            # Note: The union of shortest paths might form a DAG, but we treat it as a valid routing set.
            candidate_subgraph = nx.DiGraph()
            total_cost = 0.0
            min_throughput = float('inf')

            for u, v in topology_edges:
                data = h[u][v]
                candidate_subgraph.add_edge(u, v, **data)
                total_cost += data.get('cost', 0.0)
                t = data.get('throughput', 0.0)
                if t < min_throughput: min_throughput = t

            if min_throughput == float('inf'): min_throughput = 0.0

            candidates.append({
                'type': strategy_type,
                'cost': total_cost,
                'min_throughput': min_throughput,
                'subgraph': candidate_subgraph
            })

    # Strategy A: Economy (Minimum Egress Cost)
    # This usually finds intra-provider paths (e.g., GCP->GCP) which are cheapest.
    build_candidate('Economy', 'cost_weight')

    # Strategy B: High Performance (Bandwidth > 2 Gbps)
    # Checks if a high-speed backbone exists.
    build_candidate('Performance', 'cost_weight', lambda d: d.get('throughput', 0.0) >= 2.0)

    # Strategy C: Balanced
    # Uses the balanced weight to trade small cost increases for better bandwidth.
    build_candidate('Balanced', 'balanced_weight')

    # 3. Selection
    if not candidates:
        return bc_topology

    # Score candidates based on: Egress Cost + (Instance Cost Proxy)
    # Instance Cost Proxy = Estimated Time * Price.
    # Estimated Time ~ 1 / Throughput.
    # We normalize this to a penalty factor.
    # A penalty of 5.0 implies that improving throughput from 1Gbps to Infinity is worth $5.
    # This aligns with typical instance costs for transferring ~300GB.
    def score_candidate(c):
        throughput_penalty = 5.0 / max(c['min_throughput'], 0.001)
        return c['cost'] + throughput_penalty

    # Sort by score (ascending) and pick best
    candidates.sort(key=score_candidate)
    best_candidate = candidates[0]
    final_graph = best_candidate['subgraph']

    # 4. Path Assignment
    # We assign the paths from the best candidate to all partitions.
    # While multipath is possible, splitting partitions often moves traffic to
    # sub-optimal (more expensive) cost paths. Given cost dominance, single best tree is optimal.
    for dst in target_dsts:
        path_edges = []
        try:
            # Re-trace path in the winning topology
            path_nodes = nx.shortest_path(final_graph, src, dst) # Unweighted is fine in a tree
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                path_edges.append([u, v, h[u][v]])
        except nx.NetworkXNoPath:
            # Fallback to direct routing on original graph if topology reconstruction had issues
            try:
                p = nx.shortest_path(h, src, dst, weight='cost_weight')
                path_edges = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
            except:
                continue # Unreachable

        # Assign to all partitions
        for i in range(num_partitions):
            bc_topology.set_dst_partition_paths(dst, i, path_edges)

    return bc_topology
