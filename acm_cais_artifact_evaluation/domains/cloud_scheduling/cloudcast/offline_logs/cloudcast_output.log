import heapq
import random
import math
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _calculate_tree_metrics(G, edges):
    """
    Calculates total egress cost sum and minimum throughput for a set of edges.
    Returns (sum_of_edge_costs, min_throughput_gbps)
    """
    total_cost = 0.0
    min_throughput = float('inf')

    if not edges:
        return float('inf'), 0.001

    for u, v in edges:
        if not G.has_edge(u, v):
            continue
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t

    if min_throughput == float('inf') or min_throughput <= 0.0:
        min_throughput = 0.001

    return total_cost, min_throughput

def _extract_paths_from_tree(G, tree_edges, src, dsts):
    """
    Reconstructs individual paths from source to each destination given a tree/DAG of edges.
    Uses BFS/Shortest Path on the subgraph defined by tree_edges.
    """
    sub = nx.DiGraph()
    for u, v in tree_edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    paths = {}

    for dst in dsts:
        if dst == src: continue
        try:
            # Find path in the subgraph
            path_nodes = nx.shortest_path(sub, src, dst)
            path_segments = []
            for i in range(len(path_nodes)-1):
                u_curr, v_curr = path_nodes[i], path_nodes[i+1]
                # Retrieve original edge data
                if G.has_edge(u_curr, v_curr):
                    path_segments.append([u_curr, v_curr, G[u_curr][v_curr]])
                else:
                    # Fallback to subgraph data (should be same)
                    path_segments.append([u_curr, v_curr, sub[u_curr][v_curr]])
            paths[dst] = path_segments
        except (nx.NetworkXNoPath, Exception):
            return None # Tree does not cover this destination

    return paths

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Generates candidate topologies using multiple weighting schemes:
       - Pure Cost (minimize egress $)
       - Balanced (minimize $ + delay penalty)
       - Performance (minimize transfer time)
       - Hops (minimize latency/complexity)
    2. Generates a Steiner Tree approximation to find efficient shared edges.
    3. Evaluates candidates using a Total Cost Model (Egress + Instance Cost).

    The algorithm selects the single best topology that minimizes Total Cost
    while meeting connectivity requirements.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune incoming edges to source to simplify graph
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    valid_dsts = [d for d in dsts if d != src and d in h]
    if not valid_dsts:
        return bc_topology

    # ------------------------------------------------------------------
    # 1. Weight Configuration
    # ------------------------------------------------------------------
    # We define multiple weights to explore the Pareto frontier of Cost vs Time.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)

        # Pure Cost: favors cheap edges regardless of speed
        data['w_cost'] = c

        # Balanced: Adds a penalty for low throughput.
        # K ~= 0.005 implies 1GB instance cost overhead is roughly $0.005.
        data['w_balanced'] = c + (0.005 / t_safe)

        # Performance: Favors high throughput (Inverse T)
        data['w_perf'] = (1.0 / t_safe)

        # Hops: Penalize depth to avoid "snake" topologies unless necessary
        # Adding small cost factor to break ties towards cheaper hops
        data['w_hops'] = 1.0 + c * 0.1

    candidates = []

    # ------------------------------------------------------------------
    # 2. Candidate Generation: Union of Shortest Paths (USP)
    # ------------------------------------------------------------------
    # For each weight metric, compute the Shortest Path Tree.
    # This forms a valid multicast tree that is optimal for that specific metric
    # assuming unicast routing.

    metrics = ['w_cost', 'w_balanced', 'w_perf', 'w_hops']

    for metric in metrics:
        try:
            # Compute SPT to all nodes from src
            spt_paths = nx.shortest_path(h, source=src, weight=metric)

            tree_edges = set()
            possible = True
            for dst in valid_dsts:
                if dst not in spt_paths:
                    possible = False
                    break
                path = spt_paths[dst]
                for i in range(len(path)-1):
                    tree_edges.add((path[i], path[i+1]))

            if possible and tree_edges:
                candidates.append({
                    'edges': tree_edges,
                    'type': f'USP_{metric}'
                })
        except:
            continue

    # ------------------------------------------------------------------
    # 3. Candidate Generation: Greedy Steiner Tree
    # ------------------------------------------------------------------
    # Iteratively connects the closest destination to the existing tree.
    # Good for finding shared edges that reduce total graph weight.
    # We run this using the 'w_balanced' metric to be safe.

    for _ in range(2): # Two passes (deterministic here, but robust)
        tree_nodes = {src}
        tree_edges = set()
        remaining = set(valid_dsts)
        possible = True

        while remaining:
            try:
                # Find shortest path from ANY node in tree to ANY node in remaining
                dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight='w_balanced')

                # Pick closest target
                best_target = None
                best_dist = float('inf')

                for r in remaining:
                    if r in dists and dists[r] < best_dist:
                        best_dist = dists[r]
                        best_target = r

                if best_target:
                    # Add path to tree
                    p = paths[best_target]
                    for i in range(len(p)-1):
                        u, v = p[i], p[i+1]
                        tree_edges.add((u, v))
                        tree_nodes.add(v)
                        if v in remaining: remaining.remove(v)
                    # Explicit removal
                    if best_target in remaining: remaining.remove(best_target)
                else:
                    possible = False # Cannot reach remaining
                    break
            except:
                possible = False
                break

        if possible and tree_edges:
            candidates.append({
                'edges': tree_edges,
                'type': 'Steiner'
            })
            break # One successful Steiner is usually sufficient

    if not candidates:
        return bc_topology

    # ------------------------------------------------------------------
    # 4. Selection based on Global Cost Model
    # ------------------------------------------------------------------
    # We score each candidate by simulating the total cost.
    # Total Cost = (Volume * Egress_Sum) + (Instance_Rate * Duration)
    # Since Volume is a multiplier, we optimize per-GB cost + time-penalty-per-GB.

    # Estimation constants
    # Instance cost overhead relative to Data transfer.
    # Factor K represents (Instance_$/sec * 8 bits)
    # We use a balanced factor to penalize slow paths appropriately.
    TIME_PENALTY_FACTOR = 0.005

    scored_candidates = []
    for cand in candidates:
        c_sum, min_t = _calculate_tree_metrics(h, cand['edges'])

        # Virtual Total Score = Egress_Cost + (Penalty / Throughput)
        # This aligns with minimizing the user's total bill.
        # We add a small hop penalty to break ties against "snakes".
        # Hops approx = number of edges in tree / number of destinations (avg depth)
        avg_hops = len(cand['edges']) / max(len(valid_dsts), 1)

        score = c_sum + (TIME_PENALTY_FACTOR / min_t) + (0.0001 * avg_hops)

        # Hard constraint: If throughput is extremely low (< 50 Mbps) and
        # alternative exists, penalize heavily.
        if min_t < 0.05:
            score += 10.0

        scored_candidates.append((score, cand))

    # Pick winner
    scored_candidates.sort(key=lambda x: x[0])
    best_cand = scored_candidates[0][1]

    # ------------------------------------------------------------------
    # 5. Result Construction
    # ------------------------------------------------------------------
    final_paths = _extract_paths_from_tree(h, best_cand['edges'], src, valid_dsts)

    if final_paths:
        for dst, path_segs in final_paths.items():
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_segs)
    else:
        # Fallback (should be rare)
        for dst in valid_dsts:
            try:
                p = nx.shortest_path(h, src, dst, weight='w_balanced')
                pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, pe)
            except:
                pass

    return bc_topology
