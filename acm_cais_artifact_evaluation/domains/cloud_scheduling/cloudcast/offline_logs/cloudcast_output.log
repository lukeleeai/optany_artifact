import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Efficiently finds the shortest path from any node in 'sources' to the closest node in 'targets'.
    Returns (path_edges, target_node).
    """
    pq = []
    # Initialize PQ with all source nodes at distance 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path edges from source to target
        path_edges = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path_edges.append((par, curr))
            curr = par
        return list(reversed(path_edges)), closest_target
    return [], None

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Improvements:
    1. Multi-Objective Weights: Balances cost, throughput, and hop count to avoid deep, high-latency chains.
    2. Diverse Candidate Generation: Creates multiple topology candidates (Balanced, Direct/Star, High-BW)
       to exploit multipath opportunities.
    3. Robust Fallbacks: Ensures connectivity even if heuristic trees are partial.
    4. Cost-Aware Selection: Assigns partitions to the most cost-effective diverse paths.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weight Calculation
    h = G.copy()
    # Enforce rooted tree structure by removing incoming edges to source
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate weights for different strategies
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001) # Avoid division by zero

        # Strategy A: Balanced (Default)
        # Includes a 'hop penalty' (+0.005) to discourage long chains unless they offer significant savings.
        # Includes throughput penalty scaled to be relevant against cost (0.01/t).
        data['w_balanced'] = c + (0.01 / t_safe) + 0.005

        # Strategy B: Direct/Latency Focus
        # Heavy hop penalty to approximate a Star topology (Union of Shortest Paths).
        data['w_direct'] = c + (0.001 / t_safe) + 0.05

        # Strategy C: High Throughput
        # Penalizes low bandwidth heavily to find "fat pipes".
        data['w_perf'] = c + (0.1 / t_safe) + 0.005

    candidates = []

    # 2. Generate Candidate Topologies
    # We generate multiple trees:
    # 1. Balanced Tree (Cost/Performance tradeoff)
    # 2. Star-like Tree (Low Latency/Direct)
    # 3. High-BW Tree (Fat pipes)
    # 4. Alternative Balanced Tree (Diversity forced via penalties)

    strategies = [
        ('w_balanced', 1.0),
        ('w_direct', 1.0),
        ('w_perf', 1.0),
        ('w_balanced', 1.5) # Rerun with penalties
    ]

    global_edge_penalties = {}

    for weight_attr, penalty_factor in strategies:
        # Apply diversity penalties
        for u, v, data in h.edges(data=True):
            base_w = data[weight_attr]
            pen = global_edge_penalties.get((u, v), 1.0)
            data['current_weight'] = base_w * pen

        # Steiner Tree Heuristic
        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        while remaining:
            # Connect closest remaining destination to the current tree
            path_edges, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'current_weight')

            if not target:
                break

            # Add new edges to tree
            for u, v in path_edges:
                tree_edges.add((u, v))
                tree_nodes.add(v)

            # Update remaining set (target and any intermediate nodes found)
            remaining.discard(target)
            for u, v in path_edges:
                if v in remaining:
                    remaining.discard(v)

        if not tree_edges:
            continue

        # Build tree subgraph for path extraction
        st_graph = nx.DiGraph()
        st_graph.add_nodes_from(tree_nodes)
        for u, v in tree_edges:
            if h.has_edge(u, v):
                st_graph.add_edge(u, v, **h[u][v])

        # Extract paths and calculate metric
        paths_map = {}
        cand_extra_cost = 0.0

        for dst in dsts:
            if dst == src: continue
            try:
                # Get path in the Steiner tree (unweighted BFS is sufficient for trees)
                path_nodes = nx.shortest_path(st_graph, src, dst)
                path_edges_list = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges_list.append([u, v, st_graph[u][v]])
                paths_map[dst] = path_edges_list
            except (nx.NetworkXNoPath, KeyError):
                # Fallback: Use global shortest path if Steiner tree missed this node
                try:
                    path_nodes = nx.shortest_path(h, src, dst, weight='w_balanced')
                    path_edges_list = []
                    for k in range(len(path_nodes)-1):
                        u, v = path_nodes[k], path_nodes[k+1]
                        edge_data = h[u][v]
                        path_edges_list.append([u, v, edge_data])
                        # This edge contributes extra cost if not in tree
                        if (u,v) not in tree_edges:
                            cand_extra_cost += edge_data.get('cost', 0.0)
                    paths_map[dst] = path_edges_list
                except nx.NetworkXNoPath:
                    paths_map[dst] = None

        # Cost Metric for sorting: Total Shared Tree Cost + Individual Fallback Costs
        tree_cost = sum(h[u][v].get('cost', 0.0) for u, v in tree_edges)
        candidates.append({
            'paths': paths_map,
            'cost_metric': tree_cost + cand_extra_cost,
            'edges': tree_edges
        })

        # Penalize used edges for next iteration to encourage diversity
        for u, v in tree_edges:
            global_edge_penalties[(u, v)] = global_edge_penalties.get((u, v), 1.0) * 1.5

    # 3. Candidate Selection & Assignment
    if not candidates:
        return bc_topology

    # Sort by cost metric
    candidates.sort(key=lambda x: x['cost_metric'])

    # Select best candidates for Multipath
    # We take the best one, and any others that are reasonably close in cost (< 20% more expensive)
    # to maximize bandwidth usage without exploding costs.
    best_cost = candidates[0]['cost_metric']
    selected_candidates = [candidates[0]]

    for cand in candidates[1:]:
        if cand['cost_metric'] <= best_cost * 1.2:
            # Check if this candidate adds diversity (optional optimization)
            selected_candidates.append(cand)
            if len(selected_candidates) >= 4: # Cap at 4 diverse topologies
                break

    # 4. Round-Robin Assignment
    num_selected = len(selected_candidates)
    for i in range(num_partitions):
        cand = selected_candidates[i % num_selected]
        for dst, path in cand['paths'].items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
