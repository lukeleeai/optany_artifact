import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Returns the path as a list of (u, v) tuples and the target node reached.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing with multipath diversity and cost-throughput balancing.

    Strategies:
    1. Union of Shortest Paths (USP) for latency-sensitive baseline.
    2. Iterative Steiner Tree Heuristics for cost optimization.
    3. Diversity-enforced penalty system to find disjoint candidates.
    4. Flexible candidate selection allowing slightly higher cost for better bandwidth.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 0. Edge Case Handling
    if not dsts:
        return bc_topology
    if num_partitions == 0:
        return bc_topology

    # 1. Graph Preparation
    # Work on a copy to safely modify weights
    h = G.copy()

    # Prune incoming edges to source (broadcast constraint) and self-loops
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Define weight metrics
    # Cost ($/GB) is primary, but we penalize low throughput to avoid congestion.
    # Weight = Cost + (Alpha / Throughput) + Hop_Penalty
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001) # Avoid division by zero

        # Primary weight for Steiner Tree construction (Cost-focused)
        # 0.01/t means 1Gbps adds $0.01 penalty, 10Gbps adds $0.001
        data['steiner_weight'] = c + (0.01 / t_safe) + 0.0001

        # Secondary weight for USP (Performance-focused)
        # Higher throughput penalty encourages finding faster links even if slightly pricier
        data['fast_weight'] = c + (0.05 / t_safe) + 0.001

    candidates = []

    # Strategy A: Union of Shortest Paths (USP)
    # Often optimal for latency and serves as a high-bandwidth baseline.
    usp_edges = set()
    usp_map = {} # dst -> path_edges
    valid_usp = True

    try:
        for dst in dsts:
            if dst == src: continue
            # Use 'fast_weight' to prefer higher throughput links
            path = nx.shortest_path(h, src, dst, weight='fast_weight')
            path_edges = []
            for k in range(len(path)-1):
                u, v = path[k], path[k+1]
                usp_edges.add((u, v))
                path_edges.append([u, v, h[u][v]])
            usp_map[dst] = path_edges

        candidates.append({
            'type': 'USP',
            'edges': usp_edges,
            'cost': _get_topology_cost(usp_edges, h),
            'paths': usp_map
        })
    except nx.NetworkXNoPath:
        valid_usp = False

    # Strategy B: Iterative Steiner Tree Heuristics
    # Generates trees with shared edges to minimize total egress cost.
    edge_penalties = {}
    iterations = 3

    for i in range(iterations):
        # Apply penalties to diversify search in subsequent iterations
        for u, v, data in h.edges(data=True):
            base = data['steiner_weight']
            penalty = edge_penalties.get((u, v), 1.0)
            data['calc_weight'] = base * penalty

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        # Greedy construction: connect closest remaining destination to current tree
        while remaining:
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')

            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)
            remaining.remove(target)

        if not tree_edges:
            continue

        # Deduplicate candidates based on edge set
        is_dup = False
        for c in candidates:
            if c['edges'] == tree_edges:
                is_dup = True
                break

        if not is_dup:
            # Reconstruct per-destination paths from the Steiner tree topology
            st_graph = nx.DiGraph()
            st_graph.add_nodes_from(tree_nodes)
            for u, v in tree_edges:
                st_graph.add_edge(u, v, **h[u][v])

            paths_map = {}
            valid_tree = True
            for dst in dsts:
                if dst == src: continue
                try:
                    # BFS on the tree is sufficient as path is unique in a tree
                    path_nodes = nx.shortest_path(st_graph, src, dst)
                    p_edges = []
                    for k in range(len(path_nodes)-1):
                        u, v = path_nodes[k], path_nodes[k+1]
                        p_edges.append([u, v, h[u][v]])
                    paths_map[dst] = p_edges
                except (nx.NetworkXNoPath, KeyError):
                    # Fallback: this branch should rarely be taken if tree construction is correct
                    try:
                        path_nodes = nx.shortest_path(h, src, dst, weight='steiner_weight')
                        p_edges = []
                        for k in range(len(path_nodes)-1):
                            u, v = path_nodes[k], path_nodes[k+1]
                            p_edges.append([u, v, h[u][v]])
                        paths_map[dst] = p_edges
                    except nx.NetworkXNoPath:
                        valid_tree = False
                        break

            if valid_tree:
                candidates.append({
                    'type': f'Steiner_{i}',
                    'edges': tree_edges,
                    'cost': _get_topology_cost(tree_edges, h),
                    'paths': paths_map
                })

                # Apply strong penalties to edges in this tree to force diversity in next iteration
                for u, v in tree_edges:
                    edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 2.0

    if not candidates:
        return bc_topology

    # 4. Candidate Selection
    # Sort candidates by cost
    candidates.sort(key=lambda x: x['cost'])

    best_cost = candidates[0]['cost']

    # Filter for valid multipath candidates
    # Allow 25% cost slack to include diverse topologies (like USP) that improve throughput
    limit_cost = best_cost * 1.25
    valid_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    # Fallback to best only if filtering eliminated everything (edge case)
    if not valid_candidates:
        valid_candidates = [candidates[0]]

    # 5. Partition Assignment
    # Round-robin assignment across valid candidates distributes load
    # across potentially edge-disjoint paths, maximizing aggregate bandwidth.
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
