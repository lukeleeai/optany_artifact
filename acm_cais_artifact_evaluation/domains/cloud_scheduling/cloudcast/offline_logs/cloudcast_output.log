import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Optimized to stop early as soon as any target is reached.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    # Use a counter to avoid comparison of nodes in heapq
    entry_count = 0

    for node in sources:
        heapq.heappush(pq, (0.0, entry_count, node, None))
        entry_count += 1

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, _, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, entry_count, v, u))
            entry_count += 1

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_metrics(edges, G):
    """
    Returns (total_cost, min_throughput)
    """
    total_cost = 0.0
    min_throughput = float('inf')
    for u, v in edges:
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    return total_cost, min_throughput

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm (Steiner Tree Heuristic with Randomization).

    Improvements:
    1. Robust Weighting: Dominant 'cost' factor with minimal throughput penalty to prevent
       costly detours while still breaking ties in favor of bandwidth.
    2. Randomized Search: Runs multiple iterations of the Greedy Steiner Heuristic with
       perturbed weights to escape local optima and find better shared structures.
    3. Strict Selection: Prioritizes the absolute lowest cost topology unless a critical
       bandwidth bottleneck (<1 Gbps) is detected, significantly reducing egress fees.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()
    # Remove incoming edges to source to enforce rooted tree structure
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Base Weight: standard_weight
    # Strategy: Cost is dominant. Throughput is a tie-breaker/penalty for extremely slow links.
    # We use a smaller coefficient for throughput (0.0001) compared to the previous version.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Avoid division by zero
        t_safe = max(t, 0.001)
        # Weight = Cost + small penalty for low throughput.
        # This ensures we pick the cheapest path, but if costs are equal, pick the faster one.
        data['standard_weight'] = c + (0.0001 / t_safe)

    candidates = []

    # Strategy A: Union of Shortest Paths (USP)
    # Good baseline for latency-sensitive or "star-like" optimal structures
    usp_edges = set()
    valid_usp = True
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
        except nx.NetworkXNoPath:
            valid_usp = False
            break

    if valid_usp and usp_edges:
        c_cost, c_min_t = _get_topology_metrics(usp_edges, h)
        candidates.append({
            'edges': usp_edges,
            'cost': c_cost,
            'min_throughput': c_min_t,
            'type': 'USP'
        })

    # Strategy B: Randomized Greedy Steiner Tree
    # Run multiple iterations with random noise to find better global optima
    # Iterations scaled by complexity, fixed at 8 for good coverage/performance balance
    iterations = 8

    for i in range(iterations):
        # Apply random noise to weights for this iteration to explore diverse trees
        # Noise range +/- 15%
        for u, v, data in h.edges(data=True):
            noise = random.uniform(0.85, 1.15)
            data['calc_weight'] = data['standard_weight'] * noise

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        while remaining:
            # Connect closest unreachable destination to current tree
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')

            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining = remaining - tree_nodes

        if not tree_edges:
            continue

        # Deduplicate
        is_dup = False
        for c in candidates:
            if c['edges'] == tree_edges:
                is_dup = True
                break

        if not is_dup:
            c_cost, c_min_t = _get_topology_metrics(tree_edges, h)
            candidates.append({
                'edges': tree_edges,
                'cost': c_cost,
                'min_throughput': c_min_t,
                'type': 'Steiner'
            })

    if not candidates:
        return bc_topology

    # 3. Path Extraction & Preparation
    for cand in candidates:
        st_graph = nx.DiGraph()
        for u, v in cand['edges']:
            if h.has_edge(u, v):
                st_graph.add_edge(u, v, **h[u][v])

        paths_map = {}
        # Calculate max path time for ranking purposes (approximate)
        # Volume assumption for ranking: 100GB. Instance cost assumption: $0.5/hr
        # Score = Cost + (100 / min_throughput_of_path) * 0.0001
        # We use a combined score to break ties

        for dst in dsts:
            if dst == src: continue
            path_edges = []
            try:
                path_nodes = nx.shortest_path(st_graph, src, dst, weight='standard_weight')
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u, v, h[u][v]])
            except (nx.NetworkXNoPath, KeyError):
                # Fallback to global graph if local topology fails (should not happen)
                try:
                    path_nodes = nx.shortest_path(h, src, dst, weight='standard_weight')
                    for k in range(len(path_nodes)-1):
                        u, v = path_nodes[k], path_nodes[k+1]
                        path_edges.append([u, v, h[u][v]])
                except nx.NetworkXNoPath:
                    pass
            paths_map[dst] = path_edges
        cand['paths'] = paths_map

    # 4. Selection Logic
    # Sort primarily by raw Egress Cost.
    # Secondary sort by min_throughput (descending) to prefer faster links for same cost.
    candidates.sort(key=lambda x: (x['cost'], -x['min_throughput']))

    best_candidate = candidates[0]

    # Decide on Multipath
    # Only use multipath if:
    # 1. The best candidate has a bottleneck (< 1.5 Gbps)
    # 2. OR the second best candidate is extremely close in cost (< 0.5% diff)

    selected_candidates = [best_candidate]

    if len(candidates) > 1:
        second_best = candidates[1]
        cost_diff_ratio = (second_best['cost'] - best_candidate['cost']) / (best_candidate['cost'] + 1e-9)

        is_bottlenecked = best_candidate['min_throughput'] < 1.5
        is_cost_identical = cost_diff_ratio < 0.005

        if (is_bottlenecked and cost_diff_ratio < 0.05) or is_cost_identical:
            selected_candidates.append(second_best)
            # If bottleneck is severe, look for a third
            if is_bottlenecked and len(candidates) > 2:
                third = candidates[2]
                if (third['cost'] - best_candidate['cost']) / best_candidate['cost'] < 0.05:
                    selected_candidates.append(third)

    # 5. Partition Assignment
    num_selected = len(selected_candidates)

    for i in range(num_partitions):
        selected = selected_candidates[i % num_selected]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
