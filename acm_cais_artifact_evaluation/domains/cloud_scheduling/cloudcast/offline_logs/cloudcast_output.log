import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using a Cost-Latency weighted Steiner Tree heuristic.

    The algorithm constructs a shared multicast tree to minimize total egress cost
    while applying a "virtual cost" to low-throughput links to prevent
    excessive instance runtime costs.

    Args:
        src: Source node identifier
        dsts: List of destination node identifiers
        G: NetworkX DiGraph with 'cost' ($/GB) and 'throughput' (Gbps) attributes
        num_partitions: Number of data partitions

    Returns:
        BroadCastTopology object with paths for all destinations and partitions
    """

    # 1. Graph Preparation & Heuristic Weight Calculation
    h = G.copy()

    # Prevent loops back to source
    if src in h:
        h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # Economic Calibration:
    # We balance Egress Cost ($/GB) vs Instance Cost due to Transfer Time.
    # Assumptions:
    # - Instance cost ~ $2.00/hr (high-bandwidth instances).
    # - Data volume ~ 300GB.
    # - 1 Gbps link takes ~40 mins (~$1.33 instance cost) -> ~ $0.0044/GB.
    # - 10 Gbps link takes ~4 mins (~$0.13 instance cost) -> ~ $0.00044/GB.
    #
    # THROUGHPUT_PENALTY_FACTOR = 0.005
    # This value balances the equation so that a 1Gbps link adds roughly $0.005/GB
    # to the virtual weight, preventing selection of very slow links (<100Mbps)
    # without overriding actual egress savings (cents/GB) on medium-speed links.
    THROUGHPUT_PENALTY_FACTOR = 0.005

    # ALPHA (Depth Penalty):
    # Controls trade-off between MST (0.0) and SPT (1.0).
    # A low alpha (0.1) preserves the cost-saving aggregation of Steiner Trees (hubs)
    # while providing a slight bias against unnecessarily deep daisy-chains
    # that don't save money (triangle inequality violations) but add latency.
    DEPTH_PENALTY_ALPHA = 0.1

    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 0.1)
        throughput = data.get('throughput', 1.0)

        # Avoid division by zero
        safe_throughput = max(throughput, 1e-3)

        # Composite weight: Real Money Cost + Virtual Time Cost
        data['weight'] = cost + (THROUGHPUT_PENALTY_FACTOR / safe_throughput)

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 2. Heuristic Steiner Tree Construction (Prim-Dijkstra Hybrid)
    # Grows a single optimized tree from source to cover all reachable destinations.

    tree_nodes = {src}
    tree_edges = []

    # Track cost from source to node in the forming tree (for SPT bias calculation)
    path_cost_from_src = {src: 0.0}

    # Identify targets
    remaining_dsts = set(d for d in dsts if d != src and d in h)

    # Priority Queue: (priority_score, candidate_node, parent_node, edge_weight)
    pq = []

    # Optimization: Node priority tracking to prune stale PQ entries
    visited_priority = {}

    def add_neighbors_to_pq(u):
        if u not in h: return
        dist_u = path_cost_from_src[u]

        for v, data in h[u].items():
            if v not in tree_nodes:
                w = data['weight']
                # Priority = Edge_Weight + (Alpha * Parent_Distance_From_Source)
                # Alpha near 0 prioritizes total tree cost (Steiner/MST).
                priority = w + (DEPTH_PENALTY_ALPHA * dist_u)

                # Only push if we haven't seen a better path to v
                if v not in visited_priority or priority < visited_priority[v]:
                    visited_priority[v] = priority
                    heapq.heappush(pq, (priority, v, u, w))

    # Initialize exploration from source
    add_neighbors_to_pq(src)

    while remaining_dsts and pq:
        priority, v, u, w = heapq.heappop(pq)

        if v in tree_nodes:
            continue

        # Add v to tree
        tree_nodes.add(v)
        tree_edges.append((u, v))
        path_cost_from_src[v] = path_cost_from_src[u] + w

        if v in remaining_dsts:
            remaining_dsts.remove(v)

        # Explore neighbors
        add_neighbors_to_pq(v)

    # 3. Construct the Solution Graph
    st_graph = nx.DiGraph()
    st_graph.add_nodes_from(tree_nodes)
    for u, v in tree_edges:
        if u in G and v in G[u]:
            # Copy original edge attributes for the topology object
            st_graph.add_edge(u, v, **G[u][v])

    # 4. Path Extraction & Topology Assignment
    for dst in dsts:
        if dst == src:
            continue

        edge_path = []
        path_nodes = []

        try:
            if dst in st_graph:
                # Primary: Path in the optimized tree
                path_nodes = nx.shortest_path(st_graph, source=src, target=dst)
            else:
                # Fallback: Shortest path in original heuristic graph (e.g. for disconnected components)
                path_nodes = nx.shortest_path(h, source=src, target=dst, weight='weight')

            # Format path as list of edges [u, v, data]
            for i in range(len(path_nodes) - 1):
                u, v = path_nodes[i], path_nodes[i+1]
                edge_path.append([u, v, G[u][v]])

        except (nx.NetworkXNoPath, KeyError):
            # Destination unreachable
            pass

        if edge_path:
            # Assign the optimized path to all partitions.
            # Using a single optimized multicast tree leverages the broadcast nature of the problem
            # to minimize egress costs (sharing the cost of common links) better than multipathing.
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, edge_path)

    return bc_topology
