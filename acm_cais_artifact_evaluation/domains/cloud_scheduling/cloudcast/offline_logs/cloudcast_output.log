import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using Iterative Shortest Path Trees (ISPT).

    Improvements:
    1. Replaced Greedy Steiner Heuristic with Iterative SPT to prevent routing loops/ping-ponging.
    2. Adjusted composite weight calculation to better model real-world Instance vs Egress trade-offs.
    3. Enhanced diversity generation by penalizing edges after usage in a candidate topology.
    4. Strict cost-based filtering to prioritize budget while allowing multipath for bandwidth.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    # Work on a copy to modify weights safely
    h = G.copy()

    # Remove incoming edges to source to enforce rooted flow
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 2. Weight Initialization
    # Goal: Minimize (Egress Cost + Instance Cost).
    # Instance Cost ~ Time * Rate. Time ~ 1/Throughput.
    # Weight = Cost + (Factor / Throughput)
    # Factor estimation: Assuming ~$1/hr instance cost and large transfers.
    # 1 Gbps ~ 0.002 cost equivalent.

    base_weight_attr = 'base_calc_weight'

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Avoid division by zero, cap min throughput
        t_safe = max(t, 0.01)

        # Throughput penalty factor:
        # Higher factor = prefer speed (lower latency)
        # Lower factor = prefer low egress cost
        # 0.002 balances ~$1/hr compute against $/GB egress.
        t_penalty = 0.002 / t_safe

        # We store this as the base weight for calculations
        data[base_weight_attr] = c + t_penalty

    candidates = []
    edge_penalties = {}

    # 3. Iterative Candidate Generation
    # We generate multiple topologies (candidates).
    # Each iteration finds the best Shortest Path Tree (SPT) given current penalties,
    # then increases penalties on used edges to force diversity in the next iteration.

    # Number of diverse paths to search for
    iterations = min(num_partitions, 5) if num_partitions > 0 else 1

    for i in range(iterations):
        # Apply penalties to weights
        for u, v, data in h.edges(data=True):
            penalty = edge_penalties.get((u, v), 1.0)
            data['current_weight'] = data[base_weight_attr] * penalty

        # Build Shortest Path Tree (SPT) from Source
        # Dijkstra guarantees no loops and optimal paths from src given weights.
        # This fixes the "ping-pong" issue of greedy Steiner heuristics.

        used_edges = set()
        paths_map = {}
        valid_topology = True

        try:
            # Calculate shortest paths to all reachable nodes
            # single_source_dijkstra is efficient
            lengths, paths = nx.single_source_dijkstra(h, src, weight='current_weight')

            # Extract paths for required destinations
            topology_edges = set()

            for dst in dsts:
                if dst == src:
                    continue

                if dst not in paths:
                    # Destination unreachable in this topology iteration
                    # (Should be rare unless graph is disconnected)
                    valid_topology = False
                    break

                path_nodes = paths[dst]
                path_segment = []
                for k in range(len(path_nodes) - 1):
                    u_node, v_node = path_nodes[k], path_nodes[k+1]
                    edge_data = h[u_node][v_node]
                    path_segment.append([u_node, v_node, edge_data])
                    topology_edges.add((u_node, v_node))

                paths_map[dst] = path_segment

        except Exception:
            valid_topology = False

        if valid_topology and topology_edges:
            # Check for duplicates
            is_dup = False
            for c in candidates:
                if c['edges'] == topology_edges:
                    is_dup = True
                    break

            if not is_dup:
                candidates.append({
                    'edges': topology_edges,
                    'paths': paths_map,
                    'cost': _get_topology_cost(topology_edges, h)
                })

                # Update Penalties
                # Exponential penalty increase to strongly encourage finding new paths
                for u, v in topology_edges:
                    edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 4. Candidate Selection & Filtering
    # Sort by total topological cost (ascending)
    candidates.sort(key=lambda x: x['cost'])

    best_candidate = candidates[0]
    best_cost = best_candidate['cost']

    # Valid candidates must be within a cost tolerance of the best path.
    # Tight tolerance (5%) ensures we don't accidentally pick a 2x expensive path
    # just for diversity.
    limit_cost = best_cost * 1.05
    valid_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    # 5. Partition Assignment
    # Distribute partitions across valid candidates to utilize multipath bandwidth
    # while strictly controlling cost.

    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        # Round robin assignment
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
