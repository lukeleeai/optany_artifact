import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_candidate_metrics(candidate_edges, G):
    """Calculates total cost and min throughput for a set of edges."""
    total_cost = 0.0
    min_throughput = float('inf')
    for u, v in candidate_edges:
        if not G.has_edge(u, v): continue
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    if min_throughput == float('inf'): min_throughput = 0.0
    return total_cost, min_throughput

def _reconstruct_subgraph(G, edges):
    sub = nx.DiGraph()
    for u, v in edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])
    return sub

def _build_topology_candidate(G, edges, src, dsts):
    """
    Validates and metrics for a set of edges.
    """
    sub = _reconstruct_subgraph(G, edges)

    # Validate connectivity: All dsts must be reachable from src in the subgraph
    reachable = set()
    q = [src]
    visited = {src}
    while q:
        curr = q.pop(0)
        reachable.add(curr)
        for nbr in sub.neighbors(curr):
            if nbr not in visited:
                visited.add(nbr)
                q.append(nbr)

    if not all(d in reachable for d in dsts):
        return None

    c, t = _get_candidate_metrics(edges, sub)
    return {
        'edges': edges,
        'cost': c,
        'min_throughput': t,
        'subgraph': sub
    }

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Union of Shortest Paths (USP):
       Baseline strategy connecting source to each destination optimally.
       Prevents "Snakes" by finding the best path for each node individually.

    2. Metric Closure Steiner Tree (2-Approximation):
       Builds a Minimum Spanning Tree on the metric closure (complete graph of terminals).
       Efficiently identifies shared paths (Hubs) without aggressive tromboning.

    3. Hub-and-Spoke Heuristic:
       Explicitly checks single-hub topologies for specific cost savings.

    Selection:
    Uses a refined scoring function that heavily penalizes low throughput bottlenecks
    to minimize Instance Costs while minimizing Egress Fees.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning & Weight Calculation
    h = G.copy()

    # Remove incoming edges to src (useless for broadcast) and self-loops
    cols_to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(cols_to_remove)

    # Identify valid destinations
    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    terminals = [src] + target_dsts

    # Weight configuration
    # Goal: Minimize (Cost + Instance_Overhead).
    # Instance overhead is proportional to Time, which is proportional to 1/Throughput.
    # Hop Penalty discourages long chains that accumulate latency/failure risk.
    HOP_PENALTY = 0.002
    THROUGHPUT_FACTOR = 0.001

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = max(data.get('throughput', 1.0), 0.001)
        # Weight combines direct cost, hop penalty, and bandwidth preference
        data['opt_weight'] = c + HOP_PENALTY + (THROUGHPUT_FACTOR / t)

    candidates = []

    # ---------------------------------------------------------
    # Strategy A: Union of Shortest Paths (USP)
    # ---------------------------------------------------------
    usp_edges = set()
    try:
        for dst in target_dsts:
            path = nx.shortest_path(h, src, dst, weight='opt_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        cand = _build_topology_candidate(h, usp_edges, src, target_dsts)
        if cand:
            cand['type'] = 'USP'
            candidates.append(cand)
    except nx.NetworkXNoPath:
        pass

    # ---------------------------------------------------------
    # Strategy B: Metric Closure Steiner Tree Approximation
    # ---------------------------------------------------------
    # 1. Compute all-pairs shortest paths between terminals
    metric_closure = nx.Graph()
    path_lookup = {}

    # Run Dijkstra from each terminal to find shortest paths to other terminals
    for t1 in terminals:
        try:
            dists, paths = nx.single_source_dijkstra(h, t1, weight='opt_weight')
            for t2 in terminals:
                if t1 < t2 and t2 in dists:
                    # Add edge to metric closure with weight = shortest path distance
                    metric_closure.add_edge(t1, t2, weight=dists[t2])
                    path_lookup[(t1, t2)] = paths[t2]
                    # Note: path_lookup stores t1 -> t2
        except:
            pass

    # Check connectivity of terminals
    if nx.is_connected(metric_closure) and len(metric_closure) == len(terminals):
        # 2. Compute MST on the metric closure
        mst = nx.minimum_spanning_tree(metric_closure)

        # 3. Map MST edges back to original graph paths
        steiner_edges = set()

        # Traverse MST from Source using BFS to maintain directionality
        q = [src]
        visited_mst = {src}
        valid_tree = True

        while q:
            u = q.pop(0)
            for v in mst.neighbors(u):
                if v not in visited_mst:
                    visited_mst.add(v)
                    q.append(v)

                    # We need the path u -> v in the original graph
                    # path_lookup keys are sorted tuples or specific directions?
                    # We stored: path_lookup[(t1, t2)] = path from t1 to t2
                    # We need to check both keys (u,v) and (v,u) to find the correct pre-computed path
                    # but specifically we need the path flowing u->v

                    path_segment = None
                    if (u, v) in path_lookup:
                        # This is path u->v
                        path_segment = path_lookup[(u, v)]
                    elif (v, u) in path_lookup:
                        # This is path v->u, we need to recompute u->v or check if undirected
                        # Since graph is directed, we must recompute u->v if we only have v->u
                        pass

                    if path_segment is None:
                        try:
                            path_segment = nx.shortest_path(h, u, v, weight='opt_weight')
                        except:
                            valid_tree = False
                            break

                    if path_segment:
                        for k in range(len(path_segment)-1):
                            steiner_edges.add((path_segment[k], path_segment[k+1]))
                    else:
                        valid_tree = False
                        break

        if valid_tree:
            cand = _build_topology_candidate(h, steiner_edges, src, target_dsts)
            if cand:
                cand['type'] = 'Steiner'
                candidates.append(cand)

    # ---------------------------------------------------------
    # Strategy C: Top-K Hub Heuristic
    # ---------------------------------------------------------
    # Efficiently test potential hubs to catch cases where Steiner approx misses
    nodes = list(h.nodes())
    hub_candidates = list(h.neighbors(src))
    if len(nodes) > 10:
        # Sample additional random nodes
        others = [n for n in nodes if n not in hub_candidates and n != src]
        if others:
            hub_candidates += random.sample(others, min(5, len(others)))

    hub_candidates = set(hub_candidates)
    if src in hub_candidates: hub_candidates.remove(src)

    for hub in hub_candidates:
        try:
            hub_edges = set()
            # Path Src -> Hub
            p1 = nx.shortest_path(h, src, hub, weight='opt_weight')
            for k in range(len(p1)-1):
                hub_edges.add((p1[k], p1[k+1]))

            # Hub -> Dsts
            possible = True
            for dst in target_dsts:
                if dst == hub: continue
                p2 = nx.shortest_path(h, hub, dst, weight='opt_weight')
                for k in range(len(p2)-1):
                    hub_edges.add((p2[k], p2[k+1]))

            if possible:
                cand = _build_topology_candidate(h, hub_edges, src, target_dsts)
                if cand:
                    cand['type'] = 'Hub'
                    candidates.append(cand)
        except:
            continue

    # ---------------------------------------------------------
    # Selection
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    # Scoring Function: Minimize Virtual Cost
    # Virtual Cost = Dollar Cost + Time Penalty
    # Time Penalty is inversely proportional to throughput.
    # We apply a stronger penalty for low throughput to minimize instance costs.
    def score_candidate(c):
        t_safe = max(c['min_throughput'], 0.001)
        # Factor 2.0 ensures that dropping to < 1Gbps incurs a significant penalty
        # equivalent to ~$2.00 of cost, forcing the algorithm to prefer faster links
        # unless cost savings are massive.
        time_penalty = 2.0 / t_safe
        return c['cost'] + time_penalty

    best_cand = min(candidates, key=score_candidate)

    # ---------------------------------------------------------
    # Path Extraction
    # ---------------------------------------------------------
    subgraph = best_cand['subgraph']

    for dst in target_dsts:
        try:
            # Extract specific path from subgraph
            # Since subgraph is derived from a tree/dag construction, unweighted SP is sufficient
            path_nodes = nx.shortest_path(subgraph, src, dst)

            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                edge_data = h[u][v]
                path_edges.append([u, v, edge_data])

            # Apply to all partitions
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)
        except:
            # Fallback to direct calculation if subgraph pathfinding fails
            try:
                p = nx.shortest_path(h, src, dst, weight='opt_weight')
                pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, pe)
            except:
                pass

    return bc_topology
