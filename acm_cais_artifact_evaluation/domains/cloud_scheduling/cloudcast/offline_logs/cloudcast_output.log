import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from any node in 'sources' to the closest node in 'targets'.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.
    Focus: Minimal Cost (Egress) with bottleneck checks.
    Strategies:
      1. Union of Shortest Paths (Cost-weighted): Baseline for cost.
      2. Iterative Steiner Tree Heuristic: Optimization for shared edges.
      3. Pruning: Removes high-cost or low-bandwidth candidates.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    # Remove incoming to src, self-loops, and calculate efficient weights
    h = nx.DiGraph()
    for u, v, data in G.edges(data=True):
        if u == v or v == src:
            continue

        cost = data.get('cost', 0.0)
        throughput = data.get('throughput', 1.0)

        # Soft pruning of extremely slow links to protect latency
        if throughput < 0.05:
            continue

        # Weight Logic:
        # Primary: Cost (to minimize egress)
        # Secondary: Inverse throughput (tiny factor) to break ties in favor of speed
        # Tertiary: Constant small penalty to minimize hop count
        weight = cost + (1e-4 / max(throughput, 0.001)) + 1e-6

        h.add_edge(u, v, cost=cost, throughput=throughput, weight=weight)

    candidates = []

    # Helper to validate and package a topology
    def process_candidate(edge_set):
        # Build subgraph
        sub = h.edge_subgraph(edge_set)

        cand_paths = {}
        total_egress_cost = 0.0

        # Calculate strict topology cost
        for u, v in edge_set:
            total_egress_cost += h[u][v]['cost']

        # Extract paths and check connectivity
        min_bw = float('inf')

        for d in dsts:
            if d == src: continue
            try:
                # Shortest path on the tree/subgraph
                path_nodes = nx.shortest_path(sub, src, d, weight='weight')
                path_edges = []
                for i in range(len(path_nodes)-1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    edge_data = G[u][v] # Use original G data
                    path_edges.append([u, v, edge_data])
                    min_bw = min(min_bw, edge_data.get('throughput', 0.0))
                cand_paths[d] = path_edges
            except (nx.NetworkXNoPath, KeyError):
                # Topology incomplete
                return None

        return {
            'edges': edge_set,
            'cost': total_egress_cost,
            'paths': cand_paths,
            'min_bw': min_bw
        }

    # Strategy A: Union of Shortest Paths (SPT)
    # Computes individual shortest paths by Cost and merges them.
    # Often optimal for latency and competitive on cost.
    try:
        spt_edges = set()
        for d in dsts:
            if d == src: continue
            path = nx.shortest_path(h, src, d, weight='weight')
            for i in range(len(path)-1):
                spt_edges.add((path[i], path[i+1]))

        c_spt = process_candidate(spt_edges)
        if c_spt:
            candidates.append(c_spt)
    except nx.NetworkXNoPath:
        pass # Graph disconnected or node unreachable

    # Strategy B: Iterative Steiner Tree Heuristic
    # Run multiple times with penalties to encourage diversity

    penalties = {}
    iterations = 3

    for _ in range(iterations):
        # 1. Update weights with penalties
        for u, v, data in h.edges(data=True):
            p = penalties.get((u, v), 1.0)
            data['calc_weight'] = data['weight'] * p

        # 2. Build Tree
        tree_edges = set()
        tree_nodes = {src}
        targets = set(d for d in dsts if d != src)

        while targets:
            # Find path from ANY tree node to ANY target
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, targets, 'calc_weight')

            if not target:
                break # Cannot connect remaining

            # Add path to tree
            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            # Identify all targets now covered
            covered = [t for t in targets if t in tree_nodes]
            for t in covered:
                targets.discard(t)

        if not targets:
            # Full tree constructed
            cand = process_candidate(tree_edges)
            if cand:
                # Check duplication
                is_dup = False
                for existing in candidates:
                    if existing['edges'] == cand['edges']:
                        is_dup = True
                        break
                if not is_dup:
                    candidates.append(cand)
                    # Update penalties
                    for u, v in tree_edges:
                        penalties[(u, v)] = penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 3. Candidate Selection
    # Sort primarily by Cost, secondarily by Min Bandwidth (descending)
    candidates.sort(key=lambda x: (x['cost'], -x['min_bw']))

    best_candidate = candidates[0]
    best_cost = best_candidate['cost']

    # Filter candidates suitable for multipath
    valid_candidates = []

    for c in candidates:
        cost_ratio = c['cost'] / (best_cost + 1e-9)

        # Acceptance Criteria:
        # 1. Very close in cost (< 1.03x)
        # 2. OR significantly faster bottleneck if cost is reasonable (< 1.1x)
        # 3. AND bottleneck is not disastrously low unless it's the best we have

        if c['min_bw'] < 0.1 and c is not best_candidate:
            continue

        if cost_ratio <= 1.03:
            valid_candidates.append(c)
        elif cost_ratio <= 1.10 and c['min_bw'] > (best_candidate['min_bw'] * 2.0):
            valid_candidates.append(c)

    if not valid_candidates:
        valid_candidates = [best_candidate]

    # 4. Partition Assignment
    # Round robin assignment
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
