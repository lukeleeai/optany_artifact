import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds shortest path from any source to the closest target.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_metrics(edges, G):
    """Calculates total cost and bottleneck throughput of a topology."""
    total_cost = 0.0
    min_throughput = float('inf')
    for u, v in edges:
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    if min_throughput == float('inf'):
        min_throughput = 0.0
    return total_cost, min_throughput

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.
    Prioritizes low egress cost but penalizes low throughput to prevent instance cost inflation.
    Uses Steiner Tree heuristics and multipath selection with straggler filtering.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    h = G.copy()
    # Remove incoming edges to source to enforce rooted flow
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weight Calculation: Cost + Throughput Penalty
    # Penalty ensures we don't pick extremely slow edges just to save pennies.
    # 0.02 / throughput implies:
    # 1 Gbps -> +0.02 cost penalty (approx equivalent to $6 instance cost on 300GB)
    # 10 Gbps -> +0.002 cost penalty
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        data['standard_weight'] = c + (0.02 / t_safe)

    candidates = []

    # Helper to validate and extract paths from a set of edges
    def process_candidate(edge_set, type_tag):
        # Build subgraph
        sub = nx.DiGraph()
        for u, v in edge_set:
            if h.has_edge(u, v):
                sub.add_edge(u, v, **h[u][v])

        paths_map = {}
        valid = True

        for dst in dsts:
            if dst == src: continue
            try:
                # Find path in the subgraph (topology)
                # Unweighted shortest path is sufficient as topology is usually a tree
                path_nodes = nx.shortest_path(sub, src, dst)
                path_edges = []
                for k in range(len(path_nodes)-1):
                    u_n, v_n = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u_n, v_n, h[u_n][v_n]])
                paths_map[dst] = path_edges
            except nx.NetworkXNoPath:
                valid = False
                break

        if valid:
            c, t = _get_topology_metrics(edge_set, h)
            return {
                'edges': edge_set,
                'paths': paths_map,
                'cost': c,
                'bottleneck': t,
                'type': type_tag
            }
        return None

    # Strategy A: Union of Shortest Paths (USP)
    # Good for latency/throughput balance
    usp_edges = set()
    try:
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        cand = process_candidate(usp_edges, 'usp')
        if cand:
            candidates.append(cand)
    except nx.NetworkXNoPath:
        pass

    # Strategy B: Iterative Steiner Tree Heuristics
    # Finds shared edges to reduce egress cost
    edge_penalties = {}
    iterations = 5

    for i in range(iterations):
        # Apply diversity penalties
        for u, v, data in h.edges(data=True):
            base = data['standard_weight']
            penalty = edge_penalties.get((u, v), 1.0)
            data['calc_weight'] = base * penalty

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        while remaining:
            # Connect closest remaining node to the tree
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')
            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

        if not tree_edges:
            continue

        # Check for duplicate topology
        is_dup = False
        for c in candidates:
            if c['edges'] == tree_edges:
                is_dup = True
                break

        if not is_dup:
            cand = process_candidate(tree_edges, 'steiner')
            if cand:
                candidates.append(cand)
                # Penalize edges to force diversity
                for u, v in tree_edges:
                    edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 4. Selection Logic
    # Sort primarily by cost
    candidates.sort(key=lambda x: x['cost'])

    best = candidates[0]
    valid_candidates = [best]

    # Multipath Selection:
    # Only include other candidates if:
    # 1. Cost is very close to best (e.g., within 5%)
    # 2. Throughput is not significantly worse (e.g., >= 70% of best) to avoid "stragglers"
    #    that increase total completion time.

    cost_threshold = best['cost'] * 1.05
    throughput_threshold = best['bottleneck'] * 0.7

    for c in candidates[1:]:
        if c['cost'] <= cost_threshold:
            if c['bottleneck'] >= throughput_threshold:
                valid_candidates.append(c)

    # 5. Assign Partitions
    num_valid = len(valid_candidates)
    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths = selected['paths']
        for dst, path in paths.items():
            bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
