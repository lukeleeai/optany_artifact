import heapq
import random
from itertools import combinations
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_path_throughput(G, path_nodes):
    """Calculates bottleneck throughput of a specific path."""
    min_t = float('inf')
    for i in range(len(path_nodes) - 1):
        u, v = path_nodes[i], path_nodes[i+1]
        t = G[u][v].get('throughput', 1.0)
        if t < min_t:
            min_t = t
    return min_t if min_t != float('inf') else 0.0

def _evaluate_topology(G, edges, src, dsts, num_partitions):
    """
    Evaluates a candidate edge set.
    Returns a dict with cost metrics and the routing strategy.
    """
    # Build subgraph
    sub = nx.DiGraph()
    total_egress_cost = 0.0

    # Calculate egress cost: shared edges are paid once (Multicast model assumption for Tree)
    # or we can simulate Unicast summation.
    # Based on problem domain "BroadcastTopology", we assume tree-based distribution
    # where edge cost is paid for the volume traversing that edge.
    for u, v in edges:
        if G.has_edge(u, v):
            data = G[u][v]
            sub.add_edge(u, v, **data)
            total_egress_cost += data.get('cost', 0.0)

    # Validate paths and calculate system performance
    path_map = {}
    min_system_throughput = float('inf')

    for dst in dsts:
        try:
            # We use weight='cost' to find the best route within the constructed tree
            path = nx.shortest_path(sub, src, dst)
            path_map[dst] = path

            # Throughput for this destination
            t_dst = _get_path_throughput(sub, path)
            if t_dst < min_system_throughput:
                min_system_throughput = t_dst

        except (nx.NetworkXNoPath, Exception):
            return None # Invalid topology

    if min_system_throughput == 0 or min_system_throughput == float('inf'):
        return None

    # Total score calculation
    # We normalize volume to 1GB for scoring selection to keep it scale-independent,
    # or use heuristics.
    # Real Cost = (Volume * Egress_Sum) + (Volume/Min_Throughput * Hourly_Rate)
    # Heuristic Score = Egress_Sum + (0.5 / Min_Throughput)
    # The 0.5 factor roughly equates to $0.50/hr instance cost.
    score = total_egress_cost + (0.5 / min_system_throughput)

    return {
        'edges': edges,
        'subgraph': sub,
        'path_map': path_map,
        'score': score,
        'min_throughput': min_system_throughput,
        'egress_sum': total_egress_cost
    }

def _get_steiner_approximation(G, src, dsts, weight_key='cost'):
    """
    Constructs a Steiner Tree approximation using the MST of the Metric Closure.
    This effectively finds shared trunks to minimize total edge weight.
    """
    terminals = [src] + dsts
    metric_closure = nx.Graph()

    # 1. Compute all-pairs shortest paths between terminals
    # Using multi-source dijkstra or repeated dijkstra
    path_cache = {}

    for t in terminals:
        try:
            lengths, paths = nx.single_source_dijkstra(G, t, weight=weight_key)
            for target in terminals:
                if t != target and target in lengths:
                    metric_closure.add_edge(t, target, weight=lengths[target])
                    path_cache[(t, target)] = paths[target]
        except:
            continue

    if not nx.is_connected(metric_closure):
        # Fallback: try to connect what we can or return empty
        if len(metric_closure) < len(terminals):
             return set()

    # 2. Compute MST of the metric closure
    mst = nx.minimum_spanning_tree(metric_closure)

    # 3. Unwrap MST edges back to original graph edges
    final_edges = set()
    for u, v in mst.edges():
        if (u, v) in path_cache:
            path = path_cache[(u, v)]
        elif (v, u) in path_cache:
            path = path_cache[(v, u)]
        else:
            continue

        for i in range(len(path) - 1):
            final_edges.add((path[i], path[i+1]))

    return final_edges

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Approaches:
    1. Union of Shortest Paths (SPT): Baselines the "Unicast" cost (min latency/hops).
    2. Steiner Tree Approximation: Uses MST on metric closure to find optimal shared "Multicast" trees.
    3. Throughput-Aware Variations: Runs the above with penalized weights to avoid slow links.

    Selection:
    Evaluates candidates based on Estimated Total Cost (Egress + Latency Penalty).
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning & Prep
    h = G.copy()
    # Remove incoming edges to src to prevent cycles back to root
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # Filter reachable destinations
    valid_dsts = [d for d in dsts if d != src and d in h]
    if not valid_dsts:
        return bc_topology

    # 2. Define Weight Functions
    # We create multiple views of edge weights to explore the trade-off space.
    # W1: Pure Cost (minimizes egress $)
    # W2: Balanced (Cost + small penalty for low throughput)
    # W3: High Performance (Cost + heavy penalty)

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Avoid division by zero
        t = max(t, 0.001)

        data['w_cost'] = c
        # Balanced: $0.01 penalty for 1Gbps.
        data['w_balanced'] = c + (0.01 / t)
        # Fast: $0.10 penalty for 1Gbps (prioritizes speed significantly)
        data['w_fast'] = c + (0.1 / t)

    candidates = []

    # 3. Strategy Generation

    # Strategy A: Union of Shortest Paths (USP) / Star Topology
    # This simulates "Direct Routing" or "Best Path per Destination" independent of sharing.
    # It usually yields higher throughput and lowest latency but higher total egress if edges aren't shared.
    for w_key in ['w_cost', 'w_balanced']:
        edges = set()
        possible = True
        for d in valid_dsts:
            try:
                p = nx.shortest_path(h, src, d, weight=w_key)
                for i in range(len(p)-1):
                    edges.add((p[i], p[i+1]))
            except nx.NetworkXNoPath:
                possible = False
                break
        if possible:
            cand = _evaluate_topology(h, edges, src, valid_dsts, num_partitions)
            if cand: candidates.append(cand)

    # Strategy B: Steiner Tree Approximation (Metric Closure MST)
    # This finds the most efficient shared tree structure.
    # We run this for Cost and Balanced weights.
    for w_key in ['w_cost', 'w_balanced']:
        edges = _get_steiner_approximation(h, src, valid_dsts, weight_key=w_key)
        if edges:
            cand = _evaluate_topology(h, edges, src, valid_dsts, num_partitions)
            if cand: candidates.append(cand)

    # 4. Selection
    if not candidates:
        return bc_topology

    # Sort by score (Egress + Instance Penalty)
    # Score formula in _evaluate_topology handles the trade-off.
    candidates.sort(key=lambda x: x['score'])
    best_topology = candidates[0]

    # 5. Path Assignment
    # We assign the computed optimal paths to the topology object.
    # Currently, we assign the same path to all partitions to maintain the tree structure benefits.
    # (Splitting partitions across different trees would require a complex multipath cost model
    # that usually results in higher egress costs).

    sub = best_topology['subgraph']

    for dst in valid_dsts:
        try:
            # Re-calculate path on the selected subgraph to ensure consistency
            # Using simple hops or cost since it's a tree/DAG now
            path_nodes = nx.shortest_path(sub, src, dst, weight='cost')

            # Construct edge list with original data
            final_path = []
            for i in range(len(path_nodes)-1):
                u, v = path_nodes[i], path_nodes[i+1]
                # Fetch original data from h to ensure we have all attributes
                edge_data = h[u][v]
                final_path.append([u, v, edge_data])

            # Assign to all partitions
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, final_path)

        except nx.NetworkXNoPath:
            # Fallback: Direct Shortest Path on original graph
            try:
                p = nx.shortest_path(h, src, dst, weight='w_balanced')
                fallback_path = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, fallback_path)
            except:
                pass

    return bc_topology
