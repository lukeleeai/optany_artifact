import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_candidate_metrics(candidate_edges, G):
    """Calculates total cost and min throughput for a set of edges."""
    total_cost = 0.0
    min_throughput = float('inf')
    if not candidate_edges:
        return 0.0, 0.0
    for u, v in candidate_edges:
        if not G.has_edge(u, v): continue
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    if min_throughput == float('inf'): min_throughput = 0.0
    return total_cost, min_throughput

def _extract_topology_map(edges, src, dsts, G):
    """
    Reconstructs explicit paths from a set of edges (forming a DAG/Tree)
    and returns a map {dst: edge_list} along with metrics.
    """
    sub = nx.DiGraph()
    for u, v in edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    topo_map = {}
    valid = True

    # Verify connectivity and extract paths
    for dst in dsts:
        if dst == src: continue
        try:
            # Shortest path on the subgraph is sufficient since it's a tree/sparse DAG
            path = nx.shortest_path(sub, src, dst)
            path_edges = []
            for i in range(len(path)-1):
                u, v = path[i], path[i+1]
                path_edges.append([u, v, G[u][v]])
            topo_map[dst] = path_edges
        except (nx.NetworkXNoPath, Exception):
            valid = False
            break

    if not valid:
        return None, None

    cost, min_bw = _get_candidate_metrics(edges, sub)
    return topo_map, {'cost': cost, 'min_throughput': min_bw}

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Goals:
    1. Minimize Total Cost (Egress + Instance).
    2. Maintain Throughput (Avoid bottlenecks < 1Gbps).
    3. Exploit Multipath (Partition load balancing).

    Strategy:
    - Uses a weighted search with a penalty for low throughput to avoid slow paths
      that inflate instance costs.
    - Generates multiple candidate topologies (USP, Hub-Centroid, Randomized Steiner).
    - Selects the best primary topology based on a Cost-Time score.
    - Optionally selects a secondary topology for multipath routing if it is cost-competitive.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning
    # Remove incoming edges to src (source cannot be a transit node in broadcast)
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 2. Weight Configuration
    # We combine Cost and Throughput into a single metric for Dijkstra.
    # Metric = Cost + (Penalty / Throughput).
    # Penalty factor 0.02 means:
    # - 10 Gbps link -> +0.002 cost (negligible)
    # - 1 Gbps link  -> +0.02 cost (significant, ~20% of typical edge cost)
    # - 0.1 Gbps link -> +0.20 cost (prohibitive)

    BW_PENALTY_FACTOR = 0.02

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        data['opt_weight'] = c + (BW_PENALTY_FACTOR / t_safe)

    candidates = []

    # ---------------------------------------------------------
    # Strategy A: Union of Shortest Paths (USP)
    # ---------------------------------------------------------
    # Routes each destination individually via its optimal path.
    # Good for throughput and latency, establishes a baseline.
    try:
        usp_edges = set()
        for dst in target_dsts:
            path = nx.shortest_path(h, src, dst, weight='opt_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        tmap, metrics = _extract_topology_map(usp_edges, src, target_dsts, h)
        if tmap:
            metrics['type'] = 'USP'
            metrics['map'] = tmap
            candidates.append(metrics)
    except nx.NetworkXNoPath:
        pass

    # ---------------------------------------------------------
    # Strategy B: Hub-and-Spoke (Centroid Heuristic)
    # ---------------------------------------------------------
    # Forces traffic through high-capacity hubs to check for efficient shared trees.
    # We select hubs based on total nodal throughput capacity.

    node_capacity = {}
    for u, v, data in h.edges(data=True):
        node_capacity[u] = node_capacity.get(u, 0) + data.get('throughput', 0)

    # Check top 8 high-capacity nodes
    potential_hubs = sorted(node_capacity.keys(), key=lambda x: node_capacity[x], reverse=True)
    hubs_to_check = [n for n in potential_hubs if n != src][:8]

    for hub in hubs_to_check:
        try:
            # Path to Hub
            path1 = nx.shortest_path(h, src, hub, weight='opt_weight')
            hub_edges = set()
            for k in range(len(path1)-1):
                hub_edges.add((path1[k], path1[k+1]))

            # Hub to Dsts
            possible = True
            for dst in target_dsts:
                if dst == hub: continue
                p = nx.shortest_path(h, hub, dst, weight='opt_weight')
                for k in range(len(p)-1):
                    hub_edges.add((p[k], p[k+1]))

            if possible:
                tmap, metrics = _extract_topology_map(hub_edges, src, target_dsts, h)
                if tmap:
                    metrics['type'] = 'Hub'
                    metrics['map'] = tmap
                    candidates.append(metrics)
        except:
            continue

    # ---------------------------------------------------------
    # Strategy C: Randomized Steiner Tree (Approximation)
    # ---------------------------------------------------------
    # Iteratively connects closest nodes. Randomization allows exploring
    # slightly sub-optimal local choices that might yield better global structures.

    for i in range(5):
        # Apply noise to weights
        for u, v, data in h.edges(data=True):
            data['rand_weight'] = data['opt_weight'] * random.uniform(0.9, 1.1)

        st_edges = set()
        st_nodes = {src}
        remaining = set(target_dsts)

        while remaining:
            try:
                # Multi-source Dijkstra from existing tree
                dists, paths = nx.multi_source_dijkstra(h, list(st_nodes), weight='rand_weight')

                # Find closest remaining target
                best_t, best_dist = None, float('inf')
                for r in remaining:
                    if r in dists and dists[r] < best_dist:
                        best_dist = dists[r]
                        best_t = r

                if best_t:
                    path = paths[best_t]
                    for k in range(len(path)-1):
                        st_edges.add((path[k], path[k+1]))
                        st_nodes.add(path[k+1])
                    remaining.discard(best_t)
                    remaining -= st_nodes # Remove nodes implicitly hit
                else:
                    break # Graph disconnected
            except:
                break

        if not remaining:
            tmap, metrics = _extract_topology_map(st_edges, src, target_dsts, h)
            if tmap:
                metrics['type'] = 'Steiner'
                metrics['map'] = tmap
                candidates.append(metrics)

    # ---------------------------------------------------------
    # Selection & Multipath Assignment
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    # Filter candidates with critical bottlenecks (< 50 Mbps)
    # These often cause timeouts regardless of cost savings.
    valid_candidates = [c for c in candidates if c['min_throughput'] > 0.05]
    if not valid_candidates: valid_candidates = candidates

    # Scoring Function: Minimize Cost + Virtual Time Cost
    # We penalize low bandwidth to balance instance costs.
    # Score = Cost + (Alpha / Throughput).
    # Alpha = 5.0 implies we are willing to pay ~$5 extra Egress to improve min-throughput by 1 Gbps (at low rates).
    def score_fn(c):
        return c['cost'] + (5.0 / max(c['min_throughput'], 0.001))

    valid_candidates.sort(key=score_fn)

    # Select Primary
    best = valid_candidates[0]
    selected_topologies = [best]

    # Select Secondary (Multipath)
    # If a second candidate exists, is structurally different (heuristic via cost check),
    # and is within 3% of the cost of the primary, use it to load balance partitions.
    if len(valid_candidates) > 1:
        alt = valid_candidates[1]
        cost_ratio = alt['cost'] / max(best['cost'], 0.001)
        if cost_ratio < 1.03:
            selected_topologies.append(alt)

    # Distribute partitions round-robin
    num_selected = len(selected_topologies)
    for dst in target_dsts:
        for i in range(num_partitions):
            topo = selected_topologies[i % num_selected]
            # Fallback to primary if secondary map is incomplete (should not happen due to validity check)
            path_data = topo['map'].get(dst, best['map'].get(dst))
            if path_data:
                bc_topology.set_dst_partition_paths(dst, i, path_data)

    return bc_topology
