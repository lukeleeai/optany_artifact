import heapq
from typing import Dict, List, Set, Tuple, Optional

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_weighted_graph(G, src, penalty_map=None):
    """
    Prepares a clean graph with calculated weights.
    Weights balance egress cost and throughput.
    """
    H = nx.DiGraph()

    # Remove incoming edges to src to strictly enforce root role
    for u, v, data in G.edges(data=True):
        if v == src:
            continue

        cost = data.get('cost', 0.1)
        throughput = data.get('throughput', 1.0)

        # Heuristic: Dominant cost + small throughput penalty
        # Throughput term ensures we pick faster links when costs are equal
        # and avoid extremely slow links unless they offer massive savings.
        # 0.01/Gbps means a 10Gbps link is preferred over 1Gbps by 0.009 'dollars' per GB
        t_safe = max(throughput, 0.001)
        base_weight = cost + (0.01 / t_safe)

        # Apply diversity penalty to encourage multipath routing
        p = penalty_map.get((u, v), 1.0) if penalty_map else 1.0

        final_weight = base_weight * p

        H.add_edge(u, v, weight=final_weight, original_data=data)

    return H

def _find_path_to_nearest_target(G, tree_nodes, targets):
    """
    Dijkstra search from the set of 'tree_nodes' to find the closest node in 'targets'.
    Returns the path segment that connects the tree to that target.
    """
    pq = []
    # Initialize PQ with all current tree nodes
    for node in tree_nodes:
        # (distance, current_node, parent_node_in_path)
        heapq.heappush(pq, (0.0, node, None))

    dists = {node: 0.0 for node in tree_nodes}
    preds = {} # Map node -> parent in this specific search

    found_target = None

    while pq:
        d, u, p = heapq.heappop(pq)

        if d > dists.get(u, float('inf')):
            continue

        if p is not None:
            preds[u] = p

        if u in targets:
            found_target = u
            break

        for v in G[u]:
            # Do not re-enter the existing tree
            if v in tree_nodes:
                continue

            w = G[u][v]['weight']
            new_dist = d + w

            if new_dist < dists.get(v, float('inf')):
                dists[v] = new_dist
                heapq.heappush(pq, (new_dist, v, u))

    if found_target:
        # Reconstruct the path segment from the tree frontier to the target
        path = []
        curr = found_target
        while curr is not None and curr not in tree_nodes:
            par = preds.get(curr)
            if par is None:
                break # Should not happen if logic is correct
            path.append((par, curr))
            curr = par
        return list(reversed(path)), found_target

    return None, None

def _build_steiner_tree_paths(G, src, dsts):
    """
    Constructs a Steiner Tree and returns explicit paths from src to each dst.
    Returns: (total_tree_cost, paths_map, set_of_used_edges)
    """
    tree_nodes = {src}
    tree_edges = set()
    # Global predecessors map for the entire tree to allow backtracking
    # This guarantees that extracted paths are consistent with the tree structure (acyclic)
    global_preds = {src: None}

    remaining_targets = set(d for d in dsts if d != src and d in G)

    while remaining_targets:
        segment, target = _find_path_to_nearest_target(G, tree_nodes, remaining_targets)

        if not target:
            break

        # Add segment to tree
        for u, v in segment:
            if v not in tree_nodes:
                tree_nodes.add(v)
                tree_edges.add((u, v))
                global_preds[v] = u

        # Remove covered targets (and any other targets we might have picked up along the way)
        # We traverse up from the target to check if any other destinations were on this path
        current = target
        while current != src and current is not None:
            if current in remaining_targets:
                remaining_targets.remove(current)
            current = global_preds.get(current)

    # Extract clean paths for all destinations
    paths_map = {}
    tree_egress_cost = 0.0
    used_edges_indices = set()

    # Calculate cost based on unique edges in the tree
    for u, v in tree_edges:
        data = G[u][v]['original_data']
        tree_egress_cost += data.get('cost', 0.0)
        used_edges_indices.add((u, v))

    for dst in dsts:
        if dst == src:
            continue

        if dst not in global_preds:
            # Destination unreachable
            paths_map[dst] = []
            continue

        # Backtrack from dst to src using the tree structure
        path = []
        curr = dst
        while curr != src:
            par = global_preds.get(curr)
            if par is None:
                # Broken path (should not happen in valid tree)
                path = []
                break

            # Retrieve original edge data
            edge_data = G[par][curr]['original_data']
            path.append([par, curr, edge_data])
            curr = par

        paths_map[dst] = list(reversed(path))

    return tree_egress_cost, paths_map, used_edges_indices

def search_algorithm(src, dsts, G, num_partitions):
    """
    Generates a broadcast topology optimized for multi-cloud data transfer.

    Optimization Strategy:
    1. Graph Cleaning: Strictly enforces source as root and cleans graph.
    2. Cost Metric: Uses 'Cost + (epsilon/Throughput)' to minimize egress fees while avoiding bottlenecks.
    3. Candidate Generation: Builds multiple Steiner Trees using iterative penalties to find diverse paths.
    4. Explicit Backtracking: Uses predecessor maps to guarantee loop-free, valid paths.
    5. Selection: Filters trees within a cost tolerance (20%) to utilize multipath bandwidth without excessive cost.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    candidates = []
    edge_penalties = {}

    # Generate multiple candidate trees to exploit multipath diversity
    # We attempt to find at least 'num_partitions' distinct trees if possible,
    # or a reasonable number of variations to choose from.
    iterations = max(num_partitions, 5)

    for _ in range(iterations + 2):
        # Build graph with current penalties
        H = _get_weighted_graph(G, src, edge_penalties)

        # Build Steiner Tree
        cost, paths, used_edges = _build_steiner_tree_paths(H, src, dsts)

        if not used_edges:
            # If we failed to build a tree (e.g. graph disconnected), stop trying
            if not candidates:
                break
            continue

        # Check for duplicates based on the set of edges used
        is_dup = False
        frozen_edges = frozenset(used_edges)
        for c in candidates:
            if c['edge_set'] == frozen_edges:
                is_dup = True
                break

        if not is_dup:
            candidates.append({
                'cost': cost,
                'paths': paths,
                'edge_set': frozen_edges
            })

            # Penalize edges used in this tree to force diversity in next iteration
            for u, v in used_edges:
                edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # Sort candidates by total egress cost
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Keep those within acceptable cost range.
    # We allow a 20% cost overhead compared to the best tree to enable multipath diversity.
    # This helps improve transfer time by using distinct links/paths.
    best_cost = candidates[0]['cost']
    valid_candidates = [c for c in candidates if c['cost'] <= best_cost * 1.2]

    # Assign partitions round-robin to valid candidates
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        candidate = valid_candidates[i % num_valid]
        paths_map = candidate['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
