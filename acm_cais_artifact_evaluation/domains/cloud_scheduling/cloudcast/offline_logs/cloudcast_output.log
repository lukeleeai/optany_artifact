import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

def _get_topology_cost(edges, G):
    """Calculates total cost of unique edges in a topology."""
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def _extract_paths_from_topology(G_full, topo_edges, src, dsts, weight='standard_weight'):
    """
    Given a set of edges (topology), extracts valid paths from src to dsts.
    Returns a dict {dst: [[u,v,data], ...]}
    """
    # Build topology graph
    T = nx.DiGraph()
    for u, v in topo_edges:
        if G_full.has_edge(u, v):
            T.add_edge(u, v, **G_full[u][v])

    paths_map = {}
    for dst in dsts:
        if dst == src: continue
        try:
            # Try to find path in the topology graph T
            path_nodes = nx.shortest_path(T, src, dst, weight=weight)
            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                path_edges.append([u, v, T[u][v]])
            paths_map[dst] = path_edges
        except nx.NetworkXNoPath:
            # Fallback to full graph if topology is disconnected for this dst
            # This handles rare cases where the heuristic might have missed connectivity
            try:
                path_nodes = nx.shortest_path(G_full, src, dst, weight=weight)
                path_edges = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u, v, G_full[u][v]])
                paths_map[dst] = path_edges
            except nx.NetworkXNoPath:
                paths_map[dst] = []
    return paths_map

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing for multi-cloud data transfer.

    Strategies implemented:
    1. Union of Shortest Paths (USP): Baseline for low latency and direct routing.
    2. Single-Hub Aggregation: Probes every node as a potential distribution hub to
       exploit shared path savings (Multicast gain).
    3. Performance-Aware Routing: Secondary topology prioritizing throughput to
       avoid bottlenecks, used for load balancing.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pre-processing
    h = G.copy()
    # Remove incoming edges to source to enforce rooted flow
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weight Calculation
    # Balances Cost and Throughput.
    # Cost (approx $0.02 - $0.20/GB) vs Throughput (0.1 - 100 Gbps).
    # We add a virtual cost for low throughput to prevent selecting very slow links (e.g., VPNs)
    # unless they offer significant cost savings.
    # Penalty: 0.001 / Throughput. (1 Gbps -> +0.001, 100 Mbps -> +0.01)
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)

        # Primary weight: Cost + small throughput penalty
        data['standard_weight'] = c + (0.001 / t_safe)

        # Secondary weight: Primarily throughput (latency proxy), secondarily cost
        # Used for finding high-performance alternative paths
        data['perf_weight'] = (1.0 / t_safe) + (c * 0.1)

    candidates = []

    # --- Strategy A: Union of Shortest Paths (USP) ---
    # Finds the cost-optimal path for each destination independently and unions them.
    # This effectively creates a Source-Based Tree (Star) or simple DAG.
    usp_edges = set()
    valid_usp = True
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
        except nx.NetworkXNoPath:
            valid_usp = False
            break

    if valid_usp and usp_edges:
        candidates.append({
            'type': 'USP_Standard',
            'edges': usp_edges,
            'cost': _get_topology_cost(usp_edges, h)
        })

    # --- Strategy B: Single-Hub Aggregation Heuristic ---
    # Tries to find an intermediate node (Hub) such that Src -> Hub -> Dsts is cheaper
    # than direct paths. This captures "Regional Aggregation" patterns.

    # Precompute paths from Src to all potential hubs
    try:
        src_paths = nx.single_source_dijkstra_path(h, src, weight='standard_weight')
    except:
        src_paths = {}

    # Only consider nodes reachable from source as potential hubs
    potential_hubs = [n for n in h.nodes() if n in src_paths]

    best_hub_candidate = None
    min_hub_cost = float('inf')

    # Iterate through potential hubs to find the best aggregator
    for hub in potential_hubs:
        if hub == src: continue # Already covered by USP

        hub_edges = set()

        # Add Path: Src -> Hub
        path_to_hub = src_paths[hub]
        for k in range(len(path_to_hub)-1):
            hub_edges.add((path_to_hub[k], path_to_hub[k+1]))

        possible = True
        # Add Paths: Hub -> Dsts
        for dst in dsts:
            if dst == src: continue
            if dst == hub: continue
            try:
                # Find path from Hub to Destination
                p = nx.shortest_path(h, hub, dst, weight='standard_weight')
                for k in range(len(p)-1):
                    hub_edges.add((p[k], p[k+1]))
            except nx.NetworkXNoPath:
                possible = False
                break

        if possible:
            cost = _get_topology_cost(hub_edges, h)
            if cost < min_hub_cost:
                min_hub_cost = cost
                best_hub_candidate = {
                    'type': 'Hub_Aggregation',
                    'edges': hub_edges,
                    'cost': cost
                }

    if best_hub_candidate:
        # Add if distinct from USP
        if not candidates or candidates[0]['edges'] != best_hub_candidate['edges']:
            candidates.append(best_hub_candidate)

    # --- Strategy C: Performance/Throughput Optimized ---
    # Finds paths maximizing bottleneck bandwidth (via 'perf_weight').
    # Useful for partitions that need speed over pure cost savings.
    perf_edges = set()
    valid_perf = True
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(h, src, dst, weight='perf_weight')
            for k in range(len(path)-1):
                perf_edges.add((path[k], path[k+1]))
        except nx.NetworkXNoPath:
            valid_perf = False
            break

    if valid_perf and perf_edges:
        # Check for duplication
        is_dup = False
        for c in candidates:
            if c['edges'] == perf_edges:
                is_dup = True
                break
        if not is_dup:
            candidates.append({
                'type': 'USP_Performance',
                'edges': perf_edges,
                'cost': _get_topology_cost(perf_edges, h)
            })

    # --- Selection & Partition Assignment ---
    if not candidates:
        return bc_topology

    # Extract concrete path lists for each candidate topology
    for cand in candidates:
        cand['paths'] = _extract_paths_from_topology(h, cand['edges'], src, dsts, weight='standard_weight')

    # Sort candidates by cost (ascending)
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Keep those within 10% of the best cost.
    # This ensures we don't pick a "Performance" path that is 5x more expensive.
    best_cost = candidates[0]['cost']
    valid_candidates = [c for c in candidates if c['cost'] <= best_cost * 1.10]

    # If no candidates meet the strict cost criteria (rare), fall back to the cheapest
    if not valid_candidates:
        valid_candidates = [candidates[0]]

    # Round-Robin assignment of partitions to valid diverse topologies.
    # This enables multipath transfer (Cost-Optimal + slightly more expensive but different links).
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path is not None:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
