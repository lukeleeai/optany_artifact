import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

def _evaluate_candidate(edges, G, src, dsts):
    """
    Evaluates a set of edges forming a multicast tree/mesh.
    Returns a dict with cost metrics and valid paths.
    """
    if not edges:
        return None

    # Build subgraph to verify connectivity and extract valid paths
    sub = nx.DiGraph()
    total_egress_cost = 0.0
    min_throughput = float('inf')

    # In a multicast overlay, we pay for each edge exactly once
    for u, v in edges:
        if G.has_edge(u, v):
            data = G[u][v]
            sub.add_edge(u, v, **data)
            total_egress_cost += data.get('cost', 0.0)
            t = data.get('throughput', 1.0)
            if t < min_throughput:
                min_throughput = t

    if min_throughput == float('inf'):
        min_throughput = 0.0

    valid_paths = {}
    all_reachable = True

    for dst in dsts:
        if dst == src: continue
        try:
            # Reconstruct the specific path in the tree/DAG for this destination
            # Shortest path in hops (on the subgraph) is sufficient as the topology is usually a tree
            path_nodes = nx.shortest_path(sub, src, dst)
            path_edges = []
            for i in range(len(path_nodes) - 1):
                u, v = path_nodes[i], path_nodes[i+1]
                path_edges.append([u, v, sub[u][v]])
            valid_paths[dst] = path_edges
        except nx.NetworkXNoPath:
            all_reachable = False
            break

    if not all_reachable:
        return None

    return {
        'total_egress_cost_unit': total_egress_cost,
        'min_throughput': min_throughput,
        'paths': valid_paths,
        'edges': edges
    }

def _build_steiner_heuristic(G, src, targets, weight_attr='cost'):
    """
    Takahashi-Matsuyama heuristic for Steiner Tree.
    Iteratively connects the closest unconnected target to the growing tree.
    This effectively shares common paths to minimize total edge weight.
    """
    tree_nodes = {src}
    tree_edges = set()
    remaining = set(targets)
    if src in remaining:
        remaining.remove(src)

    while remaining:
        # Find shortest path from *any node in tree_nodes* to *all remaining targets*
        try:
            # multi_source_dijkstra returns (distance_dict, path_dict)
            dists, paths = nx.multi_source_dijkstra(G, sources=list(tree_nodes), weight=weight_attr)
        except Exception:
            return None

        # Identify the closest target
        best_target = None
        min_dist = float('inf')

        for t in remaining:
            if t in dists and dists[t] < min_dist:
                min_dist = dists[t]
                best_target = t

        if best_target is None:
            return None # Graph disconnected

        # Add the path to the tree
        path = paths[best_target]
        for i in range(len(path) - 1):
            u, v = path[i], path[i+1]
            if (u, v) not in tree_edges:
                tree_edges.add((u, v))
                tree_nodes.add(v)

        # Update remaining: remove any targets that have been covered by the new path
        remaining = remaining - tree_nodes

    return tree_edges

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Steiner Tree Heuristic (Takahashi-Matsuyama): Minimizes total tree cost by encouraging path sharing.
    2. Direct/USP Fallback: Ensures low latency if cost-optimized paths are too slow.
    3. Multi-Metric Evaluation: Balances pure Egress Cost vs. Throughput Penalty.

    Goal: Minimize Total Cost = Egress + Instance Costs (Time).
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning
    # Create a working graph, removing incoming edges to src to enforce DAG flow from source
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 2. Weight Configuration
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Weight for Pure Cost Minimization
        data['w_cost'] = c
        # Weight for Balanced (Cost + Latency penalty).
        # Small epsilon prevents 0-division.
        # This weight helps break ties in cost by preferring higher throughput.
        data['w_balanced'] = c + (0.001 / max(t, 0.001))

    candidates = []

    # -------------------------------------------------------------------------
    # Strategy A: Cost-Optimized Steiner Tree
    # -------------------------------------------------------------------------
    # Minimizes the sum of edge costs used in the tree. This is the primary
    # strategy for reducing Egress fees.
    edges_a = _build_steiner_heuristic(h, src, target_dsts, weight_attr='w_cost')
    if edges_a:
        cand_a = _evaluate_candidate(edges_a, h, src, target_dsts)
        if cand_a:
            cand_a['type'] = 'SteinerCost'
            candidates.append(cand_a)

    # -------------------------------------------------------------------------
    # Strategy B: Balanced Steiner Tree
    # -------------------------------------------------------------------------
    # Uses the balanced weight. Useful if the cheapest path has terrible throughput.
    edges_b = _build_steiner_heuristic(h, src, target_dsts, weight_attr='w_balanced')
    if edges_b:
        cand_b = _evaluate_candidate(edges_b, h, src, target_dsts)
        if cand_b:
            cand_b['type'] = 'SteinerBalanced'
            candidates.append(cand_b)

    # -------------------------------------------------------------------------
    # Strategy C: Union of Shortest Paths (USP)
    # -------------------------------------------------------------------------
    # Baseline strategy: Optimize every destination individually.
    # High cost usually, but good throughput/latency.
    usp_edges = set()
    try:
        possible_usp = True
        for dst in target_dsts:
            path = nx.shortest_path(h, src, dst, weight='w_balanced')
            for i in range(len(path)-1):
                usp_edges.add((path[i], path[i+1]))
        if possible_usp:
            cand_c = _evaluate_candidate(usp_edges, h, src, target_dsts)
            if cand_c:
                cand_c['type'] = 'USP'
                candidates.append(cand_c)
    except nx.NetworkXNoPath:
        pass

    # -------------------------------------------------------------------------
    # Selection Logic
    # -------------------------------------------------------------------------
    if not candidates:
        return bc_topology

    # Scoring Function: Minimize Virtual Cost
    # Virtual Cost = Egress Cost + Time Penalty
    # We estimate the instance cost impact relative to egress.
    # A throughput of < 0.1 Gbps is heavily penalized as it blows up transfer time.
    def score_candidate(cand):
        egress = cand['total_egress_cost_unit']
        t = cand['min_throughput']

        # Instance cost proxy:
        # Assuming typical cloud pricing, instance runtime cost is small compared to egress
        # unless throughput is extremely low.
        if t < 0.1:
            # Massive penalty for effectively broken links
            time_penalty = 10.0 / max(t, 0.0001)
        else:
            # Nominal penalty to favor faster paths among similarly priced ones
            # 0.01 factor implies we pay $0.01 extra egress to save significant time
            time_penalty = 0.01 / t

        return egress + time_penalty

    # Pick the best topology
    best_cand = min(candidates, key=score_candidate)

    # -------------------------------------------------------------------------
    # Path Assignment
    # -------------------------------------------------------------------------
    # We assign the optimal topology paths to all partitions.
    # While multipath is possible, splitting partitions across suboptimal cost paths
    # usually increases total egress without sufficient time savings in this domain.
    paths_map = best_cand['paths']

    for dst in target_dsts:
        if dst in paths_map:
            path_edges = paths_map[dst]
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

    return bc_topology
