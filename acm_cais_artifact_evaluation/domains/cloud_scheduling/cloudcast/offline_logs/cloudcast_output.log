import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _calculate_edge_weight(data: dict, cost_factor: float = 1.0) -> float:
    """
    Composite weight: Primary = Cost, Secondary = 1/Throughput.

    Formula: (Cost * factor) + epsilon / throughput
    This ensures we prioritize cost minimization but use throughput as a tie-breaker.
    """
    cost = data.get('cost', 100.0) * cost_factor
    throughput = data.get('throughput', 0.001)
    # 1e-6 ensures cost differences (typically >0.01) always win over throughput,
    # unless costs are identical/very close.
    return cost + (1e-6 / (throughput + 1e-9))

def _build_steiner_tree(G: nx.DiGraph, src: str, dsts: List[str], weight_attr: str = 'weight') -> Tuple[nx.DiGraph, float]:
    """
    Constructs a Steiner Tree approximation using a greedy Prim-like heuristic.
    Returns the tree as a DiGraph and its total cost (sum of unique edge costs).
    """
    # Initialize tree
    tree_nodes = {src}
    tree_edges = []  # List of (u, v, data)

    # Identify reachable destinations
    remaining_dsts = set(d for d in dsts if d != src and d in G)

    if src not in G:
        return nx.DiGraph(), 0.0

    # Build the tree iteratively
    while remaining_dsts:
        # Dijkstra from current tree_nodes to find closest node in remaining_dsts
        pq = []
        distances = {}
        predecessors = {}

        # Initialize PQ with all current tree nodes (dist=0)
        for node in tree_nodes:
            distances[node] = 0
            heapq.heappush(pq, (0, node))

        closest_dst = None

        visited = set()

        while pq:
            d, u = heapq.heappop(pq)

            if d > distances.get(u, float('inf')):
                continue
            if u in visited:
                continue
            visited.add(u)

            # Check if we hit a target not yet in tree
            if u in remaining_dsts:
                closest_dst = u
                break

            # Expand neighbors
            if u in G:
                for v, data in G[u].items():
                    w = data.get(weight_attr, float('inf'))
                    new_dist = d + w
                    if new_dist < distances.get(v, float('inf')):
                        distances[v] = new_dist
                        predecessors[v] = u
                        heapq.heappush(pq, (new_dist, v))

        if closest_dst:
            # Backtrack to add path to tree
            curr = closest_dst
            path_segment = []

            while curr not in tree_nodes:
                parent = predecessors.get(curr)
                if parent is None:
                    break

                edge_data = G[parent][curr]
                path_segment.append((parent, curr, edge_data))
                curr = parent

            # Add segment to tree
            for u, v, data in reversed(path_segment):
                if v not in tree_nodes:
                    tree_edges.append((u, v, data))
                    tree_nodes.add(v)

            remaining_dsts = remaining_dsts - tree_nodes
        else:
            # Cannot reach any more destinations
            break

    # Construct result graph
    st_graph = nx.DiGraph()
    st_graph.add_nodes_from(tree_nodes)
    total_cost = 0.0
    for u, v, data in tree_edges:
        st_graph.add_edge(u, v, **data)
        total_cost += data.get('cost', 0.0)

    return st_graph, total_cost

def search_algorithm(src, dsts, G, num_partitions):
    """
    Find broadcast paths from source to all destinations using multipath Steiner Trees.

    Optimizes for total cost while utilizing multipathing to improve throughput
    where cost-effective alternatives exist (ECMP-like behavior).
    """

    # 1. Prepare Graph
    # Remove incoming edges to source to prevent loops back to start
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # 2. Build Primary Tree (Cost Optimized)
    # Assign weights prioritizing cost
    for u, v, data in h.edges(data=True):
        data['weight'] = _calculate_edge_weight(data, cost_factor=1.0)

    st_primary, cost_primary = _build_steiner_tree(h, src, dsts, weight_attr='weight')

    # 3. Build Secondary Tree (Diversity/Throughput)
    # Create a graph version with penalties on edges used in the primary tree.
    # This encourages finding edge-disjoint paths or alternative routes if they are similar in cost.
    h_secondary = h.copy()
    primary_edges = set(st_primary.edges())

    for u, v, data in h_secondary.edges(data=True):
        # Apply 20% "soft" penalty to edges used in primary tree
        penalty = 1.2 if (u, v) in primary_edges else 1.0
        data['weight'] = _calculate_edge_weight(data, cost_factor=penalty)

    st_secondary, _ = _build_steiner_tree(h_secondary, src, dsts, weight_attr='weight')

    # Calculate real cost of secondary tree (using original costs)
    cost_secondary = sum(G[u][v]['cost'] for u, v in st_secondary.edges() if u in G and v in G[u])

    # 4. Decide on Multipathing Strategy
    # We only use the secondary tree if it is very close in cost to the primary (within 5%).
    # This acts like ECMP (Equal Cost Multipath). If the secondary tree is much more expensive,
    # we stick to the primary to preserve the "Minimize Cost" goal.
    use_multipath = False
    if cost_primary > 0 and cost_secondary <= cost_primary * 1.05:
        use_multipath = True
    elif cost_primary == 0:
        use_multipath = True

    # 5. Extract Paths and Assign to Topology
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Helper to extract path list for a destination from a tree
    def get_path_from_tree(tree, target):
        try:
            if target in tree:
                p_nodes = nx.shortest_path(tree, src, target)
                return [[p_nodes[i], p_nodes[i+1], G[p_nodes[i]][p_nodes[i+1]]]
                        for i in range(len(p_nodes)-1)]
        except (nx.NetworkXNoPath, KeyError):
            pass
        return None

    for dst in dsts:
        if dst == src:
            continue

        path1 = get_path_from_tree(st_primary, dst)

        # If Steiner tree didn't cover dst (disconnected component logic), fallback to direct graph
        if not path1:
            try:
                p_nodes = nx.shortest_path(h, src, dst, weight='weight')
                path1 = [[p_nodes[i], p_nodes[i+1], G[p_nodes[i]][p_nodes[i+1]]]
                         for i in range(len(p_nodes)-1)]
            except nx.NetworkXNoPath:
                path1 = []

        path2 = None
        if use_multipath:
            path2 = get_path_from_tree(st_secondary, dst)
            # If path2 is identical to path1, multipath adds no value for this specific dst
            if path2 == path1:
                path2 = None

        # Assign paths to partitions
        if path1:
            if path2:
                # Interleave partitions between Path 1 and Path 2 to balance load
                for i in range(num_partitions):
                    selected_path = path1 if i % 2 == 0 else path2
                    bc_topology.set_dst_partition_paths(dst, i, selected_path)
            else:
                # Use Primary path for all partitions
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, path1)

    return bc_topology
