Iteration 213: Proposed new text for program: import networkx as nx
import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Improvements:
    1. Throughput-aware weighting: heavily penalizes low-bandwidth links to avoid transfer time bottlenecks.
    2. Diverse Candidate Generation:
       - Latency-optimized (Widest Path via pruning)
       - Cost-optimized (Shortest Path)
       - Balanced (Weighted Metric)
       - Hub-and-Spoke (Centralized aggregation check)
    3. Robust Selection: Selects the topology that minimizes a composite Cost-Time score.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune incoming edges to source to simplify traversal
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 1. Weight Configuration
    # We use a significant penalty factor for low throughput to avoid
    # high transfer times (instance costs) even if edge cost is low.
    # TIME_VALUE_FACTOR = 0.05 implies 1Gbps adds 0.05 "virtual cost",
    # making a 10Gbps link (0.005 penalty) much more attractive.
    TIME_VALUE_FACTOR = 0.05

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        safe_t = max(t, 0.001)

        # 'balanced_weight': Balance Cost and Time
        data['balanced_weight'] = c + (TIME_VALUE_FACTOR / safe_t)
        # 'cost_weight': Prioritize Cost (fallback)
        data['cost_weight'] = c + (0.0001 / safe_t)

    candidates = []

    def build_candidate(strategy_name, weight_key, prune_threshold=0.0):
        """Generates a candidate topology based on Union of Shortest Paths."""
        # Create a view of the graph, optionally pruning slow edges
        view = h
        if prune_threshold > 0:
            view = nx.DiGraph(h)
            to_remove = [(u, v) for u, v, d in h.edges(data=True) if d.get('throughput', 0) < prune_threshold]
            view.remove_edges_from(to_remove)

        try:
            sub = nx.DiGraph()
            valid_dest_count = 0

            for dst in target_dsts:
                # If path doesn't exist in pruned graph, this candidate might be partial
                # We skip partials for strict strategies or handle them in 'except'
                path = nx.shortest_path(view, src, dst, weight=weight_key)
                for k in range(len(path)-1):
                    u, v = path[k], path[k+1]
                    if not sub.has_edge(u, v):
                        sub.add_edge(u, v, **h[u][v]) # Use original edge data
                valid_dest_count += 1

            if valid_dest_count < len(target_dsts):
                return # Incomplete topology

            # Calculate Metrics
            total_topo_cost = 0.0
            min_topo_throughput = float('inf')

            for u, v, data in sub.edges(data=True):
                total_topo_cost += data.get('cost', 0.0)
                t = data.get('throughput', 1.0)
                if t < min_topo_throughput:
                    min_topo_throughput = t

            if min_topo_throughput == float('inf'): min_topo_throughput = 0.0

            candidates.append({
                'type': strategy_name,
                'subgraph': sub,
                'cost': total_topo_cost,
                'min_throughput': min_topo_throughput
            })
        except nx.NetworkXNoPath:
            pass

    # Strategy A: Balanced (Primary)
    build_candidate('Balanced', 'balanced_weight')

    # Strategy B: High Speed (Prune slow links < 5Gbps)
    # This specifically addresses the "long transfer time" failure pattern
    build_candidate('HighSpeed', 'cost_weight', prune_threshold=5.0)

    # Strategy C: Pure Cost (Fallback if high speed is impossible)
    build_candidate('Cheap', 'cost_weight')

    # Strategy D: Hub Heuristic (Check top centrality nodes)
    # This finds star topologies that might not be found by USP if weights vary
    potential_hubs = sorted(h.nodes(), key=lambda n: h.degree(n), reverse=True)[:15]
    if src not in potential_hubs: potential_hubs.append(src)

    for hub in potential_hubs:
        if hub == src: continue
        try:
            path_to_hub = nx.shortest_path(h, src, hub, weight='balanced_weight')

            sub = nx.DiGraph()
            # Add Src -> Hub
            for k in range(len(path_to_hub)-1):
                u, v = path_to_hub[k], path_to_hub[k+1]
                sub.add_edge(u, v, **h[u][v])

            # Add Hub -> Dsts
            possible = True
            for dst in target_dsts:
                if dst == hub: continue
                try:
                    p = nx.shortest_path(h, hub, dst, weight='balanced_weight')
                    for k in range(len(p)-1):
                        u, v = p[k], p[k+1]
                        sub.add_edge(u, v, **h[u][v])
                except nx.NetworkXNoPath:
                    possible = False
                    break

            if possible:
                c_val = 0.0
                t_min = float('inf')
                for u, v, d in sub.edges(data=True):
                    c_val += d.get('cost', 0.0)
                    t = d.get('throughput', 1.0)
                    if t < t_min: t_min = t

                candidates.append({
                    'type': f'Hub-{hub}',
                    'subgraph': sub,
                    'cost': c_val,
                    'min_throughput': t_min
                })
        except nx.NetworkXNoPath:
            continue

    # ---------------------------------------------------------
    # Selection
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    # Score = Cost + (Penalty / Throughput)
    # We penalize throughput inversely. The constant 2.0 ensures that
    # gaining 10Gbps is worth paying a bit more, but drops off quickly.
    def score_candidate(cand):
        c = cand['cost']
        t = cand['min_throughput']
        if t < 0.1: return float('inf') # Reject practically broken paths

        time_penalty = 2.0 / t
        return c + time_penalty

    # Pick best topology
    best_cand = min(candidates, key=score_candidate)
    subgraph = best_cand['subgraph']

    # ---------------------------------------------------------
    # Path Extraction
    # ---------------------------------------------------------
    # Map the winning subgraph to paths for all partitions.
    # We use shortest_path on the subgraph (which is effectively a tree/DAG)
    # to reconstruct the sequence of edges.
    for dst in target_dsts:
        try:
            # We use BFS (no weight) as the subgraph defines the specific edges to use
            path_nodes = nx.shortest_path(subgraph, src, dst)

            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                edge_data = h[u][v]
                path_edges.append([u, v, edge_data])

            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

        except (nx.NetworkXNoPath, Exception):
            # Fallback: Compute direct path on original graph if subgraph extraction fails
            try:
                p = nx.shortest_path(h, src, dst, weight='balanced_weight')
                pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, pe)
            except:
                pass

    return bc_topology
