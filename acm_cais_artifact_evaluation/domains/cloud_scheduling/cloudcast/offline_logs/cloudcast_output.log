import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_nearest_target(G, sources, targets, weight_attr):
    """
    Finds shortest path from the set of 'sources' to the nearest node in 'targets'.
    Returns: (path_of_nodes, target_node)
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for s in sources:
        heapq.heappush(pq, (0.0, s, None))

    visited = {} # node -> (dist, parent)
    reached_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            reached_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            heapq.heappush(pq, (d + w, v, u))

    if reached_target:
        # Reconstruct path by backtracking
        path = []
        curr = reached_target
        while curr is not None:
            path.append(curr)
            info = visited.get(curr)
            if not info:
                break
            _, par = info
            if par is None:
                break
            curr = par
        return list(reversed(path)), reached_target
    return None, None

def _build_steiner_tree(G, src, dsts, weight_attr):
    """
    Constructs an approximate Steiner Tree connecting src to all dsts using a greedy strategy.
    Returns a set of edges (u, v) that form the tree.
    """
    tree_nodes = {src}
    tree_edges = set()
    pending_dsts = set(d for d in dsts if d != src and d in G)

    if not pending_dsts:
        return tree_edges

    while pending_dsts:
        # Connect the current tree to the closest pending destination
        path, target = _dijkstra_nearest_target(G, tree_nodes, pending_dsts, weight_attr)

        if not target:
            # Remaining destinations are unreachable
            break

        # Add the found path to the tree structure
        for i in range(len(path) - 1):
            u, v = path[i], path[i+1]
            if (u, v) not in tree_edges:
                tree_edges.add((u, v))
                tree_nodes.add(v)

        # Update pending set (remove any nodes we just connected)
        pending_dsts.remove(target)
        for node in path:
            if node in pending_dsts:
                pending_dsts.remove(node)
                tree_nodes.add(node)

    return tree_edges

def _extract_paths_from_tree(G, tree_edges, src, dsts, weight_attr):
    """
    Extracts explicit path lists for each destination from the Steiner Tree edges.
    """
    # Create a subgraph representing the multicast tree
    st = nx.DiGraph()
    for u, v in tree_edges:
        if G.has_edge(u, v):
            st.add_edge(u, v, **G[u][v])

    paths_map = {}
    for dst in dsts:
        if dst == src: continue
        path_edges = []
        try:
            # Shortest path on the tree is the unique path
            nodes = nx.shortest_path(st, src, dst, weight=weight_attr)
            for i in range(len(nodes) - 1):
                u, v = nodes[i], nodes[i+1]
                path_edges.append([u, v, st[u][v]])
        except (nx.NetworkXNoPath, KeyError):
            # Fallback: If tree construction was imperfect, use global shortest path
            try:
                nodes = nx.shortest_path(G, src, dst, weight=weight_attr)
                for i in range(len(nodes) - 1):
                    u, v = nodes[i], nodes[i+1]
                    path_edges.append([u, v, G[u][v]])
            except nx.NetworkXNoPath:
                pass
        paths_map[dst] = path_edges
    return paths_map

def _calculate_topology_cost(paths_map):
    """
    Calculates total egress cost for a topology assuming multicast (shared edges paid once).
    """
    unique_edges = set()
    total_cost = 0.0
    for dst, edges in paths_map.items():
        for u, v, data in edges:
            if (u, v) not in unique_edges:
                unique_edges.add((u, v))
                total_cost += data.get('cost', 0.0)
    return total_cost

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.
    Generates diverse Steiner Tree candidates to balance Cost vs. Throughput across partitions.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    # Remove incoming edges to src to enforce directed acyclic flow from root
    H = G.copy()
    to_remove = list(H.in_edges(src)) + list(nx.selfloop_edges(H))
    H.remove_edges_from(to_remove)

    # 2. Metric Engineering
    # We define a composite weight.
    # Cost is primary, but we penalize low throughput to avoid bottlenecks.
    # Weight = Cost + (Alpha / Throughput)
    # Alpha = 0.02 ensures that we prefer a 10Gbps link over a 1Gbps link
    # even if it costs $0.018 more per GB.
    for u, v, data in H.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        data['metric_weight'] = c + (0.02 / t_safe)

    candidates = []

    # 3. Diverse Candidate Generation
    # We generate multiple Steiner Trees. After each generation, we penalize the
    # used edges to force the next tree to find alternative bandwidth if available.

    # Working graph for penalties
    temp_G = H.copy()

    # Try to find up to 5 diverse topologies (or fewer if num_partitions is small)
    attempts = min(max(num_partitions, 3), 5)

    for i in range(attempts):
        # Build Steiner Tree on current weights
        tree_edges = _build_steiner_tree(temp_G, src, dsts, 'metric_weight')

        if not tree_edges:
            break

        # Extract paths
        paths_map = _extract_paths_from_tree(temp_G, tree_edges, src, dsts, 'metric_weight')

        # Calculate cost
        cost = _calculate_topology_cost(paths_map)

        candidates.append({
            'paths': paths_map,
            'cost': cost
        })

        # Apply Penalty: Multiplicative increase to discourage reuse in next iteration
        # This helps find disjoint paths for multipath routing
        for u, v in tree_edges:
            if temp_G.has_edge(u, v):
                curr_w = temp_G[u][v]['metric_weight']
                temp_G[u][v]['metric_weight'] = curr_w * 2.0 + 0.05

    if not candidates:
        # Fallback to pure shortest paths if Steiner heuristics fail totally
        fallback_map = {}
        for dst in dsts:
            if dst == src: continue
            try:
                p = nx.shortest_path(H, src, dst, weight='metric_weight')
                edges = [[p[k], p[k+1], H[p[k]][p[k+1]]] for k in range(len(p)-1)]
                fallback_map[dst] = edges
            except nx.NetworkXNoPath:
                fallback_map[dst] = []

        for i in range(num_partitions):
            for dst, path in fallback_map.items():
                bc_topology.set_dst_partition_paths(dst, i, path)
        return bc_topology

    # 4. Candidate Selection
    # Sort candidates by cost (lowest first)
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Keep those within 15% cost of the best one.
    # This allows for some diversity to improve throughput without exploding cost.
    best_cost = candidates[0]['cost']
    cost_limit = best_cost * 1.15
    valid_candidates = [c for c in candidates if c['cost'] <= cost_limit]

    # 5. Partition Assignment
    # Round-robin assignment of partitions to valid diverse topologies
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
