import heapq
from typing import Dict, List, Set

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using a Constrained Steiner Tree heuristic.

    Improvements:
    1. Prunes graph to (Source + Destinations) to prevent inefficient detours through
       non-destination transit nodes. This addresses the root cause of high egress costs
       where the algorithm previously selected expensive relays (like Example 2).
    2. Uses Prim's algorithm on this pruned graph to maximize edge sharing (multicast gain)
       only when it is economically beneficial.
    3. Tuned weights to strictly prioritize cost, treating throughput as a constraint
       rather than a linear objective.

    Args:
        src: Source node identifier
        dsts: List of destination node identifiers
        G: NetworkX DiGraph with cost and throughput edge attributes
        num_partitions: Number of data partitions

    Returns:
        BroadCastTopology object with paths for all destinations and partitions
    """

    # 1. Graph Pruning
    # Restrict the graph to Source and Destinations only.
    # In cloud overlays, using arbitrary transit nodes (non-destinations) generally
    # increases total cost due to extra hops (A->B->C cost > A->C cost).
    # We only want to multi-hop if the intermediate node is ALSO a destination
    # (piggybacking), effectively sharing the ingress cost.
    relevant_nodes = set(dsts)
    relevant_nodes.add(src)

    # Create subgraph with relevant nodes only
    h = G.subgraph(list(relevant_nodes)).copy()

    # 2. Weight Calculation
    # Prioritize Egress Cost ($/GB). Use Throughput only to penalize unviable links.
    MIN_THROUGHPUT_THRESHOLD = 0.1 # Gbps
    THROUGHPUT_PENALTY_FACTOR = 0.002 # Very low to prevent overriding cost logic

    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 0.1)
        throughput = data.get('throughput', 1.0)

        # Inverse throughput penalty
        tp_penalty = THROUGHPUT_PENALTY_FACTOR / (throughput + 1e-9)

        # Hard penalty for extremely slow links to avoid timeouts
        if throughput < MIN_THROUGHPUT_THRESHOLD:
            tp_penalty += 10.0

        data['metric'] = cost + tp_penalty

    # 3. Tree Construction (MST on Pruned Graph)
    # Prim's algorithm minimizes the sum of edge weights in the tree.
    # On the pruned graph, this finds the optimal structure: direct connections vs
    # sharing "last mile" paths between nearby destinations.

    mst_edges = []
    tree_nodes = {src}
    pq = []

    # Helper to push candidate edges to Priority Queue
    def add_edges_to_pq(u):
        if u in h:
            for v, data in h[u].items():
                if v not in tree_nodes:
                    # Priority is strictly the edge metric
                    heapq.heappush(pq, (data['metric'], u, v))

    add_edges_to_pq(src)

    while pq:
        w, u, v = heapq.heappop(pq)

        if v in tree_nodes:
            continue

        tree_nodes.add(v)
        mst_edges.append((u, v))
        add_edges_to_pq(v)

    # 4. Extract Paths
    # Build a temporary graph from the tree edges
    tree_graph = nx.DiGraph()
    tree_graph.add_nodes_from(tree_nodes)
    for u, v in mst_edges:
        if u in G and v in G[u]:
            tree_graph.add_edge(u, v, **G[u][v])

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    for dst in dsts:
        if dst == src:
            continue

        final_path = []

        # Strategy A: Route via the Optimized Multicast Tree
        try:
            if dst in tree_graph:
                path_nodes = nx.shortest_path(tree_graph, src, dst)
                for i in range(len(path_nodes) - 1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    final_path.append([u, v, G[u][v]])
        except nx.NetworkXNoPath:
            pass

        # Strategy B: Fallback (Global Shortest Path)
        # If a destination was unreachable in the pruned subgraph (e.g., requires
        # a specific transit node not in the destination list), fallback to full graph search.
        if not final_path:
            try:
                # Use a weight that balances cost and minimal throughput checks
                path_nodes = nx.shortest_path(
                    G, src, dst,
                    weight=lambda u,v,d: d.get('cost',0.1) + 0.005/(d.get('throughput',1.0)+1e-9)
                )
                for i in range(len(path_nodes) - 1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    final_path.append([u, v, G[u][v]])
            except (nx.NetworkXNoPath, KeyError):
                pass

        # Assign paths to partitions
        # We use the single optimal tree for all partitions to maximize volume aggregation
        # and simplicity, as splitting partitions usually degrades cost performance in cloud models.
        if final_path:
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, final_path)

    return bc_topology
