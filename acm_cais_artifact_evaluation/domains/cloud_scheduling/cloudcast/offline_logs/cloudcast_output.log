import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds shortest path from any node in 'sources' to the closest node in 'targets'.
    Optimized to stop early as soon as any target is reached.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def _extract_paths_from_tree(src, dsts, tree_edges, G):
    # Build local graph for the tree
    tree_graph = nx.DiGraph()
    for u, v in tree_edges:
        if G.has_edge(u, v):
            tree_graph.add_edge(u, v, **G[u][v])

    paths_map = {}
    for dst in dsts:
        if dst == src: continue
        path_edges = []
        try:
            # Shortest path on the tree is the unique path
            path_nodes = nx.shortest_path(tree_graph, src, dst)
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                path_edges.append([u, v, G[u][v]])
        except (nx.NetworkXNoPath, KeyError):
            # Destination not reachable in this specific topology
            pass
        paths_map[dst] = path_edges
    return paths_map

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm focusing on cost minimization
    with throughput constraints and multipath diversity.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()
    # Remove incoming edges to source (root constraint) and self-loops
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Thresholds
    # Filter edges with extremely low throughput (e.g., < 0.5 Gbps) to prevent high instance costs (time)
    # unless they are essential. We do this by applying a massive cost penalty.
    MIN_THROUGHPUT_GBPS = 0.5

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)

        # Factor to penalize low throughput links heavily without removing them
        t_penalty_factor = 1.0
        if t < MIN_THROUGHPUT_GBPS:
            t_penalty_factor = 1000.0

        # Composite Weight:
        # Primary = Cost (Dollars)
        # Secondary = 1/Throughput (Time/Latency)
        # Scale throughput influence down to act as a tie-breaker (1e-5)
        # unless throughput is critical. This prevents sacrificing cost for speed
        # unnecessarily, fixing the "zigzag" high-cost path issue.
        # Formula: Cost * Penalty + (Epsilon / Throughput)
        data['standard_weight'] = (c * t_penalty_factor) + (1e-5 / max(t, 0.001))

    candidates = []

    # Strategy A: Union of Shortest Paths (USP)
    # Good for latency (direct paths) and often cost-competitive.
    usp_edges = set()
    valid_usp = True
    try:
        for dst in dsts:
            if dst == src: continue
            # Use standard_weight to find best individual paths
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
    except nx.NetworkXNoPath:
        valid_usp = False

    if valid_usp and usp_edges:
        candidates.append({
            'edges': usp_edges,
            'cost': _get_topology_cost(usp_edges, h),
            'type': 'USP'
        })

    # Strategy B: Iterative Steiner Tree Heuristics
    # Iteratively find trees that share edges to minimize total cost.
    # We apply penalties to used edges in subsequent iterations to force diversity.

    edge_penalties = {}
    iterations = 4  # Sufficient to find diverse paths

    for i in range(iterations):
        # Update weights for this iteration
        for u, v, data in h.edges(data=True):
            base = data['standard_weight']
            penalty = edge_penalties.get((u, v), 1.0)
            data['iter_weight'] = base * penalty

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        # Greedy Construction (Prim-like for Steiner Tree)
        valid_tree = True
        while remaining:
            # Connect the tree to the closest remaining node
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'iter_weight')

            if not target:
                valid_tree = False
                break

            for u, v in path:
                tree_edges.add((u, v))
                tree_nodes.add(v)

            remaining.remove(target)

        if valid_tree and tree_edges:
            # Avoid duplicate topologies
            is_dup = False
            for c in candidates:
                if c['edges'] == tree_edges:
                    is_dup = True
                    break

            if not is_dup:
                candidates.append({
                    'edges': tree_edges,
                    'cost': _get_topology_cost(tree_edges, h),
                    'type': 'Steiner'
                })

                # Penalize edges to find diverse routes in next loop
                for u, v in tree_edges:
                    edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 3. Path Extraction & Validation
    valid_candidates = []
    for cand in candidates:
        cand['paths'] = _extract_paths_from_tree(src, dsts, cand['edges'], h)

        # Ensure the topology actually connects all destinations
        is_complete = True
        for dst in dsts:
            if dst != src and not cand['paths'].get(dst):
                is_complete = False
                break

        if is_complete:
            valid_candidates.append(cand)

    if not valid_candidates:
        return bc_topology

    # 4. Candidate Selection (Cost-based with Diversity)
    # Sort by raw dollar cost
    valid_candidates.sort(key=lambda x: x['cost'])

    # Select candidates within a tolerance of the best cost to use for multipath
    # Tighter tolerance (10%) ensures we don't pick expensive paths just for diversity
    best_cost = valid_candidates[0]['cost']
    limit_cost = best_cost * 1.10
    final_set = [c for c in valid_candidates if c['cost'] <= limit_cost]

    # 5. Partition Assignment
    # Round-robin assignment across the selected diverse, low-cost topologies
    num_final = len(final_set)

    for i in range(num_partitions):
        selected = final_set[i % num_final]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
