import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src: str, dsts: List[str], G: nx.DiGraph, num_partitions: int) -> BroadCastTopology:
    """
    Optimized broadcast routing algorithm using Iterative Steiner Tree Approximations (SPH).

    Improvements:
    1. Robust Tree Construction: Uses a strict Shortest Path Heuristic (SPH) growing from the source
       to ensure acyclic, efficient trees (Arborescences). Prevents "tromboning" and loops.
    2. Multipath Diversity: Generates multiple candidate trees by penalizing edges used in previous
       iterations, allowing different partitions to use disjoint paths for higher aggregate throughput.
    3. Balanced Cost Function: Weighs egress cost against throughput to avoid cheap but extremely slow links.
    4. Deduplication Awareness: Prioritizes shared path segments to minimize total egress cost.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Pre-processing: Create working graph
    # Filter out unreachable destinations to avoid errors
    valid_dsts = [d for d in dsts if d in G and d != src]
    if not valid_dsts:
        return bc_topology

    # Working copy of graph
    h = G.copy()

    # 1. Weight Initialization
    # We want to minimize Cost while avoiding throughput bottlenecks.
    # W = Cost + (Alpha / Throughput)
    # Alpha of 0.05 means 1GB of egress cost ($0.08-$0.15) is roughly equivalent to
    # the penalty of a 0.5 Gbps link. This encourages using higher bandwidth links (>1Gbps).
    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 0.0)
        throughput = data.get('throughput', 1.0)
        # Avoid division by zero
        t_safe = max(throughput, 0.001)

        # Base weight for shortest path calculations
        data['base_weight'] = cost + (0.05 / t_safe)
        data['penalty'] = 1.0

    candidate_trees = []

    # 2. Candidate Generation
    # We generate up to K diverse trees.
    # If num_partitions is high, we cycle through a smaller set of good trees.
    max_candidates = min(num_partitions, 8)

    for _ in range(max_candidates):
        # Update current weights with penalties
        for u, v, data in h.edges(data=True):
            data['curr_weight'] = data['base_weight'] * data['penalty']

        # --- Steiner Tree Construction (SPH) ---
        # Start with the source in the tree
        tree_nodes = {src}
        tree_edges = []
        # Track which destinations are covered
        remaining_dsts = set(valid_dsts)

        # Iteratively connect the closest remaining destination to the current tree
        while remaining_dsts:
            # Use multi_source_dijkstra to find the shortest path from ANY node in tree_nodes
            # to ANY node in remaining_dsts.
            # This implicitly builds a valid Arborescence (directed tree rooted at src).

            # Since networkx doesn't support "target set", we compute distances to all reachable
            # and filter. For dense cloud graphs (small node count < 100), this is efficient.
            try:
                dists, paths = nx.multi_source_dijkstra(
                    h, tree_nodes, weight='curr_weight'
                )
            except Exception:
                break # Should not happen if graph is connected

            # Find the closest remaining destination
            best_dst = None
            min_dist = float('inf')

            for d in remaining_dsts:
                if d in dists and dists[d] < min_dist:
                    min_dist = dists[d]
                    best_dst = d

            if best_dst is None:
                # Cannot reach remaining destinations (graph partitioned)
                break

            # Add the path to the tree
            path_nodes = paths[best_dst]

            # The path starts at a node in tree_nodes and ends at best_dst.
            # Edges in between are new tree edges.
            for i in range(len(path_nodes) - 1):
                u, v = path_nodes[i], path_nodes[i+1]
                # Avoid adding duplicates if multiple paths overlap (though SPH usually handles this)
                if v not in tree_nodes:
                    tree_edges.append((u, v))
                    tree_nodes.add(v)

            remaining_dsts.remove(best_dst)

            # Optimization: Check if this path accidentally covered other remaining destinations
            # (Nodes added to tree_nodes might include other destinations)
            covered_now = remaining_dsts.intersection(tree_nodes)
            remaining_dsts -= covered_now

        # --- Tree Validation & Storage ---
        if not tree_edges and len(valid_dsts) > 0:
            continue

        # Build a subgraph for this tree to extract precise paths
        st_graph = nx.DiGraph()
        st_graph.add_edges_from(tree_edges)

        # Verify connectivity for all destinations
        current_tree_paths = {}
        tree_total_egress_cost = 0.0
        edges_used_in_tree = set(tree_edges)

        valid_tree = True
        for dst in valid_dsts:
            try:
                # Because st_graph is a tree rooted at src, shortest path is unique and acyclic
                path_nodes = nx.shortest_path(st_graph, src, dst)
                formatted_path = []
                for i in range(len(path_nodes) - 1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    # Retrieve original edge data
                    edge_data = G[u][v]
                    formatted_path.append([u, v, edge_data])

                current_tree_paths[dst] = formatted_path
            except (nx.NetworkXNoPath, nx.NodeNotFound):
                # Fallback: If SPH failed to cover a node (rare/disconnected), try direct graph
                try:
                    path_nodes = nx.shortest_path(h, src, dst, weight='curr_weight')
                    formatted_path = []
                    for i in range(len(path_nodes) - 1):
                        u, v = path_nodes[i], path_nodes[i+1]
                        edge_data = G[u][v]
                        formatted_path.append([u, v, edge_data])
                        edges_used_in_tree.add((u, v))
                    current_tree_paths[dst] = formatted_path
                except nx.NetworkXNoPath:
                    valid_tree = False
                    break

        if valid_tree:
            # Calculate simple metric for sorting: Sum of egress costs on unique edges
            # (Approximating the shared-multicast benefit)
            for u, v in edges_used_in_tree:
                tree_total_egress_cost += G[u][v].get('cost', 0.0)

            candidate_trees.append({
                'paths': current_tree_paths,
                'cost': tree_total_egress_cost,
                'edges': edges_used_in_tree
            })

            # Penalize edges to encourage diversity in next iteration
            # Multiplicative penalty encourages finding disjoint routes
            for u, v in edges_used_in_tree:
                h[u][v]['penalty'] *= 1.5

    # 3. Selection and Assignment
    if not candidate_trees:
        return bc_topology

    # Sort candidates by cost (ascending)
    # We prefer cheaper trees, but we want to use multiple of them if they are close in cost
    candidate_trees.sort(key=lambda x: x['cost'])

    # Filter candidates: Keep those within 15% of the best cost to ensure we don't pick
    # terribly expensive paths just for the sake of diversity.
    best_cost = candidate_trees[0]['cost']
    valid_candidates = [c for c in candidate_trees if c['cost'] <= best_cost * 1.15]

    # If we have too few valid candidates compared to partitions, repeat them
    num_candidates = len(valid_candidates)

    for i in range(num_partitions):
        # Round-robin assignment
        selection = valid_candidates[i % num_candidates]
        paths_map = selection['paths']

        for dst, path_list in paths_map.items():
            bc_topology.set_dst_partition_paths(dst, i, path_list)

    return bc_topology
