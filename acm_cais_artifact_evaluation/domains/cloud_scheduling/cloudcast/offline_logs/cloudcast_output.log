import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            # Use G to get edge data for the segment
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_metrics(edges, G, src, dsts):
    """
    Calculates cost and estimates bottleneck bandwidth for the topology.
    """
    cost = 0.0
    # Construct a temporary graph for the topology
    topo = nx.DiGraph()
    topo.add_nodes_from(dsts + [src])

    min_bw = float('inf')

    for u, v in edges:
        if G.has_edge(u, v):
            data = G[u][v]
            c = data.get('cost', 0.0)
            bw = data.get('throughput', 1.0)
            cost += c
            if bw < min_bw:
                min_bw = bw
            topo.add_edge(u, v, **data)

    # Check connectivity
    is_connected = True
    try:
        for dst in dsts:
            if dst != src and not nx.has_path(topo, src, dst):
                is_connected = False
                break
    except nx.NetworkXError:
        is_connected = False

    return cost, min_bw, is_connected, topo

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing.
    Prioritizes constructing a low-cost Steiner Tree while avoiding low-throughput links.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()
    # Remove incoming edges to source to enforce rooted directionality
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Composite Weight Calculation
    # We want to minimize cost primarily, but penalize very slow links and hop count.
    # Logic:
    # - Base: Cost
    # - Hop penalty: 1e-4 (Breaks ties towards direct paths)
    # - Throughput penalty:
    #   - If BW < 1.0 Gbps: Heavy penalty (avoid unless necessary)
    #   - Else: Small inverse penalty to prefer fatter pipes for multipath potential
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)

        # Penalize low throughput heavily
        t_penalty = 0.0
        if t < 0.1:
            t_penalty = 10.0
        elif t < 1.0:
            t_penalty = 1.0
        else:
            t_penalty = 0.001 / t

        hop_penalty = 0.0001

        data['standard_weight'] = c + t_penalty + hop_penalty
        data['calc_weight'] = data['standard_weight']

    candidates = []

    # Strategy A: Greedy Steiner Tree (Iterative)
    # We run multiple iterations. In later iterations, we penalize edges used in previous best trees
    # to find diverse paths if they exist.

    edge_penalties = {}
    iterations = 3

    # Also consider Union of Shortest Paths (USP) as iteration -1
    # USP is often good for latency but bad for cost (no shared edges).
    # We check it just in case direct paths are surprisingly cheap.
    usp_edges = set()
    try:
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        cost, bw, connected, _ = _get_topology_metrics(usp_edges, h, src, dsts)
        if connected:
            candidates.append({
                'edges': usp_edges,
                'cost': cost,
                'bw': bw,
                'type': 'USP'
            })
    except nx.NetworkXNoPath:
        pass

    # Steiner Iterations
    for i in range(iterations):
        # Apply penalties from previous iterations
        for u, v, data in h.edges(data=True):
            base = data['standard_weight']
            penalty = edge_penalties.get((u, v), 1.0)
            data['calc_weight'] = base * penalty

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        # Prim's-like construction
        while remaining:
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')
            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.discard(target)
            # Remove any other nodes reached along the path from remaining
            for u, v in path:
                if v in remaining:
                    remaining.discard(v)

        if not tree_edges:
            continue

        # Evaluate candidate
        cost, bw, connected, _ = _get_topology_metrics(tree_edges, h, src, dsts)

        if connected:
            # Check for duplicates
            is_dup = False
            for c in candidates:
                if c['edges'] == tree_edges:
                    is_dup = True
                    break

            if not is_dup:
                candidates.append({
                    'edges': tree_edges,
                    'cost': cost,
                    'bw': bw,
                    'type': 'Steiner'
                })

                # Penalize edges for next iteration to force diversity
                # We multiply weight by 1.5 to encourage finding different paths
                for u, v in tree_edges:
                    edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 3. Candidate Selection
    # Sort primarily by Cost, secondarily by Bottleneck BW (descending)
    # We want MIN cost, MAX bw.
    candidates.sort(key=lambda x: (x['cost'], -x['bw']))

    best_cand = candidates[0]

    # Filter candidates for multipath
    # Only consider candidates that are extremely close in cost to the best one (<= 1% diff)
    # and have decent bandwidth.
    valid_candidates = []
    limit_cost = best_cand['cost'] * 1.01

    for cand in candidates:
        if cand['cost'] <= limit_cost:
            valid_candidates.append(cand)

    # 4. Path Extraction & Assignment
    # If we have multiple valid candidates, round robin partitions.
    # If only one (or others are too expensive), use best.

    num_valid = len(valid_candidates)

    # Pre-compute path maps for valid candidates to save time
    candidate_path_maps = []
    for cand in valid_candidates:
        topo_g = nx.DiGraph()
        for u, v in cand['edges']:
            topo_g.add_edge(u, v, **h[u][v])

        p_map = {}
        for dst in dsts:
            if dst == src: continue
            try:
                path_nodes = nx.shortest_path(topo_g, src, dst)
                path_edges = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u, v, h[u][v]])
                p_map[dst] = path_edges
            except nx.NetworkXNoPath:
                # Should not happen given _get_topology_metrics check, but safe fallback
                p_map[dst] = []
        candidate_path_maps.append(p_map)

    # Assign partitions
    for i in range(num_partitions):
        # Round robin among valid low-cost candidates
        selected_idx = i % num_valid
        paths_map = candidate_path_maps[selected_idx]

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
