import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Returns (path_of_edges, target_node).
    """
    pq = []
    counter = 0
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        # (dist, counter, u, parent)
        heapq.heappush(pq, (0.0, counter, node, None))
        counter += 1

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, _, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, counter, v, u))
            counter += 1

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _extract_paths_from_tree_edges(src, dsts, tree_edges, G, weight_attr='weight'):
    """
    Given a set of edges forming a tree/DAG, extract explicit paths from src to dsts.
    Uses Dijkstra on the subgraph to ensure loop-freedom and structural validity.
    """
    subgraph = nx.DiGraph()
    for u, v in tree_edges:
        if G.has_edge(u, v):
            subgraph.add_edge(u, v, **G[u][v])

    paths_map = {}
    try:
        # Calculate all paths from src in the subgraph
        # Dijkstra ensures we find the optimal path within the tree structure
        # and avoids any cycles if they inadvertently slipped in.
        all_paths = nx.single_source_dijkstra_path(subgraph, source=src, weight=weight_attr)
    except:
        all_paths = {}

    for dst in dsts:
        if dst == src: continue
        path_edges = []
        if dst in all_paths:
            nodes = all_paths[dst]
            for k in range(len(nodes)-1):
                u, v = nodes[k], nodes[k+1]
                path_edges.append([u, v, G[u][v]])
        else:
            # Fallback: if heuristic left a node disconnected, use global graph shortest path
            try:
                nodes = nx.shortest_path(G, src, dst, weight=weight_attr)
                for k in range(len(nodes)-1):
                    u, v = nodes[k], nodes[k+1]
                    path_edges.append([u, v, G[u][v]])
            except nx.NetworkXNoPath:
                pass
        paths_map[dst] = path_edges
    return paths_map

def _calculate_topology_cost(edges, G):
    """Calculates total egress cost for a topology."""
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using Steiner Tree heuristics with:
    1. Hop-count penalties to prevent long inefficient chains.
    2. Multi-objective weighting (Cost vs Throughput).
    3. Diversity generation for multipath bandwidth aggregation.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning
    h = G.copy()
    # Remove incoming edges to source to enforce rooted flow
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 2. Configuration for Diversity
    # We generate candidates based on different trade-offs.
    # alpha: weight for 1/throughput (latency/performance penalty)
    # beta: fixed cost per hop (prevents excessive hopping for marginal cost gains)
    configs = [
        # Pure Cost with slight hop penalty (primary for cost minimization)
        {'name': 'cost_efficient', 'alpha': 0.001, 'beta': 0.002},
        # Balanced approach
        {'name': 'balanced', 'alpha': 0.01, 'beta': 0.0},
        # Throughput focused (higher penalty for low bandwidth)
        {'name': 'high_throughput', 'alpha': 0.05, 'beta': 0.0}
    ]

    candidates = []
    global_edge_penalties = {}

    # 3. Candidate Generation Loop
    for cfg in configs:
        alpha = cfg['alpha']
        beta = cfg['beta']
        weight_attr = f"weight_{cfg['name']}"

        # Calculate weights
        for u, v, data in h.edges(data=True):
            c = data.get('cost', 0.0)
            t = data.get('throughput', 1.0)
            t_safe = max(t, 0.001)

            # Base weight calculation
            base_w = c + (alpha / t_safe) + beta

            # Apply diversity penalty
            penalty = global_edge_penalties.get((u, v), 1.0)
            data[weight_attr] = base_w * penalty

        # Steiner Tree Heuristic
        # Iteratively connect closest remaining destination to the current tree
        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        while remaining:
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, weight_attr)

            if not target:
                break

            # Add path to tree
            for u, v in path:
                tree_edges.add((u, v))
                tree_nodes.add(v)

            # Update remaining set efficiently
            if target in remaining:
                remaining.remove(target)

            # Also remove any other destinations that were incidentally reached
            reached = [r for r in remaining if r in tree_nodes]
            for r in reached:
                remaining.remove(r)

        if not tree_edges:
            continue

        # Extract Clean Paths (Topology Pruning)
        paths_map = _extract_paths_from_tree_edges(src, dsts, tree_edges, h, weight_attr)

        # Calculate Metrics
        topo_cost = _calculate_topology_cost(tree_edges, h)

        # Check for duplicates
        is_dup = False
        for c in candidates:
            if c['eval_cost'] == topo_cost and c['edges'] == tree_edges:
                is_dup = True
                break

        if not is_dup:
            candidates.append({
                'edges': tree_edges,
                'paths': paths_map,
                'eval_cost': topo_cost,
                'type': cfg['name']
            })

            # Penalize edges for next iteration to encourage diversity
            for u, v in tree_edges:
                global_edge_penalties[(u, v)] = global_edge_penalties.get((u, v), 1.0) * 1.5

    # 4. Fallback/Baseline: Union of Shortest Paths (USP)
    # Often optimal for latency and simplicity
    usp_edges = set()
    usp_weight = 'weight_balanced'
    try:
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(h, src, dst, weight=usp_weight)
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        if usp_edges:
            paths_map = _extract_paths_from_tree_edges(src, dsts, usp_edges, h, usp_weight)
            topo_cost = _calculate_topology_cost(usp_edges, h)
            candidates.append({
                'edges': usp_edges,
                'paths': paths_map,
                'eval_cost': topo_cost,
                'type': 'USP'
            })
    except nx.NetworkXNoPath:
        pass

    if not candidates:
        return bc_topology

    # 5. Selection & Assignment
    # Sort by estimated cost
    candidates.sort(key=lambda x: x['eval_cost'])
    best_cost = candidates[0]['eval_cost']

    # Filter candidates: Accept slightly more expensive trees (up to 10%)
    # if they provide diversity (which we assume from the generation process).
    # This helps balance load and reduce transfer time (instance cost).
    valid_candidates = [c for c in candidates if c['eval_cost'] <= best_cost * 1.1]

    num_valid = len(valid_candidates)

    # Round-robin assignment to partitions
    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        for dst, path in selected['paths'].items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
