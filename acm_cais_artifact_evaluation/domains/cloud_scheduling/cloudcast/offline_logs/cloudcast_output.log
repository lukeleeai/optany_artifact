import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_find_branch(G, tree_nodes, path_costs_from_root, targets, weight_attr='weight', bias_factor=0.2):
    """
    Finds the best branch extending the current tree to one of the targets.
    Implements a 'Shallow Light Tree' heuristic.

    The priority of a connection is:
    Priority = (Distance_From_Root(u) * bias_factor) + Weight(u, v)

    bias_factor:
      0.0 -> approximates Steiner Tree (MST-like), minimizing total edge weight regardless of path length.
      1.0 -> approximates Shortest Path Tree (Dijkstra), minimizing path latency but ignoring edge sharing.
      0.2 -> Balanced approach (SLT) to minimize cost while preventing excessive hops/latency.
    """
    pq = []
    # Initialize PQ with all current tree nodes.
    # The starting 'distance' in the PQ is weighted by how far the node is from the source.
    # This penalizes extending from nodes that are already deep in the tree (preventing long daisy-chains).
    for node in tree_nodes:
        root_cost = path_costs_from_root.get(node, 0.0)
        heapq.heappush(pq, (root_cost * bias_factor, node, None))

    visited_in_search = {} # node -> (priority_dist, parent)

    closest_target = None
    target_dist = float('inf')

    while pq:
        d, u, parent = heapq.heappop(pq)

        # Standard Dijkstra visited check
        if u in visited_in_search and visited_in_search[u][0] <= d:
            continue
        visited_in_search[u] = (d, parent)

        if u in targets:
            # We found the optimal connection point according to our biased metric
            closest_target = u
            target_dist = d
            break

        # Explore neighbors
        for v, attr in G[u].items():
            if v in tree_nodes:
                continue

            w = attr.get(weight_attr, 1.0)
            new_dist = d + w

            if v not in visited_in_search or new_dist < visited_in_search[v][0]:
                heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct the branch path
        path = []
        curr = closest_target
        while curr is not None:
            entry = visited_in_search.get(curr)
            if not entry: break
            _, par = entry

            if par is None:
                # 'curr' was the connection point in the existing tree
                break

            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target

    return [], None

def _build_shallow_light_steiner_tree(G, src, dsts, weight_attr='weight', bias_factor=0.2):
    """
    Constructs a Steiner Tree approximation optimized for broadcast routing.
    Balances edge sharing (cost reduction) with path length (latency reduction).
    """
    tree_edges = set()
    tree_nodes = {src}
    path_costs_from_root = {src: 0.0} # Track actual path cost from source

    remaining = set(d for d in dsts if d != src and d in G)

    # Safety mechanism
    last_count = len(remaining) + 1

    while remaining:
        if len(remaining) >= last_count:
            break # No progress
        last_count = len(remaining)

        path_segment, target = _dijkstra_find_branch(
            G, tree_nodes, path_costs_from_root, remaining,
            weight_attr=weight_attr, bias_factor=bias_factor
        )

        if not target or not path_segment:
            break

        # Integrate new branch into the tree
        for u, v in path_segment:
            if (u, v) not in tree_edges:
                tree_edges.add((u, v))
                tree_nodes.add(v)

                # Update path cost for the new node
                w = G[u][v].get(weight_attr, 1.0)
                path_costs_from_root[v] = path_costs_from_root[u] + w

        # Remove covered destinations
        if target in remaining:
            remaining.remove(target)
        for u, v in path_segment:
            if v in remaining:
                remaining.remove(v)

    return tree_edges

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized multi-cloud broadcast routing.

    Key Improvements:
    1. Shallow-Light Tree (SLT) Heuristic: Prevents "tromboning" (excessive hops) by biasing
       tree construction towards shorter paths from source.
    2. Throughput-Sensitive Weights: heavily penalizes low-bandwidth links to minimize instance costs.
    3. Diverse Multipath: Generates multiple topologically distinct trees to utilize bandwidth.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 2. Weight Initialization
    # Weight = Cost + (Alpha / Throughput) + Beta
    # Alpha=1.5: Strong penalty for low throughput (e.g. <1Gbps becomes very expensive)
    # Beta=0.005: Fixed penalty per hop to discourage unnecessary detours
    alpha = 1.5
    beta = 0.005

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.1)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        data['base_weight'] = c + (alpha / t_safe) + beta

    candidates = []
    edge_penalties = {}

    # 3. Candidate Generation
    # We generate multiple trees. In each iteration, we penalize edges used previously
    # to find diverse paths. We also vary the SLT bias factor slightly.

    num_iterations = max(num_partitions, 4)
    base_bias = 0.20

    for i in range(num_iterations):
        # Update weights with diversity penalties
        for u, v, data in h.edges(data=True):
            p = edge_penalties.get((u, v), 1.0)
            data['curr_weight'] = data['base_weight'] * p

        # Vary bias to explore trade-offs between Edge-Sharing (low cost) and Shortest-Path (low time)
        # Sequence: 0.20, 0.25, 0.15, 0.30 ...
        iter_bias = base_bias + (0.05 * (1 if i % 2 == 1 else -1) * ((i+1)//2))
        iter_bias = max(0.1, min(0.9, iter_bias))

        tree_edges = _build_shallow_light_steiner_tree(h, src, dsts, 'curr_weight', iter_bias)

        if not tree_edges:
            if not candidates: break
            continue

        # Extract strict paths for topology object
        st_graph = nx.DiGraph()
        for u, v in tree_edges:
            st_graph.add_edge(u, v, **h[u][v])

        paths_map = {}
        tree_egress_cost = 0.0
        max_path_cost = 0.0 # Proxy for transfer time/latency
        used_edges = set()
        valid_tree = True

        for dst in dsts:
            if dst == src: continue

            try:
                # Prefer tree path
                path_nodes = nx.shortest_path(st_graph, src, dst)
                path_edges = []
                dst_path_accum_weight = 0.0

                for k in range(len(path_nodes) - 1):
                    u_node, v_node = path_nodes[k], path_nodes[k+1]
                    edge_data = h[u_node][v_node]
                    path_edges.append([u_node, v_node, edge_data])

                    dst_path_accum_weight += edge_data['base_weight']

                    if (u_node, v_node) not in used_edges:
                        tree_egress_cost += edge_data.get('cost', 0.0)
                        used_edges.add((u_node, v_node))

                paths_map[dst] = path_edges
                max_path_cost = max(max_path_cost, dst_path_accum_weight)

            except nx.NetworkXNoPath:
                # Fallback to shortest path in main graph if tree construction missed a node
                try:
                    path_nodes = nx.shortest_path(h, src, dst, weight='curr_weight')
                    path_edges = []
                    for k in range(len(path_nodes) - 1):
                        u_node, v_node = path_nodes[k], path_nodes[k+1]
                        edge_data = h[u_node][v_node]
                        path_edges.append([u_node, v_node, edge_data])

                        if (u_node, v_node) not in used_edges:
                            tree_egress_cost += edge_data.get('cost', 0.0)
                            used_edges.add((u_node, v_node))
                    paths_map[dst] = path_edges
                except:
                    valid_tree = False
                    break

        if valid_tree:
            current_edge_set = frozenset(used_edges)

            # Deduplicate
            is_dup = any(c['edge_set'] == current_edge_set for c in candidates)

            if not is_dup:
                # Score combines total cost (for budget) and max path cost (for time)
                # This helps select trees that are cheap but not terribly slow
                score = tree_egress_cost + (max_path_cost * 0.5)

                candidates.append({
                    'score': score,
                    'cost': tree_egress_cost,
                    'paths': paths_map,
                    'edge_set': current_edge_set
                })

                # Penalize edges for next iteration to force diversity
                for u, v in used_edges:
                    edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.4

        if len(candidates) >= num_partitions * 2:
            break

    # 4. Selection & Assignment
    if not candidates:
        return bc_topology

    # Sort by combined score (Cost/Time balance)
    candidates.sort(key=lambda x: x['score'])

    # Use top K candidates to spread traffic across diverse good paths
    # This utilizes multipath bandwidth to reduce congestion on shared links
    top_k = min(len(candidates), 3)
    selected_candidates = candidates[:top_k]

    for i in range(num_partitions):
        # Round robin assignment
        selected = selected_candidates[i % len(selected_candidates)]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
