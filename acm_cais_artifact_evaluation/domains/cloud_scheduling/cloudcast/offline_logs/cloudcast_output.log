            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm for multi-cloud data transfer.

    Uses a greedy Steiner Tree heuristic (modified Prim's algorithm) to construct
    a multicast tree that minimizes Total Cost (Egress + Instance).

    Key optimizations:
    1. Economic Edge Weights: Balances egress cost against throughput (time/instance cost).
    2. Shallow Tree Bias: Mild penalty for tree depth to prevent excessive latency accumulation.
    3. Hub Identification: Automatically identifies intermediate regions to act as distribution hubs.
    """

    # 1. Graph Preparation
    # Work on a copy to avoid side effects
    h = G.copy()

    # Remove inbound edges to source to prevent loops/backflow
    if src in h:
        h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # Configuration Constants
    # THROUGHPUT_PENALTY_FACTOR: Converts throughput (time) into dollar-equivalent cost.
    # Value 0.01 implies saving 1 hour of transfer time is worth roughly ~$0.01-$0.05 in egress.
    # This prevents the selection of extremely slow links while prioritizing egress savings.
    THROUGHPUT_PENALTY_FACTOR = 0.01

    # DEPTH_PENALTY_ALPHA: Coefficient for tree depth penalty.
    # A small value (0.05) breaks ties in favor of shallower trees (fewer hops)
    # to maintain better reliability and latency without sacrificing significant cost.
    DEPTH_PENALTY_ALPHA = 0.05

    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 0.1)
        throughput = data.get('throughput', 1.0)

        # Avoid division by zero and handle extremely low throughputs
        safe_throughput = max(throughput, 1e-6)

        # Composite Weight = Egress Cost + Time Value
        data['weight'] = cost + (THROUGHPUT_PENALTY_FACTOR / safe_throughput)

    # 2. Heuristic Steiner Tree Construction
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    tree_nodes = {src}
    tree_edges = []

    # Track cumulative cost/distance from source within the tree for depth penalty
    node_depth_cost = {src: 0.0}

    # Priority Queue stores: (priority_score, source_node, target_node, edge_weight)
    pq = []

    def push_neighbors(u):
        if u not in h: return
        u_dist = node_depth_cost[u]

        for v, data in h[u].items():
            if v in tree_nodes:
                continue

            w = data['weight']
            # Priority Score = Local Edge Weight + (Alpha * Total Path Weight to Parent)
            # This heuristic grows a tree that is locally cheap but aware of total depth.
            priority = w + (DEPTH_PENALTY_ALPHA * u_dist)

            heapq.heappush(pq, (priority, u, v, w))

    # Initialize with source neighbors
    push_neighbors(src)

    remaining_dsts = set(d for d in dsts if d != src and d in h)

    while remaining_dsts and pq:
        prio, u, v, w = heapq.heappop(pq)

        if v in tree_nodes:
            continue

        # Add node to the Steiner Tree
        tree_nodes.add(v)
        tree_edges.append((u, v))
        node_depth_cost[v] = node_depth_cost[u] + w

        if v in remaining_dsts:
            remaining_dsts.remove(v)

        # Add new neighbors to PQ
        push_neighbors(v)

    # 3. Path Reconstruction
    # Build a directed graph representing the constructed tree
    st_graph = nx.DiGraph()
    st_graph.add_nodes_from(tree_nodes)
    for u, v in tree_edges:
        if u in G and v in G[u]:
            st_graph.add_edge(u, v, **G[u][v])

    # 4. Route Assignment
    for dst in dsts:
        if dst == src:
            continue

        final_edge_path = []
        try:
            # Attempt to retrieve the path from the Steiner Tree
            if dst in st_graph:
                path_nodes = nx.shortest_path(st_graph, source=src, target=dst)

                # Convert node path to edge list
                for i in range(len(path_nodes) - 1):
                    u_node, v_node = path_nodes[i], path_nodes[i+1]
                    final_edge_path.append([u_node, v_node, G[u_node][v_node]])
            else:
                # Fallback: If heuristic failed to connect the destination (e.g. graph partition),
                # use standard Dijkstra on the original graph.
                path_nodes = nx.shortest_path(h, source=src, target=dst, weight='weight')
                for i in range(len(path_nodes) - 1):
                    u_node, v_node = path_nodes[i], path_nodes[i+1]
                    final_edge_path.append([u_node, v_node, G[u_node][v_node]])

        except nx.NetworkXNoPath:
            # Destination is unreachable
            pass

        if final_edge_path:
            # Assign the calculated optimal path to all partitions.
            # (In this domain, aggregating partitions on the best cost path
            # is usually superior to multipathing due to egress pricing structures).
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, final_edge_path)

    return bc_topology
