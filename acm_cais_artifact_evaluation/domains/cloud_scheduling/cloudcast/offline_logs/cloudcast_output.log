import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_find_closest_target(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Returns the path (list of edges) and the target node reached.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using a Single Robust Steiner Tree heuristic.

    Improvements:
    1. Weighted metric balances cost ($) and throughput (time) to avoid slow links.
    2. Constructs a single high-quality Steiner Tree to maximize edge reuse (minimizing egress cost).
    3. Avoids forced diversity which previously selected suboptimal, expensive, and slow paths.
    4. Ensures strict DAG structure to prevent routing loops.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()
    # Remove incoming edges to source to enforce rooted tree structure
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate optimization weights
    # We combine Cost and Throughput into a single metric.
    # Logic: Minimize Cost, but add a penalty for low throughput to avoid bottlenecks.
    # A penalty of 0.002/throughput implies we are willing to pay ~$0.002 extra per GB
    # to avoid a 1Gbps link, or $0.02 to avoid a 0.1Gbps link.
    # Small epsilon added to prefer lower hop counts (proxy for instance costs).
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_eff = max(t, 0.001) # Avoid division by zero

        # Weight formula: Cost + Throughput Penalty + Hop Penalty
        data['opt_weight'] = c + (0.002 / t_eff) + 0.0001

    # 2. Construct Steiner Tree (Shortest Path Heuristic)
    # Grow a tree from source to cover all destinations using the optimized weight.
    tree_edges = set()
    tree_nodes = {src}
    remaining_targets = set(d for d in dsts if d != src and d in h)

    while remaining_targets:
        # Find the cheapest path from the current tree to any unreachable destination
        path, target = _dijkstra_find_closest_target(h, tree_nodes, remaining_targets, 'opt_weight')

        if not target:
            # Graph disconnected for remaining targets
            break

        # Add the new path to the tree
        for u, v in path:
            if (u, v) not in tree_edges:
                tree_edges.add((u, v))
                tree_nodes.add(v)

        # Update remaining targets
        remaining_targets.remove(target)
        # Optimization: Check if other targets were incidentally reached
        reached = [t for t in remaining_targets if t in tree_nodes]
        for t in reached:
            remaining_targets.remove(t)

    # 3. Extract Paths from the Steiner Tree
    # Create a subgraph representing the multicast tree
    st_graph = nx.DiGraph()
    for u, v in tree_edges:
        if h.has_edge(u, v):
            st_graph.add_edge(u, v, **h[u][v])

    # 4. Populate Topology
    # We assign the same optimal path to all partitions.
    # This strategy minimizes total egress cost by maximizing edge reuse
    # and ensures consistent transfer times by avoiding slow secondary paths.
    for dst in dsts:
        if dst == src: continue

        final_path_edges = []
        try:
            # Extract unique path in the tree
            path_nodes = nx.shortest_path(st_graph, src, dst)
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                final_path_edges.append([u, v, h[u][v]])
        except (nx.NetworkXNoPath, KeyError):
            # Fallback: Use global shortest path if Steiner tree failed to connect
            try:
                path_nodes = nx.shortest_path(h, src, dst, weight='opt_weight')
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    final_path_edges.append([u, v, h[u][v]])
            except nx.NetworkXNoPath:
                pass

        if final_path_edges:
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, final_path_edges)

    return bc_topology
