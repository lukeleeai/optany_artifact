import heapq
from typing import Dict, List, Set, Tuple, Optional

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _calculate_weight(cost: float, throughput: float) -> float:
    """
    Calculate edge weight balancing Egress Cost and virtual cost of Time.

    The objective is to minimize Cost while maintaining throughput.
    Previous iterations penalized low throughput too heavily (factor 0.2),
    causing the algorithm to prefer expensive egress paths (e.g. $0.09/GB)
    over cheap ones ($0.02/GB) just because they were faster.

    Calibration:
    - Egress Cost range: $0.00 - $0.20 per GB.
    - Instance Cost approx $0.50 - $1.00 per hour.
    - Time for 1GB at 1Gbps = 8 seconds.
    - Instance cost per GB for 1Gbps = (8/3600)*$1.00 ~= $0.002.
    - Factor should be ~0.002 to equate time-cost to egress-cost.
    """
    t_safe = max(throughput, 0.001)
    # Weight = Direct Cost + (Time Penalty / Throughput)
    return cost + (0.005 / t_safe)

def _dijkstra_find_next_branch(G, tree_nodes: Set[str], targets: Set[str], weight_attr: str = 'weight') -> Tuple[List[Tuple], Optional[str]]:
    """
    Finds the shortest path from any node in the existing 'tree_nodes' set to the
    closest node in 'targets'.

    Returns:
        (path_edges, target_node) where path_edges is list of (u, v)
    """
    pq = []
    # Initialize PQ with all current tree nodes at distance 0
    for node in tree_nodes:
        heapq.heappush(pq, (0.0, node, None))

    distances = {node: 0.0 for node in tree_nodes}
    predecessors = {}
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if d > distances.get(u, float('inf')):
            continue

        predecessors[u] = parent

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            # Prevent re-entering the existing tree (ensures acyclic expansion)
            if v in tree_nodes:
                continue

            w = attr.get(weight_attr, 1.0)
            new_dist = d + w

            if new_dist < distances.get(v, float('inf')):
                distances[v] = new_dist
                heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path from the target back to the tree connection
        path = []
        curr = closest_target
        while curr is not None:
            par = predecessors.get(curr)
            # If par is None, we hit the root of this search branch (a node originally in tree_nodes)
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target

    return [], None

def _build_steiner_tree(G, src: str, dsts: List[str], weight_attr: str = 'weight') -> nx.DiGraph:
    """
    Constructs a Steiner Tree approximation.
    Iteratively connects the closest unreachable destination to the growing tree.
    """
    # Initialize tree as a DiGraph to easily trace paths later
    T = nx.DiGraph()
    T.add_node(src)

    tree_nodes = {src}

    # Targets that need to be connected
    remaining_targets = set(d for d in dsts if d != src and d in G)

    while remaining_targets:
        # Find shortest path from ANY tree node to ANY remaining target
        path_segment, target = _dijkstra_find_next_branch(G, tree_nodes, remaining_targets, weight_attr)

        if not target:
            # Remaining targets are unreachable from the current tree
            break

        # Integrate the new path into the tree
        for u, v in path_segment:
            if not T.has_edge(u, v):
                # Copy edge attributes from main graph
                edge_data = G[u][v].copy()
                T.add_edge(u, v, **edge_data)
                tree_nodes.add(v)

        # Mark targets as covered
        remaining_targets.remove(target)
        # Check if other targets were covered by this path incidentally
        covered_incidental = [t for t in remaining_targets if t in tree_nodes]
        for t in covered_incidental:
            remaining_targets.remove(t)

    return T

def search_algorithm(src: str, dsts: List[str], G: nx.DiGraph, num_partitions: int) -> BroadCastTopology:
    """
    Optimized routing algorithm balancing Cost and Throughput.
    1. Calibrates edge weights to correctly prioritize cost.
    2. Generates Steiner Trees to minimize total multicast cost.
    3. Supports limited multipath if alternative trees have comparable costs.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Working copy of graph
    h = G.copy()

    # Enforce Source Constraints: Remove incoming edges to src to ensure it acts as root
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weight Initialization
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Apply calibrated weight formula
        data['base_weight'] = _calculate_weight(c, t)
        data['curr_weight'] = data['base_weight']

    candidates = []
    edge_penalties = {}

    # Generate Candidate Trees
    # We attempt to find up to 3 diverse trees.
    # If partitions=1, we only need the best one.
    attempts = 3 if num_partitions > 1 else 1

    for _ in range(attempts):
        # Apply penalties from previous iterations
        for u, v, data in h.edges(data=True):
            p = edge_penalties.get((u, v), 1.0)
            data['curr_weight'] = data['base_weight'] * p

        # Build Tree
        st_tree = _build_steiner_tree(h, src, dsts, weight_attr='curr_weight')

        if len(st_tree.nodes) <= 1 and len(dsts) > 0:
             # Graph likely disconnected or no paths found
             if not candidates:
                 break
             continue

        # Extract Paths
        paths_map = {}
        tree_egress_cost = 0.0
        used_edges = set()

        valid_tree = True

        for dst in dsts:
            if dst == src:
                continue

            path_list = []
            try:
                # Prefer path strictly within the Steiner Tree
                if dst in st_tree:
                    path_nodes = nx.shortest_path(st_tree, src, dst)
                    for k in range(len(path_nodes) - 1):
                        u, v = path_nodes[k], path_nodes[k+1]
                        original_data = h[u][v]
                        path_list.append([u, v, original_data])

                        if (u, v) not in used_edges:
                            tree_egress_cost += original_data.get('cost', 0.0)
                            used_edges.add((u, v))
                else:
                    # Fallback: Dijkstra on full graph (should be rare if graph connected)
                    path_nodes = nx.shortest_path(h, src, dst, weight='curr_weight')
                    for k in range(len(path_nodes) - 1):
                        u, v = path_nodes[k], path_nodes[k+1]
                        original_data = h[u][v]
                        path_list.append([u, v, original_data])

                        if (u, v) not in used_edges:
                            tree_egress_cost += original_data.get('cost', 0.0)
                            used_edges.add((u, v))

            except nx.NetworkXNoPath:
                # If any destination is unreachable, this tree might be partial
                # We still keep it if it covers some destinations
                pass

            paths_map[dst] = path_list

        # Deduplication
        current_edge_set = frozenset(used_edges)
        is_dup = False
        for c in candidates:
            if c['edge_set'] == current_edge_set:
                is_dup = True
                break

        if not is_dup and used_edges:
            candidates.append({
                'cost': tree_egress_cost,
                'paths': paths_map,
                'edge_set': current_edge_set
            })

            # Penalize edges for next iteration to encourage diversity
            for u, v in used_edges:
                edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    # Selection Strategy
    if not candidates:
        return bc_topology

    # Sort candidates by total cost
    candidates.sort(key=lambda x: x['cost'])

    best_cost = candidates[0]['cost']

    # Filter candidates: Only use multipath if cost is within 5% of optimal.
    # We prioritize cost heavily; diversity is only secondary.
    valid_candidates = [c for c in candidates if c['cost'] <= best_cost * 1.05]

    # Round-Robin Assignment
    num_valid = len(valid_candidates)
    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        p_map = selected['paths']

        for dst, path in p_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
