import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_nearest_target(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the nearest node in 'targets'.
    Returns (path_list, target_node). Path includes start (from sources) and end (target).
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            heapq.heappush(pq, (d + w, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            path.append(curr)
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break # Reached a source node
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm focusing on Steiner Tree heuristics.

    Improvements:
    1. Robust Weighting: Balances Cost vs Throughput to avoid slow links without over-penalizing cost.
    2. Steiner Tree Heuristic: iteratively builds multicast trees to minimize total shared edge cost.
    3. Strict Selection: Selects the single best topology for all partitions. Since egress pricing is
       linear, splitting partitions across suboptimal paths increases cost without benefit unless
       bandwidth is capped (which is handled by weight penalties).
    4. Graph Hygiene: Ensures valid DAG/Tree structures to prevent routing loops.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    h = G.copy()

    # Remove incoming edges to source to enforce rooted structure
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate composite weights
    # Goal: Minimize Cost, but heavily penalize extremely low throughput.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        # Weight = Cost + (0.002 / Throughput).
        # At 1Gbps, penalty is 0.002 (negligible vs 0.02-0.09 cost).
        # At 10Mbps (0.01), penalty is 0.2 (dominant).
        data['standard_weight'] = c + (0.002 / t_safe)
        data['base_cost'] = c

    candidates = []

    # Strategy A: Union of Shortest Paths (USP)
    # Baseline: Low latency, effectively a Star topology if direct links exist.
    usp_edges = set()
    usp_valid = True
    try:
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
    except nx.NetworkXNoPath:
        usp_valid = False

    if usp_valid and usp_edges:
        candidates.append({
            'type': 'USP',
            'edges': usp_edges
        })

    # Strategy B: Iterative Greedy Steiner Tree
    # Generates trees by connecting the closest unconnected destination to the current tree.
    # Iterations apply penalties to used edges to find diverse topologies.
    edge_penalties = {}
    iterations = 4

    for i in range(iterations):
        # Apply diversity penalties
        for u, v, data in h.edges(data=True):
            base = data['standard_weight']
            penalty = edge_penalties.get((u, v), 1.0)
            data['calc_weight'] = base * penalty

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        while remaining:
            # Connect nearest remaining destination to the tree
            path_nodes, target = _dijkstra_nearest_target(h, tree_nodes, remaining, 'calc_weight')

            if not target:
                break

            # Add path to tree
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            # Remove covered destinations
            remaining.remove(target)
            for node in path_nodes:
                if node in remaining:
                    remaining.remove(node)

        if not remaining: # Successful tree
            # Check for duplicates
            is_dup = False
            for c in candidates:
                if c['edges'] == tree_edges:
                    is_dup = True
                    break

            if not is_dup:
                candidates.append({
                    'type': f'Steiner_{i}',
                    'edges': tree_edges
                })

            # Increase penalties for next iteration
            for u, v in tree_edges:
                edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 3. Evaluation and Selection
    best_candidate = None
    min_topology_cost = float('inf')

    for cand in candidates:
        # Build candidate graph to verify paths and sum costs
        st_graph = nx.DiGraph()
        # Sum of unique edges in the topology (Multicast Tree Cost)
        topology_cost = 0.0

        for u, v in cand['edges']:
            if h.has_edge(u, v):
                data = h[u][v]
                st_graph.add_edge(u, v, **data)
                topology_cost += data.get('base_cost', 0.0)

        # Verify valid paths exist for all destinations
        cand_paths = {}
        valid_cand = True

        for dst in dsts:
            if dst == src: continue
            try:
                # Extract simple path from tree
                path_nodes = nx.shortest_path(st_graph, src, dst, weight='standard_weight')
                path_list = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_list.append([u, v, h[u][v]])
                cand_paths[dst] = path_list
            except nx.NetworkXNoPath:
                valid_cand = False
                break

        if valid_cand:
            cand['paths'] = cand_paths
            cand['cost'] = topology_cost

            # Select strict minimum cost
            # Since egress cost is the dominant factor, we avoid multipath splitting
            # unless costs are identical.
            if topology_cost < min_topology_cost:
                min_topology_cost = topology_cost
                best_candidate = cand
            elif abs(topology_cost - min_topology_cost) < 1e-9:
                # Tie-breaker: prefer USP for potentially lower latency (direct paths)
                if cand['type'] == 'USP':
                    best_candidate = cand

    # 4. Partition Assignment
    # Use the single best topology for all partitions.
    # This maximizes the benefit of the multicast tree structure.
    if best_candidate:
        paths_map = best_candidate['paths']
        for i in range(num_partitions):
            for dst, path in paths_map.items():
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
