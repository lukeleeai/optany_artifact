import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Returns (path_of_edges, target_node).
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def _extract_paths_from_tree(G_full, tree_edges, src, dsts):
    """
    Given a set of tree edges, reconstruct loop-free paths from src to all dsts.
    Returns a dict {dst: list_of_edges}.
    """
    T = nx.DiGraph()
    for u, v in tree_edges:
        if G_full.has_edge(u, v):
            T.add_edge(u, v, **G_full[u][v])

    paths_map = {}
    for dst in dsts:
        if dst == src: continue
        try:
            # Shortest path in a tree is unique and acyclic
            path_nodes = nx.shortest_path(T, src, dst)
            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                path_edges.append([u, v, G_full[u][v]])
            paths_map[dst] = path_edges
        except (nx.NetworkXNoPath, KeyError):
            # If the tree does not connect to a specific destination, it's invalid
            return None
    return paths_map

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing.
    Improvements:
    1. Reduced throughput penalty to prioritize cost (egress minimization).
    2. Multiple heuristic strategies: USP (Cost), Steiner (Cost), Steiner (Balanced).
    3. Strict cycle prevention by extracting paths from validated trees.
    4. Multipath selection restricted to candidates with near-optimal cost.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate weights
    # Cost is the primary driver ($/GB). Throughput is secondary (time).
    # We use a minimal penalty for throughput to break ties without distorting cost optimization.
    # 0.0001 / t_safe: 10Gbps -> +0.00001, 0.1Gbps -> +0.001.
    # This prevents taking a $0.05 path over a $0.04 path just for BW, unless the cheap path is extremely slow.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)

        data['weight_cost'] = c
        data['weight_balanced'] = c + (0.0001 / t_safe)

    candidates = []

    # Strategy A: Union of Shortest Paths (USP) - Pure Cost
    # This provides the "direct routing" baseline, often optimal for latency and competitive on cost.
    usp_edges = set()
    valid_usp = True
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(h, src, dst, weight='weight_cost')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
        except nx.NetworkXNoPath:
            valid_usp = False
            break

    if valid_usp and usp_edges:
        candidates.append({
            'edges': usp_edges,
            'cost': _get_topology_cost(usp_edges, h)
        })

    # Strategy B: Iterative Steiner Tree Heuristics
    # Iteration 1: Optimize for 'weight_cost' (Pure Cost Shared Tree)
    # Iteration 2: Optimize for 'weight_balanced' (Cost + Throughput Shared Tree)
    # Iteration 3: Diversity (Penalize edges from previous iterations)

    strategies = [
        ('weight_cost', 1.0),
        ('weight_balanced', 1.0),
        ('weight_cost', 1.3)
    ]

    edge_penalties = {}

    for weight_attr, penalty_mult in strategies:
        # Apply penalties
        for u, v, data in h.edges(data=True):
            base = data[weight_attr]
            p = edge_penalties.get((u, v), 1.0)
            data['calc_weight'] = base * p

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        valid_tree = True
        while remaining:
            # Connect the tree to the closest remaining node
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')

            if not target:
                valid_tree = False
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

        if valid_tree and tree_edges:
            # Deduplicate
            is_dup = False
            for c in candidates:
                if c['edges'] == tree_edges:
                    is_dup = True
                    break

            if not is_dup:
                candidates.append({
                    'edges': tree_edges,
                    'cost': _get_topology_cost(tree_edges, h)
                })

                # Update penalties
                if penalty_mult > 1.0:
                    for u, v in tree_edges:
                        edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * penalty_mult

    if not candidates:
        return bc_topology

    # 3. Path Extraction & Validation
    final_candidates = []
    for cand in candidates:
        paths_map = _extract_paths_from_tree(h, cand['edges'], src, dsts)
        if paths_map:
            cand['paths'] = paths_map
            final_candidates.append(cand)

    if not final_candidates:
        # Fallback to simple shortest paths if all topology constructions failed
        for dst in dsts:
            if dst == src: continue
            try:
                path = nx.shortest_path(h, src, dst, weight='weight_balanced')
                p_edges = [[path[k], path[k+1], h[path[k]][path[k+1]]] for k in range(len(path)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, p_edges)
            except nx.NetworkXNoPath:
                pass
        return bc_topology

    # 4. Candidate Selection
    # Sort by cost ascending
    final_candidates.sort(key=lambda x: x['cost'])

    # Multipath Strategy:
    # Only select multiple topologies if they are very close in cost to the best one.
    # Minimizing cost is primary; switching to a slightly more expensive path for BW
    # is only worth it if the cost delta is tiny.
    best_cost = final_candidates[0]['cost']
    limit_cost = best_cost * 1.01 # 1% margin

    valid_selection = [c for c in final_candidates if c['cost'] <= limit_cost]

    # 5. Partition Assignment
    num_valid = len(valid_selection)
    for i in range(num_partitions):
        # Round-robin assignment
        selected = valid_selection[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
