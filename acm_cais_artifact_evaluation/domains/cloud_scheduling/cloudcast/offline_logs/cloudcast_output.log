import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using Metric Closure Minimum Spanning Arborescence (MSA).

    Improvements:
    1. Robust Tree Construction: Uses MSA on the metric closure of the graph to guarantee
       cycle-free, cost-optimal multicast trees (Steiner Tree approximation).
    2. Bottleneck Avoidance: Implements a composite weight function that heavily penalizes
       throughput bottlenecks (< 50Mbps) to minimize instance costs and timeouts.
    3. Explicit Path Unrolling: Converts abstract tree edges back to physical paths deterministically,
       preventing the "loops" and "back-and-forth" routing seen in previous versions.
    4. Diversity Generation: Iteratively generates candidate trees by penalizing used edges,
       selecting a set of cost-competitive topologies for multipath routing.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()

    # Remove incoming edges to source (enforce rooted tree) and self-loops
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Composite Weight Calculation
    # Objective: Minimize Cost ($) + Time Penalty ($ equiv)
    # Factor 0.05 implies: 1 Gbps link adds $0.05 overhead cost to edge weight.
    # 100 Mbps link adds $0.50. This steers flows away from low-bandwidth links
    # unless they are significantly cheaper.
    throughput_penalty_factor = 0.05

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)

        # Prune edges with critically low throughput to prevent timeouts
        if t < 0.05:
            data['weight'] = float('inf')
        else:
            # Weight balances egress cost and transfer time
            data['weight'] = c + (throughput_penalty_factor / t)

        # Store original cost for reporting/verification
        data['actual_cost'] = c

    # 2. Candidate Generation Loop
    candidates = []
    edge_penalty_map = {}

    # Generate up to 3 diverse topologies or fewer if partitions are small
    num_iterations = min(num_partitions, 3) if num_partitions > 0 else 1

    for i in range(num_iterations):
        # Create a working graph with penalized weights for diversity
        work_graph = h.copy()
        for u, v, data in work_graph.edges(data=True):
            penalty = edge_penalty_map.get((u, v), 1.0)
            data['weight'] *= penalty

        # A. Build Metric Closure (Clique of Src + Dsts)
        # Edges in closure represent shortest paths in the physical graph
        interesting_nodes = {src} | {d for d in dsts if d in work_graph}
        closure = nx.DiGraph()
        path_cache = {} # (u, v) -> [node_list]

        # Compute Single-Source Shortest Paths from each interesting node to all others
        # This is efficient for small numbers of destinations (cloud regions)
        for start_node in interesting_nodes:
            try:
                # Get paths and lengths to all reachable nodes
                dists, paths = nx.single_source_dijkstra(work_graph, start_node, weight='weight')

                for target_node in interesting_nodes:
                    if start_node == target_node:
                        continue
                    if target_node in dists:
                        closure.add_edge(start_node, target_node, weight=dists[target_node])
                        path_cache[(start_node, target_node)] = paths[target_node]
            except Exception:
                continue

        if len(closure) < 2:
            continue

        # B. Compute Minimum Spanning Arborescence (MSA) on Closure
        # This approximates the optimal Steiner Tree
        try:
            msa = nx.minimum_spanning_arborescence(closure, attr='weight')
        except nx.NetworkXException:
            # Fallback for disconnected components: Star topology (Direct paths)
            msa = nx.DiGraph()
            for d in dsts:
                if d != src and closure.has_edge(src, d):
                    msa.add_edge(src, d)

        # C. Unroll MSA to Physical Paths
        # Traverse the MSA from root to build actual routing paths
        candidate_paths = {} # dst -> list of edges
        candidate_edges = set() # For diversity penalty

        # DFS Stack: (current_node, current_path_edges)
        stack = [(src, [])]
        visited_msa = {src}

        while stack:
            u, path_to_u = stack.pop()

            # If u is a destination, store its path
            if u in dsts and u != src:
                candidate_paths[u] = list(path_to_u) # copy

            # Traverse MSA children
            for v in msa.successors(u):
                if v in visited_msa: continue
                visited_msa.add(v)

                # Expand logical edge (u, v) to physical path
                if (u, v) in path_cache:
                    node_seq = path_cache[(u, v)]
                    segment_edges = []
                    for k in range(len(node_seq) - 1):
                        s_u, s_v = node_seq[k], node_seq[k+1]
                        if h.has_edge(s_u, s_v):
                            edge_data = h[s_u][s_v]
                            segment_edges.append([s_u, s_v, edge_data])
                            candidate_edges.add((s_u, s_v))

                    # Push child with accumulated path
                    stack.append((v, path_to_u + segment_edges))

        # Handle any unreachable destinations with direct fallback
        for d in dsts:
            if d != src and d not in candidate_paths:
                try:
                    p = nx.shortest_path(h, src, d, weight='weight')
                    edges = []
                    for k in range(len(p)-1):
                        edges.append([p[k], p[k+1], h[p[k]][p[k+1]]])
                    candidate_paths[d] = edges
                except nx.NetworkXNoPath:
                    candidate_paths[d] = []

        # Calculate Candidate Cost
        total_cost = 0.0
        used_edges = set()
        for p_list in candidate_paths.values():
            for e in p_list:
                u, v = e[0], e[1]
                if (u, v) not in used_edges:
                    total_cost += e[2].get('cost', 0.0)
                    used_edges.add((u, v))

        candidates.append({
            'paths': candidate_paths,
            'cost': total_cost,
            'edges': used_edges
        })

        # Penalize edges for next iteration to find diverse paths
        for u, v in candidate_edges:
            edge_penalty_map[(u, v)] = edge_penalty_map.get((u, v), 1.0) * 1.5

    # 3. Candidate Selection & Assignment
    if not candidates:
        return bc_topology

    # Sort by cost ascending
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Keep those within 10% of the best cost
    # This prevents selecting significantly more expensive paths just for diversity
    best_cost = candidates[0]['cost']
    limit_cost = best_cost * 1.10
    valid_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    if not valid_candidates:
        valid_candidates = [candidates[0]]

    # Round-robin assignment of partitions to valid candidates
    num_valid = len(valid_candidates)
    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        for dst, path in selected['paths'].items():
            bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
