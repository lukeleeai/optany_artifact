import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Returns (path_of_edges, target_node).
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        # Expand neighbors
        if u in G:
            for v, attr in G[u].items():
                if v in visited:
                    continue
                w = attr.get(weight_attr, 1.0)
                new_dist = d + w
                heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path_edges = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path_edges.append((par, curr))
            curr = par
        return list(reversed(path_edges)), closest_target
    return [], None

def _extract_paths_from_edges(src, dsts, edges_set, G, weight_attr='weight'):
    """
    Given a set of edges forming a topology (tree/DAG), extract simple paths from src to each dst.
    """
    # Build a temporary graph for the topology
    temp_G = nx.DiGraph()
    for u, v in edges_set:
        if G.has_edge(u, v):
            temp_G.add_edge(u, v, **G[u][v])

    paths_map = {}
    for dst in dsts:
        if dst == src:
            continue
        try:
            # shortest_path on the DAG/Tree returns the unique path or shortest if DAG
            node_path = nx.shortest_path(temp_G, src, dst, weight=weight_attr)
            path_segment = []
            for i in range(len(node_path) - 1):
                u, v = node_path[i], node_path[i+1]
                path_segment.append([u, v, temp_G[u][v]])
            paths_map[dst] = path_segment
        except (nx.NetworkXNoPath, KeyError):
            # Fallback: Try global graph if topology is disconnected (should not happen if valid)
            try:
                node_path = nx.shortest_path(G, src, dst, weight=weight_attr)
                path_segment = []
                for i in range(len(node_path) - 1):
                    u, v = node_path[i], node_path[i+1]
                    path_segment.append([u, v, G[u][v]])
                paths_map[dst] = path_segment
            except nx.NetworkXNoPath:
                paths_map[dst] = []

    return paths_map

def _calculate_candidate_metrics(paths_map, G):
    """
    Calculate total cost and bottleneck throughput for a set of paths.
    """
    used_edges = set()
    total_cost = 0.0
    min_throughput = float('inf')

    for dst, path in paths_map.items():
        if not path: continue
        for u, v, data in path:
            edge_key = (u, v)
            if edge_key not in used_edges:
                used_edges.add(edge_key)
                total_cost += data.get('cost', 0.0)
                tp = data.get('throughput', 1.0)
                if tp < min_throughput:
                    min_throughput = tp

    if min_throughput == float('inf'):
        min_throughput = 0.0

    return total_cost, min_throughput

def search_algorithm(src, dsts, G, num_partitions):
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 0. Data Preparation & Reachability Check
    reachable_dsts = []
    for dst in dsts:
        if dst != src and nx.has_path(G, src, dst):
            reachable_dsts.append(dst)

    if not reachable_dsts:
        return bc_topology

    # 1. Weight Augmentation
    # We define a balanced weight to avoid extremely slow links while optimizing cost.
    # Cost ~0.05, Throughput ~10-30.
    # Penalty: +0.02 for 1Gbps, +0.002 for 10Gbps.
    for u, v, data in G.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)

        # Primary metric: Cost + meaningful latency penalty
        data['balanced_weight'] = c + (0.02 / t_safe)
        # Secondary metric: Pure cost (for cheapest path baselines)
        data['cost_weight'] = c

    candidates = []

    # Strategy A: Union of Shortest Paths (USP) - Balanced
    # Provides latency-aware baseline paths.
    usp_edges = set()
    for dst in reachable_dsts:
        try:
            path = nx.shortest_path(G, src, dst, weight='balanced_weight')
            for i in range(len(path)-1):
                usp_edges.add((path[i], path[i+1]))
        except nx.NetworkXNoPath:
            pass

    if usp_edges:
        paths = _extract_paths_from_edges(src, reachable_dsts, usp_edges, G, 'balanced_weight')
        cost, tp = _calculate_candidate_metrics(paths, G)
        candidates.append({'type': 'USP_Balanced', 'paths': paths, 'cost': cost, 'min_tp': tp, 'edges': usp_edges})

    # Strategy B: Union of Shortest Paths (USP) - Pure Cost
    # Provides the absolute floor for cost (Direct paths or simple hops).
    usp_cost_edges = set()
    for dst in reachable_dsts:
        try:
            path = nx.shortest_path(G, src, dst, weight='cost_weight')
            for i in range(len(path)-1):
                usp_cost_edges.add((path[i], path[i+1]))
        except nx.NetworkXNoPath:
            pass

    if usp_cost_edges:
        # Avoid duplicate work if identical to Balanced
        if usp_cost_edges != usp_edges:
            paths = _extract_paths_from_edges(src, reachable_dsts, usp_cost_edges, G, 'cost_weight')
            cost, tp = _calculate_candidate_metrics(paths, G)
            candidates.append({'type': 'USP_Cost', 'paths': paths, 'cost': cost, 'min_tp': tp, 'edges': usp_cost_edges})

    # Strategy C: Randomized Iterative Steiner Tree
    # Generates tree topologies that share edges to reduce total overlay cost.
    # We run this multiple times with random weight perturbations to find diverse local optima.
    iterations = 6
    for i in range(iterations):
        # Perturb weights slightly to encourage diversity
        iter_weight_attr = f'iter_weight_{i}'
        for u, v, data in G.edges(data=True):
            noise = random.uniform(0.85, 1.15)
            data[iter_weight_attr] = data['balanced_weight'] * noise

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(reachable_dsts)

        # Greedy construction of Steiner Tree
        while remaining:
            # Find path from ANY node in current tree to ANY remaining destination
            path, target = _dijkstra_multisource_incremental(G, tree_nodes, remaining, iter_weight_attr)
            if not target:
                break

            # Add path edges to the tree
            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

        if tree_edges:
            # Deduplicate based on edge set
            if any(c.get('edges') == tree_edges for c in candidates):
                continue

            paths = _extract_paths_from_edges(src, reachable_dsts, tree_edges, G, iter_weight_attr)
            cost, tp = _calculate_candidate_metrics(paths, G)
            candidates.append({
                'type': 'Steiner',
                'paths': paths,
                'cost': cost,
                'min_tp': tp,
                'edges': tree_edges
            })

    # 3. Candidate Selection & Filtering
    if not candidates:
        return bc_topology

    # Sort by Cost primarily
    candidates.sort(key=lambda x: x['cost'])

    best_cost = candidates[0]['cost']

    # Filter candidates:
    # 1. Must be within 15% of best cost (relaxed constraint to allow better throughput options)
    # 2. Must not have extremely low throughput compared to best options
    valid_candidates = []

    # Check if we have any high-throughput candidates to baseline against
    max_available_tp = max((c['min_tp'] for c in candidates), default=1.0)
    tp_threshold = 1.0 # Min acceptable 1 Gbps

    for c in candidates:
        is_cost_competitive = c['cost'] <= best_cost * 1.15

        # Accept if throughput is decent OR if it's the only cheap option
        is_tp_acceptable = c['min_tp'] >= tp_threshold or c['min_tp'] >= max_available_tp * 0.5

        if is_cost_competitive and is_tp_acceptable:
            valid_candidates.append(c)

    # Fallback if filtering was too aggressive
    if not valid_candidates:
        valid_candidates = candidates[:max(1, len(candidates)//2)]

    # 4. Partition Assignment
    # Use round-robin assignment across valid diverse topologies to utilize multiple paths (multipath)
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
