import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_candidate_metrics(candidate_edges, G):
    """Calculates total cost and min throughput for a set of edges."""
    total_cost = 0.0
    min_throughput = float('inf')

    for u, v in candidate_edges:
        if not G.has_edge(u, v):
            return float('inf'), 0.0
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t

    if min_throughput == float('inf'): min_throughput = 0.0
    return total_cost, min_throughput

def _build_topology_from_edges(G, edges, src, dsts):
    """
    Reconstructs paths from src to dsts given a set of edges.
    Verifies connectivity and returns metrics.
    """
    sub = nx.DiGraph()
    for u, v in edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    # Verify all destinations are reachable using shortest path logic on the subgraph
    # This effectively creates the routing table for the topology
    final_edges = set()
    try:
        for dst in dsts:
            if dst == src: continue
            # Find path in the subgraph (unweighted bfs is sufficient for tree structures)
            path = nx.shortest_path(sub, src, dst)
            for i in range(len(path)-1):
                final_edges.add((path[i], path[i+1]))
    except (nx.NetworkXNoPath, Exception):
        return None

    c, t = _get_candidate_metrics(final_edges, sub)
    return {
        'edges': final_edges,
        'cost': c,
        'min_throughput': t,
        'subgraph': sub
    }

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Weighted Shortest Paths (USP): Direct routing with cost/throughput balance.
    2. Greedy Steiner Tree: Approximates minimum multicast tree cost.
    3. Latency-Aware Routing: Ensures high-throughput paths are considered.

    Optimization:
    - Penalizes low throughput heavily during graph search to avoid "cheap but slow" bottlenecks.
    - Evaluates multiple topology candidates (USP vs Steiner).
    - Selects final topology based on a Total Cost score that includes a virtual instance cost penalty.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning & Weight Calculation
    h = G.copy()

    # Remove incoming edges to src (useless for broadcast) and self-loops
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # Weight Configuration
    # We define 'balanced_weight' to optimize Cost + (Penalty / Throughput).
    # A penalty factor of 0.1 ensures that dropping from 10Gbps to 1Gbps
    # adds ~0.09 to the weight, comparable to an expensive edge cost.
    throughput_penalty = 0.1

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)

        # Balanced: Trade-off between egress cost and speed
        data['balanced_weight'] = c + (throughput_penalty / t_safe)

        # Fast: Prioritizes throughput primarily (inverse throughput), with cost as tie-breaker
        data['fast_weight'] = (1.0 / t_safe) + (c * 0.001)

    candidates = []

    def add_candidate(edges, type_tag):
        cand = _build_topology_from_edges(h, edges, src, target_dsts)
        if cand:
            cand['type'] = type_tag
            candidates.append(cand)

    # ---------------------------------------------------------
    # Strategy A: Union of Shortest Paths (USP)
    # ---------------------------------------------------------
    # Baseline strategies that connect source to each destination optimally individually.

    # 1. Balanced USP (Cost/Throughput Mix)
    usp_edges_balanced = set()
    try:
        for dst in target_dsts:
            # Dijkstra for each dst
            p = nx.shortest_path(h, src, dst, weight='balanced_weight')
            for k in range(len(p)-1): usp_edges_balanced.add((p[k], p[k+1]))
        add_candidate(usp_edges_balanced, 'USP_Balanced')
    except nx.NetworkXNoPath: pass

    # 2. High-Throughput USP (minimize transfer time)
    usp_edges_fast = set()
    try:
        for dst in target_dsts:
            p = nx.shortest_path(h, src, dst, weight='fast_weight')
            for k in range(len(p)-1): usp_edges_fast.add((p[k], p[k+1]))
        add_candidate(usp_edges_fast, 'USP_Fast')
    except nx.NetworkXNoPath: pass

    # ---------------------------------------------------------
    # Strategy B: Greedy Steiner Tree (Iterative Construction)
    # ---------------------------------------------------------
    # Builds a tree by iteratively connecting the closest remaining destination
    # to the existing tree. This maximizes edge sharing (multicast efficiency).
    # We run this multiple times with different base weights and noise.

    strategies = [
        ('balanced_weight', 0.0), # Deterministic Balanced
        ('balanced_weight', 0.15), # Randomized Balanced
        ('cost', 0.1) # Cost focused with noise (using raw cost if available, else balanced)
    ]

    for weight_attr, noise in strategies:
        # Prepare graph weights
        calc_weight_attr = 'calc_w'
        for u, v, d in h.edges(data=True):
            base_w = d.get(weight_attr, d.get('balanced_weight'))
            if noise > 0:
                d[calc_weight_attr] = base_w * random.uniform(1.0 - noise, 1.0 + noise)
            else:
                d[calc_weight_attr] = base_w

        tree_nodes = {src}
        tree_edges = set()
        remaining = set(target_dsts)

        # Iterative expansion
        while remaining:
            try:
                # Find shortest path from ANY node in the current tree to ANY remaining target
                # multi_source_dijkstra returns (distances, paths)
                dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight=calc_weight_attr)

                best_dst = None
                best_dist = float('inf')

                # Filter for remaining targets
                for r in remaining:
                    if r in dists and dists[r] < best_dist:
                        best_dist = dists[r]
                        best_dst = r

                if best_dst:
                    path = paths[best_dst]
                    # Add path to tree
                    for k in range(len(path)-1):
                        u, v = path[k], path[k+1]
                        tree_edges.add((u, v))
                        tree_nodes.add(v)
                        if v in remaining: remaining.remove(v)
                    # Also clean up any other remaining nodes that we happened to traverse
                    for n in path:
                        if n in remaining: remaining.remove(n)
                else:
                    break # Cannot reach remaining nodes
            except:
                break

        if not remaining:
            add_candidate(tree_edges, f'Steiner_{weight_attr}')

    # ---------------------------------------------------------
    # Selection Logic
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    # Score function: Minimize (Egress Cost + Virtual Time Cost)
    # Time Cost models instance uptime costs.
    # We prioritize paths that aren't bottlenecks.

    best_cand = None
    best_score = float('inf')

    for cand in candidates:
        c = cand['cost']
        t = cand['min_throughput']

        # Heuristic: Reject extremely low throughput (< 0.5 Gbps) if decent alternatives exist
        # This prevents picking a $1 cheaper path that takes 10x longer.
        if t < 0.5 and len(candidates) > 1:
            # Only skip if we have a faster candidate
            if any(other['min_throughput'] > 1.0 for other in candidates):
                continue

        # Score calculation
        # Virtual Penalty: $0.50 equivalent per Gbps inverse
        # This aligns with instance costs roughly ~$0.5/hr for data heavy instances
        time_penalty = 0.5 / max(t, 0.001)
        score = c + time_penalty

        if score < best_score:
            best_score = score
            best_cand = cand

    if not best_cand:
        best_cand = candidates[0]

    # ---------------------------------------------------------
    # Path Application
    # ---------------------------------------------------------
    # Apply the winning topology to all partitions.
    # Using the same efficient multicast tree for all partitions maximizes cost savings.

    subgraph = best_cand['subgraph']

    for dst in target_dsts:
        try:
            # Re-trace path on the optimized subgraph
            path_nodes = nx.shortest_path(subgraph, src, dst) # Unweighted shortest path on tree

            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                edge_data = h[u][v]
                path_edges.append([u, v, edge_data])

            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

        except (nx.NetworkXNoPath, Exception):
            # Fallback to direct routing on original graph if something went wrong
            try:
                p = nx.shortest_path(h, src, dst, weight='balanced_weight')
                pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, pe)
            except:
                pass

    return bc_topology
