import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_path(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from any node in 'sources' to the closest node in 'targets'.
    Returns: (list of edges [(u, v)], target_node, cost)
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target, visited[closest_target][0]
    return [], None, float('inf')

def _calculate_topology_cost(edges, G):
    """Calculates total egress cost of the topology."""
    total_cost = 0.0
    for u, v in edges:
        total_cost += G[u][v].get('cost', 0.0)
    return total_cost

def _extract_paths_from_topology(src, dsts, topology_edges, G):
    """
    Given a set of edges forming a routing topology,
    extract the individual paths for each destination.
    """
    t_graph = nx.DiGraph()
    for u, v in topology_edges:
        if G.has_edge(u, v):
            t_graph.add_edge(u, v, **G[u][v])

    paths_map = {}
    for dst in dsts:
        if dst == src: continue
        path_segments = []
        try:
            # Shortest path in the extracted topology (usually unique if tree)
            # Unweighted is fine as topology is already optimized
            nodes = nx.shortest_path(t_graph, src, dst)
            for i in range(len(nodes)-1):
                u, v = nodes[i], nodes[i+1]
                path_segments.append([u, v, t_graph[u][v]])
        except (nx.NetworkXNoPath, KeyError):
            pass
        paths_map[dst] = path_segments
    return paths_map

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing focusing on Steiner Tree heuristics to minimize total cost.
    Eliminates cyclical paths and excessive detours by prioritizing cost-efficient trees.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Pre-processing: Copy and clean graph
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 1. Weight Calculation
    # Primary Goal: Minimize Cost.
    # Secondary Goal: Avoid extremely low throughput links.
    # Weight = Cost + (0.001 / Throughput)
    # This small penalty breaks ties in favor of speed but prevents cost inflation.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        data['steiner_weight'] = c + (0.001 / t_safe)
        data['pure_cost'] = c

    candidates = []

    # ---------------------------------------------------------
    # Strategy A: Greedy Steiner Tree (Balanced Weight)
    # ---------------------------------------------------------
    # Iteratively connects the closest remaining node to the tree.
    st_edges = set()
    st_nodes = {src}
    remaining = set(d for d in dsts if d != src and d in h)
    valid_st = True

    while remaining:
        path, target, _ = _dijkstra_multisource_path(h, st_nodes, remaining, 'steiner_weight')
        if not target:
            valid_st = False
            break

        for u, v in path:
            st_edges.add((u, v))
            st_nodes.add(v)

        remaining = remaining - st_nodes

    if valid_st and st_edges:
        candidates.append({
            'edges': st_edges,
            'cost': _calculate_topology_cost(st_edges, h),
            'type': 'steiner_balanced'
        })

    # ---------------------------------------------------------
    # Strategy B: Union of Shortest Paths (USP)
    # ---------------------------------------------------------
    # Provides a baseline for latency/directness.
    usp_edges = set()
    valid_usp = True
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(h, src, dst, weight='steiner_weight')
            for i in range(len(path)-1):
                usp_edges.add((path[i], path[i+1]))
        except nx.NetworkXNoPath:
            valid_usp = False
            break

    if valid_usp and usp_edges:
        # Avoid duplicate if USP found the same tree as Steiner
        if not candidates or usp_edges != candidates[0]['edges']:
            candidates.append({
                'edges': usp_edges,
                'cost': _calculate_topology_cost(usp_edges, h),
                'type': 'usp'
            })

    # ---------------------------------------------------------
    # Strategy C: Greedy Steiner Tree (Pure Cost)
    # ---------------------------------------------------------
    # Tries to find the absolute cheapest path ignoring throughput penalties.
    # Essential for cost minimization when throughput differences are negligible.
    co_edges = set()
    co_nodes = {src}
    remaining = set(d for d in dsts if d != src and d in h)
    valid_co = True

    while remaining:
        path, target, _ = _dijkstra_multisource_path(h, co_nodes, remaining, 'pure_cost')
        if not target:
            valid_co = False
            break
        for u, v in path:
            co_edges.add((u, v))
            co_nodes.add(v)
        remaining = remaining - co_nodes

    if valid_co and co_edges:
        # Check for duplicates
        is_dup = False
        for c in candidates:
            if c['edges'] == co_edges:
                is_dup = True
                break
        if not is_dup:
            candidates.append({
                'edges': co_edges,
                'cost': _calculate_topology_cost(co_edges, h),
                'type': 'steiner_pure_cost'
            })

    # ---------------------------------------------------------
    # Selection & Assignment
    # ---------------------------------------------------------

    if not candidates:
        return bc_topology

    # Sort candidates by total egress cost (primary optimization target)
    candidates.sort(key=lambda x: x['cost'])

    # Select the single best candidate.
    # We deliberately assign all partitions to the most cost-effective topology.
    # Splitting partitions across diverse paths often increases total egress cost significantly
    # for only marginal gains in transfer time, which violates the "minimize total cost" goal.
    best_candidate = candidates[0]

    final_paths = _extract_paths_from_topology(src, dsts, best_candidate['edges'], h)

    for i in range(num_partitions):
        for dst, path_segments in final_paths.items():
            if path_segments:
                bc_topology.set_dst_partition_paths(dst, i, path_segments)

    return bc_topology
