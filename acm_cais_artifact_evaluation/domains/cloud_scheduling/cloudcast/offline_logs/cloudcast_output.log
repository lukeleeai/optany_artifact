import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _calculate_topology_cost(edges, G):
    """Calculates total cost of a set of edges (multicast tree cost)."""
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def _build_candidate_from_paths(src, dsts, paths_map, G):
    """
    Constructs a candidate object from a map of destination -> node_path.
    Aggregates edges to calculate topology cost.
    """
    all_edges = set()
    valid = True
    formatted_paths = {}

    for dst in dsts:
        if dst == src:
            continue
        path = paths_map.get(dst)
        if not path:
            valid = False
            break

        # Convert node list to edge list with data
        path_edges_data = []
        for i in range(len(path) - 1):
            u, v = path[i], path[i+1]
            all_edges.add((u, v))
            if G.has_edge(u, v):
                path_edges_data.append([u, v, G[u][v]])
            else:
                valid = False
                break
        formatted_paths[dst] = path_edges_data

    if not valid:
        return None

    return {
        'edges': all_edges,
        'paths': formatted_paths,
        'cost': _calculate_topology_cost(all_edges, G)
    }

def search_algorithm(src, dsts, G, num_partitions):
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    # Create a working graph with computed weights
    h = G.copy()

    # Remove incoming edges to source to enforce rooted flow
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weight configuration
    # Cost is primary, but we add a small penalty for low throughput to avoid congestion.
    # 1 Gbps -> +0.001 penalty. 100 Gbps -> +0.00001 penalty.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t = max(t, 0.001) # Avoid div by zero

        # Primary weight: Cost + small throughput penalty
        data['opt_weight'] = c + (0.001 / t)

    candidates = []

    # Strategy A: Direct Shortest Paths (USP)
    # Baseline: Union of individual shortest paths. Good for latency.
    try:
        usp_paths = {}
        for dst in dsts:
            if dst != src:
                usp_paths[dst] = nx.shortest_path(h, src, dst, weight='opt_weight')

        cand = _build_candidate_from_paths(src, dsts, usp_paths, h)
        if cand:
            candidates.append(cand)
    except nx.NetworkXNoPath:
        pass

    # Strategy B: Hub-Based Routing (Star/Tree Topology)
    # Check every Destination (and Source) as a potential "Transit Hub".
    # This efficiently finds patterns like Src -> Hub -> [D1, D2, D3], leveraging shared egress.
    potential_hubs = set(dsts)
    potential_hubs.add(src)

    # Calculate shortest paths from all potential hubs to all other nodes once
    # This helps construct the "Hub -> Dst" leg quickly.
    # We only need paths from hubs that are reachable from src.

    for hub in potential_hubs:
        if hub not in h: continue

        try:
            # 1. Path Src -> Hub
            path_to_hub = []
            if hub != src:
                path_to_hub = nx.shortest_path(h, src, hub, weight='opt_weight')

            # 2. Paths Hub -> Destinations
            # Use single_source_dijkstra for efficiency
            length, paths_from_hub = nx.single_source_dijkstra(h, hub, weight='opt_weight')

            hub_paths = {}
            possible = True

            for dst in dsts:
                if dst == src: continue
                if dst == hub:
                    hub_paths[dst] = path_to_hub
                else:
                    if dst in paths_from_hub:
                        # Combine: Src -> ... -> Hub -> ... -> Dst
                        # Avoid duplicating 'hub' node in the join
                        p_from = paths_from_hub[dst]
                        full_path = path_to_hub + p_from[1:]
                        hub_paths[dst] = full_path
                    else:
                        possible = False
                        break

            if possible:
                cand = _build_candidate_from_paths(src, dsts, hub_paths, h)
                if cand:
                    candidates.append(cand)

        except nx.NetworkXNoPath:
            continue

    # Strategy C: Iterative Steiner Tree Heuristic
    # Standard approximation: Start with Src, greedily add closest Dst.
    # Run a few iterations with penalties to encourage diversity.

    penalty_iterations = min(3, num_partitions)
    edge_penalties = {}

    for _ in range(penalty_iterations + 1):
        # Apply penalties to weights
        for u, v, data in h.edges(data=True):
            p = edge_penalties.get((u, v), 1.0)
            data['iter_weight'] = data['opt_weight'] * p

        # Build Tree
        tree_nodes = {src}
        tree_edges = set()
        remaining = set(d for d in dsts if d != src and d in h)

        # Incremental growth
        while remaining:
            # Dijkstra from ANY node in current tree to ANY node in remaining
            pq = []
            for node in tree_nodes:
                heapq.heappush(pq, (0.0, node, [node]))

            visited = set()
            found_path = None
            found_target = None

            while pq:
                d, u, path = heapq.heappop(pq)
                if u in visited: continue
                visited.add(u)

                if u in remaining:
                    found_path = path
                    found_target = u
                    break

                if u in h:
                    for v, attr in h[u].items():
                        if v not in visited:
                            w = attr.get('iter_weight', 1.0)
                            heapq.heappush(pq, (d + w, v, path + [v]))

            if found_target:
                # Add path to tree
                for i in range(len(found_path)-1):
                    tree_edges.add((found_path[i], found_path[i+1]))
                    tree_nodes.add(found_path[i+1])
                remaining.remove(found_target)
            else:
                break # Cannot reach remaining nodes

        if not remaining and tree_edges:
            # Extract clean paths from the constructed tree
            st_graph = nx.DiGraph()
            for u, v in tree_edges:
                if h.has_edge(u, v):
                    st_graph.add_edge(u, v, **h[u][v])

            st_paths = {}
            try:
                for dst in dsts:
                    if dst != src:
                        st_paths[dst] = nx.shortest_path(st_graph, src, dst)

                cand = _build_candidate_from_paths(src, dsts, st_paths, h)
                if cand:
                    candidates.append(cand)
                    # Penalize edges for next iteration to find diverse paths
                    for u, v in cand['edges']:
                        edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5
            except nx.NetworkXNoPath:
                pass

    # Fallback if no candidates found
    if not candidates:
        fallback_paths = {}
        for dst in dsts:
            if dst != src:
                try:
                    fallback_paths[dst] = nx.shortest_path(G, src, dst, weight='cost')
                except:
                    pass
        if fallback_paths:
            cand = _build_candidate_from_paths(src, dsts, fallback_paths, G)
            if cand:
                candidates.append(cand)

    if not candidates:
        return bc_topology

    # Deduplicate candidates
    unique_candidates = []
    seen_edges = []
    for c in candidates:
        # Create a stable key for the edge set
        e_key = tuple(sorted(list(c['edges'])))
        if e_key not in seen_edges:
            seen_edges.append(e_key)
            unique_candidates.append(c)

    # Sort by Cost
    unique_candidates.sort(key=lambda x: x['cost'])

    # Filter for quality: Keep candidates within 15% of the best cost
    # This allows for multipath usage if costs are similar.
    best_cost = unique_candidates[0]['cost']
    limit_cost = best_cost * 1.15
    valid_candidates = [c for c in unique_candidates if c['cost'] <= limit_cost]

    # Limit to avoid excessive fragmentation, but ensure enough for partitions
    valid_candidates = valid_candidates[:min(len(valid_candidates), num_partitions, 5)]

    # Assign partitions Round Robin across valid candidates
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path_data in paths_map.items():
            bc_topology.set_dst_partition_paths(dst, i, path_data)

    return bc_topology
