import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _build_prim_arborescence(G, src, dsts, weight_attr='weight', noise_factor=0.0):
    """
    Constructs a Minimum Spanning Arborescence rooted at src targeting dsts.
    Strategy: Modified Prim's Algorithm / Dijkstra from Tree.

    Optimization Targets:
    1. Minimize Cumulative Egress Cost (Standard Prim behavior).
    2. Minimize Latency/Hops (Tie-breaking mechanism).

    The Priority Queue stores: (effective_weight, hop_depth, u, v, data)
    - effective_weight: Cost of the edge (with optional throughput penalty)
    - hop_depth: Tie-breaker. Prefers nodes closer to source to prevent long chains.
    """
    pq = []

    # Helper for noise injection
    def get_w(data):
        base = data.get(weight_attr, 0)
        if noise_factor > 0:
            # Perturb weight by +/- noise_factor%
            base *= random.uniform(1.0 - noise_factor, 1.0 + noise_factor)
        return base

    # Initialize with edges from Source
    # Source has hop_depth = 0
    visited = {src}
    tree_edges = []

    # Optimization: Use a set for fast lookup of required destinations
    required = set(dsts)
    if src in required:
        required.remove(src)

    # Push initial edges
    for v, data in G[src].items():
        w = get_w(data)
        # Tie-breaker: 0 hops from root
        heapq.heappush(pq, (w, 0, src, v, data))

    while pq and required:
        w, hops, u, v, data = heapq.heappop(pq)

        if v in visited:
            continue

        visited.add(v)
        tree_edges.append((u, v, data))

        if v in required:
            required.remove(v)

        # Expand from the newly added node v
        # Its children will have hop_depth = hops + 1
        for next_v, next_data in G[v].items():
            if next_v not in visited:
                next_w = get_w(next_data)
                heapq.heappush(pq, (next_w, hops + 1, v, next_v, next_data))

    # Construct the graph from tree edges to perform pruning
    T = nx.DiGraph()
    for u, v, data in tree_edges:
        T.add_edge(u, v, **data)

    # Pruning: Remove leaf nodes that are not destinations
    # This cleans up "exploration" paths that didn't reach a target
    keep_nodes = set(dsts)
    keep_nodes.add(src)

    changed = True
    while changed:
        changed = False
        # Identify leaves: out_degree 0, and not a destination
        leaves = [n for n in T.nodes() if T.out_degree(n) == 0]
        for leaf in leaves:
            if leaf not in keep_nodes:
                T.remove_node(leaf)
                changed = True

    return T

def _extract_paths(T, src, dsts):
    """
    Converts the tree topology into explicit paths for each destination.
    Returns: Dict[dst, List[List[u, v, data]]]
    """
    paths_map = {}

    # Since T is a tree rooted at src, there is exactly one path to each node
    # usage of nx.shortest_path on a tree is efficient O(V)
    try:
        all_paths = nx.single_source_shortest_path(T, src)
    except:
        all_paths = {}

    for dst in dsts:
        if dst == src: continue
        edges_list = []
        if dst in all_paths:
            nodes = all_paths[dst]
            for i in range(len(nodes) - 1):
                u, v = nodes[i], nodes[i+1]
                # Ensure we pass the edge data
                if T.has_edge(u, v):
                    edges_list.append([u, v, T[u][v]])
        paths_map[dst] = edges_list

    return paths_map

def _evaluate_candidate(paths_map):
    """
    Returns (total_cost, min_throughput) for a set of paths.
    Counts shared edges only once for cost.
    """
    total_cost = 0.0
    min_t = float('inf')
    used_edges = set()

    for dst, path in paths_map.items():
        for edge in path:
            u, v = edge[0], edge[1]
            data = edge[2]

            edge_key = (u, v)
            if edge_key not in used_edges:
                total_cost += data.get('cost', 0.0)
                used_edges.add(edge_key)

            t = data.get('throughput', 1.0)
            if t < min_t:
                min_t = t

    if min_t == float('inf'): min_t = 0.0
    return total_cost, min_t

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Key Improvements:
    1. Correct Cost Modeling: Optimizes for global tree cost (Shared Edges) rather than individual paths.
    2. Star Topology Preference: Uses hop-count as a tie-breaker to prevent unnecessary daisy-chaining
       when direct paths have equal cost (common in cloud pricing).
    3. Throughput Protection: Heavily penalizes edges < 1 Gbps to prevent bottlenecks.
    4. Robust Search: Generates a primary 'Clean' candidate and 'Noisy' alternatives to find
       structures where intra-region forwarding saves money.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Prepare Graph & Weights
    H = G.copy()
    # Remove incoming edges to source to enforce root
    to_remove = list(H.in_edges(src)) + list(nx.selfloop_edges(H))
    H.remove_edges_from(to_remove)

    # Define optimization weight
    # prim_weight = Cost + ThroughputPenalty
    for u, v, data in H.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)

        # Penalize low throughput heavily
        if t < 1.0:
            t_penalty = 1.0 / max(t, 0.001)  # High penalty
        else:
            t_penalty = 0.0001 / t  # Tie-breaker only

        data['prim_weight'] = c + t_penalty

    candidates = []

    # 2. Generate Candidate Topologies

    # Candidate A: Greedy MST (High Precision)
    # This finds the optimal cost structure, using hop-count to break ties (preferring Star).
    tree_a = _build_prim_arborescence(H, src, dsts, weight_attr='prim_weight', noise_factor=0.0)
    paths_a = _extract_paths(tree_a, src, dsts)
    cost_a, min_t_a = _evaluate_candidate(paths_a)
    candidates.append({
        'paths': paths_a, 'cost': cost_a, 'min_t': min_t_a, 'type': 'Greedy'
    })

    # Candidate B & C: Randomized MST (Exploration)
    # Explores alternative structures if local optima exist (e.g. specific relay hubs)
    for _ in range(2):
        tree_r = _build_prim_arborescence(H, src, dsts, weight_attr='prim_weight', noise_factor=0.15)
        paths_r = _extract_paths(tree_r, src, dsts)
        cost_r, min_t_r = _evaluate_candidate(paths_r)
        candidates.append({
            'paths': paths_r, 'cost': cost_r, 'min_t': min_t_r, 'type': 'Random'
        })

    # Candidate D: Union of Shortest Paths (Fallback)
    # Strictly minimizes latency/hops. Usually close to optimal cost in cloud due to pricing models.
    try:
        usp_graph = nx.DiGraph()
        for dst in dsts:
            if dst == src: continue
            # Use original weights? No, use prim_weight to avoid bad links
            path = nx.shortest_path(H, src, dst, weight='prim_weight')
            for i in range(len(path)-1):
                u, v = path[i], path[i+1]
                usp_graph.add_edge(u, v, **H[u][v])

        paths_usp = _extract_paths(usp_graph, src, dsts)
        cost_usp, min_t_usp = _evaluate_candidate(paths_usp)
        candidates.append({
            'paths': paths_usp, 'cost': cost_usp, 'min_t': min_t_usp, 'type': 'USP'
        })
    except nx.NetworkXNoPath:
        pass

    # 3. Selection Logic
    # Sort by Cost ascending.
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates
    # We want the cheapest, but if a slightly more expensive one has much better throughput, keep it.
    unique_candidates = []
    if candidates:
        best = candidates[0]
        unique_candidates.append(best)

        for cand in candidates[1:]:
            # Calculate cost difference percentage
            diff_pct = (cand['cost'] - best['cost']) / (best['cost'] + 1e-9)

            # If essentially same cost (< 0.1%) but better throughput, add it
            if diff_pct < 0.001 and cand['min_t'] > best['min_t']:
                unique_candidates.append(cand)
            # Or if slightly more expensive (< 3%) but fixes a bottleneck (> 2x throughput or > 2Gbps)
            elif diff_pct < 0.03 and cand['min_t'] > 2.0 and best['min_t'] < 2.0:
                unique_candidates.append(cand)

    # 4. Partition Assignment
    # If we have multiple good candidates, distribute partitions to balance load/risk
    final_pool = unique_candidates[:2] # Keep top 2 distinct strategies at most
    num_pool = len(final_pool)

    for i in range(num_partitions):
        # Round robin selection of topology
        selected = final_pool[i % num_pool]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
