import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Optimized to stop early as soon as any target is reached.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path from the target back to a source
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm.
    Focus:
    1. Enforce STRICT Tree structures (no cycles, in-degree=1) to minimize total egress cost.
    2. Use Steiner Tree heuristics to maximize edge sharing.
    3. Generate diverse trees for multipath utilization.
    4. Balance Cost vs Throughput with a weighted penalty.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()
    # Remove incoming edges to source to enforce rooted tree structure from source
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weight Formulation:
    # Primary: Egress Cost ($/GB).
    # Secondary: Throughput (Time/Instance Cost).
    # Heuristic: Cost + (0.001 / Throughput_Gbps)
    # This heavily penalizes very slow links (<0.1Gbps) but selects cheap links otherwise.
    routing_weight_attr = 'routing_weight'
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        # Weight Calculation
        data[routing_weight_attr] = c + (0.001 / t_safe)

    candidates = []

    # Helper to extract paths from a set of tree edges
    def extract_paths_from_tree(tree_edges):
        # Construct a graph from the tree edges to verify connectivity and extract paths
        t_graph = nx.DiGraph()
        edge_cost_sum = 0.0
        for u, v in tree_edges:
            if h.has_edge(u, v):
                data = h[u][v]
                t_graph.add_edge(u, v, **data)
                edge_cost_sum += data.get('cost', 0.0)

        paths_map = {}
        all_reachable = True

        # Calculate paths for each destination on this specific tree
        for d in dsts:
            if d == src: continue
            try:
                # On a tree, shortest path is unique and acyclic
                path_nodes = nx.shortest_path(t_graph, src, d)
                edge_list = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    edge_list.append([u, v, t_graph[u][v]])
                paths_map[d] = edge_list
            except (nx.NetworkXNoPath, KeyError):
                all_reachable = False
                break

        if all_reachable:
            return {
                'edges': tree_edges,
                'cost': edge_cost_sum,
                'paths': paths_map
            }
        return None

    # Strategy 1: Shortest Path Tree (SPT)
    # Optimizes for individual latency/cost, baseline candidate.
    try:
        pred, _ = nx.dijkstra_predecessor_and_distance(h, src, weight=routing_weight_attr)
        spt_edges = set()
        for d in dsts:
            if d == src: continue
            if d in pred:
                curr = d
                while curr != src:
                    parents = pred[curr]
                    if not parents: break
                    p = parents[0] # Pick one parent deterministically
                    spt_edges.add((p, curr))
                    curr = p

        cand = extract_paths_from_tree(spt_edges)
        if cand:
            candidates.append(cand)
    except Exception:
        pass

    # Strategy 2: Iterative Greedy Steiner Trees
    # Generate multiple diverse trees by penalizing edges used in previous trees.
    # This creates candidates for multipath routing.

    # Limit iterations based on partitions needed, but at least a few for diversity
    num_iterations = min(num_partitions, 5) if num_partitions > 0 else 1

    # We update the routing_weight_attr in 'h' as we go to force diversity
    for _ in range(num_iterations):
        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        while remaining:
            # Connect closest remaining destination to the current tree
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, routing_weight_attr)

            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            # Optimization: Remove any destinations covered by the new path
            # (path includes target, but might pass through others)
            nodes_in_path = set(v for u, v in path)
            nodes_in_path.add(target)
            remaining = remaining - nodes_in_path

        if not remaining:
            cand = extract_paths_from_tree(tree_edges)
            if cand:
                # Dedup
                is_dup = False
                for c in candidates:
                    if c['edges'] == cand['edges']:
                        is_dup = True
                        break

                if not is_dup:
                    candidates.append(cand)

                    # Penalize edges to force diversity in next iteration
                    for u, v in tree_edges:
                        curr_w = h[u][v].get(routing_weight_attr, 1.0)
                        h[u][v][routing_weight_attr] = curr_w * 2.0 # Significant penalty to force disjointness

    if not candidates:
        return bc_topology

    # 4. Candidate Selection
    # Sort by total tree cost
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Only use those within 10% of the best cost.
    # This prevents using very expensive paths just for the sake of multipathing.
    best_cost = candidates[0]['cost']
    cost_threshold = best_cost * 1.10
    valid_candidates = [c for c in candidates if c['cost'] <= cost_threshold]

    # 5. Partition Assignment (Round Robin)
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
