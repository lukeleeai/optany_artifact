        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _get_candidate_metrics(candidate_edges, G):
    """Calculates total cost and min throughput for a set of edges."""
    total_cost = 0.0
    min_throughput = float('inf')
    for u, v in candidate_edges:
        if not G.has_edge(u, v): continue
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    if min_throughput == float('inf'): min_throughput = 0.0
    return total_cost, min_throughput

def _build_topology_from_edges(G, edges, src, dsts):
    """
    Reconstructs paths from src to dsts given a set of edges.
    Returns metrics and the subgraph.
    """
    sub = nx.DiGraph()
    for u, v in edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    final_edges = set()

    # Verify reachability and extract minimal edges needed using shortest path on subgraph
    # This cleans up any dead ends or cycles introduced during heuristic generation
    try:
        for dst in dsts:
            if dst == src: continue
            path = nx.shortest_path(sub, src, dst)
            for i in range(len(path)-1):
                final_edges.add((path[i], path[i+1]))
    except (nx.NetworkXNoPath, Exception):
        return None

    c, t = _get_candidate_metrics(final_edges, G)
    return {
        'edges': final_edges,
        'cost': c,
        'min_throughput': t,
        'subgraph': sub
    }

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Iterative Steiner Tree Heuristic (SPH): Approximates the Minimum Cost Tree by
       greedily connecting closest destinations and zeroing out path weights.
       This promotes sharing edges (multicast advantage).
    2. Randomized Search: Runs SPH with noise to escape local optima.
    3. Union of Shortest Paths: Baseline strategy for latency-sensitive scenarios.

    Selection:
    Selects topology based on Total Cost + Time Penalty proxy.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Pruning
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 2. Metric Setup
    # Weight = Cost + Penalty for very low throughput.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)

        # Penalty:
        # 1. Soft inverse throughput penalty to prefer faster links among similar costs.
        # 2. Hard penalty for < 0.5 Gbps to avoid severe bottlenecks unless unavoidable.
        penalty = 0.0001 / max(t, 0.001)
        if t < 0.5:
            penalty += 10.0

        data['base_weight'] = c + penalty
        data['metric_cost'] = c

    candidates = []

    # ---------------------------------------------------------
    # Strategy A: Iterative Steiner Tree Heuristic (SPH)
    # ---------------------------------------------------------
    # We perform multiple iterations with randomized weights.
    # Iteration 0 is deterministic (greedy based on base_weight).

    iterations = 20

    for i in range(iterations):
        # Apply noise to explore different tree structures
        noise_factor = 0.0 if i == 0 else 0.25

        # Reset calculation weights
        for u, v, data in h.edges(data=True):
            w = data['base_weight']
            if noise_factor > 0:
                w *= random.uniform(1.0 - noise_factor, 1.0 + noise_factor)
            data['calc_weight'] = w

        tree_nodes = {src}
        tree_edges = set()
        remaining = set(target_dsts)

        possible = True

        # Grow tree
        while remaining:
            # Multi-source Dijkstra: find shortest path from ANY node in tree to ANY remaining node
            try:
                dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight='calc_weight')

                # Identify closest target
                best_target = None
                best_dist = float('inf')

                for r in remaining:
                    if r in dists and dists[r] < best_dist:
                        best_dist = dists[r]
                        best_target = r

                if best_target:
                    # Add path to tree
                    path = paths[best_target]
                    for k in range(len(path)-1):
                        u, v = path[k], path[k+1]
                        if (u, v) not in tree_edges:
                            tree_edges.add((u, v))
                            tree_nodes.add(v)
                            # Key Steiner step: Set weight to 0 for used edges
                            # This makes branching from this path "free" for other nodes
                            h[u][v]['calc_weight'] = 0.0

                        # Mark nodes as visited
                        if v in remaining:
                            remaining.remove(v)

                    # Cleanup: path might have visited other remaining nodes implicitly
                    for node in path:
                        if node in remaining:
                            remaining.remove(node)
                else:
                    possible = False
                    break
            except Exception:
                possible = False
                break

        if possible and tree_edges:
            cand = _build_topology_from_edges(h, tree_edges, src, target_dsts)
            if cand:
                candidates.append(cand)

    # ---------------------------------------------------------
    # Strategy B: Union of Shortest Paths (USP)
    # ---------------------------------------------------------
    # Fallback/Alternative: purely optimal paths for each destination individually.
    try:
        usp_edges = set()
        for dst in target_dsts:
            path = nx.shortest_path(h, src, dst, weight='base_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        cand_usp = _build_topology_from_edges(h, usp_edges, src, target_dsts)
        if cand_usp:
            candidates.append(cand_usp)
    except:
        pass

    # ---------------------------------------------------------
    # Selection
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    # Deduplicate candidates
    unique_candidates = []
    seen = set()
    for c in candidates:
        fs = frozenset(c['edges'])
        if fs not in seen:
            seen.add(fs)
            unique_candidates.append(c)

    # Scoring Function
    # Balance Cost vs Time.
    # Approx: 300GB volume.
    # Time (s) = 2400 / throughput(Gbps).
    # Instance Cost Proxy = Time * Factor.
    # We use a factor that makes 1 min of transfer time roughly equivalent to $0.10 cost impact.
    def score_candidate(c):
        throughput = max(c['min_throughput'], 0.001)
        est_time_seconds = 2400.0 / throughput

        # Instance cost proxy
        # If time is 960s (16 mins) -> ~$1.60 penalty
        # If time is 100s (1.6 mins) -> ~$0.16 penalty
        time_penalty = (est_time_seconds / 60.0) * 0.1

        return c['cost'] + time_penalty

    unique_candidates.sort(key=score_candidate)
    best_cand = unique_candidates[0]

    # ---------------------------------------------------------
    # Path Assignment
    # ---------------------------------------------------------
    subgraph = best_cand['subgraph']

    for dst in target_dsts:
        try:
            # Extract explicit path from the winning topology
            path_nodes = nx.shortest_path(subgraph, src, dst)
            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                # Use original graph data for the record
                edge_data = h[u][v]
                path_edges.append([u, v, edge_data])

            # Assign to all partitions (Single-Tree Multipath approach)
            # Partition splitting is only viable if we identify edge-disjoint trees
            # with similar costs, which is rare in cloud pricing topologies.
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)
        except Exception:
            pass

    return bc_topology
