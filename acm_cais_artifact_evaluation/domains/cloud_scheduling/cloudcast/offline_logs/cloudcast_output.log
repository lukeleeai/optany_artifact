import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_penalty(G, source, target, penalties):
    """
    Dijkstra's algorithm that incorporates a dynamic penalty map for edges.
    Used to find diverse paths by penalizing edges used in previous iterations.
    """
    # Priority Queue: (distance, node, parent)
    pq = [(0.0, source, None)]
    visited = {}  # node -> parent

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = parent

        if u == target:
            break

        for v, attr in G[u].items():
            if v in visited:
                continue

            # Base weight calculated from Cost + Throughput
            base_w = attr.get('metric_weight', 1.0)

            # Apply dynamic penalty if this edge was used in a previous path
            penalty = penalties.get((u, v), 1.0)
            weight = base_w * penalty

            heapq.heappush(pq, (d + weight, v, u))

    if target not in visited:
        return None

    # Reconstruct path from target back to source
    path = []
    curr = target
    while curr is not None:
        path.append(curr)
        curr = visited.get(curr)
        # Safety break if we hit source (since source's parent is None, loop ends naturally, but explicit check handles edge cases)
        if curr == source:
            path.append(curr)
            break

    return list(reversed(path))

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using Multi-Path Dijkstra.

    Improvements over previous version:
    1. Removes Steiner Tree logic which artificially inflated costs in overlay networks.
    2. Uses K-Shortest Paths (via iterative penalty) to find diverse routes per destination.
    3. Balances Cost vs Throughput using a composite weight metric.
    4. Filters paths to ensure only cost-competitive options are used for multipath.
    """
    # 1. Initialize Topology
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 2. Graph Pre-processing
    # Work on a copy to safely modify weights
    h = G.copy()

    # Remove incoming edges to source to enforce flow direction and simplify search
    to_remove = list(h.in_edges(src))
    h.remove_edges_from(to_remove)

    # 3. Weight Calculation
    # Objective: Minimize Cost ($/GB), with a penalty for low Throughput.
    # Metric = Cost + (Alpha / Throughput)
    # Alpha = 0.002 implies:
    #   1 Gbps  -> +0.002 cost penalty (negligible)
    #   10 Mbps -> +0.200 cost penalty (significant, avoids bottlenecks unless free)
    alpha = 0.002

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Safety lower bound for throughput to avoid division by zero
        t_safe = max(t, 0.0001)

        # Composite weight for pathfinding
        data['metric_weight'] = c + (alpha / t_safe)

        # Store raw cost for final filtering
        data['real_cost'] = c

    # 4. Routing per Destination
    # Treat each destination independently to optimize its specific routes.
    for dst in dsts:
        if dst == src:
            continue

        candidates = []
        found_paths_hashes = set()

        # Dictionary to store cumulative penalties for edges: (u, v) -> multiplier
        penalties = {}

        # Attempt to find up to 4 diverse paths per destination
        max_paths = min(num_partitions, 4) if num_partitions > 0 else 1

        for _ in range(max_paths):
            # Find best path given current penalties
            path_nodes = _dijkstra_penalty(h, src, dst, penalties)

            if not path_nodes or len(path_nodes) < 2:
                break

            # Convert node sequence to edge list with data
            edge_path = []
            path_cost = 0.0
            path_hash = []

            for i in range(len(path_nodes) - 1):
                u, v = path_nodes[i], path_nodes[i+1]
                if h.has_edge(u, v):
                    edge_data = h[u][v]
                    edge_path.append([u, v, edge_data])
                    path_cost += edge_data.get('real_cost', 0.0)
                    path_hash.append((u,v))

            # Check for duplicates using edge sequence hash
            path_tuple = tuple(path_hash)
            if path_tuple not in found_paths_hashes:
                candidates.append({
                    'path': edge_path,
                    'cost': path_cost,
                    'edges': path_tuple
                })
                found_paths_hashes.add(path_tuple)

                # Penalize edges in this path to encourage diversity in next iteration
                # Multiply weight by 2.0 to make reuse expensive
                for u, v in path_hash:
                    penalties[(u, v)] = penalties.get((u, v), 1.0) * 2.0
            else:
                # If we converge to a known path, stop searching
                break

        if not candidates:
            # Fallback (rare): No path found
            continue

        # 5. Path Selection & Filtering
        # We sort candidates by real cost.
        # We only use secondary paths if they are within a reasonable cost margin
        # of the best path (e.g., +25% or +$0.02).
        candidates.sort(key=lambda x: x['cost'])

        best_cost = candidates[0]['cost']
        cost_threshold = max(best_cost * 1.25, best_cost + 0.02)

        valid_paths = [p['path'] for p in candidates if p['cost'] <= cost_threshold]

        # 6. Partition Assignment
        # Round-robin assign partitions to the set of valid, cost-effective paths
        if valid_paths:
            num_valid = len(valid_paths)
            for i in range(num_partitions):
                # Round robin selection
                selected_path = valid_paths[i % num_valid]
                bc_topology.set_dst_partition_paths(dst, i, selected_path)

    return bc_topology
