import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Standard Dijkstra from a set of sources to the closest node in targets.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing.
    Strategy:
    1. Filter graph weights to heavily penalize low throughput (bottleneck avoidance).
    2. Construct candidates using USP and Steiner Heuristics prioritized by Cost.
    3. Select best topology strictly based on Cost to minimize egress fees.
    4. Only use multipath if alternative topologies are extremely cost-competitive.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Clean Graph: Remove incoming to src
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Weight Calculation
    # Primary goal: Minimize Cost.
    # Secondary constraint: Maintain good transfer time (avoid low throughput).
    # Approach: Use Cost as base weight. Apply step-function penalties for low BW.
    # This prevents the "0.005/T" linear distortion that favored expensive high-BW links.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)

        penalty = 0.0
        # Step penalties for bandwidth thresholds
        if t < 0.1: # < 100 Mbps
            penalty = 1.0
        elif t < 1.0: # < 1 Gbps
            penalty = 0.05

        # Base weight for path finding: Cost + BW Penalty + small hop epsilon
        data['calc_weight'] = c + penalty + 1e-6

    candidates = []

    # Helper to validate and add candidate
    def add_candidate(topology_edges, strategy_name):
        if not topology_edges:
            return

        cost = _get_topology_cost(topology_edges, h)

        # Deduplication
        for c in candidates:
            if c['edges'] == topology_edges:
                return

        candidates.append({
            'edges': topology_edges,
            'cost': cost,
            'strategy': strategy_name
        })

    unique_dsts = set(dsts) - {src}
    if not unique_dsts:
        return bc_topology

    # Strategy 1: Union of Shortest Paths (USP)
    # Often optimal for latency and competitive on cost for star topologies
    usp_edges = set()
    valid_usp = True
    for dst in unique_dsts:
        try:
            path = nx.shortest_path(h, src, dst, weight='calc_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
        except nx.NetworkXNoPath:
            valid_usp = False
            break
    if valid_usp:
        add_candidate(usp_edges, "USP")

    # Strategy 2: Iterative Steiner Tree
    # Finds shared segments to reduce egress cost
    edge_penalties = {}
    iterations = 2 # Limit iterations to avoid forcing bad high-cost paths

    for i in range(iterations):
        # Apply diversity penalties dynamically
        current_weights = {}
        for u, v, data in h.edges(data=True):
            w = data['calc_weight']
            p = edge_penalties.get((u, v), 1.0)
            current_weights[(u, v)] = w * p

        nx.set_edge_attributes(h, current_weights, 'temp_weight')

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(unique_dsts)

        # Steiner Heuristic: Prim-like growth
        while remaining:
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'temp_weight')
            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)
            remaining.remove(target)

        if not remaining: # Full tree found
            add_candidate(tree_edges, f"Steiner_{i}")

            # Penalize used edges for next iteration (Diversity)
            for u, v in tree_edges:
                edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.2

    if not candidates:
        return bc_topology

    # 3. Path Extraction
    for cand in candidates:
        st_graph = nx.DiGraph()
        for u, v in cand['edges']:
            if h.has_edge(u, v):
                st_graph.add_edge(u, v, **h[u][v])

        paths_map = {}
        valid_map = True
        for dst in unique_dsts:
            try:
                # Extract simple path in the tree
                path_nodes = nx.shortest_path(st_graph, src, dst)
                path_edges = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u, v, h[u][v]])
                paths_map[dst] = path_edges
            except nx.NetworkXNoPath:
                valid_map = False
                break

        cand['paths'] = paths_map
        cand['valid'] = valid_map

    # Filter invalid candidates
    candidates = [c for c in candidates if c.get('valid', False)]
    if not candidates:
        return bc_topology

    # 4. Selection
    # Sort by cost ascending
    candidates.sort(key=lambda x: x['cost'])

    best_cost = candidates[0]['cost']

    # Only allow multipath if costs are very similar.
    # Egress costs scale linearly; diversity is not worth significant cost increases.
    limit_cost = best_cost * 1.02

    final_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    # 5. Assignment
    num_final = len(final_candidates)
    for i in range(num_partitions):
        selected = final_candidates[i % num_final]
        for dst, path in selected['paths'].items():
            bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
