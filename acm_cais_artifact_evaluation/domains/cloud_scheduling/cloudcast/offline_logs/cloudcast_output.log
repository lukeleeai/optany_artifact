import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Weighted Graph: Uses strict Cost metric and a Balanced (Cost + Penalty) metric.
    2. Candidate Generation:
       - SPT-Cost: Shortest Path Tree minimizing purely edge costs (classic Dijkstra).
       - SPT-Balanced: Shortest Path Tree balancing cost and throughput.
       - Greedy-Steiner: Iteratively builds a tree by connecting the closest remaining destination.
         This maximizes edge sharing (multicast gain) which reduces total egress cost.

    Selection:
    Selects the topology that minimizes a composite score of Total Egress Cost + Instance Cost.
    Instance Cost is estimated via bottleneck throughput (Time = Vol / MinThroughput).
    """

    # 1. Graph Pruning & Weight Setup
    # Create working graph, removing incoming edges to Source to prevent meaningless loops
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    valid_dsts = [d for d in dsts if d != src and d in h]
    if not valid_dsts:
        return BroadCastTopology(src, dsts, num_partitions)

    # Hourly rate estimation for instance cost (approx $0.5/hr heuristic)
    # Used to weigh Time against Egress Cost.
    HOURLY_RATE = 0.5

    # Pre-calculate weights on edges
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001) # Avoid div by zero

        # Pure Cost (with tiny throughput bias to break ties deterministically)
        data['w_cost'] = c + (1e-6 / t_safe)

        # Balanced: Cost + estimated instance cost impact
        # We add a penalty equivalent to instance cost for keeping the pipe open
        # Factor 0.0005 roughly equates to paying for time on a standard instance
        data['w_balanced'] = c + (0.0005 / t_safe)

    candidates = []

    def build_candidate(edges, type_tag):
        """Constructs and scores a candidate topology from a set of edges."""
        if not edges: return None

        # Create subgraph to verify connectivity and calculate specific metrics
        sub = nx.DiGraph()
        sub.add_nodes_from([src] + valid_dsts)
        for u, v in edges:
            if h.has_edge(u, v):
                sub.add_edge(u, v, **h[u][v])

        # Calculate Total Tree Cost (Multicast Model)
        # Sum of costs of all unique edges in the topology
        tree_cost = sum(d.get('cost', 0.0) for u,v,d in sub.edges(data=True))

        # Calculate Bottleneck Throughput of the tree
        min_t = float('inf')
        for u, v, d in sub.edges(data=True):
            t = d.get('throughput', 1.0)
            if t < min_t: min_t = t
        if min_t == float('inf'): min_t = 0.001

        # Verify all dsts are reachable in this subgraph
        reachable = True
        try:
            # Check reachability via shortest path search
            paths = nx.shortest_path(sub, source=src)
            for d in valid_dsts:
                if d not in paths:
                    reachable = False
                    break
        except:
            reachable = False

        if not reachable:
            return None

        # Score = Egress Cost + Instance Penalty
        # Instance Penalty = (Factor / Throughput) representing time cost
        # We normalize the penalty to ensure Egress Cost dominates unless throughput is abysmal
        instance_penalty = (HOURLY_RATE / max(min_t, 0.001)) * 0.1
        score = tree_cost + instance_penalty

        return {
            'type': type_tag,
            'subgraph': sub,
            'cost': tree_cost,
            'min_t': min_t,
            'score': score
        }

    # ---------------------------------------------------------
    # Strategy 1: Shortest Path Tree (SPT) - Cost Focused
    # ---------------------------------------------------------
    # Minimizes the path cost for each destination individually.
    # Often optimal for sparse graphs or when direct paths exist.
    try:
        spt_edges = set()
        path_dict = nx.shortest_path(h, src, weight='w_cost')
        for d in valid_dsts:
            if d in path_dict:
                path = path_dict[d]
                for k in range(len(path)-1):
                    spt_edges.add((path[k], path[k+1]))

        cand = build_candidate(spt_edges, 'SPT-Cost')
        if cand: candidates.append(cand)
    except Exception:
        pass

    # ---------------------------------------------------------
    # Strategy 2: Shortest Path Tree (SPT) - Balanced
    # ---------------------------------------------------------
    # Uses the balanced weight to avoid extremely slow links that are slightly cheaper.
    try:
        spt_edges = set()
        path_dict = nx.shortest_path(h, src, weight='w_balanced')
        for d in valid_dsts:
            if d in path_dict:
                path = path_dict[d]
                for k in range(len(path)-1):
                    spt_edges.add((path[k], path[k+1]))

        cand = build_candidate(spt_edges, 'SPT-Balanced')
        if cand: candidates.append(cand)
    except Exception:
        pass

    # ---------------------------------------------------------
    # Strategy 3: Greedy Steiner Tree Approximation
    # ---------------------------------------------------------
    # Prim-like algorithm: Start with Src, iteratively connect closest Dst to the current Tree.
    # This explicitly attempts to share edges to reduce total tree cost.
    try:
        steiner_edges = set()
        tree_nodes = {src}
        remaining_dsts = set(valid_dsts)

        while remaining_dsts:
            # Find closest node in remaining_dsts to ANY node in tree_nodes
            # using multi-source Dijkstra on the cost-weighted graph
            dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight='w_cost')

            best_dst = None
            best_dist = float('inf')

            for d in remaining_dsts:
                if d in dists and dists[d] < best_dist:
                    best_dist = dists[d]
                    best_dst = d

            if best_dst:
                # Add the path to the tree
                p = paths[best_dst]
                for k in range(len(p)-1):
                    u, v = p[k], p[k+1]
                    steiner_edges.add((u, v))
                    tree_nodes.add(v)

                # Update remaining destinations
                remaining_dsts.remove(best_dst)
                # Remove any other dsts that are now part of the tree
                covered = remaining_dsts.intersection(tree_nodes)
                remaining_dsts -= covered
            else:
                # Cannot reach remaining nodes
                break

        if not remaining_dsts:
            cand = build_candidate(steiner_edges, 'Steiner')
            if cand: candidates.append(cand)

    except Exception:
        pass

    # ---------------------------------------------------------
    # Selection & Path Extraction
    # ---------------------------------------------------------
    if not candidates:
        return BroadCastTopology(src, dsts, num_partitions)

    # Sort candidates by the composite score (Cost + Instance Penalty)
    candidates.sort(key=lambda x: x['score'])
    best_cand = candidates[0]
    best_sub = best_cand['subgraph']

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Extract paths from the winning subgraph
    for dst in valid_dsts:
        try:
            # Shortest path on the tree subgraph is deterministic
            path_nodes = nx.shortest_path(best_sub, src, dst)
            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                # Retrieve original edge data
                edge_data = h[u][v]
                path_edges.append([u, v, edge_data])

            # Apply to all partitions
            # We use the same optimal tree for all partitions to maximize multicast edge efficiency
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

        except nx.NetworkXNoPath:
            # Fallback to direct routing on original graph if subgraph extraction fails
            try:
                p = nx.shortest_path(h, src, dst, weight='w_balanced')
                pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                for i in range(num_partitions):
                    bc_topology.set_dst_partition_paths(dst, i, pe)
            except:
                pass

    return bc_topology
