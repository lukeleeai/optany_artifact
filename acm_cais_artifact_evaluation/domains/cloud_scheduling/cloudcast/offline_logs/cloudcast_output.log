import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_find_closest_target(G, src, targets, zero_edges, weight_attr):
    """
    Runs Dijkstra from src to find the closest node in 'targets'.
    Edges present in 'zero_edges' are treated as having 0 weight,
    simulating 'free' travel over the existing tree structure.
    """
    # Priority Queue: (distance, node)
    pq = [(0.0, src)]

    # Track shortest distance and parent pointers for path reconstruction
    dists = {src: 0.0}
    parents = {src: None}

    closest_target = None

    while pq:
        d, u = heapq.heappop(pq)

        # Stale entry check
        if d > dists[u]:
            continue

        # If we reached a target that isn't the source (unless source is target)
        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            # Calculate effective weight
            # If edge is already in the tree, traversal is free (sunk cost)
            if (u, v) in zero_edges:
                w = 0.0
            else:
                w = attr.get(weight_attr, 1.0)

            new_dist = d + w

            if new_dist < dists.get(v, float('inf')):
                dists[v] = new_dist
                parents[v] = u
                heapq.heappush(pq, (new_dist, v))

    if closest_target:
        # Reconstruct path from src to closest_target
        path = []
        curr = closest_target
        while curr is not None:
            # We construct the list of nodes [Src, ..., Target]
            path.append(curr)
            curr = parents[curr]
        return list(reversed(path)), closest_target
    return [], None

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using Iterative Greedy Steiner Trees.

    Strategy:
    1. For each partition, build a Multicast Tree rooted at 'src'.
    2. Use a greedy approach: Start with {src}. Iteratively connect the "closest"
       unreached destination to the current tree.
    3. Crucially, "closest" is measured from 'src' where edges ALREADY in the tree
       have 0 cost. This implicitly minimizes the incremental cost of adding a node
       (Steiner approximation).
    4. Enforce diversity across partitions by penalizing edges used in previous trees.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning
    # Use a working copy of the graph
    h = G.copy()
    # Remove incoming edges to source to enforce rooted flow
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 2. Weight Configuration
    # Balance Cost (primary), Throughput (secondary), and Hop Count (latency/reliability)
    # alpha_bw: Coefficient for 1/throughput. 10Gbps -> +0.0005 cost
    # hop_penalty: Fixed cost per edge to prevent unnecessary long chains.
    ALPHA_BW = 0.005
    HOP_PENALTY = 0.001

    # Track global penalties for multipath diversity
    # (u, v) -> multiplicative penalty
    global_edge_penalties = {}

    # Set of unique destinations to reach
    unique_dsts = set(dsts)
    if src in unique_dsts:
        unique_dsts.remove(src)

    for partition_idx in range(num_partitions):
        # A. Prepare weights for this partition
        # Apply global penalties and compute composite weights
        for u, v, data in h.edges(data=True):
            cost = data.get('cost', 0.0)
            bw = data.get('throughput', 1.0)
            bw_safe = max(bw, 0.001)

            diversity_penalty = global_edge_penalties.get((u, v), 1.0)

            # Weight = (Cost * Penalty) + (Latency/BW Term) + Hop Cost
            # This ensures we pick cheap paths, but avoid congestion (BW) and loops (Hop)
            data['calc_weight'] = (cost * diversity_penalty) + (ALPHA_BW / bw_safe) + HOP_PENALTY

        # B. Build Steiner Tree
        tree_edges = set()
        reached_nodes = {src}
        unreached = unique_dsts.copy()

        # Remove unreachable nodes from target set to prevent infinite loops
        # (Assuming graph is generally connected, but safe check)
        unreached = {d for d in unreached if d in h}

        while unreached:
            # Find path from SRC to the closest unreached node.
            # Edges in 'tree_edges' are free.
            path_nodes, target = _dijkstra_find_closest_target(
                h, src, unreached, tree_edges, 'calc_weight'
            )

            if not target:
                break # Remaining nodes are disconnected

            # Add new path edges to the tree
            for i in range(len(path_nodes) - 1):
                u, v = path_nodes[i], path_nodes[i+1]
                tree_edges.add((u, v))
                reached_nodes.add(v)

            # Remove reached destinations
            # Note: The path might have hit 'target' but also passed through other unreached nodes?
            # Standard Dijkstra finds simple paths. We just mark the target as reached.
            # More aggressively, we can check if other unreached nodes are now in reached_nodes.
            unreached -= reached_nodes

        # C. Path Extraction
        # Build a temporary graph representing the tree to extract simple paths
        if not tree_edges and unique_dsts:
            # Failed to find any path
            continue

        tree_graph = nx.DiGraph()
        for u, v in tree_edges:
            if h.has_edge(u, v):
                tree_graph.add_edge(u, v, **h[u][v])

        for dst in unique_dsts:
            try:
                # In a tree rooted at src, there is exactly one path to dst
                path_nodes = nx.shortest_path(tree_graph, src, dst)
                path_list = []
                for i in range(len(path_nodes) - 1):
                    u, v = path_nodes[i], path_nodes[i+1]
                    # Format: [src, dst, edge_data]
                    path_list.append([u, v, h[u][v]])

                bc_topology.set_dst_partition_paths(dst, partition_idx, path_list)
            except (nx.NetworkXNoPath, KeyError):
                # If a node was unreachable in this partition (e.g. disjoint graph component)
                # We leave it as None or handle gracefully
                pass

        # D. Update Diversity Penalties
        # Exponentially increase penalty for edges used in this topology
        for u, v in tree_edges:
            curr = global_edge_penalties.get((u, v), 1.0)
            global_edge_penalties[(u, v)] = curr * 2.0

    return bc_topology
