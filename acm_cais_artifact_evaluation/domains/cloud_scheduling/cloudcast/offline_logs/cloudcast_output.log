import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_closest_target(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from any node in 'sources' to the closest node in 'targets'.
    Returns the path edges [(u,v), ...] and the target node reached.
    """
    pq = []
    # Initialize priority queue with all source nodes at distance 0
    for s in sources:
        heapq.heappush(pq, (0.0, s, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            heapq.heappush(pq, (d + w, v, u))

    if closest_target:
        # Reconstruct path backwards from target to the source set
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached one of the source nodes
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target

    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing.

    Improvements:
    1. Guarantees Cycle-Free Topologies (Trees) to avoid routing loops.
    2. Prioritizes Steiner Tree heuristics for minimizing Total Egress Cost.
    3. Uses Shortest Path Tree (SPT) as a baseline for latency-sensitive paths.
    4. Strict cost filtering to prevent expensive multipath routing.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning
    # Remove incoming edges to source to enforce rooted flow and prevent back-propagation
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 2. Weight Calculation
    # Primary objective: Minimize Cost.
    # Secondary objective: Maximize Throughput / Minimize Time.
    # Logic: weight = cost + (small_factor / throughput).
    # This prioritizes cheap edges, but breaks ties with higher throughput.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        # Factor 0.0005 implies 1GB cost equivalent to significant throughput drop
        data['std_weight'] = c + (0.0005 / t_safe)

    candidates = []

    # Strategy A: Single Source Shortest Path Tree (SPT)
    # Replaces "Union of Shortest Paths" to guarantee a Tree structure (no cycles).
    # Best for latency (transfer time).
    try:
        spt_preds = nx.single_source_dijkstra_path(h, src, weight='std_weight')
        spt_edges = set()
        valid_spt = True

        for dst in dsts:
            if dst == src: continue
            if dst not in spt_preds:
                valid_spt = False
                break
            path = spt_preds[dst]
            for i in range(len(path)-1):
                spt_edges.add((path[i], path[i+1]))

        if valid_spt and spt_edges:
            candidates.append({
                'type': 'SPT',
                'edges': spt_edges,
                'cost': _get_topology_cost(spt_edges, h)
            })
    except Exception:
        pass

    # Strategy B: Iterative Greedy Steiner Tree
    # Best for minimizing total egress cost by sharing edges.
    edge_penalties = {}
    iterations = 3  # Sufficient iterations to find diverse low-cost trees

    for i in range(iterations):
        # Calculate iteration-specific weights
        iter_weight_attr = f'weight_iter_{i}'
        for u, v, data in h.edges(data=True):
            base = data['std_weight']
            penalty = edge_penalties.get((u, v), 1.0)
            data[iter_weight_attr] = base * penalty

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        valid_tree = True

        while remaining:
            # Grow tree by connecting closest remaining destination
            path, target = _dijkstra_closest_target(h, tree_nodes, remaining, iter_weight_attr)

            if not target:
                valid_tree = False
                break

            # Add new edges to tree
            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

        if valid_tree and tree_edges:
            # Dedup
            is_dup = False
            for c in candidates:
                if c['edges'] == tree_edges:
                    is_dup = True
                    break

            if not is_dup:
                candidates.append({
                    'type': f'Steiner_{i}',
                    'edges': tree_edges,
                    'cost': _get_topology_cost(tree_edges, h)
                })

                # Apply penalty for next iteration to encourage diversity
                for u, v in tree_edges:
                    edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 3. Candidate Selection
    # Sort by total topology cost
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Only use multipath if costs are nearly identical.
    # Egress cost is dominant; 1% margin allows for tie-breaking but prevents
    # using expensive paths just for "diversity" which would spike total cost.
    best_cost = candidates[0]['cost']
    limit_cost = best_cost * 1.01
    valid_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    # 4. Path Extraction & Assignment
    # Convert edge sets back to path lists for the topology object
    final_topologies = []

    for cand in valid_candidates:
        # Build a temporary graph for the topology to extract paths easily
        topo_g = nx.DiGraph()
        for u, v in cand['edges']:
            if h.has_edge(u, v):
                topo_g.add_edge(u, v, **h[u][v])

        paths_map = {}
        valid_map = True
        for dst in dsts:
            if dst == src: continue
            try:
                # Since cand['edges'] form a Tree (or forest rooted at src),
                # there is exactly one path from src to dst.
                path_nodes = nx.shortest_path(topo_g, src, dst)
                path_edges = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u, v, h[u][v]])
                paths_map[dst] = path_edges
            except nx.NetworkXNoPath:
                valid_map = False
                break

        if valid_map:
            final_topologies.append(paths_map)

    if not final_topologies:
        return bc_topology

    # Round-robin assignment of partitions to valid optimal topologies
    num_topos = len(final_topologies)
    for i in range(num_partitions):
        selected_map = final_topologies[i % num_topos]
        for dst, path in selected_map.items():
            bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
