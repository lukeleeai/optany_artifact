from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from any node in 'sources' to the closest node in 'targets'.
    Returns (list of edges, target_node).
    """
    pq = []
    # Initialize PQ: dist 0 for all sources.
    # Use counter to break ties deterministically.
    counter = 0
    for node in sources:
        heapq.heappush(pq, (0.0, counter, node, None))
        counter += 1

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, _, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        if u in G:
            for v, attr in G[u].items():
                if v in visited:
                    continue
                w = attr.get(weight_attr, 1.0)
                new_dist = d + w
                heapq.heappush(pq, (new_dist, counter, v, u))
                counter += 1

    if closest_target:
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing.
    Improvements:
    1. Adjusted weights to prioritize cost significantly over throughput (solving expensive loop issues).
    2. Enforced strict DAG/Tree structures to avoid cycles.
    3. Multiple diverse candidate generation strategies including Strict Cost and Balanced.
    4. Smart partition assignment based on cost threshold.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 0. Preprocessing
    reachable_dsts = [d for d in dsts if d != src and d in G]
    if not reachable_dsts:
        return bc_topology

    h = G.copy()
    # Remove incoming edges to source to enforce root structure
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # 1. Weight Calculation
    # Primary Goal: Minimize Cost.
    # Secondary Goal: Maximize Throughput.
    # We use a very small penalty for low throughput to break ties or prefer faster links
    # only when cost difference is negligible.
    # Hop penalty (1e-5) discourages unnecessarily long chains.

    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t = max(t, 0.001)

        # 'strict_cost_weight': Pure cost, used for baseline cheap candidates
        data['strict_cost_weight'] = c + 1e-6

        # 'balanced_weight': Cost + scaled throughput penalty + hop penalty
        # 1 Gbps -> +0.0005 cost penalty.
        data['balanced_weight'] = c + (0.0005 / t) + 1e-5

    candidates = []

    # Strategy A: Union of Shortest Paths (Balanced)
    # Provides good trade-off between latency and cost
    usp_edges = set()
    usp_paths_map = {}

    for dst in reachable_dsts:
        try:
            path = nx.shortest_path(h, src, dst, weight='balanced_weight')
            path_edges = []
            for k in range(len(path)-1):
                u, v = path[k], path[k+1]
                usp_edges.add((u, v))
                path_edges.append([u, v, h[u][v]])
            usp_paths_map[dst] = path_edges
        except nx.NetworkXNoPath:
            pass

    if usp_edges:
        candidates.append({
            'edges': usp_edges,
            'cost': _get_topology_cost(usp_edges, h),
            'paths': usp_paths_map
        })

    # Strategy B: Union of Shortest Paths (Strict Cost)
    # The absolute cost floor (usually Star or near-Star topology)
    strict_edges = set()
    strict_paths_map = {}
    for dst in reachable_dsts:
        try:
            path = nx.shortest_path(h, src, dst, weight='strict_cost_weight')
            path_edges = []
            for k in range(len(path)-1):
                u, v = path[k], path[k+1]
                strict_edges.add((u, v))
                path_edges.append([u, v, h[u][v]])
            strict_paths_map[dst] = path_edges
        except nx.NetworkXNoPath:
            pass

    if strict_edges and strict_edges != usp_edges:
        candidates.append({
            'edges': strict_edges,
            'cost': _get_topology_cost(strict_edges, h),
            'paths': strict_paths_map
        })

    # Strategy C: Iterative Steiner Tree Heuristics
    # Iteratively build trees, penalizing used edges to find diverse paths.

    edge_penalties = {}
    steiner_iterations = min(num_partitions, 3)

    for i in range(steiner_iterations):
        # Update weights with penalties
        for u, v, data in h.edges(data=True):
            base = data['balanced_weight']
            pen = edge_penalties.get((u, v), 1.0)
            data['calc_weight'] = base * pen

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(reachable_dsts)

        while remaining:
            # Connect closest remaining node to the tree
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')

            if not target:
                break

            for u, v in path:
                if (u,v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            # Remove target and any other reached nodes from remaining
            if target in remaining:
                remaining.remove(target)
            for u, v in path:
                if v in remaining:
                    remaining.remove(v)

        if not tree_edges:
            continue

        # Extract paths from this tree
        st_graph = nx.DiGraph()
        for u, v in tree_edges:
            if h.has_edge(u, v):
                st_graph.add_edge(u, v, **h[u][v])

        paths_map = {}
        for dst in reachable_dsts:
            try:
                # Tree structure guarantees unique path
                path_nodes = nx.shortest_path(st_graph, src, dst)
                path_edges = []
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u, v, h[u][v]])
                paths_map[dst] = path_edges
            except nx.NetworkXNoPath:
                # Fallback to direct path if tree construction missed a node (edge case)
                try:
                    p = nx.shortest_path(h, src, dst, weight='balanced_weight')
                    pe = [[p[k], p[k+1], h[p[k]][p[k+1]]] for k in range(len(p)-1)]
                    paths_map[dst] = pe
                except:
                    pass

        # Check dupes
        is_dup = False
        for c in candidates:
            if c['edges'] == tree_edges:
                is_dup = True
                break

        if not is_dup:
            candidates.append({
                'edges': tree_edges,
                'cost': _get_topology_cost(tree_edges, h),
                'paths': paths_map
            })

            # Update penalties for next iteration
            for u, v in tree_edges:
                edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 4. Selection & Assignment
    # Sort candidates by cost
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Consider those within 15% of the best cost for multipath diversity
    best_cost = candidates[0]['cost']
    cost_threshold = best_cost * 1.15

    valid_candidates = [c for c in candidates if c['cost'] <= cost_threshold]

    # Assign partitions round-robin among valid candidates
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        cand = valid_candidates[i % num_valid]
        c_paths = cand['paths']

        for dst in reachable_dsts:
            if dst in c_paths:
                bc_topology.set_dst_partition_paths(dst, i, c_paths[dst])

    return bc_topology
