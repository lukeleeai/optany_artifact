def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing algorithm using Iterative Shortest Path Trees (SPT).

    This approach addresses previous issues with cyclic paths and high transfer times by:
    1. Using Dijkstra's algorithm to ensure loop-free, optimal paths from source.
    2. Employing a composite weight function (Cost + Alpha/Throughput) to minimize
       total cost (Egress + Instance) and avoid slow links.
    3. Generating diverse paths across partitions by penalizing edges used in
       previous iterations, maximizing bandwidth utilization.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning
    # Prune incoming edges to source to strictly enforce it as root.
    # Remove self-loops to ensure acyclicity.
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Initialize edge penalties for multipath generation
    # Key: (u, v), Value: penalty multiplier
    edge_penalties = {}

    # Weight Tuning Configuration
    # THROUGHPUT_ALPHA: Converts throughput penalty to cost equivalent ($).
    # A value of 0.05 implies a 1Gbps link adds a virtual cost of $0.05/GB.
    # Lower throughput -> Higher penalty. This prevents selecting very slow links
    # that inflate instance costs, while still prioritizing cheap egress.
    THROUGHPUT_ALPHA = 0.05

    # HOP_PENALTY: Small fixed cost per hop to prefer shorter paths when costs are equal,
    # reducing latency accumulation.
    HOP_PENALTY = 0.0001

    for i in range(num_partitions):
        # 2. Build Weighted Graph for Current Partition
        weighted_G = nx.DiGraph()

        for u, v, data in h.edges(data=True):
            cost = data.get('cost', 0.1)
            throughput = data.get('throughput', 1.0)

            # Prevent division by zero and cap extreme penalties
            safe_throughput = max(throughput, 0.001)

            # Composite Weight Calculation
            base_weight = cost + (THROUGHPUT_ALPHA / safe_throughput) + HOP_PENALTY

            # Apply dynamic penalty from previous partitions
            penalty = edge_penalties.get((u, v), 1.0)
            final_weight = base_weight * penalty

            weighted_G.add_edge(u, v, weight=final_weight, **data)

        # 3. Compute Shortest Path Tree (SPT)
        # Using Dijkstra guarantees the path to every node is loop-free and optimal
        # with respect to the defined weight function.
        try:
            # paths_dict: {dst_node: [node_a, node_b, ...]}
            paths_dict = nx.single_source_dijkstra_path(weighted_G, src, weight='weight')
        except Exception:
            paths_dict = {}

        # 4. Extract Paths and Update Penalties
        edges_used_in_this_partition = set()

        for dst in dsts:
            if dst == src:
                continue

            path_nodes = paths_dict.get(dst)
            edge_list = []

            if path_nodes:
                # Reconstruct edge list from node sequence
                for k in range(len(path_nodes) - 1):
                    u_node = path_nodes[k]
                    v_node = path_nodes[k+1]

                    if h.has_edge(u_node, v_node):
                        edge_data = h[u_node][v_node]
                        edge_list.append([u_node, v_node, edge_data])
                        edges_used_in_this_partition.add((u_node, v_node))
            else:
                # Fallback: If destination is not reachable in cleaned graph (rare),
                # try shortest path on original graph to ensure connectivity.
                try:
                    fallback_nodes = nx.shortest_path(G, src, dst)
                    for k in range(len(fallback_nodes) - 1):
                        u_f, v_f = fallback_nodes[k], fallback_nodes[k+1]
                        edge_list.append([u_f, v_f, G[u_f][v_f]])
                except nx.NetworkXNoPath:
                    edge_list = [] # Destination truly unreachable

            bc_topology.set_dst_partition_paths(dst, i, edge_list)

        # 5. Penalize Used Edges
        # Increase the effective weight of edges used in this partition.
        # This encourages the algorithm to find alternative, diverse paths for the
        # next partition, utilizing available bandwidth across different routes.
        # A factor of 1.5 allows reusing efficient edges but encourages diversity.
        for u, v in edges_used_in_this_partition:
            current_p = edge_penalties.get((u, v), 1.0)
            edge_penalties[(u, v)] = current_p * 1.5

    return bc_topology
