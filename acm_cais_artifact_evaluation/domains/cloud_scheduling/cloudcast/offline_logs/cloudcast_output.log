import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Returns (path_of_nodes, target_node).
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                # Reached a source node
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_cost(edges, G):
    total = 0.0
    for u, v in edges:
        total += G[u][v].get('cost', 0.0)
    return total

def _extract_tree_paths(src, dsts, tree_edges, G):
    """
    Extracts explicit paths from a set of tree edges rooted at src.
    Uses BFS from src to ensure paths strictly follow the tree structure (Arborescence),
    guaranteeing no cycles or back-loops.
    """
    # Build adjacency list for the tree subgraph
    adj = {u: [] for u, v in tree_edges}
    for u, v in tree_edges:
        if u not in adj: adj[u] = []
        adj[u].append(v)

    # BFS to build parent map
    q = [src]
    parents = {src: None}

    while q:
        u = q.pop(0)
        if u in adj:
            for v in adj[u]:
                if v not in parents:
                    parents[v] = u
                    q.append(v)

    paths_map = {}
    for dst in dsts:
        if dst == src:
            continue

        if dst not in parents:
            # Destination not reachable in this specific topology candidate
            paths_map[dst] = []
            continue

        # Reconstruct path by backtracking from dst to src
        path_segments = []
        curr = dst
        while curr != src:
            par = parents.get(curr)
            if par is None:
                # Should not happen if reachable, but safety check
                break

            # Get edge data from original graph
            if G.has_edge(par, curr):
                edge_data = G[par][curr]
                path_segments.append([par, curr, edge_data])
            else:
                # Fallback (rare inconsistency)
                path_segments.append([par, curr, {}])
            curr = par

        paths_map[dst] = list(reversed(path_segments))

    return paths_map

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using diverse Steiner Tree heuristics.

    Improvements:
    1. Generates multiple candidate topologies favoring either pure cost or balanced performance.
    2. Enforces strict tree structures (Arborescence) to eliminate routing loops and reduce egress waste.
    3. Selects diverse candidates for partitions to maximize multipath throughput.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleaning & Weighting
    h = G.copy()
    # Remove incoming edges to source to enforce rooted flow
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate composite weights
    # Cost is primary ($/GB). Throughput affects time.
    # We use two weight profiles:
    # A. Cost Focused: cost + small penalty for very slow links.
    # B. Performance Focused: cost + moderate penalty for throughput (favors "wider" pipes).
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Avoid div by zero
        t_safe = max(t, 0.001)

        # 1Gbps -> +0.005 cost. 100Mbps -> +0.05 cost.
        data['cost_weight'] = c + (0.005 / t_safe)

        # 1Gbps -> +0.05 cost. 100Mbps -> +0.5 cost. (Heavier penalty favors high BW)
        data['perf_weight'] = c + (0.05 / t_safe)

    candidates = []

    # Define generation strategies
    strategies = [
        # Minimize cost (primary goal)
        {'weight_attr': 'cost_weight', 'iterations': 3, 'penalty_factor': 1.3},
        # Balance throughput (secondary goal)
        {'weight_attr': 'perf_weight', 'iterations': 2, 'penalty_factor': 1.3}
    ]

    # Global penalties to force diversity across strategies/iterations
    global_edge_penalties = {}

    for strat in strategies:
        weight_attr = strat['weight_attr']

        for _ in range(strat['iterations']):
            # Apply dynamic penalties
            for u, v, data in h.edges(data=True):
                base = data[weight_attr]
                p = global_edge_penalties.get((u, v), 1.0)
                data['calc_weight'] = base * p

            # Steiner Tree Heuristic (Prim-like growth)
            tree_edges = set()
            tree_nodes = {src}
            remaining = set(d for d in dsts if d != src and d in h)

            while remaining:
                # Connect closest remaining target to the existing tree
                path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')

                if not target:
                    break

                # Add path edges to tree
                for u, v in path:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

                # Update remaining set
                remaining = remaining - tree_nodes

            if not tree_edges:
                continue

            # Check for duplicate topology (edge set equality)
            is_dup = False
            for c in candidates:
                if c['edges'] == tree_edges:
                    is_dup = True
                    break

            if not is_dup:
                # Extract clean paths using BFS on the tree edges
                # This ensures valid routing without loops
                paths_map = _extract_tree_paths(src, dsts, tree_edges, h)

                # Verify basic connectivity
                valid_dsts = sum(1 for d in dsts if d != src and len(paths_map.get(d, [])) > 0)
                if valid_dsts > 0:
                    candidates.append({
                        'edges': tree_edges,
                        'paths': paths_map,
                        'cost': _get_topology_cost(tree_edges, h)
                    })

                    # Update global penalties to encourage different edges next time
                    for u, v in tree_edges:
                        global_edge_penalties[(u, v)] = global_edge_penalties.get((u, v), 1.0) * strat['penalty_factor']

    # Strategy C: Union of Shortest Paths (USP) Baseline
    # Good for low latency, added as a candidate if structurally sound
    usp_edges = set()
    for dst in dsts:
        if dst == src: continue
        try:
            # Use cost_weight for USP
            p = nx.shortest_path(h, src, dst, weight='cost_weight')
            for i in range(len(p)-1):
                usp_edges.add((p[i], p[i+1]))
        except nx.NetworkXNoPath:
            pass

    if usp_edges:
        is_dup = False
        for c in candidates:
            if c['edges'] == usp_edges:
                is_dup = True; break
        if not is_dup:
            # Must extract via BFS to ensure it behaves as a tree (even if graph is DAG)
            usp_paths = _extract_tree_paths(src, dsts, usp_edges, h)
            candidates.append({
                'edges': usp_edges,
                'paths': usp_paths,
                'cost': _get_topology_cost(usp_edges, h)
            })

    if not candidates:
        return bc_topology

    # 4. Candidate Selection
    # Sort by cost ascending
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: keep those within 10% of the best cost.
    # This prevents using very expensive "high performance" paths unless they are cost-competitive.
    best_cost = candidates[0]['cost']
    limit_cost = best_cost * 1.10
    valid_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    # 5. Partition Assignment
    # Round-robin among valid candidates to utilize multipath bandwidth
    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]
        paths_map = selected['paths']

        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
