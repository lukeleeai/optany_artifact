import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds shortest path from any node in 'sources' to the closest node in 'targets'.
    Returns (path_edges, target_node).
    """
    pq = []
    entry_count = 0
    # Initialize with all source nodes at distance 0
    for node in sources:
        heapq.heappush(pq, (0.0, entry_count, node, None))
        entry_count += 1

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, _, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, entry_count, v, u))
            entry_count += 1

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info: break
            _, par = dist_info
            if par is None:
                # Root of this path segment (a node in sources)
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _extract_tree_paths(G_sub, src, dsts):
    """
    Extracts explicit paths from src to all dsts using Dijkstra on the subgraph.
    This guarantees loop-free paths consistent with the tree structure.
    """
    # Dijkstra on subgraph to find predecessors
    pq = [(0.0, src)]
    visited = {src: (0.0, None)}

    while pq:
        d, u = heapq.heappop(pq)

        if d > visited[u][0]:
            continue

        for v in G_sub[u]:
            # Use unit weight or original weight?
            # Subgraph should ideally be a tree/DAG.
            # We use small weights to prefer fewer hops if cycles exist,
            # but structurally G_sub from Steiner should be a tree.
            weight = G_sub[u][v].get('calc_weight', 1.0)
            new_dist = d + weight

            if v not in visited or new_dist < visited[v][0]:
                visited[v] = (new_dist, u)
                heapq.heappush(pq, (new_dist, v))

    paths_map = {}
    for dst in dsts:
        if dst == src: continue
        if dst not in visited:
            paths_map[dst] = None # Unreachable in subgraph
            continue

        # Reconstruct
        path_edges = []
        curr = dst
        while curr != src:
            parent = visited[curr][1]
            if parent is None: break # Should not happen if curr != src and visited
            # Retrieve original edge data
            edge_data = G_sub[parent][curr]
            path_edges.append([parent, curr, edge_data])
            curr = parent
        paths_map[dst] = list(reversed(path_edges))

    return paths_map

def _get_candidate_metrics(candidate_edges, G):
    """Calculates total cost and min throughput for a set of edges."""
    total_cost = 0.0
    min_throughput = float('inf')
    for u, v in candidate_edges:
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    return total_cost, min_throughput

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Key Strategies:
    1. Steiner Tree Heuristic (Shortest Path Heuristic): Builds a shared multicast tree
       to minimize total egress cost.
    2. Robust Path Extraction: Uses BFS/Dijkstra on the generated topology to ensure
       loop-free, valid paths for every destination.
    3. Multi-start Randomization: Runs the heuristic multiple times with weight perturbations
       to escape local optima.
    4. Cost Prioritization: Heavily favors cost, using throughput only as a validity constraint
       and tie-breaker.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune incoming edges to source to enforce rooted directionality
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # Weight Configuration
    # We use a very small epsilon for throughput to allow cost to dominate completely,
    # preventing "expensive shortcuts" for minor bandwidth gains.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001)
        # Primary weight: Cost. Tie-breaker: 1/throughput.
        data['base_weight'] = c + (1e-6 / t_safe)

    candidates = []

    # ---------------------------------------------------------
    # Strategy 1: Union of Shortest Paths (Baseline)
    # ---------------------------------------------------------
    usp_edges = set()
    try:
        for dst in target_dsts:
            path = nx.shortest_path(h, src, dst, weight='base_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))

        c_cost, c_min_t = _get_candidate_metrics(usp_edges, h)
        candidates.append({
            'edges': usp_edges,
            'cost': c_cost,
            'min_throughput': c_min_t,
            'type': 'USP'
        })
    except nx.NetworkXNoPath:
        pass

    # ---------------------------------------------------------
    # Strategy 2: Randomized Steiner Tree Heuristic
    # ---------------------------------------------------------
    # Run iterations with varying noise to find lower cost shared trees
    iterations = 10

    for i in range(iterations):
        # Apply noise.
        # Iteration 0 is clean (deterministic greedy).
        # Others have +/- 20% noise to explore alternate structures.
        noise_factor = 0.0 if i == 0 else 0.2

        for u, v, data in h.edges(data=True):
            noise = random.uniform(1.0 - noise_factor, 1.0 + noise_factor)
            data['calc_weight'] = data['base_weight'] * noise

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(target_dsts)

        # Greedy construction: Connect closest remaining destination to the current tree
        while remaining:
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')

            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

        if not tree_edges:
            continue

        c_cost, c_min_t = _get_candidate_metrics(tree_edges, h)
        candidates.append({
            'edges': tree_edges,
            'cost': c_cost,
            'min_throughput': c_min_t,
            'type': 'Steiner'
        })

    if not candidates:
        # Fallback: Just use direct edges if everything failed (unlikely)
        return bc_topology

    # ---------------------------------------------------------
    # Candidate Selection & Path Construction
    # ---------------------------------------------------------

    # Sort by Cost (Ascending), then throughput (Descending)
    # We permit low throughput only if cost is significantly better,
    # but filter broken links (<0.1Gbps)
    valid_candidates = [c for c in candidates if c['min_throughput'] > 0.05]
    if not valid_candidates:
        valid_candidates = candidates

    valid_candidates.sort(key=lambda x: (x['cost'], -x['min_throughput']))

    # Select best candidate
    best_cand = valid_candidates[0]

    # Multipath Check:
    # If the best candidate has a serious bottleneck (< 1.0 Gbps) AND
    # a second candidate exists with slightly higher cost but much better throughput.
    final_selections = [best_cand]

    if best_cand['min_throughput'] < 1.0 and len(valid_candidates) > 1:
        alt = valid_candidates[1]
        cost_increase = (alt['cost'] - best_cand['cost']) / (best_cand['cost'] + 1e-9)
        if cost_increase < 0.10: # Willing to pay 10% more to fix a bottleneck
            final_selections.append(alt)

    # ---------------------------------------------------------
    # Final Topology Assignment
    # ---------------------------------------------------------

    num_selections = len(final_selections)

    for i in range(num_partitions):
        cand = final_selections[i % num_selections]

        # Build subgraph for this candidate to ensure we extract exact tree paths
        st_graph = nx.DiGraph()
        for u, v in cand['edges']:
            # Copy edge data and calc_weight for extraction logic
            data = h[u][v].copy()
            st_graph.add_edge(u, v, **data)

        # Extract paths using Dijkstra on the subgraph rooted at Src
        # This prevents cycles and ensures the path follows the tree structure
        paths_map = _extract_tree_paths(st_graph, src, dsts)

        for dst, path in paths_map.items():
            if path is None:
                # Fallback to global shortest path if tree construction missed a node (should not happen)
                try:
                    p_nodes = nx.shortest_path(h, src, dst, weight='base_weight')
                    fallback_path = []
                    for k in range(len(p_nodes)-1):
                        fallback_path.append([p_nodes[k], p_nodes[k+1], h[p_nodes[k]][p_nodes[k+1]]])
                    bc_topology.set_dst_partition_paths(dst, i, fallback_path)
                except nx.NetworkXNoPath:
                    pass
            else:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
