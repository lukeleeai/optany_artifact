import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _calculate_metrics(edges_collection, G):
    """Calculates total cost and min throughput for a collection of edges."""
    total_cost = 0.0
    min_throughput = float('inf')
    for u, v in edges_collection:
        if not G.has_edge(u, v): continue
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 0.0)
        if t < min_throughput:
            min_throughput = t
    if min_throughput == float('inf'): min_throughput = 0.0
    return total_cost, min_throughput

def _reconstruct_topology_and_extract_paths(G, tree_edges, src, dsts):
    """
    Given a set of edges (tree/dag), reconstructs the subgraph and
    extracts explicit paths for all destinations.
    """
    sub = nx.DiGraph()
    for u, v in tree_edges:
        if G.has_edge(u, v):
            sub.add_edge(u, v, **G[u][v])

    paths_map = {}
    valid = True

    # Using unweighted BFS/Shortest Path on the subgraph (topology is fixed)
    for dst in dsts:
        try:
            path_nodes = nx.shortest_path(sub, src, dst)
            path_segments = []
            for i in range(len(path_nodes)-1):
                u, v = path_nodes[i], path_nodes[i+1]
                path_segments.append([u, v, sub[u][v]])
            paths_map[dst] = path_segments
        except (nx.NetworkXNoPath, Exception):
            valid = False
            break

    if not valid:
        return None

    c, t = _calculate_metrics(tree_edges, G)
    return {
        'paths': paths_map,
        'cost': c,
        'min_throughput': t,
        'subgraph': sub
    }

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategies:
    1. Weighted Graph optimization: Balances Cost vs Throughput with a higher penalty
       for low throughput to minimize instance costs/latency.
    2. Union of Shortest Paths (USP): Baseline efficiency.
    3. Exhaustive Hub-and-Spoke: Checks all nodes as potential hubs to find low-cost star topologies.
    4. Randomized Greedy Steiner: Iteratively builds trees to find cost-optimal shared segments.

    Metric:
    Minimizes [Edge Cost + (Time Penalty / Throughput)].
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune graph: remove back-edges to src and self-loops
    h = G.copy()
    h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    target_dsts = [d for d in dsts if d != src and d in h]
    if not target_dsts:
        return bc_topology

    # 1. Weight Configuration
    # We apply a significant penalty to low throughput links.
    # Cost is roughly 0.02-0.12 $/GB.
    # Time penalty constant 0.01 implies:
    # 10 Gbps -> +0.001 (negligible)
    # 1 Gbps  -> +0.010 (significant, comparable to edge cost)
    # 0.1 Gbps -> +0.100 (prohibitive)
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = max(data.get('throughput', 1.0), 0.001)
        data['opt_weight'] = c + (0.01 / t)
        data['base_cost'] = c

    candidates = []

    def register_candidate(edges, tag):
        if not edges: return
        cand = _reconstruct_topology_and_extract_paths(h, edges, src, target_dsts)
        if cand:
            cand['type'] = tag
            candidates.append(cand)

    # ---------------------------------------------------------
    # Strategy A: Union of Shortest Paths (USP)
    # ---------------------------------------------------------
    usp_edges = set()
    try:
        for dst in target_dsts:
            path = nx.shortest_path(h, src, dst, weight='opt_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
        register_candidate(usp_edges, 'USP')
    except nx.NetworkXNoPath:
        pass

    # ---------------------------------------------------------
    # Strategy B: Exhaustive Hub-and-Spoke
    # ---------------------------------------------------------
    # Check every node as a hub.
    nodes = list(h.nodes())
    for hub in nodes:
        if hub == src: continue

        try:
            # Path Src -> Hub
            path_to_hub = nx.shortest_path(h, src, hub, weight='opt_weight')
            hub_edges = set()
            for k in range(len(path_to_hub)-1):
                hub_edges.add((path_to_hub[k], path_to_hub[k+1]))

            # Hub -> Dsts
            possible = True
            for dst in target_dsts:
                if dst == hub: continue
                p = nx.shortest_path(h, hub, dst, weight='opt_weight')
                for k in range(len(p)-1):
                    hub_edges.add((p[k], p[k+1]))

            if possible:
                register_candidate(hub_edges, 'Hub')
        except nx.NetworkXNoPath:
            continue

    # ---------------------------------------------------------
    # Strategy C: Randomized Greedy Steiner
    # ---------------------------------------------------------
    # Run multiple iterations with weight noise to explore topology space
    iterations = 10
    for i in range(iterations):
        noise = 0.2 if i > 0 else 0.0

        # Temporary weights
        for u, v, data in h.edges(data=True):
            w = data['opt_weight']
            if noise > 0:
                data['calc_weight'] = w * random.uniform(1.0 - noise, 1.0 + noise)
            else:
                data['calc_weight'] = w

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(target_dsts)
        valid_tree = True

        while remaining:
            try:
                # Find closest remaining destination to the current tree
                # multi_source_dijkstra finds shortest path from any node in sources
                dists, paths = nx.multi_source_dijkstra(h, sources=list(tree_nodes), weight='calc_weight')

                best_dst = None
                best_dist = float('inf')

                for r in remaining:
                    if r in dists and dists[r] < best_dist:
                        best_dist = dists[r]
                        best_dst = r

                if best_dst:
                    path = paths[best_dst]
                    for k in range(len(path)-1):
                        u, v = path[k], path[k+1]
                        tree_edges.add((u, v))
                        tree_nodes.add(v)
                        # Remove any destinations covered by this new path segment
                        if v in remaining: remaining.remove(v)
                else:
                    valid_tree = False
                    break
            except Exception:
                valid_tree = False
                break

        if valid_tree:
            register_candidate(tree_edges, 'Steiner')

    # ---------------------------------------------------------
    # Selection
    # ---------------------------------------------------------
    if not candidates:
        return bc_topology

    # Scoring Function: Minimize Virtual Cost
    # Virtual Cost = Dollar Cost + Time Penalty
    # Time Penalty represents instance costs + latency value.
    # Value 0.5 implies we are willing to pay $0.50 to save 1000 seconds per GB on a 1Mbps link,
    # or $0.05 to save time on a 10Gbps link.
    def score_candidate(c):
        throughput = max(c['min_throughput'], 0.001)
        time_penalty = 0.5 / throughput
        return c['cost'] + time_penalty

    # Sort candidates
    candidates.sort(key=score_candidate)
    best_cand = candidates[0]

    # ---------------------------------------------------------
    # Path Application
    # ---------------------------------------------------------
    paths_map = best_cand['paths']
    for dst, path_segments in paths_map.items():
        # Apply the chosen optimal path to all partitions.
        # (Consistent routing minimizes complexity and guarantees the calculated performance)
        for i in range(num_partitions):
            bc_topology.set_dst_partition_paths(dst, i, path_segments)

    return bc_topology
