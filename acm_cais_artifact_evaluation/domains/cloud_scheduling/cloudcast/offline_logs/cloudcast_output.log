import heapq
from typing import Dict, List, Set, Tuple, Any

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src: str, dsts: List[str], G: nx.DiGraph, num_partitions: int) -> BroadCastTopology:
    """
    Optimized broadcast routing algorithm using Iterative Penalized Shortest Path Trees (SPT).

    Analysis of previous failures:
    - Previous Steiner Tree implementation produced routing loops (trombones) due to incorrect branch connection logic.
    - Cloud egress models are strictly unicast (sender pays for every byte sent to next hop), making Shortest Path Trees (SPT)
      more cost-accurate than Steiner Trees (which assume multicast replication savings at the link layer).
    - Throughput bottlenecks were causing high instance costs.

    Optimization Strategy:
    1. Base Metric: Composite weight of Egress Cost + (Alpha / Throughput) to balance fees vs transfer time.
    2. Multipath: Generates 'num_partitions' diverse topologies by iteratively penalizing used edges.
    3. Validity: Uses Dijkstra to guarantee loop-free, reachable paths for every partition.
    4. Throughput: Explicitly penalizes low-bandwidth links to prevent bottlenecks.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Cleanup
    # Remove incoming edges to source (source must be root) and self-loops to prevent trivial cycles
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    valid_dsts = [d for d in dsts if d in h and d != src]
    if not valid_dsts:
        return bc_topology

    # 2. Heuristic Initialization
    # ALPHA represents the conversion of Time/Throughput into Dollar Value.
    # A value of 0.05 implies we are willing to pay ~$0.05/GB extra to avoid 1Gbps bottlenecks.
    # This helps route around slow links that would inflate instance costs.
    ALPHA = 0.05

    # Track usage count to apply diversity penalties
    edge_usage = {e: 0 for e in h.edges()}

    # Initialize base metrics
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.1)
        t = data.get('throughput', 1.0)
        t_safe = max(t, 0.001) # Avoid div by zero
        # Base metric: Cost dominates, but low throughput adds a "virtual cost"
        data['base_metric'] = c + (ALPHA / t_safe)

    # 3. Iterative Path Generation (Multipath)
    for i in range(num_partitions):
        # Dynamic Tuning:
        # Partitions 0-4: Balanced Cost/Performance
        # Partitions 5+: Higher penalty on congestion to force path diversity
        penalty_base = 1.2 if i < num_partitions / 2 else 1.5

        # Apply penalties to edge weights based on previous usage
        for u, v, data in h.edges(data=True):
            usage = edge_usage.get((u, v), 0)
            penalty_factor = penalty_base ** usage
            data['curr_weight'] = data['base_metric'] * penalty_factor

        # Build Shortest Path Tree from Source
        # Dijkstra guarantees loop-free paths (lowest weight sum)
        try:
            # Calculate paths to all reachable nodes
            all_paths = nx.single_source_dijkstra_path(h, src, weight='curr_weight')
        except Exception:
            all_paths = {src: [src]}

        # Assign paths for this partition
        for dst in valid_dsts:
            path_edges = []

            if dst in all_paths:
                nodes = all_paths[dst]
                # Convert node list to edge list with data
                for k in range(len(nodes) - 1):
                    u_node, v_node = nodes[k], nodes[k+1]
                    if h.has_edge(u_node, v_node):
                        # Use original graph data for the result
                        edge_data = h[u_node][v_node]
                        path_edges.append([u_node, v_node, edge_data])

                        # Mark edge as used for subsequent iterations
                        if (u_node, v_node) in edge_usage:
                            edge_usage[(u_node, v_node)] += 1
            else:
                # Fallback: If penalization made dst unreachable (rare), try raw shortest path
                try:
                    fallback_nodes = nx.shortest_path(h, src, dst, weight='base_metric')
                    for k in range(len(fallback_nodes) - 1):
                        u_node, v_node = fallback_nodes[k], fallback_nodes[k+1]
                        path_edges.append([u_node, v_node, h[u_node][v_node]])
                except nx.NetworkXNoPath:
                    pass # Destination truly unreachable

            if path_edges:
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

    return bc_topology
