import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using a Cost-Latency balanced Steiner Tree heuristic.

    Improvements:
    1. Calibrated throughput penalty to reflect realistic instance costs ($0.002 factor).
       This prevents selecting expensive paths just for minor bandwidth gains.
    2. Adjusted depth penalty (0.3) to prevent excessive daisy-chaining across continents.
    3. Strict cycle prevention and source isolation.
    """

    # 1. Graph Preparation & Weight Calculation
    h = G.copy()

    # Remove incoming edges to source to prevent loops back to start
    if src in h:
        h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # Heuristic Constants
    # THROUGHPUT_PENALTY_FACTOR: Represents the economic cost of time (instance run costs).
    # Lowered from 0.05 to 0.002 to prioritize egress savings over raw speed,
    # unless the link is critically slow (<100Mbps) or cost difference is negligible.
    THROUGHPUT_PENALTY_FACTOR = 0.002

    # DEPTH_PENALTY_ALPHA: Controls tree shallowness.
    # Increased to 0.3 to bias slightly more towards Shortest Path Tree,
    # reducing the risk of global detours (e.g. Asia->Europe->Australia).
    DEPTH_PENALTY_ALPHA = 0.3

    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 0.1)
        throughput = data.get('throughput', 1.0)

        # Avoid division by zero
        tp_safe = max(throughput, 1e-6)

        # Weight = Egress Cost + Time Cost
        # This aligns the unit of 'time' with dollars based on instance runtime reduction.
        data['weight'] = cost + (THROUGHPUT_PENALTY_FACTOR / tp_safe)

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 2. Shallow Steiner Tree Construction (Prim-Dijkstra Hybrid)

    tree_nodes = {src}
    tree_edges = []
    path_cost_from_src = {src: 0.0}

    # Identify unique destinations reachable in the graph
    valid_dsts = set(d for d in dsts if d != src and d in h)
    remaining_dsts = valid_dsts.copy()

    # Priority Queue: (priority, u, v, weight)
    # Note: u is the node IN the tree, v is the candidate neighbor
    pq = []

    # Track visited states for the PQ to avoid processing stale entries
    # Maps node -> best priority seen
    min_priority_seen = {}

    def add_neighbors(u):
        if u not in h: return
        dist_u = path_cost_from_src[u]

        for v, data in h[u].items():
            if v in tree_nodes:
                continue

            w = data['weight']
            # Hybrid Score: Edge Weight + (Alpha * Parent Distance)
            # This balances "cheapest extension" (Prim) with "shortest path from root" (Dijkstra)
            # Higher Alpha reduces tree depth, mitigating latency spikes for leaves.
            priority = w + (DEPTH_PENALTY_ALPHA * dist_u)

            if v not in min_priority_seen or priority < min_priority_seen[v]:
                min_priority_seen[v] = priority
                heapq.heappush(pq, (priority, u, v, w))

    add_neighbors(src)

    while remaining_dsts and pq:
        priority, u, v, w = heapq.heappop(pq)

        if v in tree_nodes:
            continue

        # Add to tree
        tree_nodes.add(v)
        tree_edges.append((u, v))
        path_cost_from_src[v] = path_cost_from_src[u] + w

        if v in remaining_dsts:
            remaining_dsts.remove(v)

        add_neighbors(v)

    # 3. Path Extraction
    # Reconstruct the tree as a graph for easy path finding
    st_graph = nx.DiGraph()
    st_graph.add_nodes_from(tree_nodes)
    for u, v in tree_edges:
        if u in G and v in G[u]:
            st_graph.add_edge(u, v, **G[u][v])

    for dst in dsts:
        if dst == src:
            continue

        edge_path = []
        try:
            # Prefer path in the optimized Steiner Tree
            if dst in st_graph:
                path_nodes = nx.shortest_path(st_graph, source=src, target=dst)
            else:
                # Fallback to shortest weighted path in original graph if unreachable in tree
                # (Handles disconnected components or pruning edge cases)
                path_nodes = nx.shortest_path(h, source=src, target=dst, weight='weight')

            for i in range(len(path_nodes) - 1):
                u_node, v_node = path_nodes[i], path_nodes[i+1]
                edge_path.append([u_node, v_node, G[u_node][v_node]])

        except (nx.NetworkXNoPath, KeyError):
            pass

        if edge_path:
            # Apply the optimized path to all partitions.
            # In cost-constrained broadcast, maintaining a single optimized tree
            # maximizes edge-sharing (multicast gain) and minimizes total egress fees.
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, edge_path)

    return bc_topology
