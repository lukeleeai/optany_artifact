import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using a shallow Steiner Tree heuristic.

    Balances total egress cost (tree weight) with transfer latency (tree depth)
    by using a modified Prim's algorithm that penalizes attachment to deep nodes.
    Edge weights incorporate an economic value for throughput to prevent bottlenecks.

    Args:
        src: Source node identifier
        dsts: List of destination node identifiers
        G: NetworkX DiGraph with cost and throughput edge attributes
        num_partitions: Number of data partitions

    Returns:
        BroadCastTopology object with paths for all destinations and partitions
    """

    # 1. Graph Preparation & Weight Calculation
    h = G.copy()

    # Remove incoming edges to source to prevent loops back to start
    if src in h:
        h.remove_edges_from(list(h.in_edges(src)) + list(nx.selfloop_edges(h)))

    # Heuristic constants optimization:
    # THROUGHPUT_PENALTY_FACTOR: Converts throughput limits into "virtual cost".
    # Assumes ~300GB transfers where low throughput (<1Gbps) incurs significant instance costs.
    # Value 0.05 ensures a 1Gbps link adds ~$0.05 virtual cost, comparable to egress differences.
    THROUGHPUT_PENALTY_FACTOR = 0.05

    # DEPTH_PENALTY_ALPHA: Controls the trade-off between MST (Cost) and SPT (Time/Latency).
    # 0.0 = Pure Steiner Tree (Min Cost, potentially deep daisy-chains)
    # 1.0 = Shortest Path Tree (Min Latency, Max Cost)
    # 0.2 biases towards shallower trees, preventing bottlenecks from deep chains while keeping costs low.
    DEPTH_PENALTY_ALPHA = 0.2

    for u, v, data in h.edges(data=True):
        cost = data.get('cost', 0.1)
        throughput = data.get('throughput', 1.0)

        # Composite weight: Egress Cost + Time-Value Cost
        # 1e-9 avoids division by zero
        data['weight'] = cost + (THROUGHPUT_PENALTY_FACTOR / (throughput + 1e-9))

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 2. Shallow Steiner Tree Construction (Modified Prim's Algorithm)
    # We maintain a tree and grow it to cover destinations

    tree_nodes = {src}
    tree_edges = [] # List of (u, v)
    path_cost_from_src = {src: 0.0} # Cumulative weight from source in the tree

    remaining_dsts = set(d for d in dsts if d != src and d in h)

    # Priority Queue stores: (priority_score, candidate_node, parent_node, edge_weight)
    pq = []

    # Helper to push valid neighbors of a node to PQ
    def add_neighbors_to_pq(u):
        if u not in h: return
        dist_u = path_cost_from_src[u]
        for v, data in h[u].items():
            if v not in tree_nodes:
                w = data['weight']
                # Priority Score = Edge Weight + (Alpha * Parent's Cumulative Distance from Source)
                # This penalizes extending from nodes that are already "far" (in cost/time terms) from source.
                priority = w + (DEPTH_PENALTY_ALPHA * dist_u)
                heapq.heappush(pq, (priority, v, u, w))

    # Initial population
    add_neighbors_to_pq(src)

    # Optimization: Track best priority seen to skip stale PQ entries
    visited_priority = {}

    while remaining_dsts and pq:
        priority, v, u, w = heapq.heappop(pq)

        if v in tree_nodes:
            continue

        # Check if we already found a 'better' way to this node (standard Dijkstra/Prim opt)
        if v in visited_priority and priority >= visited_priority[v]:
            continue
        visited_priority[v] = priority

        # Add v to tree
        tree_nodes.add(v)
        tree_edges.append((u, v))
        path_cost_from_src[v] = path_cost_from_src[u] + w

        if v in remaining_dsts:
            remaining_dsts.remove(v)

        # Add v's neighbors to consideration
        add_neighbors_to_pq(v)

    # 3. Construct Graph from Tree Edges
    st_graph = nx.DiGraph()
    st_graph.add_nodes_from(tree_nodes)
    for u, v in tree_edges:
        if u in G and v in G[u]:
            st_graph.add_edge(u, v, **G[u][v])

    # 4. Extract Paths and Assign to Topology
    for dst in dsts:
        edge_path = []
        try:
            if dst == src:
                continue

            path_nodes = []
            if dst in st_graph:
                # Path exists in our constructed Steiner Tree
                path_nodes = nx.shortest_path(st_graph, source=src, target=dst)
            else:
                # Fallback: Destination unreachable in Steiner Tree (e.g. disconnected component)
                # Try finding any path in the original heuristic graph
                path_nodes = nx.shortest_path(h, source=src, target=dst, weight='weight')

            # Convert node path to edge list format required by topology
            for i in range(len(path_nodes) - 1):
                u, v = path_nodes[i], path_nodes[i+1]
                edge_path.append([u, v, G[u][v]])

        except (nx.NetworkXNoPath, KeyError):
            # No path available at all
            pass

        if edge_path:
            # Assign path to all partitions.
            # While multipathing is supported, using a single optimized multicast tree
            # is generally superior for cost (edge sharing) in this domain model.
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, edge_path)

    return bc_topology
