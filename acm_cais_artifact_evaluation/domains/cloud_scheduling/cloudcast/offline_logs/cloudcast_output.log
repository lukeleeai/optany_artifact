import heapq
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds the shortest path from the set of 'sources' to the closest node in 'targets'.
    Returns the path edges (reversed from target back to source) and the target node reached.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_topology_metrics(edges, G):
    """
    Calculates total cost and minimum bottleneck throughput for a set of edges.
    """
    total_cost = 0.0
    min_bw = float('inf')
    for u, v in edges:
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        min_bw = min(min_bw, data.get('throughput', 0.0))

    if min_bw == float('inf'):
        min_bw = 0.0
    return total_cost, min_bw

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Key Improvements:
    1.  **Metric Selection**: Prioritizes Egress Cost heavily over Throughput.
        Weight = Cost + epsilon/Throughput.
    2.  **Topology Generation**: Uses a "Hub-Centric" Steiner Tree heuristic.
        It attempts to build trees rooted at the Source and forced through
        immediate high-capacity neighbors ("Hubs") to find optimal shared trunks.
    3.  **Consolidation**: Selects a single best-cost topology for all partitions
        to maximize data volume aggregation on shared edges, reducing total egress fees.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    h = G.copy()
    # Remove incoming edges to source to enforce rooted structure
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate weights
    # We want to minimize Cost. Throughput is a secondary constraint/tie-breaker.
    # We add a small penalty for low throughput to avoid extremely slow links.
    # 1e-5 / 10 Gbps = 1e-6. 1e-5 / 0.1 Gbps = 1e-4.
    # Cost difference of $0.01 dominates this factor.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 0.001)
        if t < 0.05: # Avoid effectively broken links
            data['calc_weight'] = 1000.0
        else:
            data['calc_weight'] = c + (1e-5 / t)

    candidates = []
    target_set = set(d for d in dsts if d != src and d in h)

    if not target_set:
        return bc_topology

    # 2. Strategy A: Shortest Path Tree (USP)
    # Baseline: Best for latency, potentially high cost if no sharing.
    spt_edges = set()
    try:
        valid_spt = True
        for dst in target_set:
            try:
                path = nx.shortest_path(h, src, dst, weight='calc_weight')
                for k in range(len(path)-1):
                    spt_edges.add((path[k], path[k+1]))
            except nx.NetworkXNoPath:
                valid_spt = False
                break

        if valid_spt and spt_edges:
            c_cost, c_bw = _get_topology_metrics(spt_edges, h)
            candidates.append({
                'edges': spt_edges,
                'cost': c_cost,
                'bw': c_bw,
                'type': 'spt'
            })
    except:
        pass

    # 3. Strategy B & C: Hub-Centric Greedy Steiner Tree
    # We iterate multiple times. In each iteration, we force the tree to start
    # by connecting Source to a specific neighbor ("Hub"). This helps the greedy
    # algorithm find shared trunks (e.g., Src -> Gateway -> [Dst1, Dst2]).

    # Identify hubs: Neighbors of src
    hubs = []
    for u, v, data in h.out_edges(src, data=True):
        # Only consider reasonable hubs
        if data.get('throughput', 0) > 0.5:
            hubs.append(v)

    # List of start configurations: None (pure greedy) + specific hubs
    # Limit to top 8 hubs to manage complexity
    start_configs = [None] + hubs[:8]

    for start_node in start_configs:
        tree_edges = set()
        tree_nodes = {src}
        remaining = target_set.copy()

        # Pre-seed the tree with the hub connection
        if start_node and start_node in h[src]:
            # Only if this edge actually exists (it should based on logic above)
            tree_edges.add((src, start_node))
            tree_nodes.add(start_node)
            if start_node in remaining:
                remaining.remove(start_node)

        # Greedy Expansion
        while remaining:
            # Connect the closest remaining target to the current tree
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')

            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining.remove(target)

        # If we successfully connected all targets (or as many as possible)
        if tree_edges:
            # Dedup
            is_dup = False
            for cand in candidates:
                if cand['edges'] == tree_edges:
                    is_dup = True
                    break

            if not is_dup:
                c_cost, c_bw = _get_topology_metrics(tree_edges, h)
                candidates.append({
                    'edges': tree_edges,
                    'cost': c_cost,
                    'bw': c_bw,
                    'type': 'steiner'
                })

    if not candidates:
        return bc_topology

    # 4. Selection
    # Sort primarily by Cost (Minimize Egress)
    candidates.sort(key=lambda x: x['cost'])

    best_candidate = candidates[0]
    best_cost = best_candidate['cost']

    # Check if there are other candidates with very similar cost (<= 1% diff)
    # but significantly better throughput
    alternatives = [c for c in candidates if c['cost'] <= best_cost * 1.01]
    alternatives.sort(key=lambda x: x['bw'], reverse=True)

    selected = alternatives[0]

    # 5. Path Extraction
    # Convert the selected edge set into a routable graph to extract paths
    st_graph = nx.DiGraph()
    for u, v in selected['edges']:
        if h.has_edge(u, v):
            st_graph.add_edge(u, v, **h[u][v])

    paths_map = {}
    for dst in dsts:
        if dst == src: continue
        try:
            # Extract shortest path within the selected topology
            path_nodes = nx.shortest_path(st_graph, src, dst, weight='calc_weight')
            path_edges = []
            for k in range(len(path_nodes)-1):
                u, v = path_nodes[k], path_nodes[k+1]
                path_edges.append([u, v, h[u][v]])
            paths_map[dst] = path_edges
        except nx.NetworkXNoPath:
            # Fallback to global graph if topology logic missed a node (rare safety net)
            try:
                path_nodes = nx.shortest_path(h, src, dst, weight='calc_weight')
                path_edges = [[path_nodes[k], path_nodes[k+1], h[path_nodes[k]][path_nodes[k+1]]] for k in range(len(path_nodes)-1)]
                paths_map[dst] = path_edges
            except:
                pass

    # 6. Assignment
    # Assign the SINGLE best topology to ALL partitions.
    # In broadcast, using multiple topologies splits traffic and loses the
    # benefit of shared edges (paying egress once for the stream).
    for i in range(num_partitions):
        for dst, path in paths_map.items():
            if path:
                bc_topology.set_dst_partition_paths(dst, i, path)

    return bc_topology
