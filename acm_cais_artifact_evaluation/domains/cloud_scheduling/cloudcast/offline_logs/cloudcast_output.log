import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_tree_to_targets(G, sources, targets, weight_attr):
    """
    Finds the shortest path from any node in 'sources' to the closest node in 'targets'.
    Returns (target_node, path_edges).
    """
    pq = []
    # Use a counter to act as a tie-breaker for nodes
    counter = 0
    visited = {} # node -> (dist, parent)

    # Initialize with all source nodes at distance 0
    for s in sources:
        heapq.heappush(pq, (0.0, counter, s, None))
        counter += 1
        visited[s] = (0.0, None)

    targets_set = set(targets)

    while pq:
        d, _, u, parent = heapq.heappop(pq)

        if u in targets_set:
            # Reconstruct path
            path = []
            curr = u
            p = parent
            while p is not None:
                path.append((p, curr))
                curr = p
                if curr not in visited:
                    break
                _, p = visited[curr]

            return u, list(reversed(path))

        for v, attr in G[u].items():
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w

            if v not in visited or new_dist < visited[v][0]:
                visited[v] = (new_dist, u)
                heapq.heappush(pq, (new_dist, counter, v, u))
                counter += 1

    return None, []

def _get_candidate_metrics(edges, G):
    """Calculates total cost and min throughput for a set of edges."""
    total_cost = 0.0
    min_throughput = float('inf')
    if not edges:
        return 0.0, 0.0

    for u, v in edges:
        data = G[u][v]
        total_cost += data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        if t < min_throughput:
            min_throughput = t
    return total_cost, min_throughput

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized Broadcast Routing Algorithm.

    Strategy:
    1.  Uses a Randomized Steiner Tree Heuristic to find shared paths that minimize Egress Cost.
    2.  Generates multiple candidate trees by varying the weight function to explore the
        trade-off between pure cost (Egress) and throughput (Instance Cost/Time).
    3.  Selects the best tree based on a composite score: Cost + (Penalty / Throughput).
        This avoids selecting extremely slow paths that inflate instance costs, while preserving
        low egress costs via edge sharing.
    4.  Assigns the optimal tree paths to all partitions to maximize multicast savings.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prune incoming edges to source to enforce rooted directionality
    h = G.copy()
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    valid_dsts = [d for d in dsts if d != src and d in h]
    if not valid_dsts:
        return bc_topology

    candidates = []

    # Configuration for heuristic iterations:
    # (noise_range, throughput_penalty_factor)
    # The penalty factor adds (factor / throughput) to edge weight.
    configs = [
        (0.0, 0.0),       # Pure Cost (Greedy Baseline)
        (0.2, 0.0),       # Randomized Cost (Escape local optima)
        (0.2, 0.0),       # Randomized Cost (2nd Pass)
        (0.0, 0.005),     # Slight Throughput Bias
        (0.0, 0.05),      # Stronger Throughput Bias (Avoids bottlenecks)
        (0.1, 0.01)       # Mixed Strategy
    ]

    for noise_range, th_penalty in configs:
        # 1. Prepare Weights
        work_G = h.copy()
        for u, v, data in work_G.edges(data=True):
            base_c = data.get('cost', 0.0)
            th = data.get('throughput', 1.0)
            th = max(th, 0.001) # Safety

            # Apply Random Noise
            noise = 1.0
            if noise_range > 0:
                noise = random.uniform(1.0 - noise_range, 1.0 + noise_range)

            # Calculate Weight: Cost * Noise + Penalty/Throughput
            # Use a floor for cost to ensure shortest-path behavior when costs are 0
            cost_component = max(base_c, 1e-6) * noise
            throughput_component = th_penalty / th
            data['calc_weight'] = cost_component + throughput_component

        # 2. Build Steiner Tree
        tree_nodes = {src}
        tree_edges = set()
        remaining = set(valid_dsts)

        while remaining:
            # Find closest target to the current tree
            target, path = _dijkstra_tree_to_targets(work_G, tree_nodes, remaining, 'calc_weight')

            if not target:
                break

            # Add path to tree
            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)
                    # Set weight to effectively zero to encourage sharing (Multicast gain)
                    # Used edges become "free" for subsequent paths
                    work_G[u][v]['calc_weight'] = 1e-9

            remaining.remove(target)

        if not tree_edges:
            continue

        # 3. Evaluate Candidate
        c_cost, c_bottleneck = _get_candidate_metrics(tree_edges, h)

        # Store unique candidate
        candidates.append({
            'edges': tree_edges,
            'cost': c_cost,
            'bottleneck': c_bottleneck
        })

    # 4. Selection Logic
    if not candidates:
        return bc_topology

    # Filter broken candidates
    valid_candidates = [c for c in candidates if c['bottleneck'] > 0.001]
    if not valid_candidates:
        valid_candidates = candidates

    best_cand = None
    best_score = float('inf')

    # Score = EgressCost + (K / Throughput)
    # K represents the monetary penalty for low throughput (Instance Cost proxy).
    # K=5.0 implies 1 Gbps bottleneck costs "5 units". 0.1 Gbps costs "50 units".
    # This prevents the algorithm from picking extremely slow paths to save minimal egress.
    K = 5.0

    for cand in valid_candidates:
        score = cand['cost'] + (K / cand['bottleneck'])
        if score < best_score:
            best_score = score
            best_cand = cand

    # 5. Path Construction
    # Build a subgraph of the chosen tree to extract explicit paths
    tree_subgraph = nx.DiGraph()
    for u, v in best_cand['edges']:
        tree_subgraph.add_edge(u, v) # Structure only

    try:
        # BFS/Shortest Path on the tree structure
        all_paths = nx.shortest_path(tree_subgraph, source=src)
    except Exception:
        all_paths = {}

    for dst in valid_dsts:
        edge_list = []
        if dst in all_paths:
            nodes = all_paths[dst]
            for i in range(len(nodes) - 1):
                u, v = nodes[i], nodes[i+1]
                # Retrieve original edge data from handle
                edge_list.append([u, v, h[u][v]])
        else:
            # Fallback to shortest path on original graph if tree construction failed specific node
            try:
                sp = nx.shortest_path(h, src, dst, weight='cost')
                for i in range(len(sp) - 1):
                    u, v = sp[i], sp[i+1]
                    edge_list.append([u, v, h[u][v]])
            except nx.NetworkXNoPath:
                pass

        if edge_list:
            # Assign same path to all partitions
            # Using the shared tree for all partitions minimizes total egress cost
            for i in range(num_partitions):
                bc_topology.set_dst_partition_paths(dst, i, edge_list)

    return bc_topology
