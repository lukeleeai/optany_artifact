import heapq
from typing import Dict, List, Tuple
from itertools import islice

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized routing for multi-cloud broadcast.
    Prioritizes direct or high-quality paths to avoid 'tour-of-the-cloud' inefficiencies.
    Uses multipath only when candidates are competitive in cost and performance.
    """
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Helper to identify cloud provider (e.g., 'aws', 'gcp', 'azure')
    def get_provider(node):
        return node.split(':')[0] if ':' in node else 'unknown'

    # 1. Graph Scoring & Preparation
    # Create a local view with computed weights designed to minimize Total Cost (Egress + Instance).
    # We penalize low throughput severely to prevent long transfer times.
    # We penalize unnecessary inter-provider hops to prevent "world tour" routing anomalies.

    H = G.copy()

    # Prune incoming edges to source to prevent loops back to start and simplify flow
    to_remove = list(H.in_edges(src)) + list(nx.selfloop_edges(H))
    H.remove_edges_from(to_remove)

    for u, v, data in H.edges(data=True):
        cost = data.get('cost', 0.0)
        bw = data.get('throughput', 1.0)
        bw_safe = max(bw, 0.01) # Prevent div by zero

        prov_u = get_provider(u)
        prov_v = get_provider(v)

        # Hop Penalty Logic:
        # Intra-cloud hops (same provider) are often efficient backbone links.
        # Inter-cloud hops (diff provider) involve internet/peering, adding latency and complexity.
        # We apply a 'virtual cost' penalty to guide the search towards simpler topologies.
        if prov_u == prov_v:
            hop_penalty = 0.002
        else:
            # Crossing providers is expensive in terms of reliability/latency risk.
            # 0.04 is chosen to outweigh marginal egress savings (e.g., saving $0.02 but crossing clouds).
            hop_penalty = 0.04

        # Throughput Penalty:
        # Low throughput increases instance runtime cost and total transfer time.
        # Weight component = 0.1 / BW.
        # Example: 10Gbps -> +0.01. 1Gbps -> +0.1. 0.1Gbps -> +1.0.
        bw_penalty = 0.1 / bw_safe

        # Combined Selection Weight used for Path Finding
        data['select_weight'] = cost + bw_penalty + hop_penalty

        # Store raw metrics for final evaluation
        data['raw_cost'] = cost
        data['raw_bw'] = bw_safe

    # 2. Path Finding per Destination
    for dst in dsts:
        if dst == src: continue

        candidates = []

        # Strategy: Find K-Shortest Simple Paths
        # This approach naturally finds the direct path (if viable) and any efficient relay paths.
        # Using 'select_weight' ensures we balance Cost vs Speed vs Hop Complexity.
        try:
            # nx.shortest_simple_paths returns a generator. We take the top 3.
            k_gen = nx.shortest_simple_paths(H, src, dst, weight='select_weight')

            raw_paths = list(islice(k_gen, 3))

            # Process Candidates
            for p_nodes in raw_paths:
                edges_list = []
                path_cost = 0.0
                path_bottleneck = float('inf')
                valid = True

                for i in range(len(p_nodes)-1):
                    u, v = p_nodes[i], p_nodes[i+1]
                    if not H.has_edge(u, v):
                        valid = False; break
                    d = H[u][v]
                    edges_list.append([u, v, d])
                    path_cost += d.get('cost', 0.0)
                    path_bottleneck = min(path_bottleneck, d.get('throughput', 1.0))

                if valid:
                    # Heuristic Score for Candidate Selection:
                    # We want to minimize Cost, but ensure BW is acceptable.
                    # This score is used only to rank the valid candidates found.
                    candidates.append({
                        'edges': edges_list,
                        'cost': path_cost,
                        'bw': path_bottleneck,
                        # Weighted score: Cost is primary, but very low BW penalizes heavily
                        'rank_score': path_cost + (1.0 / max(path_bottleneck, 0.001))
                    })

        except (nx.NetworkXNoPath, nx.NetworkXError):
            pass

        # 3. Candidate Selection & Partition Assignment
        if not candidates:
            # If no path found (rare), leave empty (will be handled by system as unreachable)
            continue

        # Sort candidates by the ranking score (Cost optimized with BW constraints)
        candidates.sort(key=lambda x: x['rank_score'])

        best = candidates[0]

        # Enable Multipath:
        # If we have multiple paths, use them to aggregate bandwidth,
        # BUT only if they are not significantly more expensive or slower than the best path.
        final_candidates = [best]

        # Tolerance thresholds
        cost_threshold = best['cost'] * 1.10  # Max 10% more expensive
        bw_threshold = best['bw'] * 0.5       # At least 50% of the speed of best path

        for c in candidates[1:]:
            if c['cost'] <= cost_threshold and c['bw'] >= bw_threshold:
                final_candidates.append(c)

        # Assign partitions round-robin among the accepted candidates
        num_final = len(final_candidates)
        for i in range(num_partitions):
            choice = final_candidates[i % num_final]
            bc_topology.set_dst_partition_paths(dst, i, choice['edges'])

    return bc_topology
