import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def search_algorithm(src, dsts, G, num_partitions):
    """
    Optimized broadcast routing using an Ensemble Steiner Tree heuristic.

    Improves upon standard heuristics by:
    1. Using a high 'alpha' to bias towards Shortest Path Trees (SPT), preventing
       high-latency geographic detours (e.g. Asia->Europe->Asia).
    2. applying significant penalties to low-throughput edges to minimize transfer time
       and instance costs.
    3. Generating an ensemble of diverse trees (Multipath) via noise injection to
       distribute partitions, utilizing aggregate bandwidth and avoiding single-link bottlenecks.

    Args:
        src: Source node identifier
        dsts: List of destination node identifiers
        G: NetworkX DiGraph with cost and throughput edge attributes
        num_partitions: Number of data partitions

    Returns:
        BroadCastTopology object with paths for all destinations and partitions
    """

    # --- Optimization Parameters ---
    # Controls trade-off between MST (Cost) and SPT (Latency/Hops).
    # 0.45 biases significantly towards SPT to prevent long daisy-chains/detours.
    DEPTH_PENALTY_ALPHA = 0.45

    # Converts throughput (Gbps) to virtual cost.
    # 0.5 ensures <1Gbps links are very expensive (+$0.50), prioritizing >10Gbps links.
    THROUGHPUT_PENALTY_FACTOR = 0.5

    # Create multiple trees to enable multipath routing
    # Use fewer trees if partitions are scarce
    NUM_TREES = min(num_partitions, 3)

    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # Prepare base graph (remove back-edges to source)
    base_graph = G.copy()
    if src in base_graph:
        base_graph.remove_edges_from(list(base_graph.in_edges(src)) + list(nx.selfloop_edges(base_graph)))

    # Identify valid destinations
    valid_dsts = set(d for d in dsts if d != src and d in base_graph)

    # Generate K diverse trees and assign partitions round-robin
    for tree_idx in range(NUM_TREES):
        # Deterministic RNG for this tree index to ensure reproducibility
        rng = random.Random(tree_idx + 42)

        # 1. Graph Weight Calculation with Jitter
        h = base_graph.copy()

        for u, v, data in h.edges(data=True):
            cost = data.get('cost', 0.1)
            throughput = data.get('throughput', 1.0)

            # Inverse throughput penalty: Large penalty for bottlenecks
            # E.g., 1 Gbps -> +0.5 cost; 10 Gbps -> +0.05 cost
            t_penalty = THROUGHPUT_PENALTY_FACTOR / (throughput + 1e-9)

            # Apply +/- 15% random noise to edge weights to encourage path diversity
            # Only apply noise if we are actually building multiple trees
            noise = rng.uniform(0.85, 1.15) if NUM_TREES > 1 else 1.0

            data['weight'] = (cost + t_penalty) * noise

        # 2. Heuristic Tree Construction (Prim's with Depth Penalty)
        tree_nodes = {src}
        tree_edges = []
        path_cost_from_src = {src: 0.0}
        remaining_targets = valid_dsts.copy()

        # Priority Queue: (priority_score, candidate_node, parent_node, edge_weight)
        pq = []

        def add_neighbors(u_node):
            if u_node not in h: return
            dist_u = path_cost_from_src[u_node]
            for v_node, edge_data in h[u_node].items():
                if v_node not in tree_nodes:
                    w = edge_data['weight']
                    # Heuristic: Edge Weight + (Alpha * Total Path Cost to Parent)
                    # This penalizes attaching to nodes that are already "expensive/far" from source
                    priority = w + (DEPTH_PENALTY_ALPHA * dist_u)
                    heapq.heappush(pq, (priority, v_node, u_node, w))

        add_neighbors(src)

        # Optimization: Track best priority to prune stale PQ entries
        visited_priority = {}

        while remaining_targets and pq:
            priority, v, u, w = heapq.heappop(pq)

            if v in tree_nodes:
                continue

            if v in visited_priority and priority > visited_priority[v]:
                continue
            visited_priority[v] = priority

            # Add to tree
            tree_nodes.add(v)
            tree_edges.append((u, v))
            path_cost_from_src[v] = path_cost_from_src[u] + w

            if v in remaining_targets:
                remaining_targets.remove(v)

            add_neighbors(v)

        # 3. Construct Tree Graph
        st_graph = nx.DiGraph()
        st_graph.add_nodes_from(tree_nodes)
        for u, v in tree_edges:
            # Ensure we copy original attributes, not the noisy weights
            if u in G and v in G[u]:
                st_graph.add_edge(u, v, **G[u][v])

        # 4. Route Extraction & Partition Assignment
        # Partitions are distributed round-robin across the generated trees
        target_partitions = [p for p in range(num_partitions) if p % NUM_TREES == tree_idx]

        if not target_partitions:
            continue

        for dst in dsts:
            if dst == src:
                continue

            edge_path = []
            try:
                # Find path in the Steiner Tree
                if dst in st_graph:
                    path_nodes = nx.shortest_path(st_graph, source=src, target=dst)
                else:
                    # Fallback: If heuristic failed to connect dst (disconnected in heuristic view),
                    # try shortest path on the noisy full graph
                    path_nodes = nx.shortest_path(h, source=src, target=dst, weight='weight')

                # Convert nodes to edge list
                for i in range(len(path_nodes) - 1):
                    u_node, v_node = path_nodes[i], path_nodes[i+1]
                    # Use original graph data for the topology object
                    edge_path.append([u_node, v_node, G[u_node][v_node]])

            except (nx.NetworkXNoPath, KeyError):
                # Destination completely unreachable
                continue

            if edge_path:
                for p_idx in target_partitions:
                    bc_topology.set_dst_partition_paths(dst, p_idx, edge_path)

    return bc_topology
