import heapq
import random
from typing import Dict, List, Set, Tuple

class SingleDstPath(Dict):
    partition: int
    edges: List[List]  # [[src, dst, edge data]]

class BroadCastTopology:
    def __init__(self, src: str, dsts: List[str], num_partitions: int = 4, paths: Dict[str, 'SingleDstPath'] = None):
        self.src = src
        self.dsts = dsts
        self.num_partitions = num_partitions
        if paths is not None:
            self.paths = paths
        else:
            self.paths = {dst: {str(i): None for i in range(num_partitions)} for dst in dsts}

    def get_paths(self):
        return self.paths

    def set_num_partitions(self, num_partitions: int):
        self.num_partitions = num_partitions

    def set_dst_partition_paths(self, dst: str, partition: int, paths: List[List]):
        partition = str(partition)
        if dst in self.paths:
            self.paths[dst][partition] = paths

    def append_dst_partition_path(self, dst: str, partition: int, path: List):
        partition = str(partition)
        if self.paths[dst][partition] is None:
            self.paths[dst][partition] = []
        self.paths[dst][partition].append(path)

def _dijkstra_multisource_incremental(G, sources, targets, weight_attr='weight'):
    """
    Finds shortest path from any node in 'sources' to the closest node in 'targets'.
    """
    pq = []
    # Initialize PQ with all source nodes at dist 0
    for node in sources:
        heapq.heappush(pq, (0.0, node, None))

    visited = {} # node -> (dist, parent)
    closest_target = None

    while pq:
        d, u, parent = heapq.heappop(pq)

        if u in visited:
            continue
        visited[u] = (d, parent)

        if u in targets:
            closest_target = u
            break

        for v, attr in G[u].items():
            if v in visited:
                continue
            w = attr.get(weight_attr, 1.0)
            new_dist = d + w
            heapq.heappush(pq, (new_dist, v, u))

    if closest_target:
        # Reconstruct path
        path = []
        curr = closest_target
        while curr is not None:
            dist_info = visited.get(curr)
            if not dist_info:
                break
            _, par = dist_info
            if par is None:
                break
            path.append((par, curr))
            curr = par
        return list(reversed(path)), closest_target
    return [], None

def _get_path_cost(G, path_edges):
    cost = 0.0
    for u, v in path_edges:
        cost += G[u][v].get('cost', 0.0)
    return cost

def _get_topology_cost(edges, G):
    return sum(G[u][v].get('cost', 0.0) for u, v in edges)

def search_algorithm(src, dsts, G, num_partitions):
    bc_topology = BroadCastTopology(src, dsts, num_partitions)

    # 1. Graph Preparation
    # Use a copy to avoid modifying the original graph structure outside the algorithm scope
    h = G.copy()

    # Enforce rooted tree structure: remove incoming edges to source
    to_remove = list(h.in_edges(src)) + list(nx.selfloop_edges(h))
    h.remove_edges_from(to_remove)

    # Calculate Standard Weights
    # Primary objective: Cost. Secondary: Throughput.
    # We add a small epsilon based on throughput to break cost ties in favor of performance
    # without overriding the cost objective.
    for u, v, data in h.edges(data=True):
        c = data.get('cost', 0.0)
        t = data.get('throughput', 1.0)
        # Avoid division by zero, though throughput should be positive
        t_safe = max(t, 0.001)
        # Weight = Cost + (small_factor / throughput)
        # 10 Gbps -> +0.0001, 0.1 Gbps -> +0.01
        data['standard_weight'] = c + (0.001 / t_safe)
        data['base_weight'] = data['standard_weight']

    # Pre-calculate baseline direct/unicast path costs for validity checking
    unicast_costs = {}
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            edges = [(path[k], path[k+1]) for k in range(len(path)-1)]
            unicast_costs[dst] = _get_topology_cost(edges, h)
        except nx.NetworkXNoPath:
            unicast_costs[dst] = float('inf')

    candidates = []

    # 2. Strategy A: Union of Shortest Paths (USP)
    # This forms a baseline high-performance candidate
    usp_edges = set()
    valid_usp = True
    for dst in dsts:
        if dst == src: continue
        try:
            path = nx.shortest_path(h, src, dst, weight='standard_weight')
            for k in range(len(path)-1):
                usp_edges.add((path[k], path[k+1]))
        except nx.NetworkXNoPath:
            valid_usp = False

    if valid_usp and usp_edges:
        candidates.append({
            'edges': usp_edges,
            'cost': _get_topology_cost(usp_edges, h),
            'type': 'USP'
        })

    # 3. Strategy B: Iterative Steiner Tree Heuristic with Quality Assurance
    # Generate multiple candidates with slight randomness to find better shared structures
    iterations = min(num_partitions, 8) if num_partitions > 0 else 1
    edge_penalties = {}

    for i in range(iterations + 1):
        # Apply penalties to force diversity in later iterations
        for u, v, data in h.edges(data=True):
            base = data['base_weight']
            penalty = edge_penalties.get((u, v), 1.0)
            # Add small random jitter to break symmetries
            jitter = random.uniform(0.95, 1.05) if i > 0 else 1.0
            data['calc_weight'] = base * penalty * jitter

        tree_edges = set()
        tree_nodes = {src}
        remaining = set(d for d in dsts if d != src and d in h)

        # Build Steiner Tree
        while remaining:
            path, target = _dijkstra_multisource_incremental(h, tree_nodes, remaining, 'calc_weight')
            if not target:
                break

            for u, v in path:
                if (u, v) not in tree_edges:
                    tree_edges.add((u, v))
                    tree_nodes.add(v)

            remaining = remaining - tree_nodes

        if not tree_edges:
            continue

        # Post-Processing: Path Quality Assurance
        # Check if the tree path for any destination is unreasonably expensive
        # (e.g., daisy-chaining through many regions). If so, inject direct path edges.
        temp_graph = nx.DiGraph()
        for u, v in tree_edges:
            if h.has_edge(u, v):
                temp_graph.add_edge(u, v, **h[u][v])

        refined_edges = set(tree_edges)
        for dst in dsts:
            if dst == src or dst not in unicast_costs: continue

            try:
                tree_path_nodes = nx.shortest_path(temp_graph, src, dst, weight='standard_weight')
                tree_path_edges = [(tree_path_nodes[k], tree_path_nodes[k+1]) for k in range(len(tree_path_nodes)-1)]
                tree_cost = _get_topology_cost(tree_path_edges, h)

                # Threshold: If tree path is > 30% more expensive than unicast, inject unicast path
                # This breaks inefficient daisy chains
                if tree_cost > unicast_costs[dst] * 1.3:
                    try:
                        direct_path = nx.shortest_path(h, src, dst, weight='standard_weight')
                        for k in range(len(direct_path)-1):
                            refined_edges.add((direct_path[k], direct_path[k+1]))
                    except nx.NetworkXNoPath:
                        pass
            except (nx.NetworkXNoPath, KeyError):
                # If destination not reachable in tree (should not happen), inject direct
                try:
                    direct_path = nx.shortest_path(h, src, dst, weight='standard_weight')
                    for k in range(len(direct_path)-1):
                        refined_edges.add((direct_path[k], direct_path[k+1]))
                except nx.NetworkXNoPath:
                    pass

        # Check for duplicates
        is_dup = False
        for c in candidates:
            if c['edges'] == refined_edges:
                is_dup = True
                break

        if not is_dup:
            candidates.append({
                'edges': refined_edges,
                'cost': _get_topology_cost(refined_edges, h),
                'type': 'Steiner'
            })

            # Penalize edges used in this tree for next iteration
            for u, v in refined_edges:
                edge_penalties[(u, v)] = edge_penalties.get((u, v), 1.0) * 1.5

    if not candidates:
        return bc_topology

    # 4. Final Path Extraction & Assignment
    # Sort candidates by cost
    candidates.sort(key=lambda x: x['cost'])

    # Filter candidates: Keep those within 10% of best cost to ensure we don't pick very expensive ones just for diversity
    best_cost = candidates[0]['cost']
    limit_cost = best_cost * 1.10
    valid_candidates = [c for c in candidates if c['cost'] <= limit_cost]

    if not valid_candidates:
        valid_candidates = candidates[:1]

    num_valid = len(valid_candidates)

    for i in range(num_partitions):
        selected = valid_candidates[i % num_valid]

        # Build graph for this candidate
        cand_graph = nx.DiGraph()
        for u, v in selected['edges']:
            if h.has_edge(u, v):
                cand_graph.add_edge(u, v, **h[u][v])

        for dst in dsts:
            if dst == src: continue
            path_edges = []
            try:
                # Extract path using standard weights on the constructed topology
                path_nodes = nx.shortest_path(cand_graph, src, dst, weight='standard_weight')
                for k in range(len(path_nodes)-1):
                    u, v = path_nodes[k], path_nodes[k+1]
                    path_edges.append([u, v, h[u][v]])
            except nx.NetworkXNoPath:
                # Fallback to global graph if disconnected in topology
                try:
                    path_nodes = nx.shortest_path(h, src, dst, weight='standard_weight')
                    for k in range(len(path_nodes)-1):
                        u, v = path_nodes[k], path_nodes[k+1]
                        path_edges.append([u, v, h[u][v]])
                except nx.NetworkXNoPath:
                    pass

            if path_edges:
                bc_topology.set_dst_partition_paths(dst, i, path_edges)

    return bc_topology
